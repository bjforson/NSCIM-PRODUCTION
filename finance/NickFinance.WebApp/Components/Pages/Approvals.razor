@page "/approvals"
@using Microsoft.EntityFrameworkCore
@inject PettyCashDbContext Pc
@inject IPettyCashService Svc
@inject CurrentUser User
@rendermode InteractiveServer

<PageTitle>NickFinance · Approvals</PageTitle>

<h1>Approvals queue</h1>
<p class="lede">Vouchers awaiting your decision (assigned to <code>@User.UserId.ToString("N")[..8]</code>).</p>

<section class="card">
    <table>
        <thead>
            <tr><th>No.</th><th>Requester</th><th>Category</th><th>Purpose</th><th class="right">Amount</th><th>Step</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                <tr>
                    <td><code>@row.VoucherNo</code></td>
                    <td><code>@row.Requester.ToString("N")[..8]</code></td>
                    <td>@row.Category</td>
                    <td>@row.Purpose</td>
                    <td class="right">@((row.AmountMinor / 100m).ToString("N2"))</td>
                    <td>@row.StepNo · @row.Role</td>
                    <td><a href="@($"/petty-cash/{row.VoucherId}")">decide</a></td>
                </tr>
            }
            @if (_rows.Count == 0)
            {
                <tr><td colspan="7" class="muted">Nothing awaiting your decision.</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private record Row(Guid VoucherId, string VoucherNo, Guid Requester, VoucherCategory Category, string Purpose, long AmountMinor, short StepNo, string Role);
    private List<Row> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        // Voucher approvals assigned to me + still pending — joined with the voucher.
        var pending = await Pc.VoucherApprovals
            .Where(a => a.TenantId == User.TenantId && a.Decision == ApprovalDecision.Pending && a.AssignedToUserId == User.UserId)
            .OrderBy(a => a.CreatedAt)
            .ToListAsync();
        var voucherIds = pending.Select(a => a.VoucherId).ToList();
        var vouchers = await Pc.Vouchers
            .Where(v => voucherIds.Contains(v.VoucherId))
            .ToDictionaryAsync(v => v.VoucherId, v => v);

        _rows = pending
            .Where(a => vouchers.ContainsKey(a.VoucherId))
            .Select(a =>
            {
                var v = vouchers[a.VoucherId];
                return new Row(v.VoucherId, v.VoucherNo, v.RequesterUserId, v.Category, v.Purpose, v.AmountRequestedMinor, a.StepNo, a.Role);
            })
            .OrderBy(r => r.VoucherNo)
            .ToList();
    }
}
