@page "/ar/{InvoiceId:guid}/receipt"
@using Microsoft.EntityFrameworkCore
@inject ArDbContext Db
@inject IArService Svc
@inject IPeriodService Periods
@inject CurrentUser User
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>NickFinance · Record receipt</PageTitle>

<NepPageHeader Title="Record receipt" />

@if (_invoice is null)
{
    <p>Loading…</p>
}
else
{
    <p class="lede">
        Invoice <code>@_invoice.InvoiceNo</code> · Outstanding
        <NepMoney Minor="@_invoice.OutstandingMinor" Currency="GHS" />
    </p>
    <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="recordReceipt">
        <NepCard>
            <label>
                Receipt date
                <input type="date" @bind="_form.ReceiptDate" />
            </label>
            <label>
                Amount (GHS)
                <input type="number" step="0.01" min="0.01" @bind="_form.AmountGhs" />
            </label>
            <label>
                Cash account
                <select @bind="_form.CashAccount">
                    <option value="1010">1010 Cash on hand</option>
                    <option value="1020">1020 MoMo MTN</option>
                    <option value="1030">1030 Bank GCB</option>
                    <option value="1031">1031 Bank Ecobank</option>
                    <option value="1032">1032 Bank Stanbic</option>
                </select>
            </label>
            <label>
                Reference
                <input type="text" @bind="_form.Reference" maxlength="200" />
            </label>
            <button type="submit" class="primary" disabled="@_busy">@(_busy ? "Saving…" : "Save receipt")</button>
            @if (!string.IsNullOrEmpty(_error)) { <div class="error">@_error</div> }
        </NepCard>
    </EditForm>
}

@code {
    [Parameter] public Guid InvoiceId { get; set; }
    private ArInvoice? _invoice;
    private FormModel _form = new();
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _invoice = await Db.Invoices.FirstOrDefaultAsync(i => i.ArInvoiceId == InvoiceId && i.TenantId == User.TenantId);
        _form.ReceiptDate = DateOnly.FromDateTime(DateTime.UtcNow);
        _form.AmountGhs = (_invoice?.OutstandingMinor ?? 0L) / 100m;
        _form.CashAccount = "1030";
    }

    private async Task SaveAsync()
    {
        if (_invoice is null) return;
        _busy = true; _error = null;
        try
        {
            var today = DateOnly.FromDateTime(DateTime.UtcNow);
            var period = await Periods.GetByDateAsync(_form.ReceiptDate, User.TenantId)
                ?? await Periods.CreateAsync(_form.ReceiptDate.Year, (byte)_form.ReceiptDate.Month, User.TenantId);
            var amt = (long)Math.Round(_form.AmountGhs * 100m, 0, MidpointRounding.ToEven);
            await Svc.RecordReceiptAsync(new RecordReceiptRequest(
                InvoiceId: InvoiceId,
                ReceiptDate: _form.ReceiptDate,
                AmountMinor: amt,
                CashAccount: _form.CashAccount,
                RecordedByUserId: User.UserId,
                Reference: _form.Reference,
                TenantId: User.TenantId), period.PeriodId);
            Nav.NavigateTo($"/ar/{InvoiceId}");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class FormModel
    {
        public DateOnly ReceiptDate { get; set; }
        public decimal AmountGhs { get; set; }
        public string CashAccount { get; set; } = "1030";
        public string? Reference { get; set; }
    }
}
