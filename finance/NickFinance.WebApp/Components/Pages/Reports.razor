@page "/reports"
@inject IFinancialReports ReportsSvc
@inject CurrentUser User
@rendermode InteractiveServer

<PageTitle>NickFinance · Reports</PageTitle>

<h1>Reports</h1>
<p class="lede">Live financial reports — every value rolls from the journal at query time.</p>

<section class="card">
    <label>
        As-of date
        <input type="date" @bind="_asOf" />
    </label>
    <button class="primary" @onclick="ReloadAsync">Reload</button>
</section>

<section class="card">
    <h3>Trial balance · @_asOf.ToString("yyyy-MM-dd") · GHS</h3>
    @if (_tb is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <p class="muted">Total DR @((_tb.TotalDebits.Minor / 100m).ToString("N2")) · Total CR @((_tb.TotalCredits.Minor / 100m).ToString("N2")) · @(_tb.IsBalanced ? "✓ balanced" : "✗ NOT balanced")</p>
        <table>
            <thead><tr><th>Code</th><th>Account</th><th class="right">Debits</th><th class="right">Credits</th><th class="right">Balance</th></tr></thead>
            <tbody>
                @foreach (var r in _tb.Rows)
                {
                    <tr>
                        <td><code>@r.AccountCode</code></td>
                        <td>@r.AccountName</td>
                        <td class="right">@((r.Debits.Minor / 100m).ToString("N2"))</td>
                        <td class="right">@((r.Credits.Minor / 100m).ToString("N2"))</td>
                        <td class="right">@((r.Balance.Minor / 100m).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="card">
    <h3>Profit &amp; Loss · YTD to @_asOf.ToString("yyyy-MM-dd") · GHS</h3>
    @if (_pl is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <table>
            <thead><tr><th colspan="3">Income</th></tr></thead>
            <tbody>
                @foreach (var l in _pl.Income)
                {
                    <tr><td><code>@l.AccountCode</code></td><td>@l.AccountName</td><td class="right">@((l.Balance.Minor / 100m).ToString("N2"))</td></tr>
                }
                <tr class="total"><td></td><td>Total income</td><td class="right">@((_pl.TotalIncome.Minor / 100m).ToString("N2"))</td></tr>
            </tbody>
            <thead><tr><th colspan="3">Expenses</th></tr></thead>
            <tbody>
                @foreach (var l in _pl.Expenses)
                {
                    <tr><td><code>@l.AccountCode</code></td><td>@l.AccountName</td><td class="right">@((l.Balance.Minor / 100m).ToString("N2"))</td></tr>
                }
                <tr class="total"><td></td><td>Total expenses</td><td class="right">@((_pl.TotalExpenses.Minor / 100m).ToString("N2"))</td></tr>
                <tr class="total"><td></td><td>Net result</td><td class="right">@((_pl.NetResult.Minor / 100m).ToString("N2"))</td></tr>
            </tbody>
        </table>
    }
</section>

@code {
    private DateOnly _asOf = DateOnly.FromDateTime(DateTime.UtcNow);
    private TrialBalanceReport? _tb;
    private ProfitAndLossReport? _pl;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _tb = await ReportsSvc.TrialBalanceAsync("GHS", _asOf, User.TenantId);
        _pl = await ReportsSvc.ProfitAndLossAsync("GHS", new DateOnly(_asOf.Year, 1, 1), _asOf, User.TenantId);
    }
}
