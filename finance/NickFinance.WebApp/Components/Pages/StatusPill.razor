@code {
    [Parameter, EditorRequired] public string Status { get; set; } = "";

    private string CssClass => Status switch
    {
        "Submitted" or "Issued" or "PartiallyPaid" => "pill warn",
        "Approved" or "Disbursed" or "Paid" => "pill ok",
        "Rejected" or "Void" => "pill bad",
        _ => "pill"
    };
}
<span class="@CssClass">@Status</span>
