@page "/reports/aging"
@inject IArService Ar
@inject IApService Ap
@inject CurrentUser User
@rendermode InteractiveServer

<PageTitle>NickFinance · Aging</PageTitle>

<h1>Aging</h1>
<p class="lede">Receivables and payables, bucketed by days overdue from due date.</p>

<section class="card">
    <h3>Accounts receivable</h3>
    <table>
        <thead><tr><th>Bucket</th><th class="right"># invoices</th><th class="right">Outstanding</th></tr></thead>
        <tbody>
            @foreach (var b in _ar)
            {
                <tr><td>@b.Bucket</td><td class="right">@b.InvoiceCount</td><td class="right">@((b.OutstandingTotal.Minor / 100m).ToString("N2")) @b.OutstandingTotal.CurrencyCode</td></tr>
            }
        </tbody>
    </table>
</section>

<section class="card">
    <h3>Accounts payable</h3>
    <table>
        <thead><tr><th>Bucket</th><th class="right"># bills</th><th class="right">Outstanding</th></tr></thead>
        <tbody>
            @foreach (var b in _ap)
            {
                <tr><td>@b.Bucket</td><td class="right">@b.BillCount</td><td class="right">@((b.OutstandingTotal.Minor / 100m).ToString("N2")) @b.OutstandingTotal.CurrencyCode</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private IReadOnlyList<NickFinance.AR.AgingBucket> _ar = Array.Empty<NickFinance.AR.AgingBucket>();
    private IReadOnlyList<NickFinance.AP.AgingBucket> _ap = Array.Empty<NickFinance.AP.AgingBucket>();

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        _ar = await Ar.AgingReportAsync(today, User.TenantId);
        _ap = await Ap.AgingReportAsync(today, User.TenantId);
    }
}
