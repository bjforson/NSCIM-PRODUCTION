@*
    Loading skeleton. Replaces the bare "<p>Loading…</p>" string with a
    set of grey shimmering bars so the operator sees the page is alive.
    Heights and widths intentionally vary to mimic the kind of content
    coming next.
*@

<div class="nep-skeleton">
    @for (var i = 0; i < Rows; i++)
    {
        var w = (i % 3) switch
        {
            0 => "long",
            1 => "med",
            _ => "short"
        };
        <div class="nep-skeleton-bar @w"></div>
    }
</div>

@code {
    /// <summary>Number of placeholder bars to render. Default 4.</summary>
    [Parameter] public int Rows { get; set; } = 4;
}
