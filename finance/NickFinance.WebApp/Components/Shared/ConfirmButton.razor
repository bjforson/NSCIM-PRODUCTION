@*
    A primary/secondary action button that pops a native confirm() dialog
    before invoking its callback. Used on irreversible flows — Approve,
    Reject, Issue (mints a real GRA IRN), Disburse, Void.

    Usage:
      <ConfirmButton Class="primary" Confirm="Approve voucher PC-...?"
                     OnConfirmed="DoApprove">Approve</ConfirmButton>

    The dialog text should always be specific (include the voucher number,
    invoice IRN, etc.) so the operator can spot a fat-finger before it
    fires.
*@
@inject IJSRuntime JS

<button type="@Type" class="@Class" disabled="@Disabled" @onclick="HandleClickAsync" @onclick:preventDefault="true">
    @ChildContent
</button>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    /// <summary>Confirm-dialog text. Should name the entity and the action ("Approve voucher PC-...-00042?").</summary>
    [Parameter, EditorRequired] public string Confirm { get; set; } = "Are you sure?";

    /// <summary>Fires only after the user clicks OK in the confirm dialog.</summary>
    [Parameter] public EventCallback OnConfirmed { get; set; }

    /// <summary>CSS class — typically "primary" or "secondary" or "danger".</summary>
    [Parameter] public string Class { get; set; } = "primary";

    /// <summary>HTML button type. Default is "button" — never "submit" because that would bypass the confirm.</summary>
    [Parameter] public string Type { get; set; } = "button";

    [Parameter] public bool Disabled { get; set; }

    private async Task HandleClickAsync()
    {
        if (Disabled) return;
        var ok = await JS.InvokeAsync<bool>("confirm", Confirm);
        if (ok && OnConfirmed.HasDelegate)
        {
            await OnConfirmed.InvokeAsync();
        }
    }
}
