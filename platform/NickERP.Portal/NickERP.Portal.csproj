<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <!-- Roll forward to any newer .NET major that's installed. Matches API and
         NickComms.Gateway. Without this the service pins to 10.0.x and won't
         pick up an 11.0+ runtime if one is installed alongside. -->
    <RollForward>LatestMajor</RollForward>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>NickERP.Portal</RootNamespace>
    <AssemblyName>NickERP.Portal</AssemblyName>
    <Description>NICKSCAN ERP — Portal landing page. Card grid launcher + unified stats dashboard for NickHR, NSCIM Scan, and future ERP modules.</Description>
    <Version>1.1.0</Version>
    <Company>Nick TC-Scan Ltd</Company>
    <Product>NICKSCAN ERP SOLUTION</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MudBlazor" Version="8.13.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.7" />
    <PackageReference Include="Npgsql" Version="10.0.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NickERP.Platform.Web.Shared\NickERP.Platform.Web.Shared.csproj" />
  </ItemGroup>

</Project>
