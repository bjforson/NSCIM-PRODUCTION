<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NickERP.Platform.Web.Shared</RootNamespace>
    <AssemblyName>NickERP.Platform.Web.Shared</AssemblyName>
    <Description>NICKSCAN ERP SOLUTION — Shared Razor components, branding constants, and platform-wide UI helpers used by every module's web app.</Description>
    <Version>1.0.0</Version>
    <Company>Nick TC-Scan Ltd</Company>
    <Product>NICKSCAN ERP SOLUTION</Product>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Icon-only usage from MudBlazor — we intentionally do NOT pull in
         MudThemeProvider, the brand uses our own nep-* CSS tokens.
         Version pinned to match Portal so static assets line up. -->
    <PackageReference Include="MudBlazor" Version="8.13.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NickERP.Platform.Core\NickERP.Platform.Core.csproj" />
  </ItemGroup>

</Project>
