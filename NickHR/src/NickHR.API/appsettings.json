{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=nickhr;Username=nscim_app;Password=***USE_ENV_VAR_NICKSCAN_DB_PASSWORD***"
  },
  "Jwt": {
    "Key": "***USE_ENV_VAR_NICKHR_JWT_KEY***",
    "Issuer": "NickHR.API",
    "Audience": "NickHR.Client",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "CentralAuth": {
    "BaseUrl": "http://localhost:5205",
    "TimeoutSeconds": 10
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5310", "http://localhost:5299" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Email": {
    "_comment": "Legacy SMTP settings retained for reference. NickHR now sends all email/SMS via NickComms.Gateway.",
    "FromAddress": "noreply@nickhr.local",
    "FromName": "NickHR System"
  },
  "NickComms": {
    "BaseUrl": "http://localhost:5220",
    "ApiKey": ""
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5215"
}
