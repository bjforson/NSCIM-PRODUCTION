@page "/locations"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.SeniorHR)]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Constants
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>NICKSCAN ERP — NickHR — Locations</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Location Management</MudText>

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                Locations
                @if (!_isLoading)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">@_locations.Count</MudChip>
                }
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AddLocation"
                       Size="Size.Small"
                       OnClick="OpenCreateDialog">
                Add Location
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            <MudTable Items="@_locations"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      Bordered="false"
                      T="LocationRow">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<LocationRow, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
                    <MudTh>Address</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LocationRow, object>(x => x.City ?? string.Empty)">City</MudTableSortLabel></MudTh>
                    <MudTh>Region</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LocationRow, object>(x => x.Country)">Country</MudTableSortLabel></MudTh>
                    <MudTh>Head Office</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LocationRow, object>(x => x.EmployeeCount)">Employees</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="Address">
                        <MudText Typo="Typo.caption">@(context.Address ?? "—")</MudText>
                    </MudTd>
                    <MudTd DataLabel="City">@(context.City ?? "—")</MudTd>
                    <MudTd DataLabel="Region">@(context.Region ?? "—")</MudTd>
                    <MudTd DataLabel="Country">@context.Country</MudTd>
                    <MudTd DataLabel="Head Office">
                        @if (context.IsHeadOffice)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Star">
                                Head Office
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">—</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Active">
                        @if (context.IsActive)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Inactive</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Employees">
                        <MudChip T="string" Size="Size.Small" Color="@(context.EmployeeCount > 0 ? Color.Info : Color.Default)">
                            @context.EmployeeCount
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Warning"
                                       title="Edit"
                                       OnClick="@(() => OpenEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       title="Delete"
                                       OnClick="@(() => DeleteLocation(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
                </PagerContent>
                <NoRecordsContent>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-8">
                        No locations found. Click "Add Location" to create one.
                    </MudText>
                </NoRecordsContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private List<LocationRow> _locations = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLocations();
    }

    private async Task LoadLocations()
    {
        _isLoading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            _locations = await db.Locations
                .OrderByDescending(l => l.IsHeadOffice)
                .ThenBy(l => l.Name)
                .Select(l => new LocationRow
                {
                    Id = l.Id,
                    Name = l.Name,
                    Address = l.Address,
                    City = l.City,
                    Region = l.Region,
                    Country = l.Country,
                    IsHeadOffice = l.IsHeadOffice,
                    IsActive = l.IsActive,
                    EmployeeCount = l.Employees.Count()
                })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading locations: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<LocationDialog>
        {
            { x => x.Location, null }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LocationDialog>("Add Location", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadLocations();
        }
    }

    private async Task OpenEditDialog(int id)
    {
        Location? loc;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            loc = await db.Locations.FindAsync(id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading location: {ex.Message}", Severity.Error);
            return;
        }

        if (loc == null)
        {
            Snackbar.Add("Location not found.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<LocationDialog>
        {
            { x => x.Location, loc }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LocationDialog>("Edit Location", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadLocations();
        }
    }

    private async Task DeleteLocation(LocationRow row)
    {
        if (row.EmployeeCount > 0)
        {
            Snackbar.Add($"Cannot delete '{row.Name}': {row.EmployeeCount} employee(s) are assigned to this location.", Severity.Warning);
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            $"Are you sure you want to delete the location '{row.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            var entity = await db.Locations.FindAsync(row.Id);
            if (entity == null)
            {
                Snackbar.Add("Location not found.", Severity.Warning);
                return;
            }

            entity.IsDeleted = true;
            await db.SaveChangesAsync();

            Snackbar.Add($"Location '{row.Name}' deleted.", Severity.Success);
            await LoadLocations();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting location: {ex.Message}", Severity.Error);
        }
    }

    private class LocationRow
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? Region { get; set; }
        public string Country { get; set; } = "Ghana";
        public bool IsHeadOffice { get; set; }
        public bool IsActive { get; set; }
        public int EmployeeCount { get; set; }
    }
}
