@page "/admin/holidays"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.SuperAdminOnly)]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Leave
@using NickHR.Core.Constants
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>NICKSCAN ERP — NickHR — Public Holidays</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Public Holidays</MudText>

<!-- Year Selector + Add Button -->
<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="4" md="3">
                <MudSelect T="int" Label="Year" @bind-Value="_selectedYear" @bind-Value:after="LoadHolidays" Dense="true">
                    @for (int y = DateTime.Now.Year - 1; y <= DateTime.Now.Year + 2; y++)
                    {
                        var year = y;
                        <MudSelectItem T="int" Value="@year">@year</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="8" md="9" Class="d-flex justify-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateDialog">
                    Add Holiday
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@if (_isLoading)
{
    <div class="d-flex justify-center pa-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else
{
    <MudCard Elevation="2">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">
                    Holidays — @_selectedYear
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">@_holidays.Count</MudChip>
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            <MudTable Items="@_holidays" Dense="true" Hover="true" Striped="true" T="Holiday">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<Holiday, object>(x => x.Date)">Date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Holiday, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
                    <MudTh>Recurring</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Date.ToString("dd MMM yyyy")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Date.DayOfWeek</MudText>
                    </MudTd>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Recurring">
                        @if (context.IsRecurring)
                        { <MudChip T="string" Size="Size.Small" Color="Color.Success">Yes</MudChip> }
                        else
                        { <MudChip T="string" Size="Size.Small" Color="Color.Default">No</MudChip> }
                    </MudTd>
                    <MudTd DataLabel="Description">@(string.IsNullOrWhiteSpace(context.Description) ? "—" : context.Description)</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => OpenEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteHoliday(context))" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-8">
                        No holidays found for @_selectedYear.
                    </MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 15, 25, 50 }" />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
}

@code {
    private bool _isLoading = true;
    private int _selectedYear = DateTime.Now.Year;
    private List<Holiday> _holidays = new();

    protected override async Task OnInitializedAsync() => await LoadHolidays();

    private async Task LoadHolidays()
    {
        _isLoading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            _holidays = await db.Holidays
                .Where(h => h.Year == _selectedYear)
                .OrderBy(h => h.Date)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading holidays: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters<HolidayDialog>
        {
            { x => x.Holiday, null },
            { x => x.DefaultYear, _selectedYear }
        };
        var dialog = await DialogService.ShowAsync<HolidayDialog>("Add Holiday", parameters, options);
        if (!(await dialog.Result)?.Canceled ?? false) await LoadHolidays();
    }

    private async Task OpenEditDialog(Holiday holiday)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters<HolidayDialog>
        {
            { x => x.Holiday, holiday },
            { x => x.DefaultYear, _selectedYear }
        };
        var dialog = await DialogService.ShowAsync<HolidayDialog>("Edit Holiday", parameters, options);
        if (!(await dialog.Result)?.Canceled ?? false) await LoadHolidays();
    }

    private async Task DeleteHoliday(Holiday holiday)
    {
        var confirmed = await DialogService.ShowMessageBox("Confirm Delete",
            $"Delete holiday '{holiday.Name}' on {holiday.Date:dd MMM yyyy}?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var entity = await db.Holidays.FindAsync(holiday.Id);
            if (entity == null) return;
            entity.IsDeleted = true;
            await db.SaveChangesAsync();
            Snackbar.Add("Holiday deleted.", Severity.Success);
            await LoadHolidays();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting holiday: {ex.Message}", Severity.Error);
        }
    }
}
