@page "/employees/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin,HRManager,HROfficer")]
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core

<PageTitle>NICKSCAN ERP — NickHR — Add Employee</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Add New Employee</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <!-- Personal Information Tab -->
        <MudTabPanel Text="Personal Info" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.FirstName" Label="First Name *" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.MiddleName" Label="Middle Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.LastName" Label="Last Name *" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_dateOfBirth" Label="Date of Birth" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="Gender" @bind-Value="_model.Gender" Label="Gender *" Variant="Variant.Outlined" Required="true">
                        @foreach (var g in Enum.GetValues<Gender>())
                        {
                            <MudSelectItem Value="@g">@g.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="MaritalStatus" @bind-Value="_model.MaritalStatus" Label="Marital Status" Variant="Variant.Outlined">
                        @foreach (var s in Enum.GetValues<MaritalStatus>())
                        {
                            <MudSelectItem Value="@s">@s.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.Nationality" Label="Nationality" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.GhanaCardNumber" Label="Ghana Card Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.TIN" Label="TIN" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.SSNITNumber" Label="SSNIT Number" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Contact Tab -->
        <MudTabPanel Text="Contact" Icon="@Icons.Material.Filled.ContactPhone">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PrimaryPhone" Label="Primary Phone *" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.SecondaryPhone" Label="Secondary Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PersonalEmail" Label="Personal Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Email" Label="Work Email *" Variant="Variant.Outlined" InputType="InputType.Email" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.ResidentialAddress" Label="Residential Address" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.PostalAddress" Label="Postal Address" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.Hometown" Label="Hometown" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.Region" Label="Region" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Employment Tab -->
        <MudTabPanel Text="Employment" Icon="@Icons.Material.Filled.Work">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.DepartmentId" Label="Department *" Variant="Variant.Outlined" Required="true">
                        @foreach (var dept in _departments)
                        {
                            <MudSelectItem Value="@dept.Id">@dept.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.DesignationId" Label="Designation *" Variant="Variant.Outlined" Required="true">
                        @foreach (var desig in _designations)
                        {
                            <MudSelectItem Value="@desig.Id">@desig.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.GradeId" Label="Grade *" Variant="Variant.Outlined" Required="true">
                        @foreach (var grade in _grades)
                        {
                            <MudSelectItem Value="@grade.Id">@grade.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.LocationId" Label="Location *" Variant="Variant.Outlined" Required="true">
                        @foreach (var loc in _locations)
                        {
                            <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="EmploymentType" @bind-Value="_model.EmploymentType" Label="Employment Type *" Variant="Variant.Outlined" Required="true">
                        @foreach (var t in Enum.GetValues<EmploymentType>())
                        {
                            <MudSelectItem Value="@t">@t.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_hireDate" Label="Hire Date *" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?" @bind-Value="_model.ReportingManagerId" Label="Reporting Manager" Variant="Variant.Outlined">
                        <MudSelectItem T="int?" Value="null">— None —</MudSelectItem>
                        @foreach (var mgr in _managers)
                        {
                            <MudSelectItem T="int?" Value="@((int?)mgr.Id)">@mgr.FullName (@mgr.EmployeeCode)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Compensation Tab -->
        <MudTabPanel Text="Compensation" Icon="@Icons.Material.Filled.Payments">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_model.BasicSalary" Label="Basic Salary (GHS) *" Variant="Variant.Outlined"
                                     Format="N2" Min="0m" Required="true" Adornment="Adornment.Start" AdornmentText="GH₵" />
                </MudItem>
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Bank Details</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.BankName" Label="Bank Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.BankBranch" Label="Branch" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.BankAccountNumber" Label="Account Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.MobileMoneyNumber" Label="Mobile Money Number" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>

    <!-- Form Actions -->
    <MudPaper Class="d-flex justify-end gap-2 pa-4 mt-4" Elevation="0">
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/employees">Cancel</MudButton>
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_isSubmitting" StartIcon="@Icons.Material.Filled.Save">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save Employee
        </MudButton>
    </MudPaper>
</EditForm>

@code {
    private CreateEmployeeDto _model = new();
    private DateTime? _dateOfBirth;
    private DateTime? _hireDate = DateTime.Today;
    private bool _isSubmitting = false;

    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Grade> _grades = new();
    private List<Location> _locations = new();
    private List<EmployeeListItem> _managers = new();

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Employees", href: "/employees"),
        new BreadcrumbItem("Add New", href: null, disabled: true)
    };

    private record EmployeeListItem(int Id, string EmployeeCode, string FullName);

    protected override async Task OnInitializedAsync()
    {
        await LoadDropdownData();
    }

    private async Task LoadDropdownData()
    {
        await using var scope = ServiceProvider.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

        _departments = await db.Departments
            .Where(d => d.IsActive)
            .OrderBy(d => d.Name)
            .ToListAsync();

        _designations = await db.Designations
            .Where(d => d.IsActive)
            .OrderBy(d => d.Title)
            .ToListAsync();

        _grades = await db.Grades
            .Where(g => g.IsActive)
            .OrderBy(g => g.Level)
            .ToListAsync();

        _locations = await db.Locations
            .Where(l => l.IsActive)
            .OrderBy(l => l.Name)
            .ToListAsync();

        _managers = await db.Employees
            .Where(e => e.EmploymentStatus == EmploymentStatus.Active ||
                        e.EmploymentStatus == EmploymentStatus.Confirmed)
            .OrderBy(e => e.FirstName).ThenBy(e => e.LastName)
            .Select(e => new EmployeeListItem(
                e.Id,
                e.EmployeeCode,
                (e.FirstName + " " + (e.MiddleName != null ? e.MiddleName + " " : "") + e.LastName).Trim()))
            .ToListAsync();
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        try
        {
            if (_dateOfBirth.HasValue)
                _model.DateOfBirth = _dateOfBirth.Value;
            if (_hireDate.HasValue)
                _model.HireDate = _hireDate.Value;

            await using var scope = ServiceProvider.CreateAsyncScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            // Generate employee code
            var last = await db.Employees
                .Where(e => e.EmployeeCode.StartsWith("NHR-"))
                .OrderByDescending(e => e.EmployeeCode)
                .Select(e => e.EmployeeCode)
                .FirstOrDefaultAsync();

            int next = 1;
            if (last != null && int.TryParse(last.Replace("NHR-", ""), out var num))
                next = num + 1;
            var employeeCode = $"NHR-{next:D4}";

            var employee = new Employee
            {
                EmployeeCode = employeeCode,
                FirstName = _model.FirstName,
                MiddleName = _model.MiddleName,
                LastName = _model.LastName,
                DateOfBirth = _model.DateOfBirth,
                Gender = _model.Gender,
                MaritalStatus = _model.MaritalStatus,
                Nationality = _model.Nationality,
                GhanaCardNumber = _model.GhanaCardNumber,
                TIN = _model.TIN,
                SSNITNumber = _model.SSNITNumber,
                PrimaryPhone = _model.PrimaryPhone,
                SecondaryPhone = _model.SecondaryPhone,
                PersonalEmail = _model.PersonalEmail,
                WorkEmail = _model.Email,
                ResidentialAddress = _model.ResidentialAddress,
                PostalAddress = _model.PostalAddress,
                Hometown = _model.Hometown,
                Region = _model.Region,
                DepartmentId = _model.DepartmentId,
                DesignationId = _model.DesignationId,
                GradeId = _model.GradeId,
                LocationId = _model.LocationId,
                ReportingManagerId = _model.ReportingManagerId,
                EmploymentType = _model.EmploymentType,
                HireDate = _model.HireDate,
                EmploymentStatus = EmploymentStatus.OnProbation,
                BasicSalary = _model.BasicSalary,
                BankName = _model.BankName,
                BankBranch = _model.BankBranch,
                BankAccountNumber = _model.BankAccountNumber,
                MobileMoneyNumber = _model.MobileMoneyNumber,
            };

            db.Employees.Add(employee);
            await db.SaveChangesAsync();

            Snackbar.Add("Employee created successfully!", Severity.Success);
            Navigation.NavigateTo($"/employees/{employee.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
