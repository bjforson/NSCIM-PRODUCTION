                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newECName" Label="Full Name *" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newECRelationship" Label="Relationship" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newECPrimaryPhone" Label="Primary Phone *" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newECSecondaryPhone" Label="Secondary Phone" Variant="Variant.Outlined" />
                        </MudItem>
