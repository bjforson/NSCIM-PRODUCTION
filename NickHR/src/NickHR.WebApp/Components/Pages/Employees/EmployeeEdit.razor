    private async Task HandlePhotoUpload(IBrowserFile file)
    {
        if (_employee == null || file == null) return;
        if (file.Size > 10 * 1024 * 1024) { Snackbar.Add("Photo must be under 10 MB.", Severity.Warning); return; }

        _photoUploading = true;
        StateHasChanged();
        try
        {
            using var ms = new MemoryStream();
            await using var fs = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await fs.CopyToAsync(ms);

            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var emp = await db.Employees.FindAsync(_employee.Id);
            if (emp != null)
            {
                emp.PhotoData = ms.ToArray();
                emp.PhotoContentType = file.ContentType ?? "image/jpeg";
                emp.PhotoUrl = $"db://photo/{emp.Id}";
                await db.SaveChangesAsync();

                _employee.PhotoData = emp.PhotoData;
                _employee.PhotoContentType = emp.PhotoContentType;
                _employee.PhotoUrl = emp.PhotoUrl;
                Snackbar.Add($"Photo saved ({emp.PhotoData.Length / 1024} KB)", Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Upload error: {ex.Message}", Severity.Error); }
        finally { _photoUploading = false; StateHasChanged(); }
    }
