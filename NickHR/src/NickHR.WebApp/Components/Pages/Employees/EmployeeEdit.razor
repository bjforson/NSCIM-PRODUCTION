            @if (_employee.EmergencyContacts?.Any(c => !c.IsDeleted) == true)
            {
                <MudTable Items="_employee.EmergencyContacts.Where(c => !c.IsDeleted).ToList()" Dense="true" Hover="true" T="EmergencyContact">
                    <HeaderContent>
                        <MudTh>Name</MudTh><MudTh>Relationship</MudTh><MudTh>Primary Phone</MudTh><MudTh>Secondary Phone</MudTh><MudTh>Email</MudTh><MudTh>Actions</MudTh>
