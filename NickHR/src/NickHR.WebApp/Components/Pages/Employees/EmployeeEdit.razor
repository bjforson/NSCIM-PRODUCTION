@page "/employees/{Id:int}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.HRStaff)]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Enums
@using NickHR.Core.Constants
@using NickHR.WebApp.Components.Shared
@using NickHR.WebApp.Services

@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthStateProvider AuthStateProvider
@inject IIdentityProvisioningService Provisioning

<PageTitle>NICKSCAN ERP — NickHR — Edit Employee</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />Edit Employee
    </MudText>
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo($"/employees/{Id}"))">Back to Profile</MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_employee == null)
{
    <MudAlert Severity="Severity.Warning">Employee not found.</MudAlert>
}
else
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        <MudTabPanel Text="Personal" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.FirstName" Label="First Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.MiddleName" Label="Middle Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.LastName" Label="Last Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_dobDate" Label="Date of Birth" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.Gender" Label="Gender" Variant="Variant.Outlined">
                        @foreach (var g in Enum.GetValues<Gender>())
                        {
                            <MudSelectItem Value="g">@g</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.MaritalStatus" Label="Marital Status" Variant="Variant.Outlined">
                        @foreach (var m in Enum.GetValues<MaritalStatus>())
                        {
                            <MudSelectItem Value="m">@m</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Nationality" Label="Nationality" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.GhanaCardNumber" Label="Ghana Card Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.TIN" Label="TIN" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.SSNITNumber" Label="SSNIT Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.BloodGroup" Label="Blood Group" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Religion" Label="Religion" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.EthnicGroup" Label="Ethnic Group" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.PlaceOfBirth" Label="Place of Birth" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.MothersMaidenName" Label="Mother's Maiden Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.SpouseName" Label="Spouse Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.SpousePhone" Label="Spouse Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.SpouseEmployer" Label="Spouse Employer" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_employee.NumberOfChildren" Label="Number of Children" Variant="Variant.Outlined" Min="0" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.PassportNumber" Label="Passport Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_passportExpiryDate" Label="Passport Expiry" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.DriversLicenseNumber" Label="Driver's License No." Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_licenseExpiryDate" Label="License Expiry" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.MedicalConditions" Label="Medical Conditions / Allergies" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Contact" Icon="@Icons.Material.Filled.ContactPhone">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.PrimaryPhone" Label="Primary Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.SecondaryPhone" Label="Secondary Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.PersonalEmail" Label="Personal Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.WorkEmail" Label="Work Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_employee.ResidentialAddress" Label="Residential Address" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_employee.PostalAddress" Label="Postal Address" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.GhanaPostGPS" Label="Ghana Post GPS" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Hometown" Label="Hometown" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Region" Label="Region" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Employment" Icon="@Icons.Material.Filled.Work">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.EmployeeCode" Label="Employee Code" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.DepartmentId" Label="Department" Variant="Variant.Outlined" Clearable="true">
                        @foreach (var d in _departments)
                        {
                            <MudSelectItem Value="@((int?)d.Id)">@d.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.DesignationId" Label="Designation" Variant="Variant.Outlined" Clearable="true">
                        @foreach (var d in _designations)
                        {
                            <MudSelectItem Value="@((int?)d.Id)">@d.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.GradeId" Label="Grade" Variant="Variant.Outlined" Clearable="true">
                        @foreach (var g in _grades)
                        {
                            <MudSelectItem Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                   OnClick="SuggestGrade">Auto-suggest</MudButton>
                        @if (_suggestGradeMessage != null)
                        {
                            <MudText Typo="Typo.caption" Color="@_suggestGradeMessageColor">@_suggestGradeMessage</MudText>
                        }
                    </div>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.LocationId" Label="Location" Variant="Variant.Outlined" Clearable="true">
                        @foreach (var l in _locations)
                        {
                            <MudSelectItem Value="@((int?)l.Id)">@l.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.ReportingManagerId" Label="Reporting Manager" Variant="Variant.Outlined" Clearable="true"
                              HelperText="@($"Showing Grade {Math.Max((_employee?.Grade?.Level ?? 0) + 1, 4)}+ employees")">
                        @foreach (var e in _managers)
                        {
                            <MudSelectItem Value="@((int?)e.Id)">@e.FirstName @e.LastName — @(e.Designation?.Title ?? "No Designation")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.EmploymentType" Label="Employment Type" Variant="Variant.Outlined">
                        @foreach (var t in Enum.GetValues<EmploymentType>())
                        {
                            <MudSelectItem Value="t">@t</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_employee.EmploymentStatus" Label="Employment Status" Variant="Variant.Outlined">
                        @foreach (var s in Enum.GetValues<EmploymentStatus>())
                        {
                            <MudSelectItem Value="s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_hireDate" Label="Hire Date" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_confirmationDate" Label="Confirmation Date" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_probationEndDate" Label="Probation End Date" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Compensation" Icon="@Icons.Material.Filled.AttachMoney">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_employee.BasicSalary" @bind-Value:after="OnBasicSalaryChanged"
                                     Label="Basic Salary (GHS)" Variant="Variant.Outlined" Format="N2" Min="0" />
                    @if (_salarySuggestedGrade != null)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1" Icon="@Icons.Material.Filled.Lightbulb">
                            Suggested grade: <strong>@_salarySuggestedGrade.Name</strong> (GH₵@_employee.BasicSalary.ToString("N0") fits @_salarySuggestedGrade.Name band GH₵@_salarySuggestedGrade.MinSalary.ToString("N0")–@_salarySuggestedGrade.MaxSalary.ToString("N0"))
                        </MudAlert>
                    }
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.BankName" Label="Bank Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.BankBranch" Label="Bank Branch" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.BankAccountNumber" Label="Bank Account Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.MobileMoneyNumber" Label="Mobile Money Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Tier2PensionNumber" Label="Tier 2 Pension Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Tier2Provider" Label="Tier 2 Provider" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Tier3PensionNumber" Label="Tier 3 Pension Number" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_employee.Tier3Provider" Label="Tier 3 Provider" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Photo Tab -->
        <MudTabPanel Text="Photo" Icon="@Icons.Material.Filled.CameraAlt">
            <MudGrid>
                <MudItem xs="12" Class="d-flex flex-column align-center">
                    @if (_employee.PhotoData != null && _employee.PhotoData.Length > 0)
                    {
                        <MudAvatar Style="width:150px;height:150px;">
                            <MudImage Src="@($"data:{_employee.PhotoContentType ?? "image/jpeg"};base64,{Convert.ToBase64String(_employee.PhotoData)}")"
                                      Style="width:100%;height:100%;object-fit:cover;" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Style="width:150px;height:150px;font-size:3rem;" Color="Color.Primary">
                            @(_employee.FirstName.Length > 0 ? _employee.FirstName[0] : '?')
                        </MudAvatar>
                    }
                    <MudText Typo="Typo.caption" Class="mt-3 mb-2">Upload Portrait Photo</MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.webp" FilesChanged="HandlePhotoUpload" MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload"
                                       Disabled="_photoUploading">
                                @if (_photoUploading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Choose Photo
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Qualifications Tab -->
        <MudTabPanel Text="Qualifications" Icon="@Icons.Material.Filled.School">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.subtitle2">Employee Qualifications</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddQualification">Add Qualification</MudButton>
            </div>
            @if (_employee.EmployeeQualifications?.Any(q => !q.IsDeleted) == true)
            {
                <MudTable Items="_employee.EmployeeQualifications.Where(q => !q.IsDeleted).ToList()" Dense="true" Hover="true" T="EmployeeQualification">
                    <HeaderContent>
                        <MudTh>Type</MudTh><MudTh>Institution</MudTh><MudTh>Qualification</MudTh><MudTh>Field</MudTh><MudTh>Year</MudTh><MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.QualificationType</MudTd>
                        <MudTd>@context.Institution</MudTd>
                        <MudTd>@context.Qualification</MudTd>
                        <MudTd>@context.FieldOfStudy</MudTd>
                        <MudTd>@context.EndDate?.Year</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteQualification(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else { <MudText Typo="Typo.body2" Color="Color.Secondary">No qualifications recorded.</MudText> }

            @if (_showQualForm)
            {
                <MudPaper Class="pa-4 mt-3" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Add Qualification</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudSelect @bind-Value="_newQualType" Label="Type *" Variant="Variant.Outlined" T="string">
                                <MudSelectItem Value="@("Education")">Education</MudSelectItem>
                                <MudSelectItem Value="@("Certification")">Certification</MudSelectItem>
                                <MudSelectItem Value="@("Language")">Language</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudAutocomplete T="string" @bind-Value="_newQualInstitution" Label="Institution *" Variant="Variant.Outlined"
                                             SearchFunc="SearchInstitutions" MaxItems="15" Dense="true"
                                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.School"
                                             Placeholder="Type to search Ghana universities..." CoerceText="false" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newQualName" Label="Qualification *" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newQualField" Label="Field of Study" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="_newQualEndDate" Label="End Date" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                        </MudItem>
                        <MudItem xs="12" sm="4" Class="d-flex align-end gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveQualification" Size="Size.Small">Save</MudButton>
                            <MudButton Variant="Variant.Text" OnClick="() => _showQualForm = false" Size="Size.Small">Cancel</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
        </MudTabPanel>

        <!-- Dependents Tab -->
        <MudTabPanel Text="Dependents" Icon="@Icons.Material.Filled.FamilyRestroom">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.subtitle2">Dependents</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddDependent">Add Dependent</MudButton>
            </div>
            @if (_employee.Dependents?.Any(d => !d.IsDeleted) == true)
            {
                <MudTable Items="_employee.Dependents.Where(d => !d.IsDeleted).ToList()" Dense="true" Hover="true" T="Dependent">
                    <HeaderContent>
                        <MudTh>Name</MudTh><MudTh>Relationship</MudTh><MudTh>Date of Birth</MudTh><MudTh>Gender</MudTh><MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.FullName</MudTd>
                        <MudTd>@context.Relationship</MudTd>
                        <MudTd>@context.DateOfBirth?.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@context.Gender</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => EditDependent(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteDependent(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else { <MudText Typo="Typo.body2" Color="Color.Secondary">No dependents recorded.</MudText> }

            @if (_showDepForm)
            {
                <MudPaper Class="pa-4 mt-3" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@(_editingDepId.HasValue ? "Edit Dependent" : "Add Dependent")</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newDepName" Label="Full Name *" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect @bind-Value="_newDepRelationship" Label="Relationship *" Variant="Variant.Outlined" T="string">
                                <MudSelectItem Value="@("Child")">Child</MudSelectItem>
                                <MudSelectItem Value="@("Spouse")">Spouse</MudSelectItem>
                                <MudSelectItem Value="@("Parent")">Parent</MudSelectItem>
                                <MudSelectItem Value="@("Sibling")">Sibling</MudSelectItem>
                                <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="_newDepDob" Label="Date of Birth" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect @bind-Value="_newDepGender" Label="Gender" Variant="Variant.Outlined" T="Gender">
                                @foreach (var g in Enum.GetValues<Gender>()) { <MudSelectItem Value="g">@g</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4" Class="d-flex align-end gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDependent" Size="Size.Small">Save</MudButton>
                            <MudButton Variant="Variant.Text" OnClick="() => { _showDepForm = false; _editingDepId = null; }" Size="Size.Small">Cancel</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
        </MudTabPanel>

        <!-- Beneficiaries Tab -->
        <MudTabPanel Text="Beneficiaries" Icon="@Icons.Material.Filled.VolunteerActivism">
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-3">
                Per SSNIT regulations, only blood relations, spouses, or legal dependents can be nominated. Total share must equal 100%.
            </MudAlert>
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.subtitle2">Beneficiaries</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddBeneficiary">Add Beneficiary</MudButton>
            </div>
            @{ var activeBens = _employee.Beneficiaries?.Where(b => !b.IsDeleted).ToList() ?? new(); }
            @if (activeBens.Any())
            {
                var totalShare = activeBens.Sum(b => b.PercentageShare);
                @if (totalShare != 100)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">Total share is @totalShare% — should be 100%</MudAlert>
                }
                <MudTable Items="activeBens" Dense="true" Hover="true" T="Beneficiary">
                    <HeaderContent>
                        <MudTh>Name</MudTh><MudTh>Relationship</MudTh><MudTh>Phone</MudTh><MudTh>Share %</MudTh><MudTh>Primary</MudTh><MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.FullName</MudTd>
                        <MudTd>@context.Relationship</MudTd>
                        <MudTd>@context.Phone</MudTd>
                        <MudTd>@context.PercentageShare%</MudTd>
                        <MudTd><MudIcon Icon="@(context.IsPrimary ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" Color="@(context.IsPrimary ? Color.Success : Color.Default)" /></MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => EditBeneficiary(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
