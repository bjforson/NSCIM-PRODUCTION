                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newDocDescription" Label="Description" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudFileUpload T="IBrowserFile" FilesChanged="f => _docFile = f" MaximumFileCount="1">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile">
