    // === Document CRUD ===
    private void CancelDocForm() { _showDocForm = false; _docFile = null; _newDocDescription = string.Empty; }

    private async Task SaveDocument()
    {
        if (_docFile == null) { Snackbar.Add("Please choose a file.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_newDocType)) { Snackbar.Add("Document type is required.", Severity.Warning); return; }
        try
        {
            using var ms = new MemoryStream();
            await using var fs = _docFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            await fs.CopyToAsync(ms);
            var bytes = ms.ToArray();

            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var doc = new EmployeeDocument
            {
                EmployeeId = _employee!.Id,
                DocumentType = _newDocType,
                FileName = _docFile.Name,
                FilePath = $"db://doc/{_employee.Id}/{_docFile.Name}",
                ContentType = _docFile.ContentType,
                FileSize = bytes.Length,
                Description = _newDocDescription,
                FileData = bytes,
                UploadedAt = DateTime.UtcNow
            };
            db.EmployeeDocuments.Add(doc);
            await db.SaveChangesAsync();
            _employee.EmployeeDocuments ??= new List<EmployeeDocument>();
            _employee.EmployeeDocuments.Add(doc);
            _showDocForm = false;
            _docFile = null;
            _newDocDescription = "";
            Snackbar.Add("Document uploaded.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteDocument(EmployeeDocument doc)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var entity = await db.EmployeeDocuments.FindAsync(doc.Id);
            if (entity != null) { entity.IsDeleted = true; entity.UpdatedAt = DateTime.UtcNow; await db.SaveChangesAsync(); doc.IsDeleted = true; }
            Snackbar.Add("Document deleted.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task DownloadDocument(EmployeeDocument doc)
    {
        if (doc.FileData == null || doc.FileData.Length == 0) return;
        try
        {
            var base64 = Convert.ToBase64String(doc.FileData);
            await JS.InvokeVoidAsync("downloadFileFromBase64", doc.FileName, doc.ContentType ?? "application/octet-stream", base64);
        }
        catch (Exception ex) { Snackbar.Add($"Download error: {ex.Message}", Severity.Error); }
    }

    private static string FormatDocSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024:N1} KB";
        return $"{bytes / (1024 * 1024):N1} MB";
    }

