                        </MudItem>
                        <MudItem xs="12" Class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEmergencyContact" Size="Size.Small">Save</MudButton>
                            <MudButton Variant="Variant.Text" OnClick="() => { _showECForm = false; _editingECId = null; }" Size="Size.Small">Cancel</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }
        </MudTabPanel>

        @* W3B Phase 2 (2026-04-29) — NickFinance access (15-role catalog).
           Pre-populated from existing identity.user_roles for this employee.
           Apply runs on form Save. The wave-4 fast-path (ModuleAccessPanel
           on EmployeeDetail) continues to coexist for "manage existing"
           scenarios. *@
        <MudTabPanel Text="Module access" Icon="@Icons.Material.Filled.Security">
            @if (string.IsNullOrWhiteSpace(_employee?.WorkEmail))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Add a work email under <strong>Contact</strong> before granting NickFinance access. Identity rows
                    are keyed by lower-cased work email.
                </MudAlert>
            }
            else
            {
                <NickFinanceAccessSection @ref="_nickFinanceAccessSection"
                                          Email="@_employee.WorkEmail"
                                          DisplayName="@($"{_employee.FirstName} {_employee.LastName}".Trim())"
                                          UserId="@_identityUserId"
                                          OnStateChanged="OnNickFinanceStateChanged" />
            }
        </MudTabPanel>

    </MudTabs>

    @if (_nickFinanceState is not null && !_nickFinanceState.IsValid)
    {
        <MudAlert Severity="Severity.Warning" Class="mt-3">
            NickFinance access tab has invalid grants — pick a site for every site-required role and
            fill ExpiresAt + audit firm for ExternalAuditor before saving.
        </MudAlert>
    }

    <div class="d-flex gap-3 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync"
                   Disabled="@(_saving || (_nickFinanceState is not null && !_nickFinanceState.IsValid))">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save Changes
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo($"/employees/{Id}"))">Cancel</MudButton>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _saving = false;
    private bool _photoUploading = false;

    // W3B Phase 2 — NickFinance access section.
    private NickFinanceAccessSection? _nickFinanceAccessSection;
    private NickFinanceAccessSectionState? _nickFinanceState;
    /// <summary>
    /// The identity.users.internal_user_id resolved from the employee's
    /// work email. Null until the employee has been provisioned into the
    /// shared identity store (the wave-4 fast-path on EmployeeDetail can
    /// also do this). The section copes with null by rendering in
    /// "intent capture" mode and Save then provisions before applying.
    /// </summary>
    private Guid? _identityUserId;

    private Task OnNickFinanceStateChanged(NickFinanceAccessSectionState state)
    {
        _nickFinanceState = state;
        return Task.CompletedTask;
    }

    // Qualification form
    private bool _showQualForm = false;
    private string _newQualType = "Education";
    private string _newQualInstitution = "";
    private string _newQualName = "";
    private string _newQualField = "";
    private DateTime? _newQualEndDate;

    // Dependent form
    private bool _showDepForm = false;
    private string _newDepName = "";
    private string _newDepRelationship = "Child";
    private DateTime? _newDepDob;
    private Gender _newDepGender = Gender.Male;

    // Beneficiary form
    private bool _showBenForm = false;
    private int? _editingBenId;
    private string _newBenName = "";
    private string _newBenRelationship = "Spouse";
    private string _newBenPhone = "";
    private decimal _newBenShare = 0;
    private bool _newBenPrimary = false;
    private string _newBenGhanaCard = "";

    // Dependent edit tracking
    private int? _editingDepId;

    // Document form
    private bool _showDocForm = false;
    private string _newDocType = "Ghana Card";
    private string _newDocDescription = "";
    private IBrowserFile? _docFile;

    // Emergency Contact form
    private bool _showECForm = false;
    private int? _editingECId;
    private string _newECName = "";
    private string _newECRelationship = "";
    private string _newECPrimaryPhone = "";
    private string _newECSecondaryPhone = "";
    private string _newECEmail = "";
    private string _newECAddress = "";

    // Ghana Educational Institutions
    private static readonly string[] GhanaInstitutions = {
        // Public Universities
        "University of Ghana", "Kwame Nkrumah University of Science and Technology (KNUST)",
        "University of Cape Coast", "University of Education, Winneba",
        "University for Development Studies", "University of Professional Studies, Accra",
        "University of Mines and Technology", "University of Health and Allied Sciences",
        "University of Energy and Natural Resources", "University of Environment and Sustainable Development",
        "Ghana Institute of Management and Public Administration (GIMPA)",
        "Ghana Communication Technology University (GCTU)",
        "CK Tedam University for Technology and Applied Sciences",
        "Simon Diedong Dombo University for Business and Integrated Development Studies",
        "Akenten Appiah Menkah University of Skills Training and Entrepreneurial Development",
        // Technical Universities
        "Accra Technical University", "Kumasi Technical University", "Takoradi Technical University",
        "Koforidua Technical University", "Cape Coast Technical University", "Ho Technical University",
        "Sunyani Technical University", "Tamale Technical University", "Bolgatanga Technical University",
        "Wa Technical University",
        // Private Universities
        "Ashesi University", "Valley View University", "Central University",
        "Pentecost University", "All Nations University", "Regent University College of Science and Technology",
        "Methodist University College Ghana", "Presbyterian University College",
        "Catholic University College of Ghana", "Christian Service University College",
        "Wisconsin International University College", "Islamic University College",
        "African University College of Communications", "Accra Institute of Technology",
        "Lancaster University Ghana", "Webster University Ghana", "Zenith University College",
        "BlueCrest University College", "Data Link University College", "Knutsford University College",
        "Heritage Christian University College", "Jayee University College",
        "Ghana Baptist University College", "Dominion University College",
        "KAAF University", "Regional Maritime University", "Open University of West Africa",
        "Ghana Armed Forces Command and Staff College", "Ghana Institute of Journalism",
        "National Film and Television Institute (NAFTI)",
        // Nursing/Health Training
        "Korle Bu Nursing Training College", "Kumasi Nursing Training College",
        "Tamale Nursing Training College", "Cape Coast Nursing Training College",
        // Colleges of Education
        "University of Ghana College of Education", "OLA College of Education",
        "Wesley College of Education", "Komenda College of Education",
        "Foso College of Education", "St. Louis College of Education",
        // International (common)
        "University of London", "University of South Africa (UNISA)",
        "University of Leicester", "University of Sunderland",
        "Coventry University", "University of Liverpool",
        // Other
        "Other (specify below)"
    };
    private Employee? _employee;

    private List<Department> _departments = new();
    private List<Designation> _designations = new();
    private List<Grade> _grades = new();
    private List<Location> _locations = new();
    private List<Employee> _managers = new();

    // Grade auto-suggest
    private Grade? _suggestedGrade;
    private Grade? _salarySuggestedGrade;
    private string? _suggestGradeMessage;
    private Color _suggestGradeMessageColor = Color.Info;

    // DatePicker bridge properties
    private DateTime? _dobDate
    {
        get => _employee?.DateOfBirth;
        set { if (_employee != null) _employee.DateOfBirth = value; }
    }
    private DateTime? _hireDate
    {
        get => _employee?.HireDate;
        set { if (_employee != null) _employee.HireDate = value; }
    }
    private DateTime? _confirmationDate
    {
        get => _employee?.ConfirmationDate;
        set { if (_employee != null) _employee.ConfirmationDate = value; }
    }
    private DateTime? _probationEndDate
    {
        get => _employee?.ProbationEndDate;
        set { if (_employee != null) _employee.ProbationEndDate = value; }
    }
    private DateTime? _passportExpiryDate
    {
        get => _employee?.PassportExpiry;
        set { if (_employee != null) _employee.PassportExpiry = value; }
    }
    private DateTime? _licenseExpiryDate
    {
        get => _employee?.DriversLicenseExpiry;
        set { if (_employee != null) _employee.DriversLicenseExpiry = value; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            _employee = await db.Employees
                .Include(e => e.Department)
                .Include(e => e.Designation)
                .Include(e => e.Grade)
                .Include(e => e.Location)
                .Include(e => e.ReportingManager)
                .Include(e => e.EmergencyContacts)
                .Include(e => e.Dependents)
                .Include(e => e.Beneficiaries)
                .Include(e => e.EmployeeQualifications)
                .Include(e => e.EmployeeDocuments)
                .FirstOrDefaultAsync(e => e.Id == Id);

            _departments = await db.Departments.Where(d => d.IsActive).OrderBy(d => d.Name).ToListAsync();
            _designations = await db.Designations.Where(d => d.IsActive).OrderBy(d => d.Title).ToListAsync();
            _grades = await db.Grades.Where(g => g.IsActive).OrderBy(g => g.Level).ToListAsync();
            _locations = await db.Locations.Where(l => l.IsActive).OrderBy(l => l.Name).ToListAsync();
            // Intelligent filter: only show employees at a higher grade than the current employee
            // If employee has no grade, show Grade 4+ (Supervisor and above)
            var employeeGradeLevel = _employee?.Grade?.Level ?? 0;
            var minManagerLevel = Math.Max(employeeGradeLevel + 1, 4); // At least Grade 4, or one above current

            _managers = await db.Employees
                .Include(e => e.Grade)
                .Include(e => e.Designation)
                .Where(e => (e.EmploymentStatus == EmploymentStatus.Active || e.EmploymentStatus == EmploymentStatus.Confirmed)
                    && e.Id != Id
                    && !e.IsDeleted
                    && (
                        (e.GradeId != null && e.Grade != null && e.Grade.Level >= minManagerLevel)
                        || db.Employees.Any(sub => sub.ReportingManagerId == e.Id && !sub.IsDeleted) // Already has subordinates
                    ))
                .OrderBy(e => e.Grade!.Level).ThenBy(e => e.FirstName).ThenBy(e => e.LastName)
                .ToListAsync();

            // W3B Phase 2: pre-resolve the identity uuid so the
            // NickFinanceAccessSection can pre-populate existing grants
            // on render. Returns null if the employee hasn't been
            // provisioned into identity.users yet — the section then
            // renders in "intent capture" mode.
            if (_employee is not null && !string.IsNullOrWhiteSpace(_employee.WorkEmail))
            {
                _identityUserId = await Provisioning.GetUserIdByEmailAsync(_employee.WorkEmail, tenantId: 1L);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading employee: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Grade? FindMatchingGrade(decimal salary)
    {
        return _grades.FirstOrDefault(g => salary >= g.MinSalary && salary <= g.MaxSalary);
    }

    private void SuggestGrade()
    {
        if (_employee == null) return;
        _suggestedGrade = FindMatchingGrade(_employee.BasicSalary);
        if (_suggestedGrade != null)
        {
            _employee.GradeId = _suggestedGrade.Id;
            _suggestGradeMessage = $"Auto-selected: {_suggestedGrade.Name} (salary GH₵{_employee.BasicSalary:N0})";
            _suggestGradeMessageColor = Color.Success;
            Snackbar.Add($"Suggested Grade: {_suggestedGrade.Name} based on salary GH₵{_employee.BasicSalary:N0}", Severity.Info);
        }
        else
        {
            _suggestGradeMessage = "No grade matches the current salary";
            _suggestGradeMessageColor = Color.Warning;
            Snackbar.Add("No grade matches the current salary", Severity.Warning);
        }
    }

    private void OnBasicSalaryChanged()
    {
        if (_employee == null) return;
        _salarySuggestedGrade = FindMatchingGrade(_employee.BasicSalary);
    }

    private async Task SaveAsync()
    {
        if (_employee == null) return;
        _saving = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            db.Employees.Update(_employee);
            await db.SaveChangesAsync();

            // W3B Phase 2: apply NickFinance access changes after the
            // employee row commits. Resolve / upsert the identity row
            // first so the section has a real uuid to attach grants to.
            if (_nickFinanceAccessSection is not null && !string.IsNullOrWhiteSpace(_employee.WorkEmail))
            {
                try
                {
                    var displayName = $"{_employee.FirstName} {_employee.LastName}".Trim();
                    var identityUserId = _identityUserId
                        ?? await Provisioning.ProvisionEmployeeAsync(_employee.WorkEmail, displayName, tenantId: 1L);
                    _identityUserId = identityUserId;

                    var grantedBy = await ResolveGrantedByUserIdAsync(scope.ServiceProvider);
                    var ok = await _nickFinanceAccessSection.ApplyAsync(identityUserId, grantedBy);
                    if (!ok)
                    {
                        Snackbar.Add(
                            "Employee saved but a NickFinance role grant was blocked by an SoD violation — see banner above.",
                            Severity.Warning);
                        _saving = false;
                        return; // Stay on the page so HR can adjust.
                    }
                }
                catch (Exception nfx)
                {
                    Snackbar.Add($"Employee saved but NickFinance role grants failed: {nfx.Message}", Severity.Warning);
                }
            }

            Snackbar.Add("Employee updated successfully.", Severity.Success);
            Nav.NavigateTo($"/employees/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>
    /// Resolve the cookie-authenticated admin's identity.users id, auto-
    /// provisioning a row if needed. Used as <c>granted_by_user_id</c> on
    /// every NickFinance role grant created from this form.
    /// </summary>
    private async Task<Guid> ResolveGrantedByUserIdAsync(IServiceProvider sp)
    {
        try
        {
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            var email = state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                       ?? state.User.FindFirst("email")?.Value
                       ?? state.User.Identity?.Name;
            if (string.IsNullOrWhiteSpace(email)) return Guid.Empty;

            var existing = await Provisioning.GetUserIdByEmailAsync(email, tenantId: 1L);
            if (existing is not null) return existing.Value;

            var userManager = sp.GetService<UserManager<ApplicationUser>>();
            var displayName = email;
            if (userManager is not null)
            {
                var u = await userManager.FindByEmailAsync(email);
                if (u is not null) displayName = $"{u.FirstName} {u.LastName}".Trim();
            }
            return await Provisioning.ProvisionEmployeeAsync(email, displayName, tenantId: 1L);
        }
        catch
        {
            return Guid.Empty;
        }
    }

    // === Institution Search ===
    private Task<IEnumerable<string>> SearchInstitutions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(GhanaInstitutions.AsEnumerable());
        return Task.FromResult(GhanaInstitutions.Where(i => i.Contains(value, StringComparison.OrdinalIgnoreCase)));
