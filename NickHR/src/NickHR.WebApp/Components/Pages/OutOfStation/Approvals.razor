@page "/out-of-station/approvals"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.HRStaffPlusDeptAndPayroll)]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Payroll
@using NickHR.Core.Enums
@using NickHR.Services.OutOfStation
@using NickHR.Core.Constants

@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>NICKSCAN ERP — NickHR — Out-of-Station Approvals</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Approval" Class="mr-2" />
    Out-of-Station Approvals
</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<MudCard Elevation="2">
    <MudCardContent>
        <MudTable Items="_requests" Dense="true" Hover="true" Loading="_loading"
                  LoadingProgressColor="Color.Primary" T="OutOfStationRequest"
                  OnRowClick="@(args => ToggleExpand(args.Item))">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Pending Requests</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadData">Refresh</MudButton>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Employee</MudTh>
                <MudTh>Destination</MudTh>
                <MudTh>Dates</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh>Type</MudTh>
                <MudTh Style="text-align:right">Total Allowance</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Employee">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2"><strong>@context.Employee?.FirstName @context.Employee?.LastName</strong></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Employee?.Grade?.Name ?? "No Grade")</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Destination">@context.Destination</MudTd>
                <MudTd DataLabel="Dates">
                    @context.DepartureDate.ToString("dd MMM") – @context.ReturnDate.ToString("dd MMM yyyy")
                </MudTd>
                <MudTd DataLabel="Duration">@context.NumberOfDays d / @context.NumberOfNights n</MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.DestinationType == OutOfStationDestType.International ? Color.Warning : Color.Default)">
                        @context.DestinationType
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Total" Style="text-align:right">
                    <strong>GH₵@context.TotalAllowance.ToString("N2")</strong>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" @onclick:stopPropagation="true">
                    @if (context.Status == OutOfStationStatus.Pending)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                   OnClick="@(() => OpenApproveDialog(context))" Class="mr-1">
                            Approve
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                   OnClick="@(() => OpenRejectDialog(context))">
                            Reject
                        </MudButton>
                    }
                    @if (context.Status == OutOfStationStatus.Approved)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                   OnClick="@(() => MarkCompleted(context.Id))">
                            Mark Complete
                        </MudButton>
                    }
                    @if (context.Status == OutOfStationStatus.Completed)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Dark"
                                   OnClick="@(() => OpenSettleDialog(context))">
                            Settle
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (_expandedId == context.Id)
                {
                    <MudTr>
                        <MudTd colspan="8" Style="padding:0;">
                            <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                                <MudGrid>
                                    <MudItem xs="12" md="4">
                                        <MudText Typo="Typo.subtitle2" Class="mb-2">Allowance Breakdown</MudText>
                                        <MudSimpleTable Dense="true">
                                            <tbody>
                                                <tr><td>Accommodation (@context.NumberOfNights nights)</td><td style="text-align:right">GH₵@context.AccommodationTotal.ToString("N2")</td></tr>
                                                <tr><td>Feeding (@context.NumberOfDays days)</td><td style="text-align:right">GH₵@context.FeedingTotal.ToString("N2")</td></tr>
                                                <tr><td>Transport (@context.TransportMode, 2 trips)</td><td style="text-align:right">GH₵@context.TransportTotal.ToString("N2")</td></tr>
                                                <tr><td>Miscellaneous (@context.NumberOfDays days)</td><td style="text-align:right">GH₵@context.MiscellaneousTotal.ToString("N2")</td></tr>
                                                <tr style="font-weight:bold;"><td>Total</td><td style="text-align:right">GH₵@context.TotalAllowance.ToString("N2")</td></tr>
                                            </tbody>
                                        </MudSimpleTable>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudText Typo="Typo.subtitle2" Class="mb-2">Purpose</MudText>
                                        <MudText Typo="Typo.body2">@context.Purpose</MudText>
                                    </MudItem>
                                    @if (context.AdvancePaid > 0)
                                    {
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2">Settlement Info</MudText>
                                            <MudText Typo="Typo.body2">Advance Paid: GH₵@context.AdvancePaid.ToString("N2")</MudText>
                                            @if (context.ActualExpenses.HasValue)
                                            {
                                                <MudText Typo="Typo.body2">Actual Expenses: GH₵@context.ActualExpenses.Value.ToString("N2")</MudText>
                                                <MudText Typo="Typo.body2">Settlement: GH₵@(context.SettlementAmount?.ToString("N2") ?? "—")</MudText>
                                            }
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudPaper>
                        </MudTd>
                    </MudTr>
                }
            </ChildRowContent>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                    No requests awaiting action.
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

<!-- Approve Dialog -->
<MudDialog @bind-IsVisible="_approveDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Class="mr-2" />
            Approve Request
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedRequest != null)
        {
            <MudText Class="mb-3">
                Approving allowance for <strong>@_selectedRequest.Employee?.FirstName @_selectedRequest.Employee?.LastName</strong>
                travelling to <strong>@_selectedRequest.Destination</strong>.
            </MudText>
            <MudNumericField T="decimal" @bind-Value="_advanceAmount" Label="Advance Amount (GH₵)"
                             HelperText="Amount to advance before travel (defaults to total allowance)"
                             Min="0" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                Total approved allowance: GH₵@_selectedRequest.TotalAllowance.ToString("N2")
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _approveDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ConfirmApprove" Disabled="_processing">
            @(_processing ? "Processing..." : "Confirm Approve")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Reject Dialog -->
<MudDialog @bind-IsVisible="_rejectDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2" />
            Reject Request
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_rejectionReason" Label="Reason for Rejection" Required="true"
                      Lines="3" Placeholder="Please provide a reason..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _rejectDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ConfirmReject" Disabled="_processing">
            @(_processing ? "Processing..." : "Confirm Reject")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Settle Dialog -->
<MudDialog @bind-IsVisible="_settleDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Dark" Class="mr-2" />
            Settle Request
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedRequest != null)
        {
            <MudText Class="mb-3">
                Settling for <strong>@_selectedRequest.Employee?.FirstName @_selectedRequest.Employee?.LastName</strong>.
                Advance paid: <strong>GH₵@_selectedRequest.AdvancePaid.ToString("N2")</strong>
            </MudText>
            <MudNumericField T="decimal" @bind-Value="_actualExpenses" Label="Actual Expenses (GH₵)"
                             HelperText="Total actual cost incurred during travel" Min="0" />
            @if (_actualExpenses > 0)
            {
                var diff = _actualExpenses - _selectedRequest.AdvancePaid;
                <MudAlert Severity="@(diff > 0 ? Severity.Info : Severity.Warning)" Class="mt-2" Dense="true">
                    @if (diff > 0)
                    {
                        <span>Reimburse employee: GH₵@diff.ToString("N2")</span>
                    }
                    else if (diff < 0)
                    {
                        <span>Employee to refund: GH₵@Math.Abs(diff).ToString("N2")</span>
                    }
                    else
                    {
                        <span>No further payment required.</span>
                    }
                </MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _settleDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Dark" OnClick="ConfirmSettle" Disabled="_processing">
            @(_processing ? "Processing..." : "Confirm Settlement")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<OutOfStationRequest> _requests = new();
    private bool _loading = true;
    private int _currentEmployeeId;
    private int? _expandedId;

    // Dialogs
    private bool _approveDialogOpen;
    private bool _rejectDialogOpen;
    private bool _settleDialogOpen;
    private bool _processing;
    private OutOfStationRequest? _selectedRequest;
    private decimal _advanceAmount;
    private string _rejectionReason = string.Empty;
    private decimal _actualExpenses;

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new("Home", "/"),
        new("Out-of-Station Approvals", null, true)
    };

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = authState.User?.Identity?.Name
            ?? authState.User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;

        var emp = await db.Employees.FirstOrDefaultAsync(e => e.WorkEmail == username || e.PersonalEmail == username);
        _currentEmployeeId = emp?.Id ?? 0;

        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        using var scope = ServiceProvider.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<OutOfStationService>();
        _requests = await svc.GetAllRequestsAsync();
        _loading = false;
    }

    private void ToggleExpand(OutOfStationRequest request)
    {
        _expandedId = _expandedId == request.Id ? null : request.Id;
    }

    private void OpenApproveDialog(OutOfStationRequest request)
    {
        _selectedRequest = request;
        _advanceAmount = request.TotalAllowance;
        _approveDialogOpen = true;
    }

    private void OpenRejectDialog(OutOfStationRequest request)
    {
        _selectedRequest = request;
        _rejectionReason = string.Empty;
        _rejectDialogOpen = true;
    }

    private void OpenSettleDialog(OutOfStationRequest request)
    {
        _selectedRequest = request;
        _actualExpenses = request.TotalAllowance;
        _settleDialogOpen = true;
    }

    private async Task ConfirmApprove()
    {
        if (_selectedRequest == null) return;
        _processing = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<OutOfStationService>();
            await svc.ApproveAsync(_selectedRequest.Id, _currentEmployeeId, _advanceAmount);
            Snackbar.Add("Request approved.", Severity.Success);
            _approveDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _processing = false; }
    }

    private async Task ConfirmReject()
    {
        if (_selectedRequest == null || string.IsNullOrWhiteSpace(_rejectionReason))
        {
            Snackbar.Add("Please provide a rejection reason.", Severity.Warning);
            return;
        }
        _processing = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<OutOfStationService>();
            await svc.RejectAsync(_selectedRequest.Id, _currentEmployeeId, _rejectionReason);
            Snackbar.Add("Request rejected.", Severity.Info);
            _rejectDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _processing = false; }
    }

    private async Task MarkCompleted(int id)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<OutOfStationService>();
            await svc.CompleteAsync(id);
            Snackbar.Add("Marked as completed.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmSettle()
    {
        if (_selectedRequest == null) return;
        _processing = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<OutOfStationService>();
            await svc.SettleAsync(_selectedRequest.Id, _actualExpenses);
            Snackbar.Add("Request settled.", Severity.Success);
            _settleDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _processing = false; }
    }

    private Color GetStatusColor(OutOfStationStatus status) => status switch
    {
        OutOfStationStatus.Pending => Color.Warning,
        OutOfStationStatus.Approved => Color.Info,
        OutOfStationStatus.Rejected => Color.Error,
        OutOfStationStatus.Completed => Color.Success,
        OutOfStationStatus.Settled => Color.Dark,
        _ => Color.Default
    };
}
