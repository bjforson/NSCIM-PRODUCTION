@page "/recognition/leaderboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Enums

@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<PageTitle>NICKSCAN ERP — NickHR — Recognition Leaderboard</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Class="mr-2" />Recognition Leaderboard
</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<MudGrid>
    <!-- Period selector -->
    <MudItem xs="12">
        <MudCard Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudGrid AlignItems="Center">
                    <MudItem xs="12" sm="3" md="2">
                        <MudSelect T="int" @bind-Value="_selectedMonth" Label="Month" Variant="Variant.Outlined" Dense="true">
                            @for (int m = 1; m <= 12; m++)
                            {
                                var month = m;
                                <MudSelectItem Value="@month">@(new DateTime(2000, month, 1).ToString("MMMM"))</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="3" md="2">
                        <MudNumericField T="int" @bind-Value="_selectedYear" Label="Year" Variant="Variant.Outlined"
                                         Min="2020" Max="2099" Dense="true" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadLeaderboardAsync"
                                   StartIcon="@Icons.Material.Filled.Refresh">
                            Load
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @if (_loading)
    {
        <MudItem xs="12">
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        </MudItem>
    }

    <!-- Podium for top 3 -->
    @if (_entries.Count >= 3)
    {
        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">Top Performers</MudText>
                <MudGrid Justify="Justify.Center">
                    <!-- 2nd place -->
                    <MudItem xs="4" Class="d-flex flex-column align-center">
                        <MudAvatar Size="Size.Large" Style="background-color:#C0C0C0;color:white;width:64px;height:64px;font-size:1.2rem">
                            @_entries[1].FirstName[0]@_entries[1].LastName[0]
                        </MudAvatar>
                        <MudText Typo="Typo.subtitle2" Class="mt-2">@_entries[1].FirstName @_entries[1].LastName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_entries[1].Department</MudText>
                        <MudChip T="string" Size="Size.Small" Style="background-color:#C0C0C0;color:white">@_entries[1].TotalPoints pts</MudChip>
                        <MudPaper Style="background-color:#C0C0C0;height:80px;width:80%;margin-top:8px" Elevation="0" />
                        <MudText Typo="Typo.h6" Style="color:#C0C0C0">2nd</MudText>
                    </MudItem>
                    <!-- 1st place -->
                    <MudItem xs="4" Class="d-flex flex-column align-center">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color:#FFD700;font-size:2rem" />
                        <MudAvatar Size="Size.Large" Style="background-color:#FFD700;color:white;width:72px;height:72px;font-size:1.4rem">
                            @_entries[0].FirstName[0]@_entries[0].LastName[0]
                        </MudAvatar>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:bold" Class="mt-2">@_entries[0].FirstName @_entries[0].LastName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_entries[0].Department</MudText>
                        <MudChip T="string" Size="Size.Small" Style="background-color:#FFD700;color:white">@_entries[0].TotalPoints pts</MudChip>
                        <MudPaper Style="background-color:#FFD700;height:120px;width:80%;margin-top:8px" Elevation="0" />
                        <MudText Typo="Typo.h5" Style="color:#FFD700">1st</MudText>
                    </MudItem>
                    <!-- 3rd place -->
                    <MudItem xs="4" Class="d-flex flex-column align-center">
                        <MudAvatar Size="Size.Large" Style="background-color:#CD7F32;color:white;width:60px;height:60px;font-size:1.1rem">
                            @_entries[2].FirstName[0]@_entries[2].LastName[0]
                        </MudAvatar>
                        <MudText Typo="Typo.subtitle2" Class="mt-2">@_entries[2].FirstName @_entries[2].LastName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_entries[2].Department</MudText>
                        <MudChip T="string" Size="Size.Small" Style="background-color:#CD7F32;color:white">@_entries[2].TotalPoints pts</MudChip>
                        <MudPaper Style="background-color:#CD7F32;height:55px;width:80%;margin-top:8px" Elevation="0" />
                        <MudText Typo="Typo.h6" Style="color:#CD7F32">3rd</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    }

    <!-- Full table -->
    <MudItem xs="12">
        <MudTable Items="_entries" Dense="false" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Loading="_loading">
            <HeaderContent>
                <MudTh>Rank</MudTh>
                <MudTh>Employee</MudTh>
                <MudTh>Department</MudTh>
                <MudTh>Total Points</MudTh>
                <MudTh>Kudos Received</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Rank">
                    @{
                        var rank = _entries.IndexOf(context) + 1;
                    }
                    <MudText Style="@($"font-weight:bold;color:{GetRankColor(rank)}")">
                        @(rank <= 3 ? GetRankIcon(rank) : rank.ToString())
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Employee">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                            @context.FirstName[0]@context.LastName[0]
                        </MudAvatar>
                        <MudText>@context.FirstName @context.LastName</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Department">@context.Department</MudTd>
                <MudTd DataLabel="Total Points">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Star">
                        @context.TotalPoints
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Kudos Received">@context.KudosCount</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No recognition data for this period.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private bool _loading = true;
    private int _selectedMonth = DateTime.Now.Month;
    private int _selectedYear = DateTime.Now.Year;
    private List<LeaderboardEntry> _entries = new();

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Recognition", href: "/recognition"),
        new BreadcrumbItem("Leaderboard", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaderboardAsync();
    }

    private async Task LoadLeaderboardAsync()
    {
        _loading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            var startDate = new DateTime(_selectedYear, _selectedMonth, 1, 0, 0, 0, DateTimeKind.Utc);
            var endDate = startDate.AddMonths(1);

            _entries = await db.Recognitions
                .Include(r => r.RecipientEmployee).ThenInclude(e => e.Department)
                .Where(r => !r.IsDeleted && r.CreatedAt >= startDate && r.CreatedAt < endDate)
                .GroupBy(r => new
                {
                    r.RecipientEmployeeId,
                    r.RecipientEmployee.FirstName,
                    r.RecipientEmployee.LastName,
                    DeptName = r.RecipientEmployee.Department != null ? r.RecipientEmployee.Department.Name : "N/A"
                })
                .Select(g => new LeaderboardEntry
                {
                    EmployeeId = g.Key.RecipientEmployeeId,
                    FirstName = g.Key.FirstName,
                    LastName = g.Key.LastName,
                    Department = g.Key.DeptName,
                    TotalPoints = g.Sum(x => x.Points),
                    KudosCount = g.Count()
                })
                .OrderByDescending(x => x.TotalPoints)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading leaderboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetRankColor(int rank) => rank switch
    {
        1 => "#FFD700",
        2 => "#C0C0C0",
        3 => "#CD7F32",
        _ => "inherit"
    };

    private static string GetRankIcon(int rank) => rank switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => rank.ToString()
    };

    private class LeaderboardEntry
    {
        public int EmployeeId { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public int TotalPoints { get; set; }
        public int KudosCount { get; set; }
    }
}
