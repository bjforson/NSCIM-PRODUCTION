@page "/settings/delegation"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.HRStaffOrDeptManager)]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.System
@using NickHR.Core.Entities.Core
@using NickHR.Core.Enums
@using NickHR.Services.Common
@using NickHR.Core.Constants

@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<PageTitle>NICKSCAN ERP — NickHR — Approval Delegation</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-2" />Approval Delegation
</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader><MudText Typo="Typo.h6">Create Delegation</MudText></MudCardHeader>
            <MudCardContent>
                <MudSelect T="int?" @bind-Value="_delegatorId" Label="Delegator" Required="true">
                    @foreach (var e in _employees)
                    {
                        <MudSelectItem T="int?" Value="@e.Id">@e.FirstName @e.LastName</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int?" @bind-Value="_delegateId" Label="Delegate" Required="true" Class="mt-3">
                    @foreach (var e in _employees.Where(x => x.Id != _delegatorId))
                    {
                        <MudSelectItem T="int?" Value="@e.Id">@e.FirstName @e.LastName</MudSelectItem>
                    }
                </MudSelect>
                <MudDatePicker Label="Start Date" @bind-Date="_startDate" Class="mt-3" />
                <MudDatePicker Label="End Date" @bind-Date="_endDate" Class="mt-3" />
                <MudTextField @bind-Value="_reason" Label="Reason" Lines="2" Class="mt-3" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                           OnClick="CreateDelegation">Create Delegation</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudCard Elevation="2">
            <MudCardHeader><MudText Typo="Typo.h6">Active Delegations</MudText></MudCardHeader>
            <MudCardContent>
                <MudTable Items="_delegations" Dense="true" Hover="true" Loading="_loading">
                    <HeaderContent>
                        <MudTh>Delegator</MudTh><MudTh>Delegate</MudTh><MudTh>Period</MudTh><MudTh>Reason</MudTh><MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Delegator?.FirstName @context.Delegator?.LastName</MudTd>
                        <MudTd>@context.Delegate?.FirstName @context.Delegate?.LastName</MudTd>
                        <MudTd>@context.StartDate.ToString("dd MMM") - @context.EndDate.ToString("dd MMM yyyy")</MudTd>
                        <MudTd>@context.Reason</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                                           OnClick="@(() => Deactivate(context.Id))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<ApprovalDelegation> _delegations = new();
    private List<Employee> _employees = new();
    private bool _loading = true;
    private int? _delegatorId, _delegateId;
    private DateTime? _startDate = DateTime.Today, _endDate = DateTime.Today.AddDays(7);
    private string _reason = "";
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new("Home", "/"), new("Settings", null), new("Delegation", null, true)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
        var svc = scope.ServiceProvider.GetRequiredService<DelegationService>();
        _employees = await db.Employees.Where(e => e.EmploymentStatus == EmploymentStatus.Active).OrderBy(e => e.FirstName).ToListAsync();
        _delegations = await svc.GetActiveAsync();
        _loading = false;
    }

    private async Task CreateDelegation()
    {
        if (!_delegatorId.HasValue || !_delegateId.HasValue || !_startDate.HasValue || !_endDate.HasValue)
        {
            Snackbar.Add("Please fill all fields", Severity.Warning);
            return;
        }
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<DelegationService>();
            await svc.CreateAsync(new ApprovalDelegation
            {
                DelegatorId = _delegatorId.Value, DelegateId = _delegateId.Value,
                StartDate = _startDate.Value, EndDate = _endDate.Value, Reason = _reason
            });
            Snackbar.Add("Delegation created", Severity.Success);
            await LoadData();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task Deactivate(int id)
    {
        using var scope = ServiceProvider.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<DelegationService>();
        await svc.DeactivateAsync(id);
        Snackbar.Add("Delegation deactivated", Severity.Info);
        await LoadData();
    }
}
