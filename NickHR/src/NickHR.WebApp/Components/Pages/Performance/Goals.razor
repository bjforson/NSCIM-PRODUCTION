@page "/performance/goals"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.HRStaffOrDeptManager)]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Performance
@using NickHR.Core.Entities.Core
@using NickHR.Core.Constants
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>NICKSCAN ERP — NickHR — Goals &amp; OKRs</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Goals &amp; OKRs</MudText>

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                Goals
                @if (!_isLoading)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">@_goals.Count</MudChip>
                }
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudSelect T="int?" Value="_selectedCycleId" Label="Appraisal Cycle" Variant="Variant.Outlined"
                       Dense="true" Style="min-width:220px;" Class="mr-2"
                       ValueChanged="@((int? v) => OnCycleChanged(v))">
                <MudSelectItem T="int?" Value="@((int?)null)">All Cycles</MudSelectItem>
                @foreach (var c in _cycles)
                {
                    <MudSelectItem T="int?" Value="@((int?)c.Id)">@c.Name</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                       OnClick="OpenCreateDialog">
                Create Goal
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
        @if (_isLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            <MudTable Items="@_goals" Dense="true" Hover="true" Striped="true" T="GoalRow">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<GoalRow, object>(x => x.EmployeeName)">Employee</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GoalRow, object>(x => x.Title)">Title</MudTableSortLabel></MudTh>
                    <MudTh>Target</MudTh>
                    <MudTh>Weight</MudTh>
                    <MudTh Style="min-width:160px;">Progress</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Due Date</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Employee">@context.EmployeeName</MudTd>
                    <MudTd DataLabel="Title">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Title</MudText>
                    </MudTd>
                    <MudTd DataLabel="Target">@(context.TargetValue ?? "—")</MudTd>
                    <MudTd DataLabel="Weight">@context.Weight%</MudTd>
                    <MudTd DataLabel="Progress">
                        <div class="d-flex align-center gap-2">
                            <MudProgressLinear Value="@((double)context.ProgressPercent)"
                                              Color="@GetProgressColor(context.ProgressPercent)"
                                              Rounded="true" Size="Size.Medium" Class="flex-grow-1" />
                            <MudText Typo="Typo.caption" Style="min-width:36px;">@context.ProgressPercent%</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Due Date">
                        @if (context.DueDate.HasValue)
                        {
                            <span class="@(context.DueDate.Value < DateTime.Today && context.Status != "Completed" ? "mud-error-text" : "")">
                                @context.DueDate.Value.ToString("dd MMM yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="mud-text-secondary">—</span>
                        }
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Color="Color.Info"
                                       Title="Update Progress" OnClick="@(() => OpenProgressDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => OpenEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteGoal(context.Id))" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Class="pa-4 mud-text-secondary">No goals found. Create one to get started.</MudText>
                </NoRecordsContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private bool _isLoading = true;
    private int? _selectedCycleId;
    private List<CycleOption> _cycles = new();
    private List<GoalRow> _goals = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCycles();
        await LoadGoals();
    }

    private async Task LoadCycles()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            _cycles = await db.AppraisalCycles
                .OrderByDescending(c => c.StartDate)
                .Select(c => new CycleOption { Id = c.Id, Name = c.Name })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading cycles: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadGoals()
    {
        _isLoading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var query = db.Goals.Include(g => g.Employee).AsQueryable();
            if (_selectedCycleId.HasValue)
                query = query.Where(g => g.AppraisalCycleId == _selectedCycleId.Value);

            _goals = await query
                .OrderByDescending(g => g.CreatedAt)
                .Select(g => new GoalRow
                {
                    Id = g.Id,
                    EmployeeName = g.Employee.FirstName + " " + g.Employee.LastName,
                    Title = g.Title,
                    TargetValue = g.TargetValue,
                    Weight = g.Weight,
                    ProgressPercent = g.ProgressPercent,
                    Status = g.Status,
                    DueDate = g.DueDate,
                    AppraisalCycleId = g.AppraisalCycleId
                })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading goals: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnCycleChanged(int? val)
    {
        _selectedCycleId = val;
        await LoadGoals();
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters
        {
            ["GoalId"] = (int?)null,
            ["DefaultCycleId"] = _selectedCycleId
        };
        var dialog = await DialogService.ShowAsync<GoalDialog>("Create Goal", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadGoals();
    }

    private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters
        {
            ["GoalId"] = (int?)id,
            ["DefaultCycleId"] = (int?)null
        };
        var dialog = await DialogService.ShowAsync<GoalDialog>("Edit Goal", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadGoals();
    }

    private async Task OpenProgressDialog(GoalRow row)
    {
        var parameters = new DialogParameters { ["GoalId"] = row.Id };
        var dialog = await DialogService.ShowAsync<GoalProgressDialog>("Update Progress", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadGoals();
    }

    private async Task DeleteGoal(int id)
    {
        bool? confirmed = await DialogService.ShowMessageBox("Delete Goal",
            "Are you sure you want to delete this goal?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var entity = await db.Goals.FindAsync(id);
            if (entity == null) return;
            entity.IsDeleted = true;
            await db.SaveChangesAsync();
            Snackbar.Add("Goal deleted.", Severity.Success);
            await LoadGoals();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting: {ex.Message}", Severity.Error);
        }
    }

    private Color GetProgressColor(decimal pct) => pct >= 80 ? Color.Success : pct >= 50 ? Color.Warning : Color.Error;

    private Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "InProgress" => Color.Info,
        _ => Color.Default
    };

    private class CycleOption { public int Id { get; set; } public string Name { get; set; } = ""; }

    private class GoalRow
    {
        public int Id { get; set; }
        public string EmployeeName { get; set; } = "";
        public string Title { get; set; } = "";
        public string? TargetValue { get; set; }
        public decimal Weight { get; set; }
        public decimal ProgressPercent { get; set; }
        public string Status { get; set; } = "NotStarted";
        public DateTime? DueDate { get; set; }
        public int AppraisalCycleId { get; set; }
    }
}
