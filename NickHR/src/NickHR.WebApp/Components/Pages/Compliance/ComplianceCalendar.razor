@page "/compliance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = RoleSets.SeniorHROrPayroll)]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.System
@using NickHR.Services.Compliance
@using NickHR.Core.Constants

@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar

<PageTitle>NICKSCAN ERP — NickHR — Compliance Calendar</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />Statutory Compliance Calendar
</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Compliance Deadlines</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudSelect T="string" @bind-Value="_filterCategory" Label="Category" Dense="true" Style="min-width:120px" Class="mr-3">
                <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                <MudSelectItem T="string" Value="@("SSNIT")">SSNIT</MudSelectItem>
                <MudSelectItem T="string" Value="@("GRA")">GRA</MudSelectItem>
                <MudSelectItem T="string" Value="@("NPRA")">NPRA</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Autorenew"
                       OnClick="SeedDefaults">
                Seed @DateTime.UtcNow.Year Defaults
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudTable Items="FilteredDeadlines" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Title</MudTh><MudTh>Due Date</MudTh><MudTh>Category</MudTh><MudTh>Frequency</MudTh><MudTh>Status</MudTh><MudTh>Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Title</MudTd>
                    <MudTd>
                        <MudText Color="@(context.DueDate < DateTime.UtcNow && !context.IsCompleted ? Color.Error : Color.Default)">
                            @context.DueDate.ToString("dd MMM yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                            Color="@(context.Category == "SSNIT" ? Color.Primary : context.Category == "GRA" ? Color.Secondary : Color.Tertiary)">
                            @context.Category
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Frequency</MudTd>
                    <MudTd>
                        @if (context.IsCompleted)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Completed</MudChip>
                        }
                        else if (context.DueDate < DateTime.UtcNow)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Overdue</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        @if (!context.IsCompleted)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                       OnClick="@(() => MarkComplete(context.Id))">Mark Complete</MudButton>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private List<ComplianceDeadline> _deadlines = new();
    private bool _loading = true;
    private string _filterCategory = "All";
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new("Home", "/"), new("Compliance", null, true)
    };

    private IEnumerable<ComplianceDeadline> FilteredDeadlines =>
        _filterCategory == "All" ? _deadlines : _deadlines.Where(d => d.Category == _filterCategory);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        using var scope = ServiceProvider.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ComplianceService>();
        _deadlines = await svc.GetAllAsync();
        _loading = false;
    }

    private async Task MarkComplete(int id)
    {
        using var scope = ServiceProvider.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ComplianceService>();
        await svc.MarkCompleteAsync(id, 0);
        Snackbar.Add("Marked as complete", Severity.Success);
        await LoadData();
    }

    private async Task SeedDefaults()
    {
        using var scope = ServiceProvider.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ComplianceService>();
        await svc.SeedDefaultsAsync(DateTime.UtcNow.Year);
        Snackbar.Add("Defaults seeded", Severity.Success);
        await LoadData();
    }
}
