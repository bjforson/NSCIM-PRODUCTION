@page "/change-password"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NickHR.Infrastructure.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>NICKSCAN ERP — NickHR — Change Password</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="8" md="6">
        <MudText Typo="Typo.h5" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />Change Password
        </MudText>

        @if (_isForced)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Filled">
                <MudText Typo="Typo.body2"><strong>Password change required.</strong> You must set a new password before you can continue.</MudText>
            </MudAlert>
        }

        <MudPaper Elevation="2" Class="pa-6">
            @if (_success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Password changed successfully!@(_isForced ? " Redirecting to login..." : "")
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }

            @if (!_success)
            {
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudTextField Label="Current Password"
                                  @bind-Value="_currentPassword"
                                  InputType="@(_showCurrentPw ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showCurrentPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showCurrentPw = !_showCurrentPw"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Current password is required."
                                  HelperText="@(_isForced ? "Enter the temporary password from your invitation email" : "")"
                                  Class="mb-4" />

                    <MudTextField Label="New Password"
                                  @bind-Value="_newPassword"
                                  InputType="@(_showNewPw ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showNewPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showNewPw = !_showNewPw"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="New password is required."
                                  Validation="@(new Func<string, string?>(ValidatePassword))"
                                  Class="mb-2" />

                    <MudPaper Class="pa-3 mb-4" Elevation="0" Style="background-color: var(--mud-palette-background-grey);">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <b>Password requirements:</b>
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block">
                            <MudIcon Icon="@(HasMinLength ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Size="Size.Small" Color="@(HasMinLength ? Color.Success : Color.Default)" Class="mr-1" />
                            At least 8 characters
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block">
                            <MudIcon Icon="@(HasUppercase ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Size="Size.Small" Color="@(HasUppercase ? Color.Success : Color.Default)" Class="mr-1" />
                            At least one uppercase letter
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block">
                            <MudIcon Icon="@(HasLowercase ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Size="Size.Small" Color="@(HasLowercase ? Color.Success : Color.Default)" Class="mr-1" />
                            At least one lowercase letter
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block">
                            <MudIcon Icon="@(HasDigit ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Size="Size.Small" Color="@(HasDigit ? Color.Success : Color.Default)" Class="mr-1" />
                            At least one number
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block">
                            <MudIcon Icon="@(HasSpecial ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                     Size="Size.Small" Color="@(HasSpecial ? Color.Success : Color.Default)" Class="mr-1" />
                            At least one special character (!&#64;&#35;$%^&amp;*)
                        </MudText>
                    </MudPaper>

                    <MudTextField Label="Confirm New Password"
                                  @bind-Value="_confirmPassword"
                                  InputType="@(_showConfirmPw ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirmPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showConfirmPw = !_showConfirmPw"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Please confirm your new password."
                                  Validation="@(new Func<string, string?>(ValidateConfirm))"
                                  Class="mb-4" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.LockReset"
                               OnClick="ChangePasswordAsync"
                               Disabled="_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Change Password
                    </MudButton>
                </MudForm>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery(Name = "forced")]
    public string? ForcedParam { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? EmailParam { get; set; }

    private MudForm? _form;
    private bool _formValid;
    private bool _saving;
    private bool _success;
    private string _errorMessage = string.Empty;
    private bool _isForced;

    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    private bool _showCurrentPw;
    private bool _showNewPw;
    private bool _showConfirmPw;

    private bool HasMinLength => _newPassword.Length >= 8;
    private bool HasUppercase => _newPassword.Any(char.IsUpper);
    private bool HasLowercase => _newPassword.Any(char.IsLower);
    private bool HasDigit => _newPassword.Any(char.IsDigit);
    private bool HasSpecial => _newPassword.Any(c => "!@#$%^&*()_+-=[]{}|;':\",./<>?".Contains(c));

    protected override void OnInitialized()
    {
        _isForced = string.Equals(ForcedParam, "true", StringComparison.OrdinalIgnoreCase);
    }

    private string? ValidatePassword(string password)
    {
        if (string.IsNullOrEmpty(password)) return "New password is required.";
        if (!HasMinLength) return "Password must be at least 8 characters.";
        if (!HasUppercase) return "Password must contain at least one uppercase letter.";
        if (!HasLowercase) return "Password must contain at least one lowercase letter.";
        if (!HasDigit) return "Password must contain at least one number.";
        if (!HasSpecial) return "Password must contain at least one special character.";
        return null;
    }

    private string? ValidateConfirm(string confirm)
    {
        if (confirm != _newPassword) return "Passwords do not match.";
        return null;
    }

    private async Task ChangePasswordAsync()
    {
        if (_form != null) await _form.Validate();
        if (!_formValid) return;

        _saving = true;
        _errorMessage = string.Empty;
        _success = false;

        try
        {
            ApplicationUser? user = null;

            if (_isForced && !string.IsNullOrEmpty(EmailParam))
            {
                // Forced mode: user is not authenticated yet, use email from query string
                user = await UserManager.FindByEmailAsync(EmailParam);
                if (user == null)
                {
                    _errorMessage = "User not found. Please try logging in again.";
                    return;
                }

                // Verify the current (temp) password is correct
                var checkResult = await UserManager.CheckPasswordAsync(user, _currentPassword);
                if (!checkResult)
                {
                    _errorMessage = "Current password is incorrect.";
                    return;
                }
            }
            else
            {
                // Normal mode: user is authenticated
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var userName = authState.User.Identity?.Name;
                if (string.IsNullOrEmpty(userName))
                {
                    _errorMessage = "Unable to identify the current user. Please log in again.";
                    return;
                }
                user = await UserManager.FindByNameAsync(userName);
                if (user == null)
                {
                    _errorMessage = "User not found.";
                    return;
                }
            }

            var result = await UserManager.ChangePasswordAsync(user, _currentPassword, _newPassword);
            if (result.Succeeded)
            {
                // Clear the forced password change flag
                if (user.MustChangePassword)
                {
                    user.MustChangePassword = false;
                    await UserManager.UpdateAsync(user);
                }

                _success = true;
                _currentPassword = string.Empty;
                _newPassword = string.Empty;
                _confirmPassword = string.Empty;
                if (_form != null) await _form.ResetAsync();

                if (_isForced)
                {
                    Snackbar.Add("Password changed! Redirecting to login...", Severity.Success);
                    await Task.Delay(1500);
                    Navigation.NavigateTo("/login", forceLoad: true);
                }
                else
                {
                    Snackbar.Add("Password changed successfully!", Severity.Success);
                }
            }
            else
            {
                _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
