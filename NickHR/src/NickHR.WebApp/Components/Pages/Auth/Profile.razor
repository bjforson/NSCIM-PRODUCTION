    private string? _photoError;

    private async Task HandlePhotoUpload(IBrowserFile file)
    {
        if (_employee == null) { _photoError = "No employee loaded."; return; }
        if (file == null) return;

        _photoError = null;

        if (file.Size > 10 * 1024 * 1024)
        {
            _photoError = "Photo must be under 10 MB.";
            Snackbar.Add(_photoError, Severity.Warning);
            return;
        }

        _photoUploading = true;
        StateHasChanged();

        try
        {
            // Read file into memory
            using var ms = new MemoryStream();
            await using var fileStream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await fileStream.CopyToAsync(ms);
            var photoBytes = ms.ToArray();

            if (photoBytes.Length == 0)
            {
                _photoError = "File is empty.";
                Snackbar.Add(_photoError, Severity.Error);
                return;
            }

            // Save directly to database
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var emp = await ctx.Employees.FindAsync(_employee.Id);
            if (emp != null)
            {
                emp.PhotoData = photoBytes;
                emp.PhotoContentType = file.ContentType ?? "image/jpeg";
                emp.PhotoUrl = $"db://photo/{emp.Id}";
                emp.UpdatedAt = DateTime.UtcNow;
                await ctx.SaveChangesAsync();

                // Update local state immediately
                _employee.PhotoData = emp.PhotoData;
                _employee.PhotoContentType = emp.PhotoContentType;
                _employee.PhotoUrl = emp.PhotoUrl;

                Snackbar.Add($"Photo saved ({photoBytes.Length / 1024} KB)", Severity.Success);
            }
            else
            {
                _photoError = "Employee not found in database.";
                Snackbar.Add(_photoError, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _photoError = $"Upload error: {ex.Message}";
            Snackbar.Add(_photoError, Severity.Error);
        }
        finally
        {
            _photoUploading = false;
            StateHasChanged();
        }
    }

