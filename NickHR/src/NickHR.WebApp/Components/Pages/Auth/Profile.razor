    // === Inline Qualification Edit/Delete ===
    private void OpenEditQualificationInline(EmployeeQualification q)
    {
        _editingQualId = q.Id;
        _iqType = q.QualificationType ?? "Education";
        _iqInstitution = q.Institution ?? "";
        _iqQualification = q.Qualification ?? "";
        _iqField = q.FieldOfStudy ?? "";
        _iqGrade = q.Grade ?? "";
        _iqStartDate = q.StartDate;
        _iqEndDate = q.EndDate;
        _showInlineQualForm = true;
    }

    private async Task SaveInlineQualification()
    {
        if (string.IsNullOrWhiteSpace(_iqQualification)) { Snackbar.Add("Qualification name is required.", Severity.Warning); return; }
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            if (_editingQualId.HasValue)
            {
                var entity = await db.EmployeeQualifications.FindAsync(_editingQualId.Value);
                if (entity != null)
                {
                    entity.QualificationType = _iqType; entity.Institution = _iqInstitution;
                    entity.Qualification = _iqQualification; entity.FieldOfStudy = _iqField;
                    entity.Grade = _iqGrade; entity.StartDate = _iqStartDate; entity.EndDate = _iqEndDate;
                    entity.UpdatedAt = DateTime.UtcNow;
                    await db.SaveChangesAsync();
                    Snackbar.Add("Qualification updated.", Severity.Success);
                }
            }
            _editingQualId = null;
            _showInlineQualForm = false;
            await LoadEmployeeAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteQualificationAsync(int id)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var entity = await db.EmployeeQualifications.FindAsync(id);
            if (entity != null) { entity.IsDeleted = true; entity.UpdatedAt = DateTime.UtcNow; await db.SaveChangesAsync(); }
            Snackbar.Add("Qualification removed.", Severity.Success);
            await LoadEmployeeAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteBeneficiaryAsync(int id)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var b = await ctx.Beneficiaries.FindAsync(id);
        if (b != null)
        {
            ctx.Beneficiaries.Remove(b);
            await ctx.SaveChangesAsync();
            Snackbar.Add("Beneficiary removed.", Severity.Success);
            await LoadEmployeeAsync();
        }
    }

    private async Task DeleteDependentAsync(int id)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var d = await ctx.Dependents.FindAsync(id);
        if (d != null)
        {
            ctx.Dependents.Remove(d);
            await ctx.SaveChangesAsync();
            Snackbar.Add("Dependent removed.", Severity.Success);
            await LoadEmployeeAsync();
        }
    }

    private static string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account) || account.Length < 4) return account ?? "—";
        return new string('*', account.Length - 4) + account[^4..];
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024:N1} KB";
        return $"{bytes / (1024 * 1024):N1} MB";
    }
