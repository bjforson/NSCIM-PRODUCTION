    private async Task LoadEmployeeAsync()
    {
        _loading = true;
        var employeeId = await CurrentEmployee.GetEmployeeIdAsync();
        await using var ctx = await DbFactory.CreateDbContextAsync();

        if (employeeId.HasValue)
        {
            _employee = await ctx.Employees
                .Include(e => e.Department)
                .Include(e => e.Designation)
                .Include(e => e.Grade)
                .Include(e => e.Location)
                .Include(e => e.ReportingManager)
                .Include(e => e.EmergencyContacts)
                .Include(e => e.EmployeeDocuments)
                .Include(e => e.EmployeeQualifications)
                .Include(e => e.EmploymentHistory)
                .Include(e => e.Beneficiaries)
                .Include(e => e.Dependents)
                .FirstOrDefaultAsync(e => e.Id == employeeId.Value && !e.IsDeleted);
        }

        if (_employee != null)
        {
            _dobDate = _employee.DateOfBirth;

            _salaryHistory = await ctx.EmployeeSalaryStructures
                .Include(s => s.SalaryComponent)
                .Where(s => s.EmployeeId == _employee.Id)
                .OrderByDescending(s => s.EffectiveFrom)
                .ToListAsync();

            // Load pending change requests for the banner
            _pendingChangeRequests = await ProfileChangeSvc.GetMyRequestsAsync(_employee.Id);
            _pendingChangeRequests = _pendingChangeRequests
                .Where(r => r.Status == ChangeRequestStatus.Pending)
                .ToList();
        }

        _loading = false;
    }

    private async Task SavePersonalInfoAsync()
    {
        if (_employee == null) return;

        // Snapshot the current DB values to detect what changed
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var dbEmp = await ctx.Employees.AsNoTracking().FirstOrDefaultAsync(e => e.Id == _employee.Id);
        if (dbEmp == null) return;

        // Field → new value pairs from the form (using _dobDate for DateOfBirth)
        var fields = new (string Field, string? Value)[]
        {
            ("FirstName",         _employee.FirstName),
            ("MiddleName",        _employee.MiddleName),
            ("LastName",          _employee.LastName),
            ("DateOfBirth",       _dobDate?.ToString("O")),
            ("Nationality",       _employee.Nationality),
            ("GhanaCardNumber",   _employee.GhanaCardNumber),
            ("TIN",               _employee.TIN),
            ("SSNITNumber",       _employee.SSNITNumber),
            ("PlaceOfBirth",      _employee.PlaceOfBirth),
            ("Religion",          _employee.Religion),
            ("EthnicGroup",       _employee.EthnicGroup),
            ("BloodGroup",        _employee.BloodGroup),
            ("MothersMaidenName", _employee.MothersMaidenName),
            ("GhanaPostGPS",      _employee.GhanaPostGPS),
            ("MedicalConditions", _employee.MedicalConditions),
            ("SpouseName",        _employee.SpouseName),
            ("SpousePhone",       _employee.SpousePhone),
            ("SpouseEmployer",    _employee.SpouseEmployer),
            ("NumberOfChildren",  _employee.NumberOfChildren.ToString()),
        };

        int autoCount = 0, pendingCount = 0;

        foreach (var (field, newVal) in fields)
        {
            // Get old value from DB snapshot
            var oldProp = typeof(Employee).GetProperty(field);
            var oldVal = oldProp?.GetValue(dbEmp)?.ToString();

            // Skip unchanged
            if (string.Equals(oldVal, newVal, StringComparison.Ordinal)) continue;

            var req = await ProfileChangeSvc.SubmitChangeAsync(
                _employee.Id, field, newVal, reason: null, _isSuperAdmin);

            if (req.Status == ChangeRequestStatus.Approved) autoCount++;
            else pendingCount++;
        }

        _editPersonal = false;
        await LoadEmployeeAsync();

        if (autoCount > 0 && pendingCount == 0)
            Snackbar.Add("Personal information updated.", Severity.Success);
        else if (pendingCount > 0 && autoCount == 0)
            Snackbar.Add($"{pendingCount} change{(pendingCount > 1 ? "s" : "")} submitted for HR approval.", Severity.Warning);
        else if (autoCount > 0 && pendingCount > 0)
            Snackbar.Add($"{autoCount} field{(autoCount > 1 ? "s" : "")} updated; {pendingCount} change{(pendingCount > 1 ? "s" : "")} submitted for HR approval.", Severity.Warning);
        else
            Snackbar.Add("No changes detected.", Severity.Info);
    }

