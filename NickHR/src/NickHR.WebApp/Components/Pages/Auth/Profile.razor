@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Entities.Payroll
@using NickHR.Core.Enums
@using NickHR.Services.ProfileChange
@using System.Net.Http.Headers

@inject IDbContextFactory<NickHRDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IHttpClientFactory HttpClientFactory
@inject NickHR.WebApp.Services.AuthStateProvider AuthState
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@inject IServiceProvider ServiceProvider
@inject CurrentEmployeeService CurrentEmployee
@inject ProfileChangeService ProfileChangeSvc
@inject UserManager<ApplicationUser> UserManager

<PageTitle>NICKSCAN ERP — NickHR — My Profile</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />My Profile
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_employee == null)
{
    <MudAlert Severity="Severity.Warning">No employee record found.</MudAlert>
}
else
{
    @if (_pendingChangeRequests.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4"
                  Icon="@Icons.Material.Filled.HourglassTop">
            You have <strong>@_pendingChangeRequests.Count</strong> change@(_pendingChangeRequests.Count == 1 ? "" : "s") awaiting HR approval.
            <MudTable Items="_pendingChangeRequests" Dense="true" Class="mt-2" Elevation="0">
                <HeaderContent>
                    <MudTh>Field</MudTh>
                    <MudTh>Requested Value</MudTh>
                    <MudTh>Submitted</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.FieldLabel</MudTd>
                    <MudTd>@(context.NewValue ?? "(clear)")</MudTd>
                    <MudTd>@context.CreatedAt.ToString("dd MMM yyyy")</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudAlert>
    }

    <MudGrid>
        <!-- Portrait Column -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                @if (_employee.PhotoData != null && _employee.PhotoData.Length > 0)
                {
                    <MudAvatar Style="width:150px;height:150px;">
                        <MudImage Src="@($"data:{_employee.PhotoContentType ?? "image/jpeg"};base64,{Convert.ToBase64String(_employee.PhotoData)}")"
                                  Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Style="width:150px;height:150px;font-size:3rem;" Color="Color.Primary">
                        @(_employee.FirstName.Length > 0 ? _employee.FirstName[0] : '?')
                    </MudAvatar>
                }
                <MudText Typo="Typo.h6" Class="mt-3">@_employee.FirstName @_employee.LastName</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@(_employee.Designation?.Title ?? "—")</MudText>
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-2">@_employee.EmploymentStatus</MudChip>
                <MudText Typo="Typo.caption" Class="mt-2">@_employee.EmployeeCode</MudText>
                <MudDivider Class="mt-3 mb-2" Style="width:100%" />
                <MudText Typo="Typo.caption" Class="mb-2">Change Portrait Photo</MudText>
                <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.webp" FilesChanged="HandlePhotoUpload" MaximumFileCount="1">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload"
                                   Size="Size.Small" Disabled="_photoUploading" FullWidth="true">
                            @if (_photoUploading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                @:Uploading...
                            }
                            else
                            {
                                @:Choose Photo
                            }
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (!string.IsNullOrEmpty(_photoError))
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@_photoError</MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- Tabs Column -->
        <MudItem xs="12" md="9">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

                <!-- Tab 1: Personal Info -->
                <MudTabPanel Text="Personal Info" Icon="@Icons.Material.Filled.Person">
                    <MudGrid>
                        <MudItem xs="12" Class="d-flex justify-end mb-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@(_editPersonal ? Icons.Material.Filled.Close : Icons.Material.Filled.Edit)"
                                       OnClick="() => _editPersonal = !_editPersonal">
                                @(_editPersonal ? "Cancel" : "Edit")
                            </MudButton>
                        </MudItem>

                        @if (_editPersonal)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                                    Edit your details below and click Save.
                                </MudAlert>
                            </MudItem>
                        }

                        <!-- Core identity -->
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="First Name" @bind-Value="_employee.FirstName"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Middle Name" @bind-Value="_employee.MiddleName"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Last Name" @bind-Value="_employee.LastName"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Employee Code" Value="@_employee.EmployeeCode"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Date of Birth" @bind-Date="_dobDate"
                                           ReadOnly="!_editPersonal" Variant="Variant.Outlined"
                                           DateFormat="dd/MM/yyyy" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Gender" Value="@_employee.Gender.ToString()"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Marital Status" Value="@_employee.MaritalStatus.ToString()"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Nationality" @bind-Value="_employee.Nationality"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Ghana Card Number" @bind-Value="_employee.GhanaCardNumber"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="TIN" @bind-Value="_employee.TIN"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="SSNIT Number" @bind-Value="_employee.SSNITNumber"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>

                        <!-- Ghana-specific extra fields -->
                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Additional Details</b></MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Place of Birth" @bind-Value="_employee.PlaceOfBirth"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Religion" @bind-Value="_employee.Religion"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Ethnic Group" @bind-Value="_employee.EthnicGroup"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            @if (_editPersonal)
                            {
                                <MudSelect Label="Blood Group" @bind-Value="_employee.BloodGroup"
                                           Variant="Variant.Outlined">
                                    <MudSelectItem Value="@((string?)null)">— Not specified —</MudSelectItem>
                                    @foreach (var bg in _bloodGroups)
                                    {
                                        <MudSelectItem Value="@bg">@bg</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudTextField Label="Blood Group" Value="@(_employee.BloodGroup ?? "—")"
                                              ReadOnly="true" Variant="Variant.Outlined" />
                            }
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Mother's Maiden Name" @bind-Value="_employee.MothersMaidenName"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Ghana Post GPS (Digital Address)" @bind-Value="_employee.GhanaPostGPS"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined"
                                          Placeholder="e.g. GA-123-4567" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Medical Conditions / Allergies" @bind-Value="_employee.MedicalConditions"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" Lines="2" />
                        </MudItem>

                        <!-- Spouse / children -->
                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Spouse &amp; Children</b></MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Spouse Name" @bind-Value="_employee.SpouseName"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Spouse Phone" @bind-Value="_employee.SpousePhone"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Spouse Employer" @bind-Value="_employee.SpouseEmployer"
                                          ReadOnly="!_editPersonal" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField Label="Number of Children" @bind-Value="_employee.NumberOfChildren"
                                             ReadOnly="!_editPersonal" Variant="Variant.Outlined" Min="0" />
                        </MudItem>

                        @if (_editPersonal)
                        {
                            <MudItem xs="12" Class="d-flex justify-end mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SavePersonalInfoAsync">
                                    Save Changes
                                </MudButton>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 2: Contact & Address -->
                <MudTabPanel Text="Contact & Address" Icon="@Icons.Material.Filled.ContactPhone">
                    <MudGrid>
                        <MudItem xs="12" Class="d-flex justify-end mb-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@(_editContact ? Icons.Material.Filled.Close : Icons.Material.Filled.Edit)"
                                       OnClick="() => _editContact = !_editContact">
                                @(_editContact ? "Cancel" : "Edit")
                            </MudButton>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Contact Information</b></MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Primary Phone" @bind-Value="_employee.PrimaryPhone"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Secondary Phone" @bind-Value="_employee.SecondaryPhone"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Personal Email" @bind-Value="_employee.PersonalEmail"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Work Email" Value="@_employee.WorkEmail"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12" Class="mt-3">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Address</b></MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Residential Address" @bind-Value="_employee.ResidentialAddress"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" Lines="2" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Postal Address" @bind-Value="_employee.PostalAddress"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" Lines="2" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Hometown" @bind-Value="_employee.Hometown"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Region" @bind-Value="_employee.Region"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Ghana Post GPS (Digital Address)" @bind-Value="_employee.GhanaPostGPS"
                                          ReadOnly="!_editContact" Variant="Variant.Outlined"
                                          Placeholder="e.g. GA-123-4567" />
                        </MudItem>

                        @if (_editContact)
                        {
                            <MudItem xs="12" Class="d-flex justify-end mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SaveContactInfoAsync">
                                    Save Changes
                                </MudButton>
                            </MudItem>
                        }

                        <MudItem xs="12" Class="mt-4">
                            <MudDivider />
                            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-2"><b>Emergency Contacts</b></MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="OpenAddEmergencyContactDialog" Class="mb-3">
                                Add Emergency Contact
                            </MudButton>

                            @if (_employee.EmergencyContacts.Any())
                            {
                                <MudTable Items="_employee.EmergencyContacts" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Relationship</MudTh>
                                        <MudTh>Phone</MudTh>
                                        <MudTh>Email</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.FullName</MudTd>
                                        <MudTd>@context.Relationship</MudTd>
                                        <MudTd>@context.PrimaryPhone</MudTd>
                                        <MudTd>@context.Email</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">No emergency contacts on file.</MudText>
                            }
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 3: Employment -->
                <MudTabPanel Text="Employment" Icon="@Icons.Material.Filled.Work">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Department" Value="@(_employee.Department?.Name ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Designation" Value="@(_employee.Designation?.Title ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Grade" Value="@(_employee.Grade?.Name ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Location" Value="@(_employee.Location?.Name ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Reporting Manager"
                                          Value="@(_employee.ReportingManager != null ? $"{_employee.ReportingManager.FirstName} {_employee.ReportingManager.LastName}" : "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Employment Type" Value="@_employee.EmploymentType.ToString()"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Status" Value="@_employee.EmploymentStatus.ToString()"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Hire Date" Value="@(_employee.HireDate?.ToString("dd/MM/yyyy") ?? "N/A")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Confirmation Date"
                                          Value="@(_employee.ConfirmationDate.HasValue ? _employee.ConfirmationDate.Value.ToString("dd/MM/yyyy") : "Not yet confirmed")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>

                        @if (_employee.EmploymentHistory.Any())
                        {
                            <MudItem xs="12" Class="mt-4">
                                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Employment History</b></MudText>
                                <MudTimeline>
                                    @foreach (var record in _employee.EmploymentHistory.OrderByDescending(h => h.StartDate))
                                    {
                                        <MudTimelineItem Color="Color.Primary">
                                            <MudText Typo="Typo.subtitle2">@record.JobTitle at @record.CompanyName</MudText>
                                            <MudText Typo="Typo.body2">
                                                @record.StartDate.ToString("MMM yyyy") — @(record.EndDate.HasValue ? record.EndDate.Value.ToString("MMM yyyy") : "Present")
                                            </MudText>
                                            @if (!string.IsNullOrEmpty(record.Description))
                                            {
                                                <MudText Typo="Typo.caption">@record.Description</MudText>
                                            }
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 4: Compensation -->
                <MudTabPanel Text="Compensation" Icon="@Icons.Material.Filled.Payments">
                    <MudGrid>
                        <MudItem xs="12" Class="d-flex justify-end mb-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@(_editCompensation ? Icons.Material.Filled.Close : Icons.Material.Filled.Edit)"
                                       OnClick="() => _editCompensation = !_editCompensation">
                                @(_editCompensation ? "Cancel" : "Edit Banking Details")
                            </MudButton>
                        </MudItem>

                        @if (_editCompensation)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
                                    Banking and payment changes require HR approval before taking effect.
                                </MudAlert>
                            </MudItem>
                        }

                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Basic Salary" Value="@($"GH₵ {_employee.BasicSalary:N2}")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Bank Name" @bind-Value="_employee.BankName"
                                          ReadOnly="!_editCompensation" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Bank Branch" @bind-Value="_employee.BankBranch"
                                          ReadOnly="!_editCompensation" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Account Number"
                                          Value="@(_editCompensation ? _employee.BankAccountNumber : MaskAccount(_employee.BankAccountNumber))"
                                          ValueChanged="@((string? v) => { if (_editCompensation) _employee.BankAccountNumber = v; })"
                                          ReadOnly="!_editCompensation" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Mobile Money Number" @bind-Value="_employee.MobileMoneyNumber"
                                          ReadOnly="!_editCompensation" Variant="Variant.Outlined" />
                        </MudItem>

                        @if (_editCompensation)
                        {
                            <MudItem xs="12" Class="d-flex justify-end mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SaveCompensationInfoAsync">
                                    Submit for Approval
                                </MudButton>
                            </MudItem>
                        }

                        <MudItem xs="12" Class="mt-2">
                            <MudDivider />
                            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-2"><b>Pension Details</b></MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Tier 2 Pension Number" Value="@(_employee.Tier2PensionNumber ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Tier 2 Provider" Value="@(_employee.Tier2Provider ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Tier 3 Pension Number" Value="@(_employee.Tier3PensionNumber ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Tier 3 Provider" Value="@(_employee.Tier3Provider ?? "—")"
                                          ReadOnly="true" Variant="Variant.Outlined" />
                        </MudItem>

                        @if (_salaryHistory.Any())
                        {
                            <MudItem xs="12" Class="mt-4">
                                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Salary History</b></MudText>
                                <MudTable Items="_salaryHistory" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Component</MudTh>
                                        <MudTh>Amount</MudTh>
                                        <MudTh>Effective From</MudTh>
                                        <MudTh>Effective To</MudTh>
                                        <MudTh>Status</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.SalaryComponent?.Name</MudTd>
                                        <MudTd>GH₵ @context.Amount.ToString("N2")</MudTd>
                                        <MudTd>@context.EffectiveFrom.ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd>@(context.EffectiveTo.HasValue ? context.EffectiveTo.Value.ToString("dd/MM/yyyy") : "Current")</MudTd>
                                        <MudTd>
                                            <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                                                @(context.IsActive ? "Active" : "Inactive")
                                            </MudChip>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 5: Documents -->
                <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Folder">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               OnClick="OpenDocumentUploadDialog" Class="mb-3">
                        Upload Document
                    </MudButton>

                    @if (_employee.EmployeeDocuments.Any())
                    {
                        <MudTable Items="_employee.EmployeeDocuments.OrderByDescending(d => d.UploadedAt)"
                                  Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Type</MudTh>
                                <MudTh>File Name</MudTh>
                                <MudTh>Uploaded</MudTh>
                                <MudTh>Size</MudTh>
