@page "/login"
@layout NickHR.WebApp.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Identity
@using NickHR.Infrastructure.Data
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IServiceProvider ServiceProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<Login> Logger

<PageTitle>NICKSCAN ERP — NickHR — Login</PageTitle>

<div class="nhr-login">
    <!-- Left Panel: Branding -->
    <div class="nhr-login-left">
        <div class="nhr-login-left-inner">
            <!-- Logo -->
            <div class="nhr-logo">
                <div class="nhr-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size:28px;color:white;" />
                </div>
                <span class="nhr-logo-text">NickHR</span>
            </div>

            <!-- Headline -->
            <h1 class="nhr-headline">Your People,<br/>Your Platform.</h1>
            <p class="nhr-subheadline">
                Manage your entire workforce from one place — payroll, attendance, leave, recruitment, and performance.
            </p>

            <!-- Stats -->
            <div class="nhr-stats-row">
                <div class="nhr-stat">
                    <span class="nhr-stat-num">147</span>
                    <span class="nhr-stat-label">Employees</span>
                </div>
                <div class="nhr-stat-divider"></div>
                <div class="nhr-stat">
                    <span class="nhr-stat-num">10</span>
                    <span class="nhr-stat-label">Locations</span>
                </div>
                <div class="nhr-stat-divider"></div>
                <div class="nhr-stat">
                    <span class="nhr-stat-num">40+</span>
                    <span class="nhr-stat-label">Modules</span>
                </div>
                <div class="nhr-stat-divider"></div>
                <div class="nhr-stat">
                    <span class="nhr-stat-num">24/7</span>
                    <span class="nhr-stat-label">Access</span>
                </div>
            </div>

            <!-- Features -->
            <div class="nhr-features">
                <div class="nhr-feature">
                    <div class="nhr-feature-icon"><MudIcon Icon="@Icons.Material.Filled.Payments" Style="font-size:18px;color:white;" /></div>
                    <span>Ghana PAYE & SSNIT payroll</span>
                </div>
                <div class="nhr-feature">
                    <div class="nhr-feature-icon"><MudIcon Icon="@Icons.Material.Filled.GpsFixed" Style="font-size:18px;color:white;" /></div>
                    <span>GPS geo-fenced attendance</span>
                </div>
                <div class="nhr-feature">
                    <div class="nhr-feature-icon"><MudIcon Icon="@Icons.Material.Filled.PhoneIphone" Style="font-size:18px;color:white;" /></div>
                    <span>Mobile app for all staff</span>
                </div>
            </div>

            <!-- Module pills -->
            <div class="nhr-pills">
                <span class="nhr-pill">Payroll</span>
                <span class="nhr-pill">Leave</span>
                <span class="nhr-pill">Attendance</span>
                <span class="nhr-pill">Recruitment</span>
                <span class="nhr-pill">Performance</span>
                <span class="nhr-pill">Analytics</span>
            </div>

            <p class="nhr-powered">Powered by NickScan Ltd</p>
        </div>
    </div>

    <!-- Right Panel: Login Form -->
    <div class="nhr-login-right">
        <div class="nhr-form-card">
            <!-- Header -->
            <div class="nhr-form-header">
                <div class="nhr-form-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:32px;color:#4F46E5;" />
                </div>
                <h2>Welcome Back</h2>
                <p>Sign in to your workspace</p>
            </div>

            <!-- Form -->
            <EditForm Model="_loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="nhr-field">
                    <label>Email Address</label>
                    <MudTextField @bind-Value="_loginModel.Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.MailOutline"
                                  Placeholder="you@company.com"
                                  Required="true" />
                </div>

                <div class="nhr-field">
                    <label>Password</label>
                    <MudTextField @bind-Value="_loginModel.Password"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="() => _showPassword = !_showPassword"
                                  Placeholder="Enter your password"
                                  Required="true" />
                </div>

                <!-- Location Status -->
                @if (!_locationChecked)
                {
                    <div class="nhr-gps-status nhr-gps-loading">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:#4F46E5;width:16px;height:16px;" />
                        <span>Detecting your location...</span>
                    </div>
                }
                else if (_locationReady && _loginModel.Latitude.HasValue)
                {
                    <div class="nhr-gps-status nhr-gps-ok">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size:16px;" />
                        <span>@_locationStatus</span>
                    </div>
                }
                else if (_locationReady && !_loginModel.Latitude.HasValue && _isSecureContext)
                {
                    <div class="nhr-gps-status nhr-gps-warn">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOff" Style="font-size:16px;" />
                        <span>@(_locationStatus ?? "Signing in without GPS location")</span>
                        <MudLink OnClick="RequestGPSLocation" Style="color:#4F46E5;font-size:12px;margin-left:auto;cursor:pointer;">Retry</MudLink>
                    </div>
                }
                else if (_locationReady && !_isSecureContext)
                {
                    <div class="nhr-gps-status nhr-gps-warn">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Style="font-size:16px;" />
                        <span>GPS requires HTTPS</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="nhr-gps-status nhr-gps-error" style="margin-top:4px;">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="font-size:16px;" />
                        <span>@_errorMessage</span>
                    </div>
                }

                <!-- Sign In Button -->
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@_isLoading"
                           Class="nhr-signin-btn">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:white;width:20px;height:20px;" Class="mr-2" />
                    }
                    Sign In
                </MudButton>

                <div class="nhr-forgot-link-wrap">
                    <MudLink Href="/forgot-password" Class="nhr-forgot-link">Forgot password?</MudLink>
                </div>

                <div class="nhr-form-footer">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:14px;color:#9CA3AF;" />
                    <span>Secured with SSL encryption</span>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<style>
    * { box-sizing: border-box; }

    .nhr-login {
        display: flex;
        min-height: 100vh;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* ── Left Panel ── */
    .nhr-login-left {
        flex: 1;
        background: linear-gradient(160deg, #4F46E5 0%, #7C3AED 50%, #6D28D9 100%);
        display: flex;
        align-items: center;
        padding: 48px 56px;
        position: relative;
        overflow: hidden;
    }

    .nhr-login-left::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -20%;
        width: 500px;
        height: 500px;
        background: rgba(255,255,255,0.06);
        border-radius: 50%;
    }

    .nhr-login-left::after {
        content: '';
        position: absolute;
        bottom: -20%;
        left: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.04);
        border-radius: 50%;
    }

    .nhr-login-left-inner {
        position: relative;
        z-index: 1;
        max-width: 480px;
    }

    .nhr-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
    }

    .nhr-logo-icon {
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nhr-logo-text {
        color: white;
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 0.5px;
    }

    .nhr-headline {
        color: white;
        font-size: 2.8rem;
        font-weight: 800;
        line-height: 1.15;
        margin: 0 0 16px 0;
    }

    .nhr-subheadline {
        color: rgba(255,255,255,0.75);
        font-size: 15px;
        line-height: 1.6;
        margin: 0 0 36px 0;
        max-width: 380px;
    }

    .nhr-stats-row {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 36px;
        flex-wrap: wrap;
    }

    .nhr-stat {
        text-align: center;
    }

    .nhr-stat-num {
        display: block;
        color: white;
        font-size: 1.8rem;
        font-weight: 800;
    }

    .nhr-stat-label {
        display: block;
        color: rgba(255,255,255,0.55);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 2px;
    }

    .nhr-stat-divider {
        width: 1px;
        height: 36px;
        background: rgba(255,255,255,0.15);
    }

    .nhr-features {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-bottom: 28px;
    }

    .nhr-feature {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.85);
        font-size: 14px;
        font-weight: 500;
    }

    .nhr-feature-icon {
        width: 32px;
        height: 32px;
        background: rgba(255,255,255,0.15);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .nhr-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 32px;
    }

    .nhr-pill {
        background: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.9);
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .nhr-powered {
        color: rgba(255,255,255,0.3);
        font-size: 12px;
        margin: 0;
    }

    /* ── Right Panel ── */
    .nhr-login-right {
        width: 480px;
        min-width: 420px;
        background: #F8FAFC;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

    .nhr-form-card {
        width: 100%;
        max-width: 380px;
        background: white;
        border-radius: 20px;
        padding: 40px 32px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .nhr-form-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .nhr-form-avatar {
        width: 60px;
        height: 60px;
        background: #EEF2FF;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .nhr-form-header h2 {
        color: #1E293B;
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .nhr-form-header p {
        color: #94A3B8;
        font-size: 14px;
        margin: 0;
    }

    .nhr-field {
        margin-bottom: 18px;
    }

    .nhr-field label {
        display: block;
        color: #475569;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .nhr-field .mud-input-outlined-border {
        border-color: #E2E8F0 !important;
        border-radius: 10px !important;
    }

    .nhr-field .mud-input-outlined-border:hover {
        border-color: #CBD5E1 !important;
    }

    .nhr-field .mud-input-slot:focus-within .mud-input-outlined-border {
        border-color: #4F46E5 !important;
    }

    .nhr-field .mud-input {
        color: #1E293B !important;
        font-size: 14px !important;
    }

    .nhr-field input::placeholder {
        color: #CBD5E1 !important;
    }

    .nhr-gps-status {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .nhr-gps-loading { background: #EEF2FF; color: #4F46E5; }
    .nhr-gps-ok { background: #F0FDF4; color: #16A34A; }
    .nhr-gps-error { background: #FEF2F2; color: #DC2626; }
    .nhr-gps-warn { background: #FFFBEB; color: #D97706; }
    .nhr-gps-error a { color: #4F46E5; text-decoration: underline; margin-left: auto; }

    .nhr-signin-btn {
        background: linear-gradient(135deg, #4F46E5, #7C3AED) !important;
        color: white !important;
        font-weight: 700 !important;
        font-size: 15px !important;
        border-radius: 12px !important;
        padding: 14px !important;
        text-transform: none !important;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 14px rgba(79,70,229,0.35) !important;
        margin-top: 20px !important;
        transition: all 0.25s !important;
    }

    .nhr-signin-btn:hover:not(:disabled) {
        box-shadow: 0 6px 22px rgba(79,70,229,0.5) !important;
        transform: translateY(-1px);
    }

    .nhr-signin-btn:disabled {
        opacity: 0.5 !important;
        box-shadow: none !important;
    }

    .nhr-forgot-link-wrap {
        text-align: center;
        margin-top: 14px;
    }

    .nhr-forgot-link {
        color: #4F46E5 !important;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
    }

    .nhr-forgot-link:hover {
        text-decoration: underline;
    }

    .nhr-form-footer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 20px;
        color: #9CA3AF;
        font-size: 12px;
    }

    /* ── Mobile ── */
    @@media (max-width: 900px) {
        .nhr-login { flex-direction: column; }
        .nhr-login-left { display: none; }
        .nhr-login-right {
            width: 100%;
            min-width: auto;
            min-height: 100vh;
            padding: 24px;
            background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 100%);
        }
        .nhr-form-card {
            max-width: 100%;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        }
    }
</style>

@code {
    private NickHR.Core.DTOs.Auth.LoginRequest _loginModel = new();
    private bool _showPassword = false;
    private bool _isLoading = false;
    private string? _errorMessage;
    private string? _locationStatus;
    private bool _locationReady = false;
    private bool _locationChecked = false;
    private bool _isSecureContext = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _isSecureContext = await JS.InvokeAsync<bool>("eval", "window.isSecureContext"); }
            catch { _isSecureContext = false; }

            if (_isSecureContext) { await RequestGPSLocation(); }
            else { _locationStatus = "GPS requires HTTPS"; _locationReady = true; _locationChecked = true; StateHasChanged(); }
        }
    }

    private async Task RequestGPSLocation()
    {
        _locationChecked = false; _locationReady = false; StateHasChanged();
        try
        {
            var result = await JS.InvokeAsync<GeoResult>("getGPSLocation");
            if (result.Success) { _loginModel.Latitude = result.Latitude; _loginModel.Longitude = result.Longitude; _loginModel.Accuracy = result.Accuracy; _locationStatus = $"Location captured ({result.Accuracy:N0}m accuracy)"; _locationReady = true; }
            else { _locationStatus = $"Signing in without GPS ({result.Error})"; _locationReady = true; }
        }
        catch { _locationStatus = "Signing in without GPS (unavailable)"; _locationReady = true; }
        _locationChecked = true; StateHasChanged();
    }

    private async Task HandleLogin()
    {
        _isLoading = true; _errorMessage = null;
        try
        {
            var user = await UserManager.FindByEmailAsync(_loginModel.Email);
            if (user == null || !user.IsActive) { await LogFailedLoginAsync(_loginModel.Email); _errorMessage = "Invalid email or password."; return; }
            var result = await SignInManager.CheckPasswordSignInAsync(user, _loginModel.Password, lockoutOnFailure: true);
            if (result.IsLockedOut) { await LogFailedLoginAsync(_loginModel.Email); _errorMessage = "Account locked. Try again later."; return; }
            if (!result.Succeeded) { await LogFailedLoginAsync(_loginModel.Email); _errorMessage = "Invalid email or password."; return; }
            user.LastLoginAt = DateTime.UtcNow; await UserManager.UpdateAsync(user);
            // Audit logging is best-effort and runs out-of-band so an audit failure
            // never blocks a successful login. Log the audit failure though.
            _ = Task.Run(async () =>
            {
                try { await LogLoginAuditAsync(user); }
                catch (Exception ex) { Logger.LogWarning(ex, "Login audit logging failed for user {UserId}", user.Id); }
            });

            // Force password change on first login
            if (user.MustChangePassword)
            {
                Navigation.NavigateTo($"/change-password?forced=true&email={Uri.EscapeDataString(_loginModel.Email)}", forceLoad: true);
                return;
            }

            Navigation.NavigateTo($"/login-callback?email={Uri.EscapeDataString(_loginModel.Email)}", forceLoad: true);
        }
        catch (Exception ex) { _errorMessage = $"Error: {ex.Message}"; }
        finally { _isLoading = false; }
    }

    private async Task LogLoginAuditAsync(ApplicationUser user)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            string? ip = null; string? ua = null;
            try { var hc = HttpContextAccessor.HttpContext; ip = hc?.Connection?.RemoteIpAddress?.ToString(); ua = hc?.Request?.Headers["User-Agent"].FirstOrDefault(); } catch { }
            var audit = new NickHR.Core.Entities.System.LoginAudit { Email = user.Email ?? "", EmployeeId = user.EmployeeId, EmployeeName = user.FullName, Success = true, LoginTime = DateTime.UtcNow, Latitude = _loginModel.Latitude, Longitude = _loginModel.Longitude, Accuracy = _loginModel.Accuracy, IPAddress = ip, UserAgent = ua?.Length > 500 ? ua[..500] : ua };
            if (_loginModel.Latitude.HasValue && _loginModel.Longitude.HasValue)
            {
                var locs = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(db.Locations.Where(l => l.IsActive && !l.IsDeleted && l.Latitude.HasValue && l.Longitude.HasValue));
                double nearest = double.MaxValue;
                foreach (var loc in locs) { var dist = Haversine(_loginModel.Latitude.Value, _loginModel.Longitude.Value, loc.Latitude!.Value, loc.Longitude!.Value); if (dist < nearest) { nearest = dist; audit.NearestLocationName = loc.Name; audit.DistanceFromNearestLocation = Math.Round(dist, 1); audit.WithinGeoFence = dist <= loc.GeoFenceRadiusMeters; } }
            }
            db.LoginAudits.Add(audit); await db.SaveChangesAsync();
        } catch { }
    }

    private async Task LogFailedLoginAsync(string email)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            string? ip = null; try { ip = HttpContextAccessor.HttpContext?.Connection?.RemoteIpAddress?.ToString(); } catch { }
            var audit = new NickHR.Core.Entities.System.LoginAudit { Email = email, Success = false, LoginTime = DateTime.UtcNow, Latitude = _loginModel.Latitude, Longitude = _loginModel.Longitude, Accuracy = _loginModel.Accuracy, IPAddress = ip };
            if (_loginModel.Latitude.HasValue && _loginModel.Longitude.HasValue)
            {
                var locs = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(db.Locations.Where(l => l.IsActive && !l.IsDeleted && l.Latitude.HasValue && l.Longitude.HasValue));
                double nearest = double.MaxValue;
                foreach (var loc in locs) { var dist = Haversine(_loginModel.Latitude.Value, _loginModel.Longitude.Value, loc.Latitude!.Value, loc.Longitude!.Value); if (dist < nearest) { nearest = dist; audit.NearestLocationName = loc.Name; audit.DistanceFromNearestLocation = Math.Round(dist, 1); audit.WithinGeoFence = dist <= loc.GeoFenceRadiusMeters; } }
            }
            db.LoginAudits.Add(audit); await db.SaveChangesAsync();
        } catch { }
    }

    private static double Haversine(double lat1, double lon1, double lat2, double lon2) { const double R = 6371000; var dLat = (lat2 - lat1) * Math.PI / 180; var dLon = (lon2 - lon1) * Math.PI / 180; var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) * Math.Sin(dLon / 2) * Math.Sin(dLon / 2); return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a)); }

    private class GeoResult { public bool Success { get; set; } public double Latitude { get; set; } public double Longitude { get; set; } public double Accuracy { get; set; } public string? Error { get; set; } }
}
