@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core

@inject IDbContextFactory<NickHRDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.School" Class="mr-2" />Add Qualification
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect Label="Type" @bind-Value="_qualification.QualificationType"
                           Variant="Variant.Outlined" Required="true">
                    <MudSelectItem Value="@("Education")">Education</MudSelectItem>
                    <MudSelectItem Value="@("Certification")">Certification</MudSelectItem>
                    <MudSelectItem Value="@("Language")">Language</MudSelectItem>
                    <MudSelectItem Value="@("Professional")">Professional</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Institution" @bind-Value="_qualification.Institution"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Qualification / Certificate" @bind-Value="_qualification.Qualification"
                              Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Field of Study" @bind-Value="_qualification.FieldOfStudy"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="Start Date" @bind-Date="_startDate"
                               Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="End Date" @bind-Date="_endDate"
                               Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Grade / Score" @bind-Value="_qualification.Grade"
                              Variant="Variant.Outlined" Placeholder="e.g. 2nd Class Upper, Distinction" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-center">
                <MudCheckBox @bind-Value="_qualification.IsHighest" Label="Highest Qualification" Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="() => OnClose.InvokeAsync()">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int EmployeeId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private EmployeeQualification _qualification = new() { QualificationType = "Education" };
    private bool _saving = false;
    private DateTime? _startDate;
    private DateTime? _endDate;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_qualification.Qualification)) return;

        _saving = true;
        _qualification.EmployeeId = EmployeeId;
        _qualification.StartDate = _startDate;
        _qualification.EndDate = _endDate;
        _qualification.CreatedAt = DateTime.UtcNow;

        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.EmployeeQualifications.Add(_qualification);
        await ctx.SaveChangesAsync();
        _saving = false;
        await OnSaved.InvokeAsync();
    }
}
