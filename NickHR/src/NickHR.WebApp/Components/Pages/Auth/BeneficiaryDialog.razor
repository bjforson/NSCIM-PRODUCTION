@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Enums

@inject IDbContextFactory<NickHRDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
            @(IsEdit ? "Edit Beneficiary" : "Add Beneficiary")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Full Name" @bind-Value="_model.FullName"
                              Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect Label="Relationship" @bind-Value="_model.Relationship"
                           Variant="Variant.Outlined" Required="true">
                    <MudSelectItem Value="@("Spouse")">Spouse</MudSelectItem>
                    <MudSelectItem Value="@("Child")">Child</MudSelectItem>
                    <MudSelectItem Value="@("Parent")">Parent</MudSelectItem>
                    <MudSelectItem Value="@("Sibling")">Sibling</MudSelectItem>
                    <MudSelectItem Value="@("Legal Guardian")">Legal Guardian</MudSelectItem>
                    <MudSelectItem Value="@("Legal Dependent")">Legal Dependent</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="Date of Birth" @bind-Date="_dobDate"
                               Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect Label="Gender" @bind-Value="_model.Gender"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@((Gender?)Gender.Male)">Male</MudSelectItem>
                    <MudSelectItem Value="@((Gender?)Gender.Female)">Female</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Phone" @bind-Value="_model.Phone"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Ghana Card Number" @bind-Value="_model.GhanaCardNumber"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField Label="% Share" @bind-Value="_model.PercentageShare"
                                 Variant="Variant.Outlined" Min="0" Max="100"
                                 Adornment="Adornment.End" AdornmentText="%" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-center gap-4">
                <MudCheckBox @bind-Value="_model.IsPrimary" Label="Primary Beneficiary" Color="Color.Primary" />
                <MudCheckBox @bind-Value="_model.IsActive" Label="Active" Color="Color.Success" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Address" @bind-Value="_model.Address"
                              Variant="Variant.Outlined" Lines="2" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Notes" @bind-Value="_model.Notes"
                              Variant="Variant.Outlined" Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="() => OnClose.InvokeAsync()">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int EmployeeId { get; set; }
    [Parameter] public Beneficiary? Existing { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Beneficiary _model = new() { IsActive = true, PercentageShare = 0 };
    private DateTime? _dobDate;
    private bool _saving = false;
    private bool IsEdit => Existing != null;

    protected override void OnParametersSet()
    {
        if (Existing != null)
        {
            _model = new Beneficiary
            {
                Id = Existing.Id,
                EmployeeId = Existing.EmployeeId,
                FullName = Existing.FullName,
                Relationship = Existing.Relationship,
                DateOfBirth = Existing.DateOfBirth,
                Gender = Existing.Gender,
                Phone = Existing.Phone,
                GhanaCardNumber = Existing.GhanaCardNumber,
                Address = Existing.Address,
                PercentageShare = Existing.PercentageShare,
                IsPrimary = Existing.IsPrimary,
                IsActive = Existing.IsActive,
                Notes = Existing.Notes
            };
            _dobDate = Existing.DateOfBirth;
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.FullName) || string.IsNullOrWhiteSpace(_model.Relationship))
            return;

        _saving = true;
        _model.DateOfBirth = _dobDate;

        await using var ctx = await DbFactory.CreateDbContextAsync();

        if (IsEdit)
        {
            var existing = await ctx.Beneficiaries.FindAsync(_model.Id);
            if (existing != null)
            {
                existing.FullName = _model.FullName;
                existing.Relationship = _model.Relationship;
                existing.DateOfBirth = _model.DateOfBirth;
                existing.Gender = _model.Gender;
                existing.Phone = _model.Phone;
                existing.GhanaCardNumber = _model.GhanaCardNumber;
                existing.Address = _model.Address;
                existing.PercentageShare = _model.PercentageShare;
                existing.IsPrimary = _model.IsPrimary;
                existing.IsActive = _model.IsActive;
                existing.Notes = _model.Notes;
                existing.UpdatedAt = DateTime.UtcNow;
            }
        }
        else
        {
            _model.EmployeeId = EmployeeId;
            _model.CreatedAt = DateTime.UtcNow;
            ctx.Beneficiaries.Add(_model);
        }

        await ctx.SaveChangesAsync();
        _saving = false;
        await OnSaved.InvokeAsync();
    }
}
