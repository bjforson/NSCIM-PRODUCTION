@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core

@inject IDbContextFactory<NickHRDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />Add Emergency Contact
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Full Name" @bind-Value="_contact.FullName"
                              Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Relationship" @bind-Value="_contact.Relationship"
                              Variant="Variant.Outlined" Placeholder="e.g. Spouse, Parent, Sibling" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Primary Phone" @bind-Value="_contact.PrimaryPhone"
                              Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Secondary Phone" @bind-Value="_contact.SecondaryPhone"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Email" @bind-Value="_contact.Email"
                              Variant="Variant.Outlined" InputType="InputType.Email" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField Label="Address" @bind-Value="_contact.Address"
                              Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="() => OnClose.InvokeAsync()">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int EmployeeId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private EmergencyContact _contact = new();
    private bool _saving = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_contact.FullName) || string.IsNullOrWhiteSpace(_contact.PrimaryPhone))
            return;

        _saving = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _contact.EmployeeId = EmployeeId;
        _contact.CreatedAt = DateTime.UtcNow;
        ctx.EmergencyContacts.Add(_contact);
        await ctx.SaveChangesAsync();
        _saving = false;
        await OnSaved.InvokeAsync();
    }
}
