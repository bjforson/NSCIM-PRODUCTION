@page "/forgot-password"
@layout NickHR.WebApp.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using NickHR.Core.Interfaces
@using NickHR.Infrastructure.Data

@inject UserManager<ApplicationUser> UserManager
@inject IEmailService EmailService
@inject NavigationManager Navigation
@inject ILogger<ForgotPassword> Logger

<PageTitle>NICKSCAN ERP — NickHR — Forgot Password</PageTitle>

<div class="nhr-auth-wrap">
    <div class="nhr-auth-card">
        <div class="nhr-auth-avatar">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size:32px;color:#4F46E5;" />
        </div>
        <h2 class="nhr-auth-title">Forgot your password?</h2>
        <p class="nhr-auth-sub">Enter your email and we'll send you a link to set a new one.</p>

        @if (_sent)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4" Icon="@Icons.Material.Filled.MarkEmailRead">
                If that email is registered, a reset link has been sent. Check your inbox (and spam folder).
            </MudAlert>
            <MudLink Href="/login" Class="nhr-auth-back">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:14px;vertical-align:middle;" />
                Back to Sign In
            </MudLink>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="nhr-auth-field">
                    <label>Email Address</label>
                    <MudTextField @bind-Value="_model.Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.MailOutline"
                                  Placeholder="you@company.com"
                                  Required="true" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        @_errorMessage
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="_isLoading"
                           Class="nhr-auth-submit">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:white;width:20px;height:20px;" Class="mr-2" />
                    }
                    Send Reset Link
                </MudButton>
            </EditForm>

            <div class="nhr-auth-back-wrap">
                <MudLink Href="/login" Class="nhr-auth-back">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:14px;vertical-align:middle;" />
                    Back to Sign In
                </MudLink>
            </div>
        }
    </div>
</div>

<style>
    .nhr-auth-wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: linear-gradient(160deg, #EEF2FF 0%, #F8FAFC 100%);
        font-family: 'Inter', -apple-system, sans-serif;
    }
    .nhr-auth-card {
        width: 100%;
        max-width: 440px;
        background: white;
        border-radius: 20px;
        padding: 40px 32px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        text-align: center;
    }
    .nhr-auth-avatar {
        width: 60px; height: 60px;
        background: #EEF2FF;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
    }
    .nhr-auth-title { color:#1E293B; font-size:22px; font-weight:700; margin:0 0 6px; }
    .nhr-auth-sub   { color:#94A3B8; font-size:14px; margin:0 0 24px; }
    .nhr-auth-field { text-align:left; margin-bottom:18px; }
    .nhr-auth-field label { display:block; color:#475569; font-size:13px; font-weight:600; margin-bottom:6px; }
    .nhr-auth-submit {
        background: linear-gradient(135deg, #4F46E5, #7C3AED) !important;
        color: white !important;
        font-weight: 700 !important;
        font-size: 15px !important;
        border-radius: 12px !important;
        padding: 14px !important;
        text-transform: none !important;
        box-shadow: 0 4px 14px rgba(79,70,229,0.35) !important;
        margin-top: 8px !important;
    }
    .nhr-auth-submit:disabled { opacity: 0.5 !important; box-shadow: none !important; }
    .nhr-auth-back-wrap { margin-top: 20px; text-align: center; }
    .nhr-auth-back { color:#4F46E5 !important; font-size:13px; font-weight:600; text-decoration:none; }
    .nhr-auth-back:hover { text-decoration: underline; }
</style>

@code {
    private Model _model = new();
    private bool _isLoading;
    private bool _sent;
    private string? _errorMessage;

    private class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            // Always show success to prevent user enumeration.
            var user = await UserManager.FindByEmailAsync(_model.Email);

            if (user != null && user.IsActive && !string.IsNullOrWhiteSpace(user.Email))
            {
                try
                {
                    var rawToken = await UserManager.GeneratePasswordResetTokenAsync(user);
                    var encodedToken = Uri.EscapeDataString(rawToken);
                    var encodedEmail = Uri.EscapeDataString(user.Email);
                    var baseUri = Navigation.BaseUri.TrimEnd('/');
                    var resetUrl = $"{baseUri}/reset-password?email={encodedEmail}&token={encodedToken}";
                    var displayName = string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
                    var safeName = System.Net.WebUtility.HtmlEncode(displayName);
                    var safeUrl  = System.Net.WebUtility.HtmlEncode(resetUrl);

                    var htmlBody = $@"
<div style=""font-family:Inter,Arial,sans-serif;max-width:600px;margin:0 auto;color:#1E293B;"">
  <div style=""background:linear-gradient(135deg,#4F46E5,#7C3AED);padding:24px;border-radius:12px 12px 0 0;color:white;"">
    <h2 style=""margin:0;font-weight:800;"">NickHR — Password Reset</h2>
  </div>
  <div style=""padding:24px;border:1px solid #E2E8F0;border-top:none;border-radius:0 0 12px 12px;background:white;"">
    <p>Hello {safeName},</p>
    <p>We received a request to reset the password on your NickHR account.
       Click the button below to choose a new password. This link expires in a few hours.</p>
    <p style=""text-align:center;margin:28px 0;"">
      <a href=""{resetUrl}"" style=""background:linear-gradient(135deg,#4F46E5,#7C3AED);color:white;padding:14px 28px;border-radius:10px;text-decoration:none;font-weight:700;display:inline-block;"">Reset Password</a>
    </p>
    <p style=""color:#64748B;font-size:13px;"">Or copy &amp; paste this link into your browser:</p>
    <p style=""color:#475569;font-size:12px;word-break:break-all;background:#F1F5F9;padding:12px;border-radius:8px;"">{safeUrl}</p>
    <p style=""color:#64748B;font-size:13px;margin-top:24px;"">If you didn't request this, you can safely ignore this email — your password won't change.</p>
    <p style=""color:#94A3B8;font-size:12px;margin-top:16px;"">— NickHR System</p>
  </div>
</div>";

                    await EmailService.SendAsync(user.Email, "NickHR — Reset your password", htmlBody);
                    Logger.LogInformation("Password reset email dispatched for {Email}", user.Email);
                }
                catch (Exception ex)
                {
                    // Don't surface internal failures to the caller. Log for ops.
                    Logger.LogError(ex, "Failed to send password reset email for {Email}", _model.Email);
                }
            }
            else
            {
                Logger.LogInformation("Password reset requested for unknown/inactive email {Email}", _model.Email);
            }

            _sent = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ForgotPassword.HandleSubmit unexpected failure");
            _errorMessage = "Something went wrong. Please try again in a moment.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
