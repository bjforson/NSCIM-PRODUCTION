@page "/reset-password"
@layout NickHR.WebApp.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using NickHR.Infrastructure.Data

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<ResetPassword> Logger

<PageTitle>NICKSCAN ERP — NickHR — Reset Password</PageTitle>

<div class="nhr-auth-wrap">
    <div class="nhr-auth-card">
        <div class="nhr-auth-avatar">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:32px;color:#4F46E5;" />
        </div>
        <h2 class="nhr-auth-title">Set a new password</h2>
        <p class="nhr-auth-sub">
            @if (!string.IsNullOrEmpty(Email))
            {
                <text>for <b>@Email</b></text>
            }
            else
            {
                <text>Choose a strong password you haven't used before.</text>
            }
        </p>

        @if (_missingToken)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                This reset link is invalid or incomplete. Request a new one.
            </MudAlert>
            <MudLink Href="/forgot-password" Class="nhr-auth-back">Request a new reset link</MudLink>
        }
        else if (_success)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4" Icon="@Icons.Material.Filled.CheckCircle">
                Password updated! Redirecting you to sign in...
            </MudAlert>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_formValid">
                <div class="nhr-auth-field">
                    <label>New Password</label>
                    <MudTextField @bind-Value="_newPassword"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showNew ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showNew ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showNew = !_showNew"
                                  Placeholder="Enter a new password"
                                  Required="true"
                                  RequiredError="New password is required."
                                  Validation="@(new Func<string, string?>(ValidatePassword))" />
                </div>

                <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background-color:#F8FAFC;text-align:left;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary"><b>Password requirements:</b></MudText>
                    <MudText Typo="Typo.caption" Class="d-block">
                        <MudIcon Icon="@(HasMinLength ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small" Color="@(HasMinLength ? Color.Success : Color.Default)" Class="mr-1" />
                        At least 8 characters
                    </MudText>
                    <MudText Typo="Typo.caption" Class="d-block">
                        <MudIcon Icon="@(HasUppercase ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small" Color="@(HasUppercase ? Color.Success : Color.Default)" Class="mr-1" />
                        At least one uppercase letter
                    </MudText>
                    <MudText Typo="Typo.caption" Class="d-block">
                        <MudIcon Icon="@(HasLowercase ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small" Color="@(HasLowercase ? Color.Success : Color.Default)" Class="mr-1" />
                        At least one lowercase letter
                    </MudText>
                    <MudText Typo="Typo.caption" Class="d-block">
                        <MudIcon Icon="@(HasDigit ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small" Color="@(HasDigit ? Color.Success : Color.Default)" Class="mr-1" />
                        At least one number
                    </MudText>
                    <MudText Typo="Typo.caption" Class="d-block">
                        <MudIcon Icon="@(HasSpecial ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small" Color="@(HasSpecial ? Color.Success : Color.Default)" Class="mr-1" />
                        At least one special character (!&#64;&#35;$%^&amp;*)
                    </MudText>
                </MudPaper>

                <div class="nhr-auth-field">
                    <label>Confirm New Password</label>
                    <MudTextField @bind-Value="_confirmPassword"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showConfirm = !_showConfirm"
                                  Placeholder="Re-enter the new password"
                                  Required="true"
                                  RequiredError="Please confirm your new password."
                                  Validation="@(new Func<string, string?>(ValidateConfirm))" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        @_errorMessage
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="SubmitAsync"
                           Disabled="_isLoading"
                           Class="nhr-auth-submit">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:white;width:20px;height:20px;" Class="mr-2" />
                    }
                    Update Password
                </MudButton>
            </MudForm>

            <div class="nhr-auth-back-wrap">
                <MudLink Href="/login" Class="nhr-auth-back">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:14px;vertical-align:middle;" />
                    Back to Sign In
                </MudLink>
            </div>
        }
    </div>
</div>

<style>
    .nhr-auth-wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: linear-gradient(160deg, #EEF2FF 0%, #F8FAFC 100%);
        font-family: 'Inter', -apple-system, sans-serif;
    }
    .nhr-auth-card {
        width: 100%;
        max-width: 440px;
        background: white;
        border-radius: 20px;
        padding: 40px 32px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        text-align: center;
    }
    .nhr-auth-avatar {
        width: 60px; height: 60px;
        background: #EEF2FF;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
    }
    .nhr-auth-title { color:#1E293B; font-size:22px; font-weight:700; margin:0 0 6px; }
    .nhr-auth-sub   { color:#94A3B8; font-size:14px; margin:0 0 24px; }
    .nhr-auth-field { text-align:left; margin-bottom:16px; }
    .nhr-auth-field label { display:block; color:#475569; font-size:13px; font-weight:600; margin-bottom:6px; }
    .nhr-auth-submit {
        background: linear-gradient(135deg, #4F46E5, #7C3AED) !important;
        color: white !important;
        font-weight: 700 !important;
        font-size: 15px !important;
        border-radius: 12px !important;
        padding: 14px !important;
        text-transform: none !important;
        box-shadow: 0 4px 14px rgba(79,70,229,0.35) !important;
        margin-top: 8px !important;
    }
    .nhr-auth-submit:disabled { opacity: 0.5 !important; box-shadow: none !important; }
    .nhr-auth-back-wrap { margin-top: 20px; text-align: center; }
    .nhr-auth-back { color:#4F46E5 !important; font-size:13px; font-weight:600; text-decoration:none; }
    .nhr-auth-back:hover { text-decoration: underline; }
</style>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private MudForm? _form;
    private bool _formValid;
    private bool _isLoading;
    private bool _success;
    private bool _missingToken;
    private string? _errorMessage;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showNew;
    private bool _showConfirm;

    private bool HasMinLength => _newPassword.Length >= 8;
    private bool HasUppercase => _newPassword.Any(char.IsUpper);
    private bool HasLowercase => _newPassword.Any(char.IsLower);
    private bool HasDigit     => _newPassword.Any(char.IsDigit);
    private bool HasSpecial   => _newPassword.Any(c => "!@#$%^&*()_+-=[]{}|;':\",./<>?".Contains(c));

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _missingToken = true;
        }
    }

    private string? ValidatePassword(string p)
    {
        if (string.IsNullOrEmpty(p))      return "New password is required.";
        if (!HasMinLength)                return "At least 8 characters.";
        if (!HasUppercase)                return "At least one uppercase letter.";
        if (!HasLowercase)                return "At least one lowercase letter.";
        if (!HasDigit)                    return "At least one number.";
        if (!HasSpecial)                  return "At least one special character.";
        return null;
    }

    private string? ValidateConfirm(string c) => c != _newPassword ? "Passwords do not match." : null;

    private async Task SubmitAsync()
    {
        if (_missingToken) return;
        if (_form != null) await _form.Validate();
        if (!_formValid) return;

        _isLoading = true;
        _errorMessage = null;
        try
        {
            var user = await UserManager.FindByEmailAsync(Email!);
            if (user == null || !user.IsActive)
            {
                // Do not reveal whether the email exists.
                _errorMessage = "This reset link is no longer valid. Request a new one.";
                return;
            }

            var result = await UserManager.ResetPasswordAsync(user, Token!, _newPassword);
            if (!result.Succeeded)
            {
                var err = string.Join(" ", result.Errors.Select(e => e.Description));
                if (string.IsNullOrWhiteSpace(err)) err = "This reset link is invalid or has expired. Request a new one.";
                _errorMessage = err;
                Logger.LogWarning("Password reset failed for {Email}: {Errors}", Email,
                    string.Join("; ", result.Errors.Select(e => e.Code + ":" + e.Description)));
                return;
            }

            // Clear forced-change flag + unlock, so the user can sign in immediately.
            user.MustChangePassword = false;
            user.LockoutEnd = null;
            user.AccessFailedCount = 0;
            await UserManager.UpdateAsync(user);
            await UserManager.UpdateSecurityStampAsync(user);

            Logger.LogInformation("Password reset succeeded for {Email}", Email);
            _success = true;
            Snackbar.Add("Password updated. You can now sign in.", Severity.Success);
            await Task.Delay(1500);
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ResetPassword.SubmitAsync error for {Email}", Email);
            _errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
