@page "/announcements"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.EntityFrameworkCore
@using NickHR.Infrastructure.Data
@using NickHR.Core.Entities.Core
@using NickHR.Core.Constants

<PageTitle>NICKSCAN ERP — NickHR — Announcements</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h5" Class="mb-1">Announcements</MudText>
        <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0" />
    </div>
    <AuthorizeView Roles="@RoleSets.HRStaff">
        <Authorized>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">
                Create Announcement
            </MudButton>
        </Authorized>
    </AuthorizeView>
</div>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (!_announcements.Any())
{
    <div class="d-flex flex-column align-center pa-12">
        <MudIcon Icon="@Icons.Material.Filled.Campaign" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">No active announcements</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Check back later for updates.</MudText>
    </div>
}
else
{
    <MudGrid>
        @foreach (var ann in _announcements)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudCard Elevation="2" Class="h-100">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary">
                                <MudIcon Icon="@Icons.Material.Filled.Campaign" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Style="line-height:1.3;">@ann.Title</MudText>
                            <div class="d-flex align-center gap-1 mt-1">
                                @if (ann.Department != null)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@ann.Department.Name</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Company-wide</MudChip>
                                }
                            </div>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <AuthorizeView Roles="@RoleSets.HRStaff">
                                <Authorized>
                                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                                        <MudMenuItem OnClick="() => OpenEditDialog(ann)">Edit</MudMenuItem>
                                        <MudMenuItem OnClick="() => DeleteAnnouncement(ann.Id)">Delete</MudMenuItem>
                                    </MudMenu>
                                </Authorized>
                            </AuthorizeView>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_expandedIds.Contains(ann.Id))
                        {
                            <MudText Typo="Typo.body2" Style="white-space:pre-line;">@ann.Content</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">
                                @(ann.Content.Length > 150 ? ann.Content[..150] + "..." : ann.Content)
                            </MudText>
                        }
                        @if (ann.Content.Length > 150)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       Class="mt-1 pa-0"
                                       OnClick="() => ToggleExpand(ann.Id)">
                                @(_expandedIds.Contains(ann.Id) ? "Show less" : "Read more")
                            </MudButton>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                            By @(ann.Author != null ? $"{ann.Author.FirstName} {ann.Author.LastName}" : "HR")
                            &bull; @ann.PublishedAt.ToLocalTime().ToString("dd MMM yyyy")
                        </MudText>
                        @if (ann.ExpiresAt.HasValue)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="ml-auto mr-2">
                                Expires @ann.ExpiresAt.Value.ToString("dd MMM")
                            </MudText>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<!-- Create/Edit Dialog -->
@if (_dialogOpen)
{
    <MudDialog @bind-IsVisible="_dialogOpen">
        <TitleContent>
            <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Edit Announcement" : "Create Announcement")</MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formTitle" Label="Title *" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formContent" Label="Content *" Variant="Variant.Outlined"
                                  Lines="6" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="int?" @bind-Value="_formDepartmentId" Label="Department (leave blank for company-wide)"
                               Variant="Variant.Outlined" Clearable="true">
                        @foreach (var dept in _departments)
                        {
                            <MudSelectItem Value="@((int?)dept.Id)">@dept.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudDatePicker @bind-Date="_formExpiresAt" Label="Expires At (optional)"
                                   Variant="Variant.Outlined" DateFormat="dd/MM/yyyy"
                                   MinDate="DateTime.Today.AddDays(1)" Clearable="true" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveAnnouncement" Disabled="_isSubmitting">
                @(_editingId.HasValue ? "Update" : "Publish")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<Announcement> _announcements = new();
    private List<Department> _departments = new();
    private HashSet<int> _expandedIds = new();
    private bool _isLoading = true;
    private bool _isSubmitting;
    private int? _employeeId;

    private bool _dialogOpen;
    private int? _editingId;
    private string _formTitle = string.Empty;
    private string _formContent = string.Empty;
    private int? _formDepartmentId;
    private DateTime? _formExpiresAt;

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Announcements", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        _employeeId = await GetCurrentEmployeeIdAsync();
        await LoadData();
    }

    private async Task<int?> GetCurrentEmployeeIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true) return null;

        var employeeIdClaim = user.FindFirst("employeeId")?.Value;
        if (int.TryParse(employeeIdClaim, out var empId)) return empId;

        var email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    ?? user.FindFirst("email")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? user.Identity?.Name;
        if (string.IsNullOrEmpty(email)) return null;

        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
        var emp = await db.Employees.FirstOrDefaultAsync(e => e.WorkEmail == email && !e.IsDeleted);
        return emp?.Id;
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            _announcements = await db.Announcements
                .Include(a => a.Author)
                .Include(a => a.Department)
                .Where(a => a.IsActive && (a.ExpiresAt == null || a.ExpiresAt >= DateTime.UtcNow))
                .OrderByDescending(a => a.PublishedAt)
                .ToListAsync();

            _departments = await db.Departments
                .Where(d => d.IsActive)
                .OrderBy(d => d.Name)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleExpand(int id)
    {
        if (_expandedIds.Contains(id)) _expandedIds.Remove(id);
        else _expandedIds.Add(id);
    }

    private void OpenCreateDialog()
    {
        _editingId = null;
        _formTitle = string.Empty;
        _formContent = string.Empty;
        _formDepartmentId = null;
        _formExpiresAt = null;
        _dialogOpen = true;
    }

    private void OpenEditDialog(Announcement ann)
    {
        _editingId = ann.Id;
        _formTitle = ann.Title;
        _formContent = ann.Content;
        _formDepartmentId = ann.DepartmentId;
        _formExpiresAt = ann.ExpiresAt;
        _dialogOpen = true;
    }

    private async Task SaveAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(_formTitle) || string.IsNullOrWhiteSpace(_formContent))
        {
            Snackbar.Add("Title and content are required.", Severity.Warning);
            return;
        }
        if (_employeeId == null)
        {
            Snackbar.Add("Not linked to employee record.", Severity.Warning);
            return;
        }

        _isSubmitting = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();

            if (_editingId.HasValue)
            {
                var ann = await db.Announcements.FindAsync(_editingId.Value);
                if (ann != null)
                {
                    ann.Title = _formTitle;
                    ann.Content = _formContent;
                    ann.DepartmentId = _formDepartmentId;
                    ann.ExpiresAt = _formExpiresAt;
                }
            }
            else
            {
                db.Announcements.Add(new Announcement
                {
                    Title = _formTitle,
                    Content = _formContent,
                    DepartmentId = _formDepartmentId,
                    ExpiresAt = _formExpiresAt,
                    AuthorId = _employeeId.Value,
                    PublishedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }

            await db.SaveChangesAsync();
            _dialogOpen = false;
            Snackbar.Add(_editingId.HasValue ? "Announcement updated!" : "Announcement published!", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteAnnouncement(int id)
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<NickHRDbContext>();
            var ann = await db.Announcements.FindAsync(id);
            if (ann != null)
            {
                ann.IsDeleted = true;
                await db.SaveChangesAsync();
            }
            Snackbar.Add("Announcement deleted.", Severity.Info);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
