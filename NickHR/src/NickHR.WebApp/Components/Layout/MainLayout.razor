        {"/my-documents", "My Documents"}, {"/directory", "Company Directory"},
        {"/change-password", "Change Password"}, {"/assets/my", "My Assets"},
        {"/journal", "My Journal"}, {"/handbook", "Employee Handbook"},
        {"/attendance/clock", "Clock In/Out"}, {"/attendance/my-records", "My Attendance"},
        {"/attendance/qr-scan", "QR Check-in"}, {"/attendance/reports", "Attendance Reports"},
        {"/attendance/shifts", "Shift Management"}, {"/attendance/qr-generate", "QR Generate"},
        {"/leave/request", "Request Leave"}, {"/leave/my-requests", "My Leave"},
        {"/leave/calendar", "Team Calendar"}, {"/leave/approvals", "Leave Approvals"},
        {"/leave/policies", "Leave Policies"},
        {"/excuse-duty/request", "Excuse Duty Request"}, {"/excuse-duty/my-requests", "My Excuse Duty"},
        {"/excuse-duty/approvals", "Excuse Duty Approvals"}, {"/excuse-duty/report", "Excuse Duty Report"},
        {"/overtime/request", "Request Overtime"}, {"/overtime/my-requests", "My Overtime"},
