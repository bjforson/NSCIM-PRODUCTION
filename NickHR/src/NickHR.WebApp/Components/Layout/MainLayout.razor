    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePageTitle();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdatePageTitle();
        InvokeAsync(StateHasChanged);
    }

    private void UpdatePageTitle()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path)) path = "/";

        if (PageTitles.TryGetValue(path, out var title))
        {
            _currentPageTitle = "/ " + title;
        }
        else if (path.StartsWith("/employees/") && path.Contains("/edit"))
        {
            _currentPageTitle = "/ Edit Employee";
        }
        else if (path.StartsWith("/employees/"))
        {
            _currentPageTitle = "/ Employee Detail";
        }
        else if (path.StartsWith("/surveys/take/"))
        {
            _currentPageTitle = "/ Take Survey";
        }
        else if (path.StartsWith("/surveys/results/"))
        {
            _currentPageTitle = "/ Survey Results";
        }
        else if (path.StartsWith("/policies/"))
        {
            _currentPageTitle = "/ Policy Detail";
        }
        else
        {
            _currentPageTitle = "";
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#00897B",
            AppbarBackground = "#1565C0",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#424242",
            Success = "#2E7D32",
            Warning = "#F57F17",
            Error = "#C62828",
            Info = "#0277BD"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#4DB6AC",
            AppbarBackground = "#1E1E2D",
            Background = "#121212",
            Surface = "#1E1E2D",
            DrawerBackground = "#1E1E2D",
            DrawerText = "#E0E0E0"
        },
        Typography = new Typography
        {
            // MudBlazor 8: Default typography class renamed to DefaultTypography
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Inter", "Helvetica", "Arial", "sans-serif" }
            }
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Re-initialize auth from localStorage after prerender
                await AuthState.InitializeAsync();

                var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
                _isMobile = width <= 768;
                if (_isMobile) _drawerOpen = false;
                StateHasChanged();
            }
            catch
            {
                // JS interop may not be available in SSR prerender
            }
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    private void Logout()
    {
        Navigation.NavigateTo("/logout", forceLoad: true);
    }
}
