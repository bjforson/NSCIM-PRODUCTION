        {"/departments", "Departments"}, {"/designations", "Designations"},
        {"/grades", "Grades"}, {"/locations", "Locations"},
        {"/transfer/initiate", "Transfer/Promotion"}, {"/transfer/approvals", "Transfer Approvals"},
        {"/transfer/history", "Transfer History"}, {"/probation", "Probation Reviews"},
        {"/succession", "Succession Planning"},
