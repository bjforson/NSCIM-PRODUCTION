        {"/out-of-station/request", "Out of Station Request"}, {"/out-of-station/my", "My Out of Station"},
        {"/out-of-station/approvals", "Out of Station Approvals"}, {"/out-of-station/rates", "Out of Station Rates"},
        {"/recognition", "Recognition Wall"}, {"/recognition/leaderboard", "Leaderboard"},
        {"/surveys", "Surveys"}, {"/surveys/create", "Create Survey"},
        {"/announcements", "Announcements"}, {"/calendar", "Calendar"},
        {"/policies", "Company Policies"}, {"/timesheets", "Timesheets"}, {"/projects", "Projects"},
        {"/employees", "Employees"}, {"/employees/create", "Add Employee"},
