<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.7" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.1" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="10.0.7">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Identity" Version="2.2.0" />
    <!-- SECURITY: Microsoft.AspNetCore.Identity 2.2.0 (kept for ABI reasons —
         the legacy 2.x package surface is what NickHR.Services consumes)
         transitively pulls System.Security.Cryptography.Xml 4.5.0 which has
         GHSA-vh55-786g-wjwj (moderate). Explicit pin to a clean 10.0.x patch
         overrides it. Mirrors the wiring on NickERP.Platform.Tenancy.Database. -->
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\platform\NickERP.Platform.Core\NickERP.Platform.Core.csproj" />
    <ProjectReference Include="..\..\..\platform\NickERP.Platform.Tenancy\NickERP.Platform.Tenancy.csproj" />
    <ProjectReference Include="..\NickHR.Core\NickHR.Core.csproj" />
  </ItemGroup>

</Project>
