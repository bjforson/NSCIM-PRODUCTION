<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <add key="http_maxRetryCount" value="5" />
    <add key="globalPackagesFolder" value="C:\Users\Administrator\.nuget\packages" />
  </config>
</configuration>
