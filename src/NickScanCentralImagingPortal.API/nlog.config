<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="C:\Shared\NSCIM_PRODUCTION\Data\Logs\internal-nlog-AspNetCore.txt">

  <!-- Enable ASP.NET Core layout renderers -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <!-- Define targets to write to -->
  <targets>
    <!-- File Target for all logs -->
    <target xsi:type="File" name="allfile" fileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\nick-scan-api-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} ${message} ${exception:format=tostring}"
            archiveFileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\archives\nick-scan-api-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false" />

    <!-- File Target for structured logs only -->
    <target xsi:type="File" name="structuredfile" fileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\structured-api-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${message}"
            archiveFileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\archives\structured-api-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false" />

    <!-- File Target for errors only -->
    <target xsi:type="File" name="errorfile" fileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\errors-api-${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${logger} ${message} ${exception:format=tostring}"
            archiveFileName="C:\Shared\NSCIM_PRODUCTION\Data\Logs\archives\errors-api-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false" />

    <!-- Console Target with color coding -->
    <target xsi:type="ColoredConsole" name="console"
            layout="${longdate} ${uppercase:${level}} ${logger} ${message} ${exception:format=tostring}"
            useDefaultRowHighlightingRules="true" />
  </targets>

  <!-- Rules to map from logger name to target -->
  <rules>
    <!-- Skip non-critical Microsoft logs and so log only own logs (BlackHole) -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />
    
    <!-- Structured logging services -->
    <logger name="*" minlevel="Trace" writeTo="structuredfile" final="true" />
    
    <!-- All logs to console in development -->
    <logger name="*" minlevel="Debug" writeTo="console" />
    
    <!-- All logs to file -->
    <logger name="*" minlevel="Debug" writeTo="allfile" />
    
    <!-- Error logs to error file -->
    <logger name="*" minlevel="Error" writeTo="errorfile" />
  </rules>
</nlog>
