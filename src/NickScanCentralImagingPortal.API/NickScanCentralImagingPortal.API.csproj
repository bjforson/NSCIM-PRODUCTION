<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <!-- CANONICAL publish dir — this is where the NSCIM_API Windows service runs from.
         Running `dotnet publish -c Release` without -o will deploy here automatically.
         Do NOT change without also updating nssm service binPath. -->
    <PublishDir>C:\Shared\NSCIM_PRODUCTION\publish\API\</PublishDir>
  </PropertyGroup>

  <!-- 2026-05-05 audit 8.04: removed AspNetCore.HealthChecks.UI (and its
       Client / InMemory.Storage / IdentityModel / KubernetesClient transitives)
       in favour of the plain /health JSON endpoint. The UI assembled query
       URLs that exceeded Kestrel's 8 KiB request-line cap (414 URI Too Long)
       once IdentityModel was pinned in Sprint 1A. The WebApp already renders
       a visual dashboard at /monitoring/health backed by the
       /api/Monitoring/health/overview controller, so the HealthChecks.UI
       surface was redundant. The Microsoft.AspNetCore.Diagnostics.HealthChecks
       JSON writer below preserves the same JSON shape consumers were already
       reading from /health. -->
  <ItemGroup>
    <PackageReference Include="AspNetCore.HealthChecks.NpgSql" Version="8.0.2" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.7" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="10.0.7">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.EntityFrameworkCore" Version="10.0.7" />
    <PackageReference Include="NLog" Version="5.3.4" />
    <PackageReference Include="Polly" Version="8.6.4" />
    <PackageReference Include="Polly.Extensions.Http" Version="3.0.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="9.0.0" />
    <PackageReference Include="Serilog.Sinks.PostgreSQL.Alternative" Version="4.2.0" />
    <PackageReference Include="StackExchange.Redis" Version="2.7.33" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.7" />
    <PackageReference Include="Swashbuckle.AspNetCore.Annotations" Version="10.1.7" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    <PackageReference Include="Swashbuckle.AspNetCore.Filters" Version="10.0.1" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.14.0" />
    <PackageReference Include="System.Management" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NickScanCentralImagingPortal.Core\NickScanCentralImagingPortal.Core.csproj" />
    <ProjectReference Include="..\NickScanCentralImagingPortal.Infrastructure\NickScanCentralImagingPortal.Infrastructure.csproj" />
    <ProjectReference Include="..\NickScanCentralImagingPortal.Services\NickScanCentralImagingPortal.Services.csproj" />
    <ProjectReference Include="..\NickScanCentralImagingPortal.Services.FS6000\NickScanCentralImagingPortal.Services.FS6000.csproj" />
    <ProjectReference Include="..\NickScanCentralImagingPortal.Services.ImageProcessing\NickScanCentralImagingPortal.Services.ImageProcessing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="tessdata\eng.traineddata">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
