{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Warning"
    },
    "StructuredLogging": {
      "EnableStructuredLogging": true,
      "ServiceSettings": {
        "REALTIME-DASHBOARD": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 120,
          "MinLogLevel": "Warning"
        },
        "ENHANCED-DASHBOARD": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 180,
          "MinLogLevel": "Warning"
        },
        "CONTAINER-DETAILS": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 300,
          "MinLogLevel": "Information"
        },
        "CONTAINER-VALIDATION-API": {
          "EnableThrottling": false,
          "ThrottleIntervalSeconds": 30,
          "MinLogLevel": "Information"
        },
        "IMAGE-ANALYSIS": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 300,
          "MinLogLevel": "Information"
        },
        "USER-REPOSITORY": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 600,
          "MinLogLevel": "Warning"
        },
        "COMPREHENSIVE-HEALTH-CHECK": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 60,
          "MinLogLevel": "Information"
        },
        "ICUMS-BACKGROUND": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 120,
          "MinLogLevel": "Information"
        },
        "FS6000-BACKGROUND": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 120,
          "MinLogLevel": "Information"
        },
        "ASE-BACKGROUND": {
          "EnableThrottling": true,
          "ThrottleIntervalSeconds": 180,
          "MinLogLevel": "Information"
        }
      },
      "SpamOperations": [
        "BroadcastSystemStatusUpdate",
        "BroadcastScannerStatusUpdate",
        "BroadcastICUMSUpdate",
        "BroadcastSystemHealthUpdate",
        "GetEnhancedDashboardData",
        "GetBasicInfo",
        "GetScannerData",
        "GetICUMSData",
        "GetImageMetadata",
        "SearchContainerData",
        "ClearContainerCache",
        "BroadcastToRole",
        "DatabaseHealthCheck",
        "FileSystemHealthCheck",
        "NetworkHealthCheck",
        "BackgroundServiceHealthCheck"
      ]
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "NickScanCentralImagingPortal.Services.IcumApi.IcumJsonIngestionService": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\Shared\\NSCIM_PRODUCTION\\Data\\Logs\\nickscan-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 30,
          "retainedFileTimeLimit": "30.00:00:00",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\Shared\\NSCIM_PRODUCTION\\Data\\Logs\\nickscan-errors-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 30,
          "retainedFileTimeLimit": "30.00:00:00",
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  }
}
