{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CargoGroup": {
    "_comment": "Phase 1 — Theme E follow-up routing endpoint. Enabled in dev so frontend devs can wire up Phase 2 against a live endpoint without touching production config.",
    "UseFullEndpoint": true
  },
  "CameraEvidence": {
    "Enabled": false,
    "WebhookIngestionEnabled": false,
    "MediaFetchEnabled": false,
    "OcrEnabled": false,
    "ExternalVisionFallbackEnabled": false,
    "CoreReadOnlyLookupEnabled": false,
    "CoreDisplayPromotionEnabled": false,
    "CoreDecisionSupportEnabled": false,
    "CoreAutomationEnabled": false,
    "StorageRoot": "Data/CameraEvidence"
  },
  "UniFiProtect": {
    "ApiKeyHeader": "X-API-KEY",
    "WebhookSecretHeader": "X-NSCIM-Webhook-Secret",
    "Sites": []
  }
}
