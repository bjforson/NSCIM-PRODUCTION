@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    @if (CargoGroup?.Data?.ScannerData?.Any() == true)
    {
        @foreach (var scannerGroup in CargoGroup.Data.ScannerData)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Outlined.Scanner" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">
                            Container: <strong>@scannerGroup.ContainerNumber</strong>
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                            @scannerGroup.ScannerType
                        </MudChip>
                        @if (scannerGroup.ScanDate.HasValue)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Scanned: @scannerGroup.ScanDate.Value.ToString("g")
                            </MudText>
                        }
                    </MudStack>

                    <!-- Group records by category -->
                    @foreach (var categoryGroup in scannerGroup.Records.GroupBy(r => r.Category))
                    {
                        <MudPaper Elevation="1" Class="pa-3 mb-2">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                                @categoryGroup.Key
                            </MudText>
                            <MudGrid Spacing="2">
                                @foreach (var record in categoryGroup)
                                {
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                <strong>@record.Field</strong>
                                            </MudText>
                                            <MudText Typo="Typo.body2">@record.Value</MudText>
                                        </MudStack>
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    }
                </MudStack>
            </MudPaper>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Info">
            No scanner data available for this cargo group.
        </MudAlert>
    }
</MudContainer>

@code {
    [Parameter] public CargoGroupDto? CargoGroup { get; set; }
}

