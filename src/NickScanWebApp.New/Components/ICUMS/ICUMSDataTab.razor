@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    @if (isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1">Loading ICUMS data...</MudText>
        </MudStack>
    }
    else if (icumsData?.Data?.Any() == true)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="px-2 py-1" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @($"Showing {GetGroupedData().SelectMany(g => g.Value).Count()} of {icumsData.Data.Count(d => !IsUnmappedField(d))} fields")
            </MudText>
            <MudSwitch T="bool" Value="ShowEmptyFields" ValueChanged="@(async v => { ShowEmptyFields = v; await InvokeAsync(StateHasChanged); })"
                       Label="Show empty fields" Color="Color.Primary" Size="Size.Small" />
        </MudStack>

        <MudExpansionPanels MultiExpansion="true" Class="pa-2">
            @foreach (var categoryGroup in GetGroupedData())
            {
                <MudExpansionPanel Text="@categoryGroup.Key" 
                                   Icon="@GetCategoryIcon(categoryGroup.Key)"
                                   Color="@GetCategoryColor(categoryGroup.Key)"
                                   IsExpanded="false">
                    <MudStack Spacing="2" Class="pa-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                            @categoryGroup.Value.Count field(s)
                        </MudChip>

                        @{
                            var itemGroups = GroupRecordsByItem(categoryGroup.Value);
                        }

                        @if (itemGroups.Count > 1)
                        {
                            @* Multi-item: show grouped by item number *@
                            @foreach (var itemGroup in itemGroups)
                            {
                                <MudPaper Elevation="1" Class="pa-3 mb-2" Style="border-left: 3px solid #2563EB;">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600; color:#2563EB;" Class="mb-2">
                                        @itemGroup.Key
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">@itemGroup.Value.Count fields</MudChip>
                                    </MudText>
                                    <MudGrid Spacing="2">
                                        @foreach (var record in itemGroup.Value)
                                        {
                                            <MudItem xs="12" sm="6" md="4">
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary"><strong>@StripItemPrefix(record.Field)</strong></MudText>
                                                    <MudText Typo="Typo.body2">@record.Value</MudText>
                                                </MudStack>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudPaper>
                            }
                        }
                        else
                        {
                            @* Single item or no item prefix: flat grid *@
                            <MudGrid Spacing="2">
                                @foreach (var record in categoryGroup.Value)
                                {
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    <strong>@record.Field</strong>
                                                </MudText>
                                                @if (record.IsRequired)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Style="height: 18px; font-size: 0.7rem;">Required</MudChip>
                                                }
                                            </MudStack>
                                            <MudText Typo="Typo.body2">@record.Value</MudText>
                                        </MudStack>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </MudStack>
                </MudExpansionPanel>
            }
            
            <!-- Unmapped Fields Section -->
            @if (HasUnmappedFields)
            {
                <MudExpansionPanel Text="Additional Fields" 
                                   Icon="@Icons.Material.Outlined.Info"
                                   Color="Color.Warning"
                                   IsExpanded="false"
                                   Class="mt-2">
                    <MudStack Spacing="2" Class="pa-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            @UnmappedFieldsCount field(s)
                        </MudChip>
                        
                        <MudGrid Spacing="2">
                            @foreach (var record in GetUnmappedFields())
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.caption" Color="Color.Warning">
                                                <strong>@record.Field</strong>
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Style="height: 18px; font-size: 0.7rem;">
                                                @record.Category
                                            </MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body2">@record.Value</MudText>
                                    </MudStack>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudStack>
                </MudExpansionPanel>
            }
            
            <!-- Summary -->
            <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true">
                <MudText Typo="Typo.caption">
                    Total ICUMS Fields: @icumsData.TotalCount | Categories: @GetGroupedData().Count
                    @if (HasUnmappedFields)
                    {
                        <span> | Additional Fields: @UnmappedFieldsCount</span>
                    }
                </MudText>
            </MudAlert>
        </MudExpansionPanels>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="ma-4">
            <MudText Typo="Typo.body1">No ICUMS data available for this container</MudText>
        </MudAlert>
    }
</MudContainer>

@code {
    [Parameter] public string ContainerNumber { get; set; } = string.Empty;
    [Parameter] public int TotalRecords { get; set; }
    /// <summary>
    /// Optional preloaded ICUMS data for this container. When provided, the tab will render from this
    /// data instead of issuing its own API call.
    /// </summary>
    [Parameter] public NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ICUMSDataRecord>? PreloadedData { get; set; }

    private NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ICUMSDataRecord>? icumsData;
    private bool isLoading = false;

    protected override async Task OnParametersSetAsync()
    {
        // Prefer preloaded data when available (from ContainerDetailsModal / view context)
        if (PreloadedData != null && PreloadedData.Data != null && PreloadedData.Data.Any())
        {
            Console.WriteLine($"✅ [ICUMSDataTab] Using preloaded data: {PreloadedData.TotalCount} records");
            icumsData = PreloadedData;
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // If preloaded data is null or empty, load it ourselves
        if (PreloadedData == null)
        {
            Console.WriteLine($"⚠️ [ICUMSDataTab] PreloadedData is null, loading data...");
        }
        else if (PreloadedData.Data == null || !PreloadedData.Data.Any())
        {
            Console.WriteLine($"⚠️ [ICUMSDataTab] PreloadedData exists but has no data (TotalCount: {PreloadedData.TotalCount}), loading data...");
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            Console.WriteLine($"🔍 [ICUMSDataTab] Loading ALL ICUMS data for container: {ContainerNumber}");
            // Fetch ALL data at once (use large page size to get everything)
            icumsData = await ContainerDetailsService.GetICUMSDataAsync(ContainerNumber, 1, 1000);
            
            if (icumsData != null)
            {
                Console.WriteLine($"✅ [ICUMSDataTab] Loaded {icumsData.Data?.Count ?? 0} ICUMS records (Total: {icumsData.TotalCount})");
                Console.WriteLine($"   Categories found: {icumsData.Data?.Select(d => d.Category).Distinct().Count() ?? 0}");
                if (icumsData.Data != null && icumsData.Data.Any())
                {
                    Console.WriteLine($"   Sample record: {icumsData.Data.First().Field} = {icumsData.Data.First().Value}");
                }
            }
            else
            {
                Console.WriteLine($"❌ [ICUMSDataTab] icumsData is NULL!");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [ICUMSDataTab] Error loading ICUMS data: {ex.Message}");
            Console.WriteLine($"   Stack trace: {ex.StackTrace}");
            Snackbar.Add("Could not load ICUMS data", Severity.Error);
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Dictionary<string, List<NickScanWebApp.Shared.Models.ICUMSDataRecord>> GetGroupedData()
    {
        if (icumsData?.Data == null) return new Dictionary<string, List<NickScanWebApp.Shared.Models.ICUMSDataRecord>>();

        // Filter out unmapped fields from standard display (they're shown separately)
        var standardFields = icumsData.Data.Where(d => !IsUnmappedField(d)).ToList();

        // Visibility policy (c): hide records whose value is null/empty/placeholder,
        // UNLESS the record is required (surfaces warnings) or user opted into "Show empty fields".
        if (!ShowEmptyFields)
        {
            standardFields = standardFields.Where(r => r.IsRequired || HasMeaningfulValue(r.Value)).ToList();
        }

        return standardFields
            .GroupBy(d => d.Category)
            .OrderBy(g => GetCategoryOrder(g.Key))
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private static bool HasMeaningfulValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        var trimmed = value.Trim();
        // Placeholder tokens produced by the service when an underlying BOE field is null.
        return !string.Equals(trimmed, "Not available", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "N/A", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "None", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "Not applicable", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "Not yet processed", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "Not assessed", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(trimmed, "Unknown", StringComparison.OrdinalIgnoreCase);
    }

    [Parameter] public bool ShowEmptyFields { get; set; } = false;

    private Dictionary<string, List<NickScanWebApp.Shared.Models.ICUMSDataRecord>> GroupRecordsByItem(
        List<NickScanWebApp.Shared.Models.ICUMSDataRecord> records)
    {
        var groups = new Dictionary<string, List<NickScanWebApp.Shared.Models.ICUMSDataRecord>>();
        foreach (var r in records)
        {
            var match = System.Text.RegularExpressions.Regex.Match(r.Field ?? "", @"^Item\s+\d+:");
            var key = match.Success ? match.Value.TrimEnd(':') : "General";
            if (!groups.ContainsKey(key)) groups[key] = new();
            groups[key].Add(r);
        }
        return groups;
    }

    private string StripItemPrefix(string field)
    {
        return System.Text.RegularExpressions.Regex.Replace(field ?? "", @"^Item\s+\d+:\s*", "");
    }

    private bool HasUnmappedFields => GetUnmappedFields().Any();

    private int UnmappedFieldsCount => GetUnmappedFields().Count;

    private List<NickScanWebApp.Shared.Models.ICUMSDataRecord> GetUnmappedFields()
    {
        if (icumsData?.Data == null) return new List<NickScanWebApp.Shared.Models.ICUMSDataRecord>();
        
        return icumsData.Data
            .Where(IsUnmappedField)
            .ToList();
    }

    private bool IsUnmappedField(NickScanWebApp.Shared.Models.ICUMSDataRecord record)
    {
        // Unmapped fields are identified by their category being "Additional Fields"
        // or by having a specific marker in the field name
        return record.Category == "Additional Fields" || 
               (record.Category == "Data Info" && record.Field.Contains("⚠️"));
    }

    private int GetCategoryOrder(string category)
    {
        return category switch
        {
            "Container Info" => 1,
            "Declaration Info" => 2,
            "CMR Info" => 3, // ✅ CMR-specific category
            "Manifest Info" => 4,
            "Party Info" => 5,
            "Location Info" => 6,
            "Cargo Info" => 7,
            "Financial Info" => 8,
            "Risk Assessment" => 9,
            "Integrity" => 10, // Part B: ingestion warnings / data quality flags
            "Status" => 11,
            "Data Info" => 12,
            "Additional Fields" => 13,  // Unmapped fields appear last
            _ => 99
        };
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Container Info" => Icons.Material.Outlined.Inventory,
            "Declaration Info" => Icons.Material.Outlined.Description,
            "CMR Info" => Icons.Material.Outlined.Sailing, // ✅ Ship icon for CMR (transit cargo)
            "Manifest Info" => Icons.Material.Outlined.Assignment,
            "Party Info" => Icons.Material.Outlined.People,
            "Location Info" => Icons.Material.Outlined.LocationOn,
            "Cargo Info" => Icons.Material.Outlined.LocalShipping,
            "Financial Info" => Icons.Material.Outlined.AttachMoney,
            "Risk Assessment" => Icons.Material.Outlined.Security, // ✅ CRMS/Risk info
            "Integrity" => Icons.Material.Outlined.ReportProblem, // Part B: ingestion warnings
            "Status" => Icons.Material.Outlined.CheckCircle,
            "Data Info" => Icons.Material.Outlined.Info,
            "Additional Fields" => Icons.Material.Outlined.Info,  // ⚠️ Unmapped fields
            _ => Icons.Material.Outlined.Label
        };
    }

    private Color GetCategoryColor(string category)
    {
        return category switch
        {
            "Container Info" => Color.Primary,
            "Declaration Info" => Color.Secondary,
            "CMR Info" => Color.Info, // ✅ Blue for CMR (transit)
            "Manifest Info" => Color.Info,
            "Party Info" => Color.Success,
            "Location Info" => Color.Warning,
            "Cargo Info" => Color.Tertiary,
            "Financial Info" => Color.Error,
            "Risk Assessment" => Color.Warning, // ✅ Yellow for risk/security
            "Integrity" => Color.Error, // Red for ingestion warnings (stands out)
            "Status" => Color.Success,
            "Data Info" => Color.Default,
            "Additional Fields" => Color.Warning,  // ⚠️ Yellow/warning for unmapped fields
            _ => Color.Default
        };
    }
}
