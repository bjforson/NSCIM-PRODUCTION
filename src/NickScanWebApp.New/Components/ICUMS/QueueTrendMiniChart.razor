@* Simple ASCII-style queue trend visualization *@

<MudPaper Elevation="2" Class="pa-4 rounded-lg">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Class="mr-2" />
            Queue Size Trend (24h)
        </MudText>
        
        @if (Loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.caption" Align="Align.Center">Loading trend data...</MudText>
        }
        else if (TrendData != null && TrendData.Any())
        {
            <!-- Simple bar chart visualization using MudProgressLinear -->
            <MudStack Spacing="1">
                @foreach (var dataPoint in TrendData.TakeLast(12)) // Last 12 hours
                {
                    var maxValue = TrendData.Max(d => d.TotalQueueSize);
                    var minValue = TrendData.Min(d => d.TotalQueueSize);
                    var range = maxValue - minValue;
                    var percentage = range > 0 ? ((dataPoint.TotalQueueSize - minValue) / (double)range) * 100 : 50;
                    var color = GetTrendColor(dataPoint.TotalQueueSize);
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.caption" Style="min-width: 60px;">
                            @dataPoint.Timestamp.ToString("HH:mm")
                        </MudText>
                        <MudProgressLinear Color="@color" 
                                          Value="@percentage" 
                                          Min="0" 
                                          Max="100" 
                                          Size="Size.Small" 
                                          Rounded="true"
                                          Style="flex: 1;" />
                        <MudText Typo="Typo.caption" Style="min-width: 40px; text-align: right;">
                            @dataPoint.TotalQueueSize
                        </MudText>
                    </MudStack>
                }
            </MudStack>
            
            <!-- Summary Statistics -->
            <MudDivider Class="my-2" />
            <MudGrid>
                <MudItem xs="4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Current</MudText>
                    <MudText Typo="Typo.body2"><strong>@CurrentQueueSize</strong></MudText>
                </MudItem>
                <MudItem xs="4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Peak</MudText>
                    <MudText Typo="Typo.body2"><strong>@GetPeakValue()</strong></MudText>
                </MudItem>
                <MudItem xs="4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Average</MudText>
                    <MudText Typo="Typo.body2"><strong>@GetAverageValue()</strong></MudText>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No trend data available. Run database setup to enable charts.
            </MudAlert>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public List<QueueSnapshot> TrendData { get; set; } = new();
    [Parameter] public int CurrentQueueSize { get; set; }
    [Parameter] public bool Loading { get; set; } = false;
    
    private Color GetTrendColor(int queueSize)
    {
        if (queueSize > 500) return Color.Error;
        if (queueSize > 200) return Color.Warning;
        if (queueSize > 100) return Color.Info;
        return Color.Success;
    }
    
    private int GetPeakValue()
    {
        return TrendData != null && TrendData.Any() ? TrendData.Max(d => d.TotalQueueSize) : 0;
    }
    
    private int GetAverageValue()
    {
        return TrendData != null && TrendData.Any() ? (int)TrendData.Average(d => d.TotalQueueSize) : 0;
    }
    
    public class QueueSnapshot
    {
        public DateTime Timestamp { get; set; }
        public int TotalQueueSize { get; set; }
        public int PendingCount { get; set; }
        public int ProcessingCount { get; set; }
    }
}

