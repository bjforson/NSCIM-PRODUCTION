@using MudBlazor
@implements IDisposable
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NickScanWebApp.Shared.Services.IcumsDownloadQueueClient DownloadQueueClient
@inject NickScanWebApp.Shared.Services.IcumsBatchClient BatchClient
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation


<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    
    <MudBreadcrumbs Items="@_breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Header -->
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h4">
                    <MudIcon Icon="@Icons.Material.Outlined.Download" Class="mr-2" />
                    ICUMS Individual Download Management
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Control, monitor, and manage per-container ICUMS data downloads
                </MudText>
            </div>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          StartIcon="@Icons.Material.Outlined.Refresh"
                          OnClick="@RefreshAll"
                          Disabled="@_isLoading">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Quick Enqueue Section -->
    <MudPaper Elevation="2" Class="mb-4 pa-4 rounded-lg">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Outlined.AddCircle" Class="mr-2" />
                Quick Enqueue Container
            </MudText>
        </MudStack>
        
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="@_enqueueContainerNumber" 
                              Label="Container Number" 
                              Variant="Variant.Outlined"
                              Placeholder="e.g. MSCU1234567"
                              HelperText="Enter container number to download from ICUMS"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Class="mb-2"
                              OnKeyDown="@OnEnqueueKeyDown" />
            </MudItem>
            <MudItem xs="12" sm="3" md="2">
                <MudSelect @bind-Value="@_enqueuePriority" 
                          Label="Priority" 
                          Variant="Variant.Outlined"
                          HelperText="Download priority"
                          Class="mb-2">
                    <MudSelectItem Value="3">High</MudSelectItem>
                    <MudSelectItem Value="2">Normal</MudSelectItem>
                    <MudSelectItem Value="1">Low</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" md="2">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Style="height: 100%;">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary"
                              StartIcon="@Icons.Material.Outlined.CloudDownload"
                              OnClick="@EnqueueContainer"
                              Disabled="@(_isEnqueuing || string.IsNullOrWhiteSpace(_enqueueContainerNumber))"
                              Size="Size.Medium">
                        @if (_isEnqueuing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @:Queuing...
                        }
                        else
                        {
                            @:Enqueue
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Info"
                              StartIcon="@Icons.Material.Outlined.ContentPaste"
                              OnClick="@ShowBulkEnqueueDialog"
                              Size="Size.Medium">
                        Bulk
                    </MudButton>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="12" md="4">
                @if (!string.IsNullOrEmpty(_enqueueStatus))
                {
                    <MudAlert Severity="@_enqueueStatusSeverity" Dense="true" Class="mt-2">
                        @_enqueueStatus
                    </MudAlert>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
    
    <!-- Statistics Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="High Priority"
                     Value="@_queueStats.HighPriority.ToString()"
                     Icon="@Icons.Material.Outlined.PriorityHigh"
                     Color="@Color.Error"
                     Trend="Urgent" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Normal Priority"
                     Value="@_queueStats.NormalPriority.ToString()"
                     Icon="@Icons.Material.Outlined.List"
                     Color="@Color.Warning"
                     Trend="Queued" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Completed"
                     Value="@_queueStats.Completed.ToString()"
                     Icon="@Icons.Material.Outlined.CheckCircle"
                     Color="@Color.Success"
                     Trend="@($"Success rate: {_queueStats.SuccessRate:F1}%")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Failed"
                     Value="@_queueStats.Failed.ToString()"
                     Icon="@Icons.Material.Outlined.Error"
                     Color="@(_queueStats.Failed > 0 ? Color.Error : Color.Success)"
                     Trend="@(_queueStats.Failed > 0 ? "Review required" : "All successful")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Pending"
                     Value="@_queueStats.Pending.ToString()"
                     Icon="@Icons.Material.Outlined.PendingActions"
                     Color="@(_queueStats.Pending > 0 ? Color.Warning : Color.Success)"
                     Trend="@(_queueStats.Pending > 0 ? "Awaiting download" : "Queue empty")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Processing"
                     Value="@_queueStats.Processing.ToString()"
                     Icon="@Icons.Material.Outlined.Downloading"
                     Color="@Color.Info"
                     Trend="@(_queueStats.Processing > 0 ? "In progress" : "Idle")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Avg Wait Time"
                     Value="@($"{_queueStats.AverageWaitTimeMinutes:F1} min")"
                     Icon="@Icons.Material.Outlined.Timer"
                     Color="@Color.Info"
                     Trend="Average queue wait" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Archived"
                     Value="@_archiveStats.TotalArchived.ToString()"
                     Icon="@Icons.Material.Outlined.Archive"
                     Color="@Color.Secondary"
                     Trend="@($"{_archiveStats.Failed} failed, {_archiveStats.Completed} completed")" />
        </MudItem>
    </MudGrid>
    
    <!-- Main Content Tabs -->
    <MudPaper Elevation="2" Class="rounded-lg">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary" @bind-ActivePanelIndex="@_activeTab">
            
            <!-- Queue Items Tab (All) -->
            <MudTabPanel Text="All Queue Items" Icon="@Icons.Material.Outlined.List" BadgeData="@_queueItems.Count">
                <QueueTable Items="@_queueItems" 
                            OnRetry="@RetryDownload" 
                            OnDelete="@DeleteDownload"
                            EnableBulkActions="true"
                            @bind-SelectedItems="@_selectedAll"
                            OnBulkDelete="@BulkDeleteItems"
                            OnBulkPriorityChange="@BulkChangePriority" />
            </MudTabPanel>
            
            <!-- Pending Tab -->
            <MudTabPanel Text="Pending" Icon="@Icons.Material.Outlined.PendingActions" BadgeData="@_pendingItems.Count" BadgeColor="Color.Warning">
                @if (_pendingItems.Any())
                {
                    <MudStack Row="true" Spacing="2" Class="mb-4">
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary"
                                  StartIcon="@Icons.Material.Outlined.Replay"
                                  OnClick="@ShowRequeuePendingDialog"
                                  Size="Size.Small">
                            Requeue All Pending (@_pendingItems.Count)
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" 
                                  Color="Color.Warning"
                                  StartIcon="@Icons.Material.Outlined.PriorityHigh"
                                  OnClick="@RequeueHighPriorityPending"
                                  Size="Size.Small"
                                  Disabled="@(!_pendingItems.Any(x => x.Priority >= 2))">
                            Requeue High Priority (@_pendingItems.Count(x => x.Priority >= 2))
                        </MudButton>
                    </MudStack>
                }
                <QueueTable Items="@_pendingItems" 
                            OnRetry="@RetryDownload" 
                            OnDelete="@DeleteDownload"
                            EnableBulkActions="true"
                            @bind-SelectedItems="@_selectedPending"
                            OnBulkDelete="@BulkDeleteItems"
                            OnBulkPriorityChange="@BulkChangePriority" />
            </MudTabPanel>
            
            <!-- Processing Tab -->
            <MudTabPanel Text="Processing" Icon="@Icons.Material.Outlined.Downloading" BadgeData="@_processingItems.Count" BadgeColor="Color.Info">
                <QueueTable Items="@_processingItems" OnRetry="@RetryDownload" OnDelete="@DeleteDownload" />
            </MudTabPanel>
            
            <!-- Completed Tab -->
            <MudTabPanel Text="Completed" Icon="@Icons.Material.Outlined.CheckCircle" BadgeData="@_completedItems.Count" BadgeColor="Color.Success">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText Typo="Typo.h6">Completed Downloads</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" 
                                  Color="Color.Primary"
                                  StartIcon="@Icons.Material.Outlined.FileDownload"
                                  OnClick="@ExportCompletedList"
                                  Size="Size.Small">
                            Export
                        </MudButton>
                    </MudStack>
                </MudStack>
                <QueueTable Items="@_completedItems" 
                            OnRetry="@RetryDownload" 
                            OnDelete="@DeleteDownload"
                            EnableBulkActions="true"
                            @bind-SelectedItems="@_selectedCompleted"
                            OnBulkDelete="@BulkDeleteItems" />
            </MudTabPanel>
            
            <!-- Failed Tab -->
            <MudTabPanel Text="Failed" Icon="@Icons.Material.Outlined.Error" BadgeData="@_failedItems.Count" BadgeColor="Color.Error">
                <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
                    @_failedItems.Count failed download(s). Click "Retry All" to attempt again.
                </MudAlert>
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary"
                          StartIcon="@(_isRetryingAll ? Icons.Material.Outlined.HourglassTop : Icons.Material.Outlined.Replay)"
                          OnClick="@RetryAllFailed"
                          Class="mb-4"
                          Disabled="@(!_failedItems.Any() || _isRetryingAll)">
                    @if (_isRetryingAll)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @:Retrying...
                    }
                    else
                    {
                        @:Retry All Failed (@_failedItems.Count)
                    }
                </MudButton>
                <QueueTable Items="@_failedItems" 
                            OnRetry="@RetryDownload" 
                            OnDelete="@DeleteDownload" 
                            ShowError="true"
                            EnableBulkActions="true"
                            @bind-SelectedItems="@_selectedFailed"
                            OnBulkDelete="@BulkDeleteItems" />
            </MudTabPanel>
            
            <!-- Data Transfer Tab -->
            <MudTabPanel Text="Data Transfer" Icon="@Icons.Material.Outlined.SwapHoriz">
                <MudStack Spacing="3">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Outlined.SwapHoriz" Class="mr-2" />
                                Transfer Service Status
                            </MudText>
                            <MudChip T="string" 
                                    Size="Size.Medium" 
                                    Color="@(_transferStatus.IsEnabled ? Color.Success : Color.Error)"
                                    Icon="@(_transferStatus.IsEnabled ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Cancel)">
                                @(_transferStatus.IsEnabled ? "Running" : "Stopped")
                            </MudChip>
                        </MudStack>
                        <MudGrid>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField Value="@_transferStatus.TransferIntervalMinutes.ToString()" 
                                            Label="Transfer Interval (Minutes)" 
                                            Variant="Variant.Outlined"
                                            ReadOnly="true"
                                            HelperText="Time between transfer cycles" />
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField Value="@(_transferStatus.LastTransferTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")" 
                                            Label="Last Transfer Time" 
                                            Variant="Variant.Outlined"
                                            ReadOnly="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField Value="@(_transferStatus.NextScheduledTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "N/A")" 
                                            Label="Next Scheduled" 
                                            Variant="Variant.Outlined"
                                            ReadOnly="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudButton Variant="Variant.Outlined" 
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Outlined.PlayArrow"
                                          OnClick="@TriggerManualTransfer"
                                          Disabled="@(_isLoading || !_transferStatus.IsEnabled)"
                                          Size="Size.Small"
                                          FullWidth="true">
                                    Trigger Transfer
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <MudGrid>
                        <MudItem xs="12" sm="6" md="3">
                            <StatCard Title="Pending Transfers"
                                     Value="@_transferStats.PendingTransfers.ToString()"
                                     Icon="@Icons.Material.Outlined.PendingActions"
                                     Color="@(_transferStats.PendingTransfers > 0 ? Color.Warning : Color.Success)"
                                     Trend="@(_transferStats.PendingTransfers > 0 ? "Ready to transfer" : "All transferred")" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <StatCard Title="Total Transferred"
                                     Value="@_transferStats.TotalTransferred.ToString()"
                                     Icon="@Icons.Material.Outlined.CheckCircle"
                                     Color="@Color.Success"
                                     Trend="@($"Last 24h: {_transferStats.TransferredLast24h}")" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <StatCard Title="Transfer Rate"
                                     Value="@_transferStats.TransferRatePerHour.ToString("F1")"
                                     Icon="@Icons.Material.Outlined.Speed"
                                     Color="@Color.Info"
                                     Trend="per hour" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <StatCard Title="Failed Transfers"
                                     Value="@_transferStats.FailedTransfers.ToString()"
                                     Icon="@Icons.Material.Outlined.Error"
                                     Color="@(_transferStats.FailedTransfers > 0 ? Color.Error : Color.Success)"
                                     Trend="@(_transferStats.FailedTransfers > 0 ? "Review required" : "All successful")" />
                        </MudItem>
                    </MudGrid>

                    <MudPaper Elevation="1" Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudText Typo="Typo.h6">Transfer History</MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudDatePicker Date="@_transferDateFrom" 
                                              Label="From Date" 
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Style="width: 150px;"
                                              DateChanged="@(async (DateTime? d) => { _transferDateFrom = d; await LoadTransferHistory(); })" />
                                <MudDatePicker Date="@_transferDateTo" 
                                              Label="To Date" 
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Style="width: 150px;"
                                              DateChanged="@(async (DateTime? d) => { _transferDateTo = d; await LoadTransferHistory(); })" />
                                <MudButton Variant="Variant.Outlined" 
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Outlined.Refresh"
                                          OnClick="@LoadTransferHistory"
                                          Disabled="@_isLoading"
                                          Size="Size.Small">
                                    Refresh
                                </MudButton>
                            </MudStack>
                        </MudStack>
                        <MudTable Items="@_transferHistory" 
                                  Hover="true" 
                                  Striped="true"
                                  Loading="@_isLoading"
                                  LoadingProgressColor="Color.Info">
                            <HeaderContent>
                                <MudTh>Container</MudTh>
                                <MudTh>Declaration</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Transferred At</MudTh>
                                <MudTh>Clearance Type</MudTh>
                                <MudTh>Type</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Container">@context.ContainerNumber</MudTd>
                                <MudTd DataLabel="Declaration">@context.DeclarationNumber</MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" 
                                            Size="Size.Small" 
                                            Color="@(context.Status == "Transferred" ? Color.Success : Color.Error)"
                                            Variant="Variant.Filled">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Transferred At">@context.TransferredAt.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                                <MudTd DataLabel="Clearance Type">@context.ClearanceType</MudTd>
                                <MudTd DataLabel="Type">
                                    <MudChip T="string" 
                                            Size="Size.Small" 
                                            Color="@(context.IsConsolidated ? Color.Primary : Color.Secondary)"
                                            Variant="Variant.Outlined">
                                        @(context.IsConsolidated ? "Consolidated" : "Non-Consolidated")
                                    </MudChip>
                                </MudTd>
                                @if (!string.IsNullOrEmpty(context.ErrorMessage))
                                {
                                    <MudTd ColSpan="6">
                                        <MudAlert Severity="Severity.Error" Dense="true">
                                            <MudText Typo="Typo.caption">Error: @context.ErrorMessage</MudText>
                                        </MudAlert>
                                    </MudTd>
                                }
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudPaper>
                </MudStack>
            </MudTabPanel>
            
            <!-- Archive Tab -->
            <MudTabPanel Text="Archive" Icon="@Icons.Material.Outlined.Archive" BadgeData="@_archiveStats.TotalArchived" BadgeColor="Color.Secondary">
                <MudPaper Elevation="0" Class="mb-4 pa-4" Style="background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h6">Archived Items</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @_archiveStats.TotalArchived items archived (@_archiveStats.Failed failed, @_archiveStats.Completed completed)
                            </MudText>
                        </div>
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" 
                                      Color="Color.Primary"
                                      StartIcon="@Icons.Material.Outlined.Replay"
                                      OnClick="@ShowRequeueFromArchiveDialog"
                                      Disabled="@(_archiveStats.TotalArchived == 0)">
                                Requeue from Archive
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" 
                                      Color="Color.Info"
                                      StartIcon="@Icons.Material.Outlined.Refresh"
                                      OnClick="@LoadArchiveStats">
                                Refresh Stats
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
                
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    <MudText Typo="Typo.body2">
                        <strong>Archive Information:</strong><br/>
                        Failed items: Containers that exceeded max retry attempts<br/>
                        Completed items: Old downloads archived for cleanup<br/>
                        Use "Requeue from Archive" to retry failed containers
                    </MudText>
                </MudAlert>
                
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.h6" Color="Color.Error" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Error" /> Failed Downloads
                            </MudText>
                            <MudText Typo="Typo.h4">@_archiveStats.Failed</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Containers that could not be downloaded from ICUMS
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.h6" Color="Color.Success" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" /> Old Completed
                            </MudText>
                            <MudText Typo="Typo.h4">@_archiveStats.Completed</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Successfully completed downloads (archived for cleanup)
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Activity Log Tab -->
            <MudTabPanel Text="Activity Log" Icon="@Icons.Material.Outlined.History">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText Typo="Typo.h6">Download Queue Activity Log</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudSelect T="string"
                                  Value="@_logLevelFilter" 
                                  Label="Log Level" 
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  Style="width: 150px;"
                                  ValueChanged="@(async (string? s) => { _logLevelFilter = s; await LoadActivityLogs(); })">
                            <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@("Info")">Info</MudSelectItem>
                            <MudSelectItem Value="@("Warning")">Warning</MudSelectItem>
                            <MudSelectItem Value="@("Error")">Error</MudSelectItem>
                        </MudSelect>
                        <MudDatePicker Date="@_logDateFrom" 
                                      Label="From Date" 
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Style="width: 150px;"
                                      DateChanged="@(async (DateTime? d) => { _logDateFrom = d; await LoadActivityLogs(); })" />
                        <MudDatePicker Date="@_logDateTo" 
                                      Label="To Date" 
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Style="width: 150px;"
                                      DateChanged="@(async (DateTime? d) => { _logDateTo = d; await LoadActivityLogs(); })" />
                    </MudStack>
                </MudStack>
                
                <MudTable Items="@_activityLogs" 
                          Hover="true" 
                          Striped="true"
                          Loading="@_isLoading"
                          LoadingProgressColor="Color.Info"
                          SortMode="SortMode.Multiple">
                    <HeaderContent>
                        <MudTh>Timestamp</MudTh>
                        <MudTh>Level</MudTh>
                        <MudTh>Message</MudTh>
                        <MudTh>Details</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Timestamp">
                            <MudText>@context.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Level">
                            <MudChip T="string" 
                                    Size="Size.Small" 
                                    Color="@GetLogLevelColor(context.Level)"
                                    Variant="Variant.Filled">
                                @context.Level
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Message">
                            <MudText>@context.Message</MudText>
                        </MudTd>
                        <MudTd DataLabel="Details">
                            @if (!string.IsNullOrEmpty(context.Details))
                            {
                                <MudIconButton Icon="@Icons.Material.Outlined.Info" 
                                             Size="Size.Small"
                                             Color="Color.Info"
                                             OnClick="@(() => ShowLogDetails(context))" />
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100, 200 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            
        </MudTabs>
    </MudPaper>
    
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Home", "/", icon: Icons.Material.Outlined.Home),
        new BreadcrumbItem("ICUMS", "/icums", icon: Icons.Material.Outlined.Cloud),
        new BreadcrumbItem("Individual Download Management", "/icums/individual-download", icon: Icons.Material.Outlined.Download)
    };
    
    // Quick Enqueue
    private string _enqueueContainerNumber = "";
    private int _enqueuePriority = 2;
    private bool _isEnqueuing = false;
    private string _enqueueStatus = "";
    private Severity _enqueueStatusSeverity = Severity.Info;
    
    // Queue Stats
    private QueueStatsDto _queueStats = new();
    
    // Archive
    private ArchiveStatsDto _archiveStats = new();
    
    // Queue Items
    private List<DownloadQueueItem> _queueItems = new();
    private List<DownloadQueueItem> _pendingItems => _queueItems.Where(x => x.Status == "Pending").ToList();
    private List<DownloadQueueItem> _processingItems => _queueItems.Where(x => x.Status == "Processing").ToList();
