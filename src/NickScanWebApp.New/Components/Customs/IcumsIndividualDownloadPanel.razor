    // --- Enqueue ---
    
    private async Task OnEnqueueKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_enqueueContainerNumber))
        {
            await EnqueueContainer();
        }
    }
    
    private async Task EnqueueContainer()
    {
        if (string.IsNullOrWhiteSpace(_enqueueContainerNumber)) return;
        
        _isEnqueuing = true;
        _enqueueStatus = "";
        try
        {
            var request = new
            {
                containerNumber = _enqueueContainerNumber.Trim().ToUpper(),
                priority = _enqueuePriority,
                requestedBy = "Manual"
            };
            
            var response = await DownloadQueueClient.EnqueueAsync<EnqueueResponseDto>(request);
            
            if (response != null)
            {
                _enqueueStatus = response.Message;
                _enqueueStatusSeverity = response.Message.Contains("queued") ? Severity.Success : Severity.Info;
                Snackbar.Add(response.Message, _enqueueStatusSeverity == Severity.Success ? Severity.Success : Severity.Info);
                _enqueueContainerNumber = "";
                await LoadQueueData();
                await LoadStatistics();
            }
        }
        catch (Exception ex)
        {
            _enqueueStatus = $"Error: {ex.Message}";
            _enqueueStatusSeverity = Severity.Error;
            Snackbar.Add($"Error enqueuing container: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isEnqueuing = false;
        }
    }
    
    private async Task ShowBulkEnqueueDialog()
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Bulk Enqueue Containers",
            ["ContentText"] = "Enter container numbers (one per line):"
        };
        
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<BulkEnqueueDialog>("Bulk Enqueue Containers", parameters, options);
        var result = await dialog.Result;
        
        if (!result.Canceled && result.Data is List<string> containers)
        {
            int successCount = 0;
            int failCount = 0;
            
            foreach (var container in containers.Where(c => !string.IsNullOrWhiteSpace(c)))
            {
                try
                {
                    var request = new
                    {
                        containerNumber = container.Trim().ToUpper(),
                        priority = _enqueuePriority,
                        requestedBy = "Manual-Bulk"
                    };
                    await DownloadQueueClient.EnqueueAsync<EnqueueResponseDto>(request);
                    successCount++;
                }
                catch
                {
                    failCount++;
                }
            }
            
            Snackbar.Add($"Enqueued {successCount} of {containers.Count} containers" + (failCount > 0 ? $" ({failCount} failed)" : ""), 
                failCount > 0 ? Severity.Warning : Severity.Success);
            await LoadQueueData();
            await LoadStatistics();
        }
    }
    
