    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
        
        _refreshTimer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadQueueData();
            await LoadStatistics();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }
    
    private async Task LoadAllData()
    {
        _isLoading = true;
        try
        {
            await Task.WhenAll(
                LoadQueueData(),
                LoadStatistics(),
                LoadArchiveStats(),
                LoadTransferStatus(),
                LoadTransferStatistics(),
                LoadTransferHistory(),
                LoadActivityLogs()
            );
        }
        finally
        {
            _isLoading = false;
        }
    }
    
