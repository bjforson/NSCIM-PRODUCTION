    // --- Export ---
    
    private async Task ExportCompletedList()
    {
        try
        {
            var csv = "ContainerNumber,Status,Priority,QueuedAt,ProcessedAt,RetryCount,Source\n";
            foreach (var item in _completedItems)
            {
                csv += $"{item.ContainerNumber},{item.Status},{item.Priority},{item.QueuedAt:yyyy-MM-dd HH:mm:ss},{item.ProcessedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? ""},{item.RetryCount},{item.Source ?? ""}\n";
            }
            
            var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"individual-downloads-completed-{DateTime.Now:yyyyMMddHHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("eval", $"var blob = new Blob([atob('{base64}')], {{type: 'text/csv'}}); var url = window.URL.createObjectURL(blob); var a = document.createElement('a'); a.href = url; a.download = '{fileName}'; a.click(); window.URL.revokeObjectURL(url);");
            Snackbar.Add("Completed list exported", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting: {ex.Message}", Severity.Error);
        }
    }
    
