@using MudBlazor
@using NickScanWebApp.Shared.Services
@inject ImageProcessingClient ImageProcessingClient
@inject ISnackbar Snackbar
@inject ILogger<ImageProcessingPanel> Logger


<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Outlined.Image" Class="mr-2" />
        Image Processing Management
    </MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary" @bind-ActivePanelIndex="activeTab">
        <!-- Image Search Tab -->
        <MudTabPanel Text="Image Search" Icon="@Icons.Material.Outlined.Search">
            <MudStack Spacing="3">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="@_searchContainerNumber" 
                                     Label="Container Number" 
                                     Variant="Variant.Outlined"
                                     Placeholder="Filter by container..." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="@_searchScannerType" Label="Scanner Type" Variant="Variant.Outlined">
                            <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@("FS6000")">FS6000</MudSelectItem>
                            <MudSelectItem Value="@("ASE")">ASE</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchImages" StartIcon="@Icons.Material.Outlined.Search">
                    Search Images
                </MudButton>
                @if (_imageResults != null && _imageResults.Any())
                {
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.h6" Class="mb-4">Search Results (@_imageResults.Count)</MudText>
                        <MudTable Items="@_imageResults" Hover="true" Dense="true" Context="image">
                            <HeaderContent>
                                <MudTh>Container</MudTh>
                                <MudTh>Scanner</MudTh>
                                <MudTh>Image Type</MudTh>
                                <MudTh>Created</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Container">@(image.ContainerNumber ?? "")</MudTd>
                                <MudTd DataLabel="Scanner">@(image.ScannerType ?? "")</MudTd>
                                <MudTd DataLabel="Image Type">@(image.ImageType ?? "")</MudTd>
                                <MudTd DataLabel="Created">@FormatDateTime(image.CreatedAt)</MudTd>
                                <MudTd DataLabel="Actions">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => ViewImage(image.Id))">
                                        View
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }
            </MudStack>
        </MudTabPanel>

        <!-- Processing Statistics Tab -->
        <MudTabPanel Text="Statistics" Icon="@Icons.Material.Outlined.BarChart">
            @if (_statistics != null)
            {
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Images</MudText>
                            <MudText Typo="Typo.h5">@(_statistics.TotalImages?.ToString("N0") ?? "0")</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Processed Images</MudText>
                            <MudText Typo="Typo.h5">@(_statistics.ProcessedImages?.ToString("N0") ?? "0")</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pending Images</MudText>
                            <MudText Typo="Typo.h5">@(_statistics.PendingImages?.ToString("N0") ?? "0")</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Success Rate</MudText>
                            <MudText Typo="Typo.h5">@(_statistics.ProcessingSuccessRate?.ToString("F1") ?? "0")%</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadStatistics" Class="mt-4">
                Refresh Statistics
            </MudButton>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private int activeTab = 0;
    private string _searchContainerNumber = "";
    private string? _searchScannerType;
    private List<ImageDetailDto>? _imageResults;
    private ImageProcessingStatsDto? _statistics;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task SearchImages()
    {
        try
        {
            var response = await ImageProcessingClient.SearchImagesAsync(_searchContainerNumber, _searchScannerType);
            _imageResults = response?.Images;
            Snackbar.Add($"Found {_imageResults?.Count ?? 0} images", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching images");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadStatistics()
    {
        try
        {
            _statistics = await ImageProcessingClient.GetStatisticsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading statistics");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void ViewImage(int imageId)
    {
        // Navigate to image viewer
        // Implementation depends on your image viewer route
    }

    private string FormatDateTime(DateTime? dateTime)
    {
        if (dateTime == null) return "N/A";
        return dateTime.Value.ToString("yyyy-MM-dd HH:mm:ss");
    }
}

