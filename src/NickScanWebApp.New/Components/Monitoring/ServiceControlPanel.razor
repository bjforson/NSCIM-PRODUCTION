    private Dictionary<string, List<ServiceInfo>> GetServicesByCategory()
    {
        return _services
            .Where(s => !s.IsDeprecated)
            .GroupBy(s => s.Category)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private Dictionary<int, List<ServiceInfo>> GetServicesByStartupPhase()
    {
        return _services
            .Where(s => !s.IsDeprecated && s.StartupPhase > 0)
            .GroupBy(s => s.StartupPhase)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

