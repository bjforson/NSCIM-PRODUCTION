@using Microsoft.Extensions.Configuration
@using NickScanCentralImagingPortal.Core.Constants
@using MudBlazor
@using System.Timers
@implements IDisposable
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Outlined.Settings" Class="mr-2" />
        Service Control Panel
    </MudText>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        <MudText>
            Real-time monitoring and configuration of all background services. 
            Health checks are performed by ComprehensiveHealthCheckService every 5 minutes.
        </MudText>
    </MudAlert>

    <!-- Summary Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h6">Total Services</MudText>
                    <MudText Typo="Typo.h3" Color="Color.Primary">@_systemServices.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Registered</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h6">Running</MudText>
                    <MudText Typo="Typo.h3" Color="Color.Success">@_systemServices.Count(s => s.Status == "Running")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Active Services</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h6">Stopped</MudText>
                    <MudText Typo="Typo.h3" Color="Color.Default">@_systemServices.Count(s => s.Status == "Stopped")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Inactive Services</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h6">Failed</MudText>
                    <MudText Typo="Typo.h3" Color="Color.Error">@_systemServices.Count(s => s.Status == "Failed")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Requires Attention</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Services Table -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Background Services</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton StartIcon="@Icons.Material.Outlined.Refresh" 
                           Color="Color.Primary" 
                           Variant="Variant.Filled"
                           OnClick="LoadServices">
                    Refresh
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Settings" 
                           Color="Color.Secondary" 
                           Variant="Variant.Outlined"
                           Href="/admin/settings"
                           Class="ml-2">
                    Edit Config
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudTable Items="@_services" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh>Service</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Interval</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Dependencies</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Service">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@GetServiceIcon(context.Name)" 
                                     Color="@GetServiceIconColor(context)" />
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                    @context.Name
                                </MudText>
                                @if (context.IsDeprecated)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2">
                                        DEPRECATED
                                    </MudChip>
                                }
                            </div>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @{
                            var systemService = _systemServices.FirstOrDefault(s => s.Name == context.Name);
                            var status = systemService?.Status ?? (context.Enabled ? "Running" : "Stopped");
                        }
                        <MudChip T="string" Color="@GetStatusColor(status)" Size="Size.Small">
                            <MudIcon Icon="@GetStatusIcon(status)" Size="Size.Small" Class="mr-1" />
                            @status
                        </MudChip>
                        @if (systemService?.Uptime.HasValue == true && status == "Running")
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                Uptime: @FormatTimeSpan(systemService.Uptime.Value)
                            </MudText>
                        }
                        @if (!string.IsNullOrEmpty(systemService?.LastError))
                        {
                            <MudTooltip Text="@systemService.LastError">
                                <MudIcon Icon="@Icons.Material.Outlined.Error" Size="Size.Small" Color="Color.Error" Class="ml-1" />
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Interval">
                        @if (!string.IsNullOrEmpty(context.Interval))
                        {
                            <MudText Typo="Typo.body2">@context.Interval</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">N/A</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Description">
                        <MudText Typo="Typo.body2" Style="max-width: 400px;">
                            @context.Description
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Dependencies">
                        @if (context.Dependencies.Any())
                        {
                            <MudStack Row="true" Spacing="1">
                                @foreach (var dep in context.Dependencies.Take(2))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@dep</MudChip>
                                }
                                @if (context.Dependencies.Count > 2)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                        +@(context.Dependencies.Count - 2)
                                    </MudChip>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        @{
                            var systemService = _systemServices.FirstOrDefault(s => s.Name == context.Name);
                            var serviceStatus = systemService?.Status ?? (context.Enabled ? "Running" : "Stopped");
                            var isTransitioning = IsServiceTransitioning(context.Name);
                        }
                        <MudStack Row="true" Spacing="1">
                            @if (serviceStatus == "Running")
                            {
                                <MudButton Size="Size.Small" 
                                         Color="Color.Warning"
                                         Variant="Variant.Outlined"
                                         StartIcon="@Icons.Material.Outlined.Stop"
                                         OnClick="@(() => StopService(context.Name))"
                                         Disabled="@isTransitioning">
                                    Stop
                                </MudButton>
                                <MudButton Size="Size.Small" 
                                         Color="Color.Primary"
                                         Variant="Variant.Outlined"
                                         StartIcon="@Icons.Material.Outlined.Refresh"
                                         OnClick="@(() => RestartService(context.Name))"
                                         Disabled="@isTransitioning">
                                    Restart
                                </MudButton>
                            }
                            else if (serviceStatus == "Stopped")
                            {
                                <MudButton Size="Size.Small" 
                                         Color="Color.Success"
                                         Variant="Variant.Outlined"
                                         StartIcon="@Icons.Material.Outlined.PlayArrow"
                                         OnClick="@(() => StartService(context.Name))"
                                         Disabled="@isTransitioning">
                                    Start
                                </MudButton>
                            }
                            else if (serviceStatus == "Failed")
                            {
                                <MudButton Size="Size.Small" 
                                         Color="Color.Error"
                                         Variant="Variant.Outlined"
                                         StartIcon="@Icons.Material.Outlined.Refresh"
                                         OnClick="@(() => RestartService(context.Name))">
                                    Retry
                                </MudButton>
                            }
                            else if (isTransitioning)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <MudText Typo="Typo.body2">@serviceStatus...</MudText>
                            }
                            <MudButton Size="Size.Small" 
                                     Color="Color.Default"
                                     Variant="Variant.Text"
                                     OnClick="@(() => ViewServiceDetails(context))">
                                Details
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>

    <!-- Service Details Dialog -->
    <MudDialog @bind-Visible="_showDetailsDialog" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@GetServiceIcon(_selectedService?.Name ?? "")" Class="mr-2" />
                @_selectedService?.Name
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (_selectedService != null)
            {
                <MudGrid>
                    <MudItem xs="12">
                        @{
                            var selectedSystemService = _systemServices.FirstOrDefault(s => s.Name == _selectedService?.Name);
                            var selectedStatus = selectedSystemService?.Status ?? (_selectedService?.Enabled == true ? "Running" : "Stopped");
                        }
                        <MudAlert Severity="@(selectedStatus == "Running" ? Severity.Success : selectedStatus == "Failed" ? Severity.Error : Severity.Warning)">
                            Service is currently <strong>@selectedStatus</strong>
                            @if (selectedSystemService?.Uptime.HasValue == true && selectedStatus == "Running")
                            {
                                <span> - Uptime: @FormatTimeSpan(selectedSystemService.Uptime.Value)</span>
                            }
                        </MudAlert>
                    </MudItem>

                    @if (_selectedService.IsDeprecated)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Error">
                                <strong>DEPRECATED:</strong> This service is deprecated and should remain disabled.
                            </MudAlert>
                        </MudItem>
                    }

                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Service Status</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudStack Spacing="2">
                                @{
                                    var selectedSystemService = _systemServices.FirstOrDefault(s => s.Name == _selectedService?.Name);
                                }
                                <MudText Typo="Typo.body2">
                                    <strong>Current Status:</strong>
                                    <MudChip T="string" Color="@GetStatusColor(selectedSystemService?.Status ?? "Unknown")" Size="Size.Small" Class="ml-2">
                                        @(selectedSystemService?.Status ?? "Unknown")
                                    </MudChip>
                                </MudText>
                                @if (selectedSystemService?.Uptime.HasValue == true)
                                {
                                    <MudText Typo="Typo.body2">
                                        <strong>Uptime:</strong> @FormatTimeSpan(selectedSystemService.Uptime.Value)
                                    </MudText>
                                }
                                @if (selectedSystemService?.LastRestart.HasValue == true)
                                {
                                    <MudText Typo="Typo.body2">
                                        <strong>Last Restart:</strong> @selectedSystemService.LastRestart.Value.ToString("yyyy-MM-dd HH:mm:ss")
                                    </MudText>
                                }
                                <MudText Typo="Typo.body2">
                                    <strong>Health Status:</strong>
                                    <MudChip T="string" Color="@GetHealthColor(selectedSystemService?.HealthStatus)" Size="Size.Small" Class="ml-2">
                                        @(selectedSystemService?.HealthStatus ?? "Unknown")
                                    </MudChip>
                                </MudText>
                                @if (!string.IsNullOrEmpty(selectedSystemService?.LastError))
                                {
                                    <MudAlert Severity="Severity.Error" Class="mt-2">
                                        <strong>Last Error:</strong> @selectedSystemService.LastError
                                    </MudAlert>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Configuration</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.body2">
                                    <strong>Enabled:</strong> @_selectedService.Enabled
                                </MudText>
                                @if (!string.IsNullOrEmpty(_selectedService.Interval))
                                {
                                    <MudText Typo="Typo.body2">
                                        <strong>Interval:</strong> @_selectedService.Interval
                                    </MudText>
                                }
                                <MudText Typo="Typo.body2">
                                    <strong>Category:</strong> @_selectedService.Category
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    <strong>Startup Order:</strong> Phase @_selectedService.StartupPhase
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Service Actions</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudStack Row="true" Spacing="2">
                                @{
                                    var selectedSystemServiceForActions = _systemServices.FirstOrDefault(s => s.Name == _selectedService?.Name);
                                    var selectedStatusForActions = selectedSystemServiceForActions?.Status ?? (_selectedService?.Enabled == true ? "Running" : "Stopped");
                                }
                                @if (selectedStatusForActions == "Running")
                                {
                                    <MudButton Color="Color.Warning" Variant="Variant.Outlined"
                                             StartIcon="@Icons.Material.Outlined.Stop"
                                             OnClick="@(() => StopService(_selectedService.Name))">
                                        Stop Service
                                    </MudButton>
                                    <MudButton Color="Color.Primary" Variant="Variant.Outlined"
                                             StartIcon="@Icons.Material.Outlined.Refresh"
                                             OnClick="@(() => RestartService(_selectedService.Name))">
                                        Restart Service
                                    </MudButton>
                                }
                                else if (selectedStatusForActions == "Stopped")
                                {
                                    <MudButton Color="Color.Success" Variant="Variant.Outlined"
                                             StartIcon="@Icons.Material.Outlined.PlayArrow"
                                             OnClick="@(() => StartService(_selectedService.Name))">
                                        Start Service
                                    </MudButton>
                                }
                                else if (selectedStatusForActions == "Failed")
                                {
                                    <MudButton Color="Color.Error" Variant="Variant.Outlined"
                                             StartIcon="@Icons.Material.Outlined.Refresh"
                                             OnClick="@(() => RestartService(_selectedService.Name))">
                                        Retry Service
                                    </MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Dependencies</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            @if (_selectedService.Dependencies.Any())
                            {
                                <MudStack Spacing="1">
                                    @foreach (var dep in _selectedService.Dependencies)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@dep</MudChip>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    No dependencies - service is independent
                                </MudText>
                            }
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Description</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.body2">@_selectedService.Description</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Configuration Path</MudText>
                        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.body2" Style="font-family: monospace;">
                                BackgroundServices:@_selectedService.Name
                            </MudText>
                        </MudPaper>
                    </MudItem>

                    @if (!string.IsNullOrEmpty(_selectedService.DatabaseDependencies))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Database Dependencies</MudText>
                            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.body2">@_selectedService.DatabaseDependencies</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CloseDetailsDialog">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <!-- Service Architecture Diagram -->
    <MudCard Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Service Architecture</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" @bind-ActivePanelIndex="_activeTab">
                <MudTabPanel Text="By Category">
                    <MudGrid>
                        @foreach (var category in GetServicesByCategory())
                        {
                            <MudItem xs="12" md="6" lg="4">
                                <MudPaper Class="pa-4" Elevation="2">
                                    <MudText Typo="Typo.h6" Class="mb-2">@category.Key</MudText>
                                    <MudStack Spacing="1">
                                        @foreach (var service in category.Value)
                                        {
                                            <MudChip T="string" 
                                                     Size="Size.Small" 
                                                     Color="@(service.Enabled ? Color.Success : Color.Default)">
                                                @service.Name
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Startup Order">
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var phase in GetServicesByStartupPhase())
                        {
                            <MudTimelineItem Color="Color.Primary">
                                <ItemOpposite>
                                    <MudText Color="Color.Primary" Typo="Typo.h6">Phase @phase.Key</MudText>
                                </ItemOpposite>
                                <ItemContent>
                                    <MudStack Spacing="2">
                                        @foreach (var service in phase.Value)
                                        {
                                            <MudPaper Class="pa-3" Elevation="1">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                    <div>
                                                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                                            @service.Name
                                                        </MudText>
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                            @service.Category
                                                        </MudText>
                                                    </div>
                                                    <MudChip T="string" 
                                                             Size="Size.Small" 
                                                             Color="@(service.Enabled ? Color.Success : Color.Default)">
                                                        @(service.Enabled ? "Enabled" : "Disabled")
                                                    </MudChip>
                                                </MudStack>
                                            </MudPaper>
                                        }
                                    </MudStack>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                </MudTabPanel>
                <MudTabPanel Text="Dependencies">
                </MudTabPanel>
                
                <!-- System Administration Tab -->
                <MudTabPanel Text="System Admin" Icon="@Icons.Material.Outlined.AdminPanelSettings">
                    <MudStack Spacing="3">
                        <!-- System Information -->
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Outlined.Computer" Class="mr-2" />
                                    System Information
                                </MudText>
                                <MudButton Variant="Variant.Outlined" 
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Outlined.Refresh"
                                          OnClick="LoadSystemInfo"
                                          Disabled="@_isLoadingSystem">
                                    Refresh
                                </MudButton>
                            </MudStack>
                            @if (_systemInfo != null)
                            {
                                <MudGrid>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Machine Name</MudText>
                                        <MudText Typo="Typo.body1">@_systemInfo.MachineName</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">OS Version</MudText>
                                        <MudText Typo="Typo.body1">@_systemInfo.OSVersion</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">.NET Version</MudText>
                                        <MudText Typo="Typo.body1">@_systemInfo.DotNetVersion</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Processor Count</MudText>
                                        <MudText Typo="Typo.body1">@_systemInfo.ProcessorCount</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Working Set Memory</MudText>
                                        <MudText Typo="Typo.body1">@_systemInfo.WorkingSetMemoryMB MB</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Uptime</MudText>
                                        <MudText Typo="Typo.body1">@FormatTimeSpan(_systemInfo.Uptime)</MudText>
                                    </MudItem>
                                </MudGrid>
                            }
                        </MudPaper>

                        <!-- Performance Metrics -->
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Outlined.Speed" Class="mr-2" />
                                    Performance Metrics
                                </MudText>
                                <MudButton Variant="Variant.Outlined" 
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Outlined.Refresh"
                                          OnClick="LoadPerformanceMetrics"
                                          Disabled="@_isLoadingSystem">
                                    Refresh
                                </MudButton>
                            </MudStack>
                            @if (_performanceMetrics != null)
                            {
                                <MudGrid>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudCard>
                                            <MudCardContent>
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">CPU Usage</MudText>
                                                    <MudText Typo="Typo.h5" Color="@GetCpuColor(_performanceMetrics.CpuUsagePercent)">
                                                        @_performanceMetrics.CpuUsagePercent.ToString("F1")%
                                                    </MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudCard>
                                            <MudCardContent>
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Memory Usage</MudText>
                                                    <MudText Typo="Typo.h5">@_performanceMetrics.MemoryUsageMB MB</MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudCard>
                                            <MudCardContent>
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Threads</MudText>
                                                    <MudText Typo="Typo.h5">@_performanceMetrics.ThreadCount</MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudCard>
                                            <MudCardContent>
                                                <MudStack Spacing="1">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">GC Memory</MudText>
                                                    <MudText Typo="Typo.h5">@_performanceMetrics.GCTotalMemoryMB MB</MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                </MudGrid>
                            }
                        </MudPaper>

                        <!-- Service Management -->
                        <MudPaper Elevation="1" Class="pa-4">
