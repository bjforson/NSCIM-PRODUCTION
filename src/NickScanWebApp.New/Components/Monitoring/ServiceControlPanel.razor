    private async Task RestartService(string serviceName)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Restart Service",
            $"Are you sure you want to restart {serviceName}? This may cause a brief interruption.",
            yesText: "Yes", cancelText: "Cancel");
        
        if (confirmed != true) return;

        _transitioningServices.Add(serviceName);
        var systemService = _systemServices.FirstOrDefault(s => s.Name == serviceName);
        
        try
        {
            // Update UI immediately
            if (systemService != null) systemService.Status = "Restarting";
            StateHasChanged();
            
            var result = await ApiService.PostAsync<object, ServiceRestartResponse>(
                $"/api/SystemAdmin/service/{Uri.EscapeDataString(serviceName)}/restart", 
                new { });
            
            Snackbar.Add($"✅ {serviceName} restart initiated", Severity.Info);
            
            // Poll for status update (max 30 seconds)
            await PollServiceStatus(serviceName, maxAttempts: 30);
            
            Snackbar.Add($"✅ {serviceName} restarted successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            if (systemService != null) systemService.Status = "Failed";
            Snackbar.Add($"❌ Error restarting {serviceName}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _transitioningServices.Remove(serviceName);
            await LoadSystemInfo(); // Refresh all services
        }
    }

    private async Task StopService(string serviceName)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Stop Service",
            $"Are you sure you want to stop {serviceName}? This will halt all processing.",
            yesText: "Yes", cancelText: "Cancel");
        
        if (confirmed != true) return;

        _transitioningServices.Add(serviceName);
        var systemService = _systemServices.FirstOrDefault(s => s.Name == serviceName);
        
        try
        {
            if (systemService != null) systemService.Status = "Stopping";
            StateHasChanged();
            
            await ApiService.PostAsync<object, object>($"/api/SystemAdmin/service/{Uri.EscapeDataString(serviceName)}/stop", new { });
            
            Snackbar.Add($"✅ {serviceName} stop initiated", Severity.Info);
            await Task.Delay(2000); // Brief delay
            await LoadSystemInfo();
            Snackbar.Add($"✅ {serviceName} stopped successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            if (systemService != null) systemService.Status = "Failed";
            Snackbar.Add($"❌ Error stopping {serviceName}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _transitioningServices.Remove(serviceName);
        }
    }

    private async Task StartService(string serviceName)
    {
        _transitioningServices.Add(serviceName);
        var systemService = _systemServices.FirstOrDefault(s => s.Name == serviceName);
        
        try
        {
            if (systemService != null) systemService.Status = "Starting";
            StateHasChanged();
            
            await ApiService.PostAsync<object, object>($"/api/SystemAdmin/service/{Uri.EscapeDataString(serviceName)}/start", new { });
            
            Snackbar.Add($"✅ {serviceName} start initiated", Severity.Info);
            await Task.Delay(2000); // Brief delay
            await LoadSystemInfo();
            Snackbar.Add($"✅ {serviceName} started successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            if (systemService != null) systemService.Status = "Failed";
            Snackbar.Add($"❌ Error starting {serviceName}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _transitioningServices.Remove(serviceName);
        }
    }

    private async Task PollServiceStatus(string serviceName, int maxAttempts = 30)
    {
        for (int i = 0; i < maxAttempts; i++)
        {
            await Task.Delay(1000); // Wait 1 second between polls
            
            var services = await ApiService.GetAsync<List<SystemServiceInfoDto>>("/api/SystemAdmin/services");
            var service = services?.FirstOrDefault(s => s.Name == serviceName);
            
            if (service != null && service.Status == "Running")
            {
                return; // Service is running
            }
            
            if (service != null && service.Status == "Failed")
            {
                throw new Exception("Service failed to start");
            }
            
            // Update UI with current status
            var currentService = _systemServices.FirstOrDefault(s => s.Name == serviceName);
            if (currentService != null && service != null)
            {
                currentService.Status = service.Status;
                await InvokeAsync(StateHasChanged);
            }
        }
        
        throw new Exception("Service restart timeout - status unknown");
    }

    private bool IsServiceTransitioning(string serviceName)
    {
        return _transitioningServices.Contains(serviceName);
    }

