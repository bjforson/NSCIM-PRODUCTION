@* StatCard Component - Colorful gradient pill cards (Logistix + Domiex style) *@

<MudPaper Elevation="0"
          Class="@($"stat-pill {GradientClass} {ClickableClass} {Class}")"
          Style="@GetCardStyle()"
          @onclick="HandleClick">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudAvatar Size="Size.Large"
                   Style="background: rgba(255,255,255,0.2); width: 46px; height: 46px;">
            <MudIcon Icon="@Icon" Style="color: white; font-size: 24px;" />
        </MudAvatar>
        <div style="flex: 1; min-width: 0;">
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85); font-size: 11px;">
                @Title
            </MudText>
            <MudText Typo="Typo.h5" Style="color: white; font-weight: 700; line-height: 1.1;">
                @Value
            </MudText>
            @if (!string.IsNullOrEmpty(SubText))
            {
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.65); font-size: 10px; margin-top: 2px;">
                    @SubText
                </MudText>
            }
        </div>
        @if (!string.IsNullOrEmpty(Trend))
        {
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.9); font-weight: 600; font-size: 12px;">
                <MudIcon Icon="@GetTrendIcon()" Size="Size.Small" Style="color: rgba(255,255,255,0.9);" />
                @Trend
            </MudText>
        }
    </MudStack>

    @if (ChildContent != null)
    {
        <div class="mt-3">
            @ChildContent
        </div>
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.Info;
    [Parameter] public Color IconColor { get; set; } = Color.Primary;
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public string? Trend { get; set; }
    [Parameter] public string? TrendDirection { get; set; }
    [Parameter] public string? SubText { get; set; }
    [Parameter] public bool Small { get; set; } = false;
    [Parameter] public int Elevation { get; set; } = 0;
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool UseGradient { get; set; } = true;
    [Parameter] public string? GradientType { get; set; } = null;
    [Parameter] public bool UseHybrid { get; set; } = false;

    /// <summary>
    /// Gradient color preset. Options: blue, red, green, orange, purple, teal, pink, indigo
    /// </summary>
    [Parameter] public string GradientColor { get; set; } = "blue";

    /// <summary>
    /// Optional URL to navigate to on click. If set, the card becomes clickable.
    /// </summary>
    [Parameter] public string? Href { get; set; }

    /// <summary>
    /// Optional click callback. Fires in addition to Href navigation.
    /// </summary>
    [Parameter] public EventCallback OnClick { get; set; }

    [Inject] private NavigationManager Nav { get; set; } = null!;

    private string GradientClass => $"stat-pill-{GradientColor}";
    private string ClickableClass => (!string.IsNullOrEmpty(Href) || OnClick.HasDelegate) ? "stat-pill-clickable" : "";

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate) { await OnClick.InvokeAsync(); }
        if (!string.IsNullOrEmpty(Href)) { Nav.NavigateTo(Href); }
    }

    private string GetCardStyle()
    {
        // If GradientType is set (legacy), use that mapping
        if (!string.IsNullOrEmpty(GradientType))
        {
            return GradientType switch
            {
                "success" => "background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%); color: white;",
                "info" => "background: linear-gradient(135deg, #4e73df 0%, #224abe 100%); color: white;",
                "warning" => "background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%); color: white;",
                "error" => "background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%); color: white;",
                "primary" => "background: linear-gradient(135deg, #4e73df 0%, #224abe 100%); color: white;",
                _ => ""
            };
        }
        return "";
    }

    private string GetTrendIcon() => TrendDirection switch
    {
        "up" => Icons.Material.Outlined.TrendingUp,
        "down" => Icons.Material.Outlined.TrendingDown,
        _ => Icons.Material.Outlined.TrendingFlat
    };
}
