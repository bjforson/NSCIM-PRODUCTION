@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject NickScanWebApp.New.Services.ApiService ApiService
@inject NickScanWebApp.Shared.Services.ContainerCompletenessClient ContainerCompletenessClient
@inject NickScanWebApp.Shared.Services.ConsolidatedCargoClient ConsolidatedCargoClient
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable


<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="@breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Header -->
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h4">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Class="mr-2" />
                    New Container Completeness Model
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Consolidated cargo model with completeness tracking by Master BL and House BL
                </MudText>
            </div>
            <MudStack Row="true" Spacing="2">
                <MudChip T="string" 
                         Size="Size.Medium" 
                         Color="Color.Info"
                         Icon="@Icons.Material.Outlined.Info">
                    @(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count) Cargo Groups
                </MudChip>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Primary" 
                          StartIcon="@Icons.Material.Outlined.Refresh"
                          OnClick="@RefreshData"
                          Disabled="@isLoadingCargoGroups">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Statistics Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Cargo Groups</MudText>
                        <MudText Typo="Typo.h4">@(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @nonConsolidatedGroupsWithCompleteness.Count Non-Consolidated, @consolidatedGroupsWithCompleteness.Count Consolidated
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Complete Groups</MudText>
                        <MudText Typo="Typo.h4" Style="color: var(--mud-palette-success);">@completeGroupsCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@completeGroupsPercentage.ToString("F1")% of total</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Partial Groups</MudText>
                        <MudText Typo="Typo.h4" Style="color: var(--mud-palette-warning);">@partialGroupsCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@partialGroupsPercentage.ToString("F1")% of total</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Incomplete Groups</MudText>
                        <MudText Typo="Typo.h4" Style="color: var(--mud-palette-error);">@incompleteGroupsCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@incompleteGroupsPercentage.ToString("F1")% of total</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    
    <!-- Main Content -->
    <MudPaper Elevation="2" Class="rounded-lg">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">
            
            <!-- Cargo Groups Tab - PRIMARY VIEW -->
            <MudTabPanel Text="Cargo Groups" Icon="@Icons.Material.Outlined.Inventory2" BadgeData="@(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count)" BadgeColor="Color.Info">
                
                <!-- Filters -->
                <MudPaper Elevation="1" Class="pa-3 mb-4">
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="string" 
                                      Label="Completeness Status" 
                                      Variant="Variant.Outlined"
                                      @bind-Value="filterCompletenessStatus"
                                      Clearable="true">
                                <MudSelectItem T="string" Value="@("All")">All Status</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Complete")">Complete</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Partial")">Partial</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Incomplete")">Incomplete</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="string" 
                                      Label="Clearance Type" 
                                      Variant="Variant.Outlined"
                                      @bind-Value="filterClearanceType"
                                      Clearable="true">
                                <MudSelectItem T="string" Value="@("All")">All Types</MudSelectItem>
                                <MudSelectItem T="string" Value="@("CMR")">CMR</MudSelectItem>
                                <MudSelectItem T="string" Value="@("IMEX")">IMEX</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField T="string" 
                                         Label="Search" 
                                         Variant="Variant.Outlined"
                                         @bind-Value="searchTerm"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Outlined.Search"
                                         Placeholder="Master BL, Declaration, Container..." />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="2">
                            <MudButton Variant="Variant.Filled" 
                                      Color="Color.Primary" 
                                      FullWidth="true"
                                      StartIcon="@Icons.Material.Outlined.FilterList"
                                      OnClick="@ApplyCargoGroupFilters">
                                Filter
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" Color="Color.Info">
                    <!-- Non-Consolidated Sub-Tab -->
                    <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Outlined.LocalShipping" BadgeData="@filteredNonConsolidatedGroups.Count" BadgeColor="Color.Primary">
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            <MudText>Non-Consolidated Cargo: One Master BL covers multiple containers. Click to expand each record and see all containers.</MudText>
                        </MudAlert>
                        
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                        }
                        
                        @if (!filteredNonConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No non-consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-4">
                            @foreach (var group in filteredNonConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Style="width: 100%;">
                                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                                <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" Class="mr-2" />
                                                @group.DeclarationNumber
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                Master BL: @group.MasterBL
                                            </MudText>
                                            <MudSpacer />
                                            <MudChip T="string" 
                                                    Size="Size.Small" 
                                                    Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                    Icon="@GetCompletenessStatusIcon(group.CompletenessStatus)">
                                                @group.CompletenessStatus
                                            </MudChip>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @group.ContainersWithData / @group.TotalContainers containers
                                            </MudText>
                                            <MudProgressLinear Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                               Value="@group.CompletionPercentage"
                                                               Min="0" Max="100"
                                                               Size="Size.Small"
                                                               Rounded="true"
                                                               Style="width: 100px;" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @group.CompletionPercentage%
                                            </MudText>
                                            @if (group.AnalysisReviewedCount > 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                         Color="@(group.AnalysisAbnormalCount > 0 ? Color.Error : Color.Success)"
                                                         Icon="@Icons.Material.Outlined.ImageSearch">
                                                    @group.AnalysisReviewedCount reviewed (@(group.AnalysisNormalCount)N @(group.AnalysisAbnormalCount)A)
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-background-grey);">
                                            <MudStack Spacing="3">
                                                <!-- Summary Info -->
                                                <MudGrid>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Consignee</MudText>
                                                        <MudText Typo="Typo.body2">@group.ConsigneeName</MudText>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Clearance Type</MudText>
                                                        <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(group.ClearanceType)">
                                                            @group.ClearanceType
                                                        </MudChip>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Containers</MudText>
                                                        <MudText Typo="Typo.body2">@group.TotalContainers</MudText>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Containers with Data</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success);">
                                                            @group.ContainersWithData
                                                        </MudText>
                                                    </MudItem>
                                                </MudGrid>
                                                
                                                <MudDivider />
                                                
                                                <!-- Containers List -->
                                                <MudText Typo="Typo.h6">Containers (@group.Containers.Count)</MudText>
                                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                                    <thead>
                                                        <tr>
                                                            <th>Container Number</th>
                                                            <th>Status</th>
                                                            <th>Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var container in group.Containers)
                                                        {
                                                            var isComplete = group.CompleteContainers.Contains(container);
                                                            var isMissing = group.MissingContainers.Contains(container);
                                                            <tr>
                                                                <td>
                                                                    <MudLink Href="@($"/containers/{container}")" Typo="Typo.body2">
                                                                        <strong>@container</strong>
                                                                    </MudLink>
                                                                </td>
                                                                <td>
                                                                    @if (isComplete)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Outlined.CheckCircle">
                                                                            Complete
                                                                        </MudChip>
                                                                    }
                                                                    else if (isMissing)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Outlined.Warning">
                                                                            Missing
                                                                        </MudChip>
                                                                    }
                                                                    else
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Outlined.Info">
                                                                            Unknown
                                                                        </MudChip>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    <MudStack Row="true" Spacing="1">
                                                                        <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                                      Size="Size.Small"
                                                                                      Color="Color.Info"
                                                                                      Href="@($"/containers/{container}")"
                                                                                      title="View container details" />
                                                                        @if (isMissing)
                                                                        {
                                                                            <MudIconButton Icon="@Icons.Material.Outlined.CloudDownload"
                                                                                          Size="Size.Small"
                                                                                          Color="Color.Primary"
                                                                                          OnClick="@(() => RequestBOE(container))"
                                                                                          title="Request BOE from ICUMS" />
                                                                        }
                                                                    </MudStack>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                    
                    <!-- Consolidated Sub-Tab -->
                    <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Outlined.Inventory" BadgeData="@filteredConsolidatedGroups.Count" BadgeColor="Color.Warning">
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            <MudText>Consolidated Cargo: One Master BL has multiple House BLs (different consignees). A Master BL can span one or multiple containers. Click to expand each record and see all House BLs.</MudText>
                        </MudAlert>
                        
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                        }
                        
                        @if (!filteredConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-4">
                            @foreach (var group in filteredConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Style="width: 100%;">
                                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                                <MudIcon Icon="@Icons.Material.Outlined.Inventory" Size="Size.Small" Class="mr-2" />
                                                @group.MasterBL
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @group.ContainerNumbers.Count container(s)
                                            </MudText>
                                            <MudSpacer />
                                            <MudChip T="string" 
                                                    Size="Size.Small" 
                                                    Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                    Icon="@GetCompletenessStatusIcon(group.CompletenessStatus)">
                                                @group.CompletenessStatus
                                            </MudChip>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @group.CompleteHouseBLs / @group.TotalHouseBLs House BLs
                                            </MudText>
                                            <MudProgressLinear Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                               Value="@group.CompletionPercentage"
                                                               Min="0" Max="100"
                                                               Size="Size.Small"
                                                               Rounded="true"
                                                               Style="width: 100px;" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @group.CompletionPercentage%
                                            </MudText>
                                            @if (group.AnalysisReviewedCount > 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                         Color="@(group.AnalysisAbnormalCount > 0 ? Color.Error : Color.Success)"
                                                         Icon="@Icons.Material.Outlined.ImageSearch">
                                                    @group.AnalysisReviewedCount reviewed (@(group.AnalysisNormalCount)N @(group.AnalysisAbnormalCount)A)
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-background-grey);">
                                            <MudStack Spacing="3">
                                                <!-- Summary Info -->
                                                <MudGrid>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Containers</MudText>
                                                        <MudStack Spacing="1">
                                                            @foreach (var container in group.ContainerNumbers.Take(5))
                                                            {
                                                                <MudLink Href="@($"/containers/{container}")" Typo="Typo.caption">
                                                                    @container
                                                                </MudLink>
                                                            }
                                                            @if (group.ContainerNumbers.Count > 5)
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    +@(group.ContainerNumbers.Count - 5) more
                                                                </MudText>
                                                            }
                                                        </MudStack>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total House BLs</MudText>
                                                        <MudText Typo="Typo.body2">@group.TotalHouseBLs</MudText>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Complete House BLs</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success);">
                                                            @group.CompleteHouseBLs
                                                        </MudText>
                                                    </MudItem>
                                                    <MudItem xs="12" md="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Clearance Type</MudText>
                                                        @if (group.HouseBLDetails.Any())
                                                        {
                                                            var clearanceType = group.HouseBLDetails.First().ClearanceType;
                                                            <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(clearanceType)">
                                                                @clearanceType
                                                            </MudChip>
                                                        }
                                                    </MudItem>
                                                </MudGrid>
                                                
                                                <MudDivider />
                                                
                                                <!-- House BLs List -->
                                                <MudText Typo="Typo.h6">House BLs (@group.HouseBLDetails.Count)</MudText>
                                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                                    <thead>
                                                        <tr>
                                                            <th>House BL</th>
                                                            <th>Declaration</th>
                                                            <th>Consignee</th>
                                                            <th>Clearance Type</th>
                                                            <th>Container</th>
                                                            <th>Status</th>
                                                            <th>Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var hbl in group.HouseBLDetails)
                                                        {
                                                            var isComplete = group.CompleteHouseBLsList.Contains(hbl.HouseBL);
                                                            <tr>
                                                                <td><strong>@hbl.HouseBL</strong></td>
                                                                <td>@hbl.DeclarationNumber</td>
                                                                <td>@hbl.ConsigneeName</td>
                                                                <td>
                                                                    <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(hbl.ClearanceType)">
                                                                        @hbl.ClearanceType
                                                                    </MudChip>
                                                                </td>
                                                                <td>
                                                                    <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                        @hbl.ContainerNumber
                                                                    </MudLink>
                                                                </td>
                                                                <td>
                                                                    @if (isComplete)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Outlined.CheckCircle">
                                                                            Complete
                                                                        </MudChip>
                                                                    }
                                                                    else
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Outlined.Warning">
                                                                            Incomplete
                                                                        </MudChip>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    <MudStack Row="true" Spacing="1">
                                                                        <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                                      Size="Size.Small"
                                                                                      Color="Color.Info"
                                                                                      Href="@($"/containers/{hbl.ContainerNumber}")"
                                                                                      title="View container details" />
                                                                        @if (!isComplete)
                                                                        {
                                                                            <MudIconButton Icon="@Icons.Material.Outlined.CloudDownload"
                                                                                          Size="Size.Small"
                                                                                          Color="Color.Primary"
                                                                                          OnClick="@(() => RequestBOE(hbl.ContainerNumber))"
                                                                                          title="Request BOE from ICUMS" />
                                                                        }
                                                                    </MudStack>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
            
            <!-- Missing Data Tab - Using Consolidated Model -->
            <MudTabPanel Text="Missing Data" Icon="@Icons.Material.Outlined.Warning" BadgeData="@incompleteGroupsCount" BadgeColor="Color.Error">
                <MudAlert Severity="Severity.Warning" Class="mb-4">
                    <MudText>Showing cargo groups with incomplete data. Expand to see which containers or House BLs are missing data.</MudText>
                </MudAlert>
                
                <!-- Filters -->
                <MudPaper Elevation="1" Class="pa-3 mb-4">
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="string" 
                                      Label="Cargo Type" 
                                      Variant="Variant.Outlined"
                                      @bind-Value="filterMissingCargoType"
                                      Clearable="true">
                                <MudSelectItem T="string" Value="@("All")">All Types</MudSelectItem>
                                <MudSelectItem T="string" Value="@("NonConsolidated")">Non-Consolidated</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Consolidated")">Consolidated</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="string" 
                                      Label="Clearance Type" 
                                      Variant="Variant.Outlined"
                                      @bind-Value="filterMissingClearanceType"
                                      Clearable="true">
                                <MudSelectItem T="string" Value="@("All")">All Types</MudSelectItem>
                                <MudSelectItem T="string" Value="@("CMR")">CMR</MudSelectItem>
                                <MudSelectItem T="string" Value="@("IMEX")">IMEX</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField T="string" 
                                         Label="Search" 
                                         Variant="Variant.Outlined"
                                         @bind-Value="searchTermMissing"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Outlined.Search"
                                         Placeholder="Master BL, Declaration, Container..." />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" Color="Color.Error">
                    <!-- Non-Consolidated Missing -->
                    <MudTabPanel Text="Non-Consolidated Missing" Icon="@Icons.Material.Outlined.LocalShipping" BadgeData="@incompleteNonConsolidatedGroups.Count" BadgeColor="Color.Error">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Error" Indeterminate="true" Class="mb-4" />
                        }
                        
                        @if (!incompleteNonConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No incomplete non-consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-4">
                            @foreach (var group in incompleteNonConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Style="width: 100%;">
                                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: var(--mud-palette-error);">
                                                <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small" Class="mr-2" />
                                                @group.DeclarationNumber
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                Master BL: @group.MasterBL
                                            </MudText>
                                            <MudSpacer />
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Outlined.Warning">
                                                @group.MissingContainers.Count missing
                                            </MudChip>
