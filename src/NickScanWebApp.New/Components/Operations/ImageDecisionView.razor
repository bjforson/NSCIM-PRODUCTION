    /// <summary>
    /// Check if image exists in database by calling the existing image processing pipeline
    /// </summary>
    private async Task CheckImageExists(NickScanWebApp.Shared.Models.ImageMetadata image)
    {
        _checkingImageExists = true;
        StateHasChanged();
        
        try
        {
            Console.WriteLine($"🔍 [ImageDecisionView] Checking if image exists in database for container {ContainerNumber}, imageType: {image.ImageType}");
            
            // ✅ Use existing image processing endpoint to check if image exists
            // This calls the same pipeline that serves the image (reuses existing functionality).
            // Build a signed URL so the raw HttpClient below is authenticated without a JWT header.
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var uid = authState.User.Identity?.Name ?? "anon";
            var urlPath = $"/api/ImageProcessing/container/{Uri.EscapeDataString(ContainerNumber)}/complete/image";
            if (image.ImageType != "ASE")
            {
                urlPath += $"?imageType={Uri.EscapeDataString(image.ImageType)}";
            }
            var checkUrl = UrlBuilder.Build(urlPath, uid);
            
            // Make GET request to check existence (API doesn't support HEAD)
            // We'll check the status code to determine if image exists
            // Use ResponseHeadersRead to avoid downloading full image
            using var httpClient = new System.Net.Http.HttpClient();
            httpClient.Timeout = TimeSpan.FromSeconds(10);
            
            using var response = await httpClient.GetAsync(checkUrl, HttpCompletionOption.ResponseHeadersRead);
            
            // Dispose content without reading to minimize data transfer
            response.Content?.Dispose();
            
            var result = new ImageExistsCheckResult
            {
                Exists = response.IsSuccessStatusCode,
                StatusCode = (int)response.StatusCode,
                Details = response.IsSuccessStatusCode 
                    ? $"HTTP {response.StatusCode} - Image found in database" 
                    : $"HTTP {response.StatusCode} - {response.ReasonPhrase}"
            };
            
            _imageExistsCheckResult[image.Id] = result;
            
            Console.WriteLine($"{(result.Exists ? "✅" : "❌")} [ImageDecisionView] Image existence check: {result.Details}");
            Console.WriteLine($"   Container: {ContainerNumber}");
            Console.WriteLine($"   ImageType: {image.ImageType}");
            Console.WriteLine($"   Check URL: {checkUrl}");
            
            if (result.Exists)
            {
                Snackbar.Add($"✅ Image exists in database (HTTP {result.StatusCode})", Severity.Success);
            }
            else
            {
                Snackbar.Add($"❌ Image NOT found in database: {result.Details}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            var result = new ImageExistsCheckResult
            {
                Exists = false,
                StatusCode = 0,
                Details = $"Error checking: {ex.Message}"
            };
            _imageExistsCheckResult[image.Id] = result;
            
            Console.WriteLine($"❌ [ImageDecisionView] Error checking image existence: {ex.Message}");
            Console.WriteLine($"   Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Error checking image: {ex.Message}", Severity.Error);
        }
        finally
        {
            _checkingImageExists = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Result of image existence check
    /// </summary>
    private class ImageExistsCheckResult
    {
        public bool Exists { get; set; }
        public int StatusCode { get; set; }
        public string Details { get; set; } = string.Empty;
    }

    private async Task OpenFullImage(NickScanWebApp.Shared.Models.ImageMetadata image)
    {
        Console.WriteLine($"🖼️ Opening advanced image viewer for: {image.ImageType} - {image.FullImageUrl}");
        await LogToBrowserConsole($"🖼️ [ImageDecisionView] Opening fullscreen viewer for container: {ContainerNumber}, image: {image.ImageType}");
        
        // ✅ Capture container info in closure (don't capture images - use component field directly in callback)
        var currentContainerNumber = ContainerNumber;
        var currentGroupIdentifier = GroupIdentifier;
        var currentIsConsolidated = IsConsolidated;
        
        // ✅ CRITICAL: Notify parent that this container is being processed
        // This ensures _currentProcessingContainer is set correctly for auto-progression
        await LogToBrowserConsole($"🔄 [ImageDecisionView] Notifying parent that container {currentContainerNumber} is being processed");
        
        // ✅ Log current images state when dialog opens
        Console.WriteLine($"📋 [ImageDecisionView] Images list at dialog open: {images?.Count ?? 0} image(s)");
        if (images != null && images.Any())
        {
            Console.WriteLine($"   - Images: {string.Join(", ", images.Select(i => i.ImageType))}");
        }
        
        IDialogReference? dialogRef = null;
        var parameters = new DialogParameters
        {
            ["ImageUrl"] = image.FullImageUrl,
            ["ContainerNumber"] = currentContainerNumber,
            ["ScannerType"] = image.ImageType,
            ["ScanDate"] = DateTime.Now,
            ["GroupIdentifier"] = currentGroupIdentifier,
            ["IsConsolidated"] = currentIsConsolidated,
            ["OnClose"] = EventCallback.Factory.Create(this, () =>
            {
                // ✅ Close the dialog when OnClose is called
                if (dialogRef != null)
                {
                    dialogRef.Close(DialogResult.Ok(true));
                }
                return Task.CompletedTask;
            }),
            ["OnDecisionSaved"] = EventCallback.Factory.Create<ImageAnalysisViewer.DecisionSaveResponse?>(this, async (response) =>
            {
                if (response == null || !response.Success || dialogRef == null)
                    return;
                
                string? nextContainer = response.NextContainerNumber;
                bool allDecided = response.AllContainersDecided;
                
                Console.WriteLine($"🔄 [ImageDecisionView] Decision saved - allDecided={allDecided}, nextContainer={nextContainer ?? "null"}");
                
                dialogRef.Close(DialogResult.Ok(true));
                await Task.Delay(300);
                
                try
                {
                    await LoadDecisions();
                    await OnDecisionChanged.InvokeAsync();
                        
                    if (allDecided)
                    {
                        Snackbar.Add("All containers in this group have been decided.", Severity.Success);
                        if (OnAllContainersDecided.HasDelegate)
                            await OnAllContainersDecided.InvokeAsync();
                        await OnDecisionSaved.InvokeAsync();
                    }
                    else if (!string.IsNullOrEmpty(nextContainer))
                    {
                        Snackbar.Add($"Decision saved. Loading next container: {nextContainer}...", Severity.Info);
                        if (OnNextContainer.HasDelegate)
                            await OnNextContainer.InvokeAsync(nextContainer);
                        else
                            Snackbar.Add($"Error: Cannot auto-progress to {nextContainer}.", Severity.Error);
                    }
                    else
                    {
                        Snackbar.Add("Decision saved. Check if there are more containers to analyze.", Severity.Info);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ [ImageDecisionView] Auto-progression error: {ex.Message}");
                    Snackbar.Add($"Error during auto-progression: {ex.Message}", Severity.Error);
                }
            })
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            FullScreen = true, // ✅ Always open in fullscreen to make all functions visible
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        dialogRef = await DialogService.ShowAsync<ImageAnalysisViewer>(
            $"🔍 Image Analysis - {image.ImageType} Scanner - {ContainerNumber}", 
            parameters, 
            options);
        
        var result = await dialogRef.Result;

        // Reload decisions after viewer closes (in case tags were added)
        await LoadDecisions();
        await OnDecisionChanged.InvokeAsync();
    }

