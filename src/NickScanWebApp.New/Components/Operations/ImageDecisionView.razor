    /// <summary>
    /// Get image source URL with cache buster, removing duplicate retry/t parameters
    /// </summary>
    private string GetImageSrc(NickScanWebApp.Shared.Models.ImageMetadata image)
    {
        var currentRetry = imageRetryCount.TryGetValue(image.Id, out var count) ? count : 0;
        var cacheBuster = $"&retry={currentRetry}&t={DateTime.Now.Ticks}";
        
        var baseUrl = image.FullImageUrl;
        
        // Use regex to remove retry and t parameters (handles both &retry=... and ?retry=...)
        baseUrl = System.Text.RegularExpressions.Regex.Replace(baseUrl, @"[&?]retry=\d+", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        baseUrl = System.Text.RegularExpressions.Regex.Replace(baseUrl, @"[&?]t=\d+", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        
        // Clean up double ampersands, ?&, and trailing/leading separators
        baseUrl = baseUrl.Replace("&&", "&").Replace("?&", "?").TrimEnd('&', '?');
        
        // Append cache buster
        if (!baseUrl.Contains("?"))
        {
            return $"{baseUrl}?{cacheBuster.TrimStart('&')}";
        }
        else
        {
            return $"{baseUrl}{cacheBuster}";
        }
    }

    private async Task HandleImageError(int imageId, string imageUrl)
    {
        var retries = imageRetryCount.GetValueOrDefault(imageId, 0);

        // Auto re-mint signed URL once on first failure.
        //
        // The most common <img> failure on this view is signed-URL expiry: the
        // analyst keeps the record open longer than the URL TTL, then the next
        // browser repaint reissues the same expired src and the API middleware
        // 401s. Just bumping a cache-buster (?t=...) wouldn't help — the path
        // is unchanged, so the signature/exp is unchanged. We have to refetch
        // the image metadata so the API mints fresh exp/sig. ContainerDetailsService
        // caches metadata for 1 min, so we clear it before reloading.
        if (retries == 0)
        {
            imageRetryCount[imageId] = 1;
            Console.WriteLine($"[ImageDecisionView] Image {imageId} failed — re-minting signed URL (attempt 1)");
            try
            {
                ContainerDetailsService.ClearContainerCache(ContainerNumber);
                await LoadImages();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ImageDecisionView] Re-mint failed for image {imageId}: {ex.Message}");
            }
            StateHasChanged();
            return;
        }

        imageLoadError[imageId] = true;
        var image = images?.FirstOrDefault(i => i.Id == imageId);
        if (image != null)
        {
            var actualSrc = GetImageSrc(image);
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";

            imageErrorMessages[imageId] = $"Image could not be loaded for container {ContainerNumber}. The scan data may be missing or corrupted in the database.";

            Console.WriteLine($"[ImageDecisionView] Image {imageId} ({image.ImageType}) failed after re-mint | Container: {ContainerNumber} | URL: {actualSrc}");

            Snackbar.Add($"Image {image.ImageType} unavailable for {ContainerNumber}.", Severity.Info);
        }
        StateHasChanged();
    }

    private void HandleImageLoad(NickScanWebApp.Shared.Models.ImageMetadata image)
    {
        // ✅ FIX: Only log and update state once per image load (prevent excessive re-renders)
        // The @onload event can fire multiple times, but we only need to update state once
        var wasAlreadyLoaded = imageLoadError.ContainsKey(image.Id) && !imageLoadError[image.Id];

        if (!wasAlreadyLoaded)
        {
            imageLoadError[image.Id] = false; // Mark as successfully loaded
        Console.WriteLine($"✅ [ImageDecisionView] Image {image.Id} ({image.ImageType}) loaded successfully");
        Console.WriteLine($"   URL: {GetImageSrc(image)}");
        StateHasChanged();
        }
        // If already loaded, skip StateHasChanged to prevent render loop
    }

