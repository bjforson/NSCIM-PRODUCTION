@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using NickScanWebApp.New.Components.Images
@using Microsoft.JSInterop
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject NickScanWebApp.New.Services.SignedImageUrlBuilder UrlBuilder

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    @* Header with proper name *@
    <MudPaper Elevation="2" Class="pa-3 mb-3" Style="background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); border-left: 5px solid #9c27b0;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Outlined.Assignment" Size="Size.Medium" Style="color: #7b1fa2;" />
            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #7b1fa2;">
                Image Decision Panel
            </MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                Container: @ContainerNumber
            </MudChip>
        </MudStack>
    </MudPaper>
    
    @* Visual indicator - click images to open fullscreen viewer for decisions *@
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Outlined.ZoomIn" Size="Size.Medium" />
            <MudText Typo="Typo.subtitle1"><strong>Image Gallery</strong> - Click any image to open fullscreen viewer for analysis and decision-making</MudText>
        </MudStack>
    </MudAlert>

    @if (isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1">Loading images and decisions...</MudText>
            <MudText Typo="Typo.caption">Container: @ContainerNumber</MudText>
        </MudStack>
    }
    else if (images?.Any() == true)
    {
        <MudStack Spacing="3" Class="pa-2">
            @foreach (var image in images)
            {
                var decision = _decisions.FirstOrDefault(d => d.ScannerType == image.ImageType);
                var currentDecision = decision?.Decision ?? "Pending";
                var currentComments = decision?.Comments ?? "";

                <MudPaper Elevation="3" Class="pa-0" Style="overflow: hidden;">
                    <!-- Image Header with Decision Status -->
                    <MudToolBar Dense="true" Style="@GetHeaderStyle(currentDecision)">
                        <MudIcon Icon="@GetScannerIcon(image.ImageType)" />
                        <MudText Typo="Typo.subtitle1" Class="ml-2">
                            <strong>@image.ImageType Scanner Image</strong>
                        </MudText>
                        <MudSpacer />
                        <MudChip T="string" Size="Size.Small" Style="@GetDecisionChipStyle(currentDecision)">
                            @GetDecisionIcon(currentDecision) @currentDecision
                        </MudChip>
                    </MudToolBar>

                    <!-- Image Display Area -->
                    <MudCardContent Class="pa-0">
                        <div style="position: relative; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 400px;" @onclick="@(() => OpenFullImage(image))">
                            @if (imageLoadError.ContainsKey(image.Id) && imageLoadError[image.Id])
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                                    <MudIcon Icon="@Icons.Material.Outlined.BrokenImage" Color="Color.Error" Size="Size.Large" />
                                    <MudText Typo="Typo.body2" Color="Color.Error">Image failed to load</MudText>
                                    @if (imageErrorMessages.ContainsKey(image.Id) && !string.IsNullOrEmpty(imageErrorMessages[image.Id]))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="max-width: 500px; text-align: center; word-break: break-all;">
                                            @imageErrorMessages[image.Id]
                                        </MudText>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="max-width: 500px; text-align: center; word-break: break-all;">
                                        URL: @image.ThumbnailUrl
                                    </MudText>
                                    @if (imageRetryCount.ContainsKey(image.Id) && imageRetryCount[image.Id] > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                            Retry attempt: @imageRetryCount[image.Id]
                                        </MudChip>
                                    }
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Refresh" OnClick="@(() => RetryImageLoad(image))">
                                            Retry
                                        </MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Outlined.OpenInNew" OnClick="@(() => TestImageUrl(image))">
                                            Test URL
                                        </MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Outlined.Search" OnClick="@(() => CheckImageExists(image))" Disabled="@(_checkingImageExists)">
                                            @if (_checkingImageExists)
                                            {
                                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                <span class="ml-2">Checking...</span>
                                            }
                                            else
                                            {
                                                <span>Check DB</span>
                                            }
                                        </MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Outlined.Clear" OnClick="@(() => ClearImageError(image.Id))">
                                            Dismiss
                                        </MudButton>
                                    </MudStack>
                                    @if (_imageExistsCheckResult.ContainsKey(image.Id))
                                    {
                                        var checkResult = _imageExistsCheckResult[image.Id];
                                        <MudAlert Severity="@(checkResult.Exists ? Severity.Success : Severity.Warning)" Dense="true" Class="mt-2">
                                            <MudText Typo="Typo.caption">
                                                @if (checkResult.Exists)
                                                {
                                                    <text>✅ Image exists in database (@checkResult.Details)</text>
                                                }
                                                else
                                                {
                                                    <text>❌ Image NOT found in database: @checkResult.Details</text>
                                                }
                                            </MudText>
                                        </MudAlert>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <img src="@GetImageSrc(image)"
                                     alt="@image.ImageType Image"
                                     style="max-width: 100%; max-height: 600px; cursor: none;"
                                     @ref="@(_imageRefs[image.Id])"
                                     @onerror="@(() => HandleImageError(image.Id, GetImageSrc(image)))"
                                     @onload="@(() => HandleImageLoadWithMagnifier(image))"
                                     @onloadstart="@(() => HandleImageLoadStart(image))"
                                     loading="lazy" />
                                
                                <!-- Rectangle overlays for suspicious areas -->
                                @if (_imageRectangles.ContainsKey(image.ImageType) && _imageRectangles[image.ImageType].Any())
                                {
                                    <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">
                                        @foreach (var rect in _imageRectangles[image.ImageType])
                                        {
                                            <rect x="@(rect.X)" 
                                                  y="@(rect.Y)" 
                                                  width="@(rect.Width)" 
                                                  height="@(rect.Height)"
                                                  fill="none"
                                                  stroke="red"
                                                  stroke-width="3"
                                                  opacity="0.8" />
                                        }
                                    </svg>
                                }
                            }
                        </div>

                        <!-- Decision Status Info (Read-Only) -->
                        @if (decision != null)
                        {
                            <MudPaper Elevation="0" Class="pa-3" Style="background: #fafafa; border-top: 2px solid #e0e0e0;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Reviewed by <strong>@decision.ReviewedBy</strong> on @decision.ReviewedAt.ToString("MMM dd, yyyy HH:mm")
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(decision.Comments))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            | Comments: @decision.Comments
                                        </MudText>
                                    }
                                    @if (!string.IsNullOrEmpty(decision.Tags))
                                    {
                                        <MudSpacer />
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            @foreach (var tag in decision.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@tag</MudChip>
                                            }
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudPaper>
                        }
                        else
                        {
                            <MudPaper Elevation="0" Class="pa-3" Style="background: #fafafa; border-top: 2px solid #e0e0e0;">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-style: italic;">
                                    💡 Click the image above to open fullscreen viewer for analysis and decision-making
                                </MudText>
                            </MudPaper>
                        }
                    </MudCardContent>
                </MudPaper>
            }
        </MudStack>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Outlined.ImageNotSupported" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">No images available</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Container: @ContainerNumber</MudText>
        </MudPaper>
    }
</MudContainer>

@implements IDisposable

@code {
    [Parameter] public string ContainerNumber { get; set; } = string.Empty;
    [Parameter] public string GroupIdentifier { get; set; } = string.Empty;
    [Parameter] public bool IsConsolidated { get; set; }
    [Parameter] public EventCallback OnDecisionChanged { get; set; }
    [Parameter] public EventCallback OnDecisionSaved { get; set; }
    [Parameter] public EventCallback<string?> OnNextContainer { get; set; }
    [Parameter] public EventCallback OnAllContainersDecided { get; set; }
    [Parameter] public bool AutoOpenImage { get; set; }
    [Parameter] public EventCallback OnAutoOpenHandled { get; set; }

    // Response DTO for decision save
    private class DecisionSaveResponse
    {
        public bool Success { get; set; }
        public bool AdvancedToAudit { get; set; }
        public bool AllContainersDecided { get; set; }
        public string? NextContainerNumber { get; set; }
        public string? Message { get; set; }
    }

    private bool isLoading = true;
    private List<NickScanWebApp.Shared.Models.ImageMetadata>? images;
    
    // ✅ Helper method to log to browser console (not server console)
    private async Task LogToBrowserConsole(string message)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("console.log", message);
        }
        catch
        {
            // Silently fail if JS interop isn't available (e.g., during prerendering)
        }
    }
    private Dictionary<int, bool> imageLoadError = new();
    private Dictionary<int, int> imageRetryCount = new(); // ✅ Track retry attempts
    private Dictionary<int, string> imageErrorMessages = new(); // ✅ Store error messages
    private Dictionary<int, ElementReference> _imageRefs = new(); // Magnifier element refs
    private Dictionary<int, ImageExistsCheckResult> _imageExistsCheckResult = new(); // ✅ Store image existence check results
    private bool _checkingImageExists = false; // ✅ Track if check is in progress
    private List<ImageAnalysisDecisionDto> _decisions = new();
    private Dictionary<string, string> _imageComments = new();
    private Dictionary<string, List<SuspiciousAreaRect>> _imageRectangles = new();
    private string _currentUsername = "System";
    private Dictionary<string, string> _selectedDecision = new();
    private string _lastContainerNumber = string.Empty;
    private bool _hasLoadedOnce = false;
    private bool _isLoading = false;
    private bool _pendingAutoOpen = false;

    protected override async Task OnInitializedAsync()
    {
        // Get current user
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUsername = authState.User.Identity?.Name ?? "System";
        Console.WriteLine($"👤 [ImageDecisionView] Current user: {_currentUsername}");
    }

    protected override async Task OnParametersSetAsync()
    {
        // ✅ FIX: Load data when parameters are set (especially when used in tabs)
        // Also reload if ContainerNumber changes (for non-consolidated cargo with multiple containers)
        if (!string.IsNullOrEmpty(ContainerNumber))
        {
            if (ContainerNumber != _lastContainerNumber)
            {
                Console.WriteLine($"🎬 [ImageDecisionView] Container changed from '{_lastContainerNumber}' to '{ContainerNumber}', resetting state");
                _lastContainerNumber = ContainerNumber;
                _hasLoadedOnce = false; // Reset flag when container changes
                _isLoading = false; // Reset loading flag
                images = null; // Clear previous images
                _decisions.Clear(); // Clear previous decisions
            }
            
            // ✅ FIX: Check both flags to prevent double loading
            if (!_hasLoadedOnce && !_isLoading)
            {
                _isLoading = true; // Set loading flag first to prevent concurrent loads
                _hasLoadedOnce = true; // Mark as loaded to prevent OnAfterRenderAsync from also loading
                Console.WriteLine($"🎬 [ImageDecisionView] Parameters set for container: {ContainerNumber}, Group: {GroupIdentifier} - Loading images...");
                isLoading = true;
                await InvokeAsync(StateHasChanged); // Show loading state immediately
                try
                {
                await LoadImages();
                await LoadDecisions();
                }
                finally
                {
                    _isLoading = false; // Reset loading flag
                }
                await InvokeAsync(StateHasChanged); // Update UI after loading
            }
            else
            {
                if (_isLoading)
                {
                    Console.WriteLine($"ℹ️ [ImageDecisionView] Already loading for container: {ContainerNumber}, skipping duplicate load");
            }
            else
            {
                Console.WriteLine($"ℹ️ [ImageDecisionView] Already loaded for container: {ContainerNumber}, skipping reload");
                }
            }
        }

        if (AutoOpenImage && !_pendingAutoOpen && _hasLoadedOnce && images?.Any() == true)
        {
            _pendingAutoOpen = true;
            Console.WriteLine($"🔄 [ImageDecisionView] Scheduling auto-open for container: {ContainerNumber}");
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await Task.Delay(400);
                    if (!_pendingAutoOpen) return;
                    _pendingAutoOpen = false;
                    Console.WriteLine($"🔄 [ImageDecisionView] Auto-opening fullscreen viewer for container: {ContainerNumber}");
                    if (OnAutoOpenHandled.HasDelegate)
                        await OnAutoOpenHandled.InvokeAsync();
                    if (images?.Any() == true)
                        await OpenFullImage(images.First());
                }
                catch (ObjectDisposedException) { }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ [ImageDecisionView] Auto-open error: {ex.Message}");
                }
            });
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(ContainerNumber) && !_hasLoadedOnce && !_isLoading)
        {
            _isLoading = true;
            _hasLoadedOnce = true;
            Console.WriteLine($"🖼️ [ImageDecisionView] First render fallback - loading images for: {ContainerNumber}");
            isLoading = true;
            await InvokeAsync(StateHasChanged);
            try
            {
            await LoadImages();
            await LoadDecisions();
            }
            finally
            {
                _isLoading = false;
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadImages()
    {
        isLoading = true;
        try
        {
            Console.WriteLine($"🔍 [ImageDecisionView] Loading images for container: {ContainerNumber}");
            images = await ContainerDetailsService.GetImageMetadataAsync(ContainerNumber);
            
            if (images != null && images.Any())
            {
                // Ensure ElementReference entries exist for magnifier attachment
                foreach (var img in images)
                {
                    if (!_imageRefs.ContainsKey(img.Id))
                        _imageRefs[img.Id] = default;
                }

                Console.WriteLine($"✅ [ImageDecisionView] Loaded {images.Count} image(s)");

                // ✅ NOTE: URLs are already normalized by ContainerDetailsService, but verify they're correct
                var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
                Console.WriteLine($"🔧 [ImageDecisionView] API Base URL: {apiBaseUrl}");
                
                foreach (var img in images)
                {
                    Console.WriteLine($"   📸 [ImageDecisionView] Processing image {img.Id} ({img.ImageType})");
                    Console.WriteLine($"      ThumbnailUrl: {img.ThumbnailUrl}");
                    Console.WriteLine($"      FullImageUrl: {img.FullImageUrl}");
                    
                    // ✅ Verify URL format - check if imageType parameter is present
                    if (!string.IsNullOrEmpty(img.ThumbnailUrl))
                    {
                        if (img.ThumbnailUrl.Contains("imageType="))
                        {
                            Console.WriteLine($"      ✅ imageType parameter found in URL");
                        }
                        else
                        {
                            Console.WriteLine($"      ⚠️ WARNING: imageType parameter missing from URL!");
                        }
                        
                        // Verify URL is absolute
                        if (Uri.TryCreate(img.ThumbnailUrl, UriKind.Absolute, out var uri))
                        {
                            Console.WriteLine($"      ✅ URL is absolute: {uri.AbsoluteUri}");
                            Console.WriteLine($"      ✅ Query string: {uri.Query}");
                        }
                        else
                        {
                            Console.WriteLine($"      ⚠️ WARNING: URL is not absolute, normalizing...");
                            img.ThumbnailUrl = NormalizeImageUrl(img.ThumbnailUrl, apiBaseUrl);
                            img.FullImageUrl = NormalizeImageUrl(img.FullImageUrl, apiBaseUrl);
                            Console.WriteLine($"      ✅ Normalized ThumbnailUrl: {img.ThumbnailUrl}");
                        }
                    }
                    
                    _imageComments[img.ImageType] = "";
                    _selectedDecision[img.ImageType] = "Pending";
                }
            }
            else
            {
                Console.WriteLine($"⚠️ [ImageDecisionView] No images found");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [ImageDecisionView] Error loading images: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Normalize image URL to ensure it's a full URL (not relative)
    /// </summary>
    private string NormalizeImageUrl(string url, string apiBaseUrl)
    {
        if (string.IsNullOrEmpty(url))
            return string.Empty;
        
        // Already a full URL
        if (url.StartsWith("http://") || url.StartsWith("https://"))
            return url;
        
        // Relative URL with leading slash
        if (url.StartsWith("/"))
            return $"{apiBaseUrl}{url}";
        
        // Relative URL without leading slash
        return $"{apiBaseUrl}/{url}";
    }

    private async Task LoadDecisions()
    {
        try
        {
            Console.WriteLine($"🔍 [ImageDecisionView] Loading decisions for container: {ContainerNumber}");
            _decisions = await ApiService.GetAsync<List<ImageAnalysisDecisionDto>>(
                $"/api/ImageAnalysisDecision/container/{ContainerNumber}") ?? new();
            
            Console.WriteLine($"✅ [ImageDecisionView] Loaded {_decisions.Count} decision(s)");
            
            // Populate comment fields and rectangles from existing decisions
            foreach (var decision in _decisions)
            {
                Console.WriteLine($"   - {decision.ScannerType}: {decision.Decision} ('{decision.Comments}')");
                if (!string.IsNullOrEmpty(decision.Comments))
                {
                    _imageComments[decision.ScannerType] = decision.Comments;
                }
                _selectedDecision[decision.ScannerType] = string.IsNullOrEmpty(decision.Decision) ? "Pending" : decision.Decision;
                
                // Load suspicious area rectangles
                if (!string.IsNullOrEmpty(decision.SuspiciousAreas))
                {
                    try
                    {
                        var rectangles = System.Text.Json.JsonSerializer.Deserialize<List<SuspiciousAreaRect>>(decision.SuspiciousAreas);
                        if (rectangles != null && rectangles.Any())
                        {
                            _imageRectangles[decision.ScannerType] = rectangles;
                            Console.WriteLine($"   - Loaded {rectangles.Count} suspicious area(s) for {decision.ScannerType}");
                        }
                    }
                    catch (Exception parseEx)
                    {
                        Console.WriteLine($"⚠️ [ImageDecisionView] Error parsing rectangles for {decision.ScannerType}: {parseEx.Message}");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [ImageDecisionView] Error loading decisions: {ex.Message}");
        }
    }

    private async Task SaveImageDecision(string scannerType, string decision, string comments)
    {
        // ✅ PRIORITY 2.1: Retry logic for API failures
        const int maxRetries = 3;
        const int retryDelayMs = 1000; // 1 second
        
        DecisionSaveResponse? response = null;
        Exception? lastException = null;
        
        for (int attempt = 1; attempt <= maxRetries; attempt++)
    {
        try
        {
            // Guard missing dictionary keys
            var selectedDecision = _selectedDecision.TryGetValue(scannerType, out var d) ? d : (string.IsNullOrWhiteSpace(decision) ? "Pending" : decision);
            var selectedComments = _imageComments.TryGetValue(scannerType, out var c) ? c : comments ?? string.Empty;

                if (attempt == 1)
                {
                    await LogToBrowserConsole($"➡️ [ImageDecisionView] Saving decision | Container={ContainerNumber} | Scanner={scannerType} | Decision={selectedDecision} | User={_currentUsername}");
                }
                else
                {
                    await LogToBrowserConsole($"🔄 [ImageDecisionView] Retry attempt {attempt}/{maxRetries} | Container={ContainerNumber} | Scanner={scannerType}");
                    Snackbar.Add($"Retrying... (Attempt {attempt}/{maxRetries})", Severity.Warning);
                    await Task.Delay(retryDelayMs * attempt); // Exponential backoff
                }

            var request = new
            {
                ContainerNumber,
                ScannerType = scannerType,
                Decision = selectedDecision,
                Comments = selectedComments,
                ReviewedBy = _currentUsername,
                GroupIdentifier,
                IsConsolidated
            };

                response = await ApiService.PostAsync<object, DecisionSaveResponse>("/api/ImageAnalysisDecision", request);
                
                // Success - break out of retry loop
                await LogToBrowserConsole($"✅ [ImageDecisionView] Decision saved | Scanner={scannerType} | Decision={selectedDecision} (Attempt {attempt})");
                
                // ✅ DIAGNOSTIC: Log raw response values for debugging (TO BROWSER CONSOLE)
                if (response != null)
                {
                    await LogToBrowserConsole($"🔍 [ImageDecisionView] API Response received:");
                    await LogToBrowserConsole($"   - Success: {response.Success}");
                    await LogToBrowserConsole($"   - AllContainersDecided: {response.AllContainersDecided}");
                    await LogToBrowserConsole($"   - NextContainerNumber: {response.NextContainerNumber ?? "null"}");
                    await LogToBrowserConsole($"   - AdvancedToAudit: {response.AdvancedToAudit}");
                    await LogToBrowserConsole($"   - Message: {response.Message ?? "null"}");
                }
                else
                {
                    await LogToBrowserConsole($"⚠️ [ImageDecisionView] API Response is NULL!");
                }
                
                break;
            }
            catch (Exception ex)
            {
                lastException = ex;
                await LogToBrowserConsole($"❌ [ImageDecisionView] Error saving decision (Attempt {attempt}/{maxRetries}): {ex.Message}");
                
                // Check if it's a transient error (network, timeout, etc.)
                bool isTransientError = ex.Message.Contains("timeout", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("network", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("connection", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("500", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("502", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("503", StringComparison.OrdinalIgnoreCase) ||
                                       ex.Message.Contains("504", StringComparison.OrdinalIgnoreCase);
                
                if (!isTransientError || attempt == maxRetries)
                {
                    // Not a transient error or max retries reached - don't retry
                    break;
                }
            }
        }
        
        // Check if we have a response or if all retries failed
        if (response == null)
        {
            var errorMessage = lastException != null 
                ? $"Failed to save decision after {maxRetries} attempts: {lastException.Message}" 
                : $"Failed to save decision after {maxRetries} attempts";
            Console.WriteLine($"❌ [ImageDecisionView] {errorMessage}");
            Snackbar.Add(errorMessage, Severity.Error);
            return;
        }
        
        try
        {
            // Get selected decision for success message
            var selectedDecision = _selectedDecision.TryGetValue(scannerType, out var d) ? d : (string.IsNullOrWhiteSpace(decision) ? "Pending" : decision);
            
            // ✅ AUTO-PROGRESSION: Check response for next container or completion
            string? nextContainer = response?.NextContainerNumber;
            bool allDecided = response?.AllContainersDecided ?? false;
            
            await LogToBrowserConsole($"🔄 [ImageDecisionView] Auto-progression check: allDecided={allDecided}, nextContainer={nextContainer ?? "null"}");
            
            Snackbar.Add($"{scannerType} image marked as {selectedDecision}", Severity.Success);
            
            // Reload decisions to update UI
            await LoadDecisions();
            
            // Notify parent that decision changed (for overall calculation)
            await OnDecisionChanged.InvokeAsync();
            
            // ✅ AUTO-PROGRESSION: Handle next container or completion
            if (allDecided)
            {
                // ✅ FIX: Only close dialog when ALL containers are truly decided
                await LogToBrowserConsole($"✅ [ImageDecisionView] All containers decided - closing dialog and returning to assignments");
                Snackbar.Add("All containers in this group have been decided. Group moved to audit queue.", Severity.Success);
                await OnAllContainersDecided.InvokeAsync();
                await OnDecisionSaved.InvokeAsync(); // Close dialog
            }
            else if (!string.IsNullOrEmpty(nextContainer))
            {
                // ✅ FIX: Load next container - dialog stays open
                await LogToBrowserConsole($"🔄 [ImageDecisionView] Loading next container: {nextContainer} - dialog stays open");
                Snackbar.Add($"Decision saved. Loading next container: {nextContainer}...", Severity.Info);
                await OnNextContainer.InvokeAsync(nextContainer);
                // Don't close dialog - it will reload with next container
            }
            else
            {
                // ✅ FIX: Don't close dialog if nextContainer is null but allDecided is false
                // This might indicate an API issue, but we shouldn't close prematurely
                await LogToBrowserConsole($"⚠️ [ImageDecisionView] No next container returned but allDecided=false - keeping dialog open");
                Snackbar.Add("Decision saved. Please check if there are more containers to analyze.", Severity.Info);
                // Don't close dialog - let user manually navigate or wait for API to return correct nextContainer
            }
        }
        catch (Exception ex)
        {
            await LogToBrowserConsole($"❌ [ImageDecisionView] Error processing decision response: {ex.Message}");
            Snackbar.Add($"Error processing decision response: {ex.Message}", Severity.Error);
        }
    }

