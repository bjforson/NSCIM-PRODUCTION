    private async Task RetryImageLoad(NickScanWebApp.Shared.Models.ImageMetadata image)
    {
        // ✅ Increment retry count
        if (!imageRetryCount.ContainsKey(image.Id))
            imageRetryCount[image.Id] = 0;
        imageRetryCount[image.Id]++;

        // ✅ Clear error state
        imageLoadError[image.Id] = false;
        imageErrorMessages.Remove(image.Id);

        // ✅ Clear cache for this container to force fresh load
        ContainerDetailsService.ClearContainerCache(ContainerNumber);

        // ✅ FIX: Don't modify the original URL - GetImageSrc will handle cache busting
        // This prevents duplicate query parameters from accumulating
        // The retry count is tracked in imageRetryCount dictionary, and GetImageSrc
        // will append fresh cache buster parameters each time

        Console.WriteLine($"🔄 [ImageDecisionView] Retrying image {image.Id} (attempt {imageRetryCount[image.Id]})");
        Console.WriteLine($"   URL will be: {GetImageSrc(image)}");
        
        Snackbar.Add($"Retrying image load (attempt {imageRetryCount[image.Id]})...", Severity.Info);
        StateHasChanged();

        // ✅ Small delay to allow UI to update
        await Task.Delay(100);
    }

    private void ClearImageError(int imageId)
    {
        imageLoadError[imageId] = false;
        imageErrorMessages.Remove(imageId);
        imageRetryCount.Remove(imageId);
        StateHasChanged();
    }

