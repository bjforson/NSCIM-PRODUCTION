@using MudBlazor
@using NickScanCentralImagingPortal.Core.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@StageName - Stage Details</MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer>
            @if (StageData != null)
            {
                <MudText Typo="Typo.h5" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Outlined.Timeline" Class="mr-2" />
                    @StageName - Stage Details
                </MudText>

                <MudGrid Spacing="3">
                    <!-- Key Metrics -->
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="2">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-3">Key Metrics</MudText>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Current Count:</MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary">@StageData.Count</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Status:</MudText>
                                        <MudChip T="string" Color="@GetStatusColor(StageData.Status)" Size="Size.Small">@StageData.Status</MudChip>
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Average Age:</MudText>
                                        <MudText Typo="Typo.body1">@FormatTimeSpan(StageData.AverageAge)</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Oldest Item:</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Warning">@FormatTimeSpan(StageData.OldestAge)</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <!-- Flow Metrics -->
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="2">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-3">Flow Metrics</MudText>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Incoming Rate:</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Success">@StageData.IncomingRate.ToString("F1")/hr</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Outgoing Rate:</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Info">@StageData.OutgoingRate.ToString("F1")/hr</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Net Change:</MudText>
                                        <MudText Typo="Typo.body1" Color="@GetNetChangeColor(StageData.NetChange)">
                                            @(StageData.NetChange >= 0 ? "+" : "")@StageData.NetChange.ToString("F1")/hr
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <!-- Status Information -->
                    <MudItem xs="12">
                        <MudCard Elevation="2">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Class="mb-3">Status Information</MudText>
                                <MudAlert Severity="@GetStatusSeverity(StageData.Status)" Variant="Variant.Filled">
                                    <MudText Typo="Typo.body1">
                                        @GetStatusMessage(StageData.Status, StageData.Count, StageData.OldestAge)
                                    </MudText>
                                </MudAlert>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="Typo.body1" Color="Color.Error">No data available for this stage.</MudText>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string StageName { get; set; } = string.Empty;
    [Parameter] public StageMetrics? StageData { get; set; }

    private void Close()
    {
        // Dialog closes via the close button (X) in DialogOptions
        // This is a placeholder for the button click handler
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Normal" => Color.Success,
            "Warning" => Color.Warning,
            "Critical" => Color.Error,
            _ => Color.Default
        };
    }

    private Severity GetStatusSeverity(string status)
    {
        return status switch
        {
            "Normal" => Severity.Success,
            "Warning" => Severity.Warning,
            "Critical" => Severity.Error,
            _ => Severity.Info
        };
    }

    private Color GetNetChangeColor(double netChange)
    {
        if (netChange > 0) return Color.Error; // Growing queue
        if (netChange < 0) return Color.Success; // Shrinking queue
        return Color.Info; // Stable
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalDays >= 1)
            return $"{(int)timeSpan.TotalDays}d {timeSpan.Hours}h";
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        if (timeSpan.TotalMinutes >= 1)
            return $"{(int)timeSpan.TotalMinutes}m {timeSpan.Seconds}s";
        return $"{timeSpan.TotalSeconds:F0}s";
    }

    private string GetStatusMessage(string status, int count, TimeSpan oldestAge)
    {
        return status switch
        {
            "Normal" => $"Stage is operating normally with {count} items. Average processing time is acceptable.",
            "Warning" => $"Stage has {count} items. Consider monitoring closely. Oldest item: {FormatTimeSpan(oldestAge)}",
            "Critical" => $"⚠️ CRITICAL: Stage has {count} items with oldest item aged {FormatTimeSpan(oldestAge)}. Immediate attention required!",
            _ => $"Stage status: {status}"
        };
    }
}

