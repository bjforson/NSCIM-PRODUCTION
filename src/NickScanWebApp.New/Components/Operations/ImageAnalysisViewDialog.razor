    private async Task LoadWaveContext()
    {
        try
        {
            // First, look up the group ID from the GroupIdentifier
            var groupResponse = await ApiService.GetAsync<GroupLookupDto>($"/api/image-analysis/group-by-identifier?identifier={Uri.EscapeDataString(GroupIdentifier)}&scannerType={Uri.EscapeDataString(ScannerType)}");
            if (groupResponse?.GroupId == null)
                return;

            _waveContext = await ApiService.GetAsync<WaveContextDto>($"/api/image-analysis/wave-context/{groupResponse.GroupId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ [Wave] Could not load wave context: {ex.Message}");
            // Non-critical — silently fail
        }
    }

    private class GroupLookupDto
    {
        public Guid? GroupId { get; set; }
    }
