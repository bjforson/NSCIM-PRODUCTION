    private ElementReference _tabScrollRef0, _tabScrollRef1, _tabScrollRef2, _tabScrollRef3, _tabScrollRefSummary; // Consolidated view tab scroll refs
    private Dictionary<int, double> _tabScrollPositions = new(); // Consolidated view scroll positions
    private Dictionary<string, Dictionary<int, double>> _nestedTabScrollPositions = new(); // Non-consolidated: container -> tab index -> position
    
