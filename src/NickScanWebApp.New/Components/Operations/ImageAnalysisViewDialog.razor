    protected override Task OnInitializedAsync()
    {
        Console.WriteLine($"🚀🚀🚀 [ImageAnalysisViewDialog] OnInitializedAsync START");
        Console.WriteLine($"   GroupIdentifier: {GroupIdentifier}");
        Console.WriteLine($"   IsConsolidated: {IsConsolidated}");
        Console.WriteLine($"   ScannerType: {ScannerType}");
        Console.WriteLine($"   Passed Containers: {(Containers?.Any() == true ? string.Join(", ", Containers) : "None")}");
        
        // ✅ FIX #1: Disable standardized view - always use legacy view to prevent tab switching
        _useStandardizedView = false;
        _determiningView = false;
        
        // ✅ FIX #2: Set up containers without loading heavy data
        if (IsConsolidated)
        {
            Console.WriteLine($"📦 [ImageAnalysisViewDialog] CONSOLIDATED cargo - Container: {GroupIdentifier}");
            if (Containers == null || !Containers.Any())
            {
                Containers = new List<string> { GroupIdentifier };
            }
            // ✅ AUTO-PROGRESSION: For consolidated, set current container
            _currentProcessingContainer = GroupIdentifier;
        }
        else
        {
            Console.WriteLine($"📦 [ImageAnalysisViewDialog] NON-CONSOLIDATED cargo - BOE: {GroupIdentifier}");
            // ✅ AUTO-PROGRESSION: Find first undecided container and expand it
            // This will be handled after containers are loaded
            // ✅ FIX #2: Only load containers if not provided - do it in background
            if (Containers == null || !Containers.Any())
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await LoadContainers();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error loading containers: {ex.Message}");
                    }
                });
            }
        }

        // ✅ FIX #2: Load overall decision in background (non-blocking)
        _ = Task.Run(async () =>
        {
            try
            {
                await RefreshOverallDecision();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error loading overall decision: {ex.Message}");
            }
        });
        
        // Preload image analysis context (cargo group + container contexts)
        _ = Task.Run(async () =>
        {
            try
            {
                await LoadImageAnalysisContext();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error loading image analysis context: {ex.Message}");
            }
        });
        
        // ✅ FIX: Preload ICUMS data in background for non-consolidated cargo (shared across containers)
        if (!IsConsolidated)
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await PreloadICUMSData();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error preloading ICUMS data: {ex.Message}");
                }
            });
        }
        
        // Load cargo group for summary (fallback if preloader disabled)
        _ = Task.Run(async () =>
        {
            try
            {
                await LoadCargoGroupForSummary();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error loading cargo group for summary: {ex.Message}");
            }
        });
        
        // Load wave context in background (non-blocking)
        _ = Task.Run(async () =>
        {
            try
            {
                await LoadWaveContext();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error loading wave context: {ex.Message}");
            }
        });

        Console.WriteLine($"✅✅✅ [ImageAnalysisViewDialog] OnInitializedAsync COMPLETE - UI ready immediately");

        // Return completed task since all async work is done in background Task.Run calls
        return Task.CompletedTask;
    }

    private async Task LoadImageAnalysisContext()
    {
        _isLoadingImageAnalysisContext = true;
        await InvokeAsync(StateHasChanged);
        
        try
        {
            _imageAnalysisContext = await ImageAnalysisPreloader.LoadAsync(
                GroupIdentifier,
                IsConsolidated,
                Containers,
                forceRefresh: false);

            if (_imageAnalysisContext != null)
            {
                // Use preloaded cargo group for summary if available
                if (_imageAnalysisContext.CargoGroupContext?.Group != null)
                {
                    _cargoGroupForSummary = _imageAnalysisContext.CargoGroupContext.Group;
                    _loadingCargoGroupForSummary = false;
                }

                // ✅ FIX: Extract preloaded ICUMS data from container contexts
                if (_imageAnalysisContext.ContainerContexts.Any())
                {
                    if (IsConsolidated)
                    {
                        // For consolidated, use the consolidated container context
                        var consolidatedCtx = _imageAnalysisContext.GetConsolidatedContainerContext();
                        if (consolidatedCtx?.ICUMSData?.Data != null && consolidatedCtx.ICUMSData.Data.Any())
                        {
                            _allBOEData = consolidatedCtx.ICUMSData.Data.Select(r => new ICUMSDataRecordDto
                            {
                                Field = r.Field,
                                Value = r.Value,
                                Category = r.Category,
                                IsRequired = r.IsRequired,
                                HouseBL = r.HouseBL
                            }).ToList();
                            _icumsDataLoaded = true;
                            Console.WriteLine($"✅ [ImageAnalysisViewDialog] Extracted {_allBOEData.Count} preloaded ICUMS records from consolidated context");
                        }
                    }
                    else
                    {
                        // For non-consolidated, ICUMS data is shared - use first container's ICUMS data
                        var firstContainerCtx = _imageAnalysisContext.ContainerContexts.Values.FirstOrDefault();
                        if (firstContainerCtx?.ICUMSData?.Data != null && firstContainerCtx.ICUMSData.Data.Any())
                        {
                            _allBOEData = firstContainerCtx.ICUMSData.Data.Select(r => new ICUMSDataRecordDto
                            {
                                Field = r.Field,
                                Value = r.Value,
                                Category = r.Category,
                                IsRequired = r.IsRequired,
                                HouseBL = r.HouseBL
                            }).ToList();
                            _icumsDataLoaded = true;
                            Console.WriteLine($"✅ [ImageAnalysisViewDialog] Extracted {_allBOEData.Count} preloaded ICUMS records from context");
                        }
                    }
                }

                Console.WriteLine($"✅ [ImageAnalysisViewDialog] Loaded image analysis context: {_imageAnalysisContext.ContainerContexts.Count} container(s)");
                Snackbar.Add($"Loaded data for {_imageAnalysisContext.ContainerContexts.Count} container(s)", Severity.Success);
            }
            else
            {
                Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Image analysis context preload returned null");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [ImageAnalysisViewDialog] Error loading image analysis context: {ex.Message}");
            Snackbar.Add("Using fallback data loading", Severity.Info);
        }
        finally
        {
            _isLoadingImageAnalysisContext = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ✅ FIX: Preload ICUMS data in background for non-consolidated cargo
    private async Task PreloadICUMSData()
    {
        if (IsConsolidated || string.IsNullOrEmpty(GroupIdentifier))
            return;

        try
        {
            Console.WriteLine($"🔍 [PreloadICUMSData] Preloading ICUMS data for declaration: {GroupIdentifier}");
            
            // Load BOE details in background
            if (Containers?.Any() == true)
            {
                var firstContainer = Containers.First();
                // 6.01: routed through BuildContainerEndpointUrl helper
                var icumsResponse = await ApiService.GetAsync<NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ICUMSDataRecord>>(
                    BuildContainerEndpointUrl("icums", GroupIdentifier, IsConsolidated, routeContainer: firstContainer));

                if (icumsResponse?.Data?.Any() == true)
                {
                    _allBOEData = icumsResponse.Data.Select(r => new ICUMSDataRecordDto
                    {
                        Field = r.Field,
                        Value = r.Value,
                        Category = r.Category,
                        IsRequired = r.IsRequired,
                        HouseBL = r.HouseBL
                    }).ToList();
                    _icumsDataLoaded = true;
                    Console.WriteLine($"✅ [PreloadICUMSData] Preloaded {_allBOEData.Count} ICUMS records for declaration {GroupIdentifier}");
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    Console.WriteLine($"⚠️ [PreloadICUMSData] No ICUMS data found for declaration {GroupIdentifier}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [PreloadICUMSData] Error preloading ICUMS data: {ex.Message}");
        }
    }
    
    private async Task LoadCargoGroupForSummary()
    {
        var totalStopwatch = System.Diagnostics.Stopwatch.StartNew();
        var identifierResolutionStopwatch = System.Diagnostics.Stopwatch.StartNew();
        var cargoGroupLoadStopwatch = System.Diagnostics.Stopwatch.StartNew();
        
        Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] START - GroupIdentifier: {GroupIdentifier}, IsConsolidated: {IsConsolidated}");
        
        _loadingCargoGroupForSummary = true;
        await InvokeAsync(StateHasChanged);
        
        try
        {
            // ✅ FIX: For consolidated cargo, GroupIdentifier is container number, but cargo group service needs Master BL
            // ✅ FIX: For non-consolidated cargo, GroupIdentifier is declaration number, which is correct
            // First, try to get the correct group identifier from container number if needed
            string actualGroupIdentifier = GroupIdentifier;
            CargoType? actualCargoType = IsConsolidated ? CargoType.Consolidated : CargoType.NonConsolidated;
            
            // ✅ FIX: Use same approach as ICUMS data - query BOE documents directly by container number
            // This works even when BlNumber/DeclarationNumber fields are empty, as long as BOE document exists
            if (IsConsolidated)
            {
                // For consolidated, GroupIdentifier is container number - need to find Master BL from BOE document
                var containerNumber = GroupIdentifier; // For consolidated, GroupIdentifier = ContainerNumber
                
                // ✅ PERFORMANCE FIX #3: Check cache first
                CachedGroupIdentifier? cachedIdentifier = null;
                lock (_groupIdentifierCacheLock)
                {
                    if (_groupIdentifierCache.TryGetValue(containerNumber, out cachedIdentifier))
                    {
                        actualGroupIdentifier = cachedIdentifier.GroupIdentifier;
                        actualCargoType = cachedIdentifier.Type;
                        Console.WriteLine($"✅ [LoadCargoGroupForSummary] Using cached group identifier for container {containerNumber}: {actualGroupIdentifier} (Type: {actualCargoType}, cached at {cachedIdentifier.CachedAt:HH:mm:ss})");
                    }
                }
                
                if (cachedIdentifier == null)
                {
                    identifierResolutionStopwatch.Restart();
                    // Cache miss - resolve group identifier
                    // ✅ FIX: Try the API endpoint first (requires BlNumber/DeclarationNumber to be populated)
                    var groupIdentifierInfo = await CargoGroupService.GetGroupIdentifierByContainerAsync(containerNumber);
                    identifierResolutionStopwatch.Stop();
                    Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] GetGroupIdentifierByContainerAsync took: {identifierResolutionStopwatch.ElapsedMilliseconds}ms");
                    
                    if (groupIdentifierInfo != null)
                    {
                        actualGroupIdentifier = groupIdentifierInfo.GroupIdentifier;
                        actualCargoType = groupIdentifierInfo.Type;
                        Console.WriteLine($"🔍 [LoadCargoGroupForSummary] Resolved container {containerNumber} to group identifier: {actualGroupIdentifier} (Type: {actualCargoType})");
                        
                        // Cache the result
                        lock (_groupIdentifierCacheLock)
                        {
                            if (_groupIdentifierCache.Count >= MaxGroupIdentifierCacheSize)
                            {
                                // Remove oldest entries (simple FIFO - remove first 20 entries)
                                var keysToRemove = _groupIdentifierCache.Keys.Take(20).ToList();
                                foreach (var key in keysToRemove)
                                {
                                    _groupIdentifierCache.Remove(key);
                                }
                            }
                            _groupIdentifierCache[containerNumber] = new CachedGroupIdentifier
                            {
                                GroupIdentifier = actualGroupIdentifier,
                                Type = actualCargoType.Value,
                                CachedAt = DateTime.UtcNow
                            };
                        }
                    }
                    else
                    {
                        identifierResolutionStopwatch.Restart();
                        // ✅ FALLBACK: Get full BOE data directly (same approach as ICUMS tab uses)
                        // This extracts DeclarationNumber/BlNumber from the actual BOE document that has data
                        Console.WriteLine($"⚠️ [LoadCargoGroupForSummary] GetGroupIdentifierByContainerAsync returned null, trying GetFullBOEDataAsync for container {containerNumber}");
                        
                        var fullBOEData = await ContainerDetailsService.GetFullBOEDataAsync(containerNumber);
                        identifierResolutionStopwatch.Stop();
                        Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] GetFullBOEDataAsync took: {identifierResolutionStopwatch.ElapsedMilliseconds}ms");
                        
                        if (fullBOEData != null)
                        {
                            // BOE document exists - extract group identifier from it
                            if (!string.IsNullOrEmpty(fullBOEData.BlNumber))
                            {
                                // Consolidated cargo - use Master BL
                                actualGroupIdentifier = fullBOEData.BlNumber;
                                actualCargoType = CargoType.Consolidated;
                                Console.WriteLine($"✅ [LoadCargoGroupForSummary] Extracted Master BL from BOE data: {actualGroupIdentifier} (Type: {actualCargoType})");
                            }
                            else if (!string.IsNullOrEmpty(fullBOEData.DeclarationNumber))
                            {
                                // Non-consolidated cargo - use Declaration Number
                                actualGroupIdentifier = fullBOEData.DeclarationNumber;
                                actualCargoType = CargoType.NonConsolidated;
                                Console.WriteLine($"✅ [LoadCargoGroupForSummary] Extracted Declaration Number from BOE data: {actualGroupIdentifier} (Type: {actualCargoType})");
                            }
                            else
                            {
                                // BOE exists but BlNumber and DeclarationNumber are both NULL/empty
                                _cargoGroupLoadFailed = true;
                                Console.WriteLine($"⚠️ [LoadCargoGroupForSummary] BOE document exists for container {containerNumber}, but BlNumber and DeclarationNumber are both NULL/empty");
                                Console.WriteLine($"   BOE Document ID: {fullBOEData.AllFields?.GetValueOrDefault("BOEDocumentId") ?? "N/A"}");
                                Console.WriteLine($"   Clearance Type: {fullBOEData.ClearanceType ?? "N/A"}");
                                Console.WriteLine($"   Issue: Cannot create cargo group without group identifier (Master BL or Declaration Number)");
                                Console.WriteLine($"   Action Required: BOE document needs to have BlNumber (for consolidated) or DeclarationNumber (for non-consolidated) populated");
                            }
                            
                            // Cache the result if we successfully extracted a group identifier
                            if (!string.IsNullOrEmpty(actualGroupIdentifier) && actualCargoType.HasValue)
                            {
                                lock (_groupIdentifierCacheLock)
                                {
                                    if (_groupIdentifierCache.Count >= MaxGroupIdentifierCacheSize)
                                    {
                                        var keysToRemove = _groupIdentifierCache.Keys.Take(20).ToList();
                                        foreach (var key in keysToRemove)
                                        {
                                            _groupIdentifierCache.Remove(key);
                                        }
                                    }
                                    _groupIdentifierCache[containerNumber] = new CachedGroupIdentifier
                                    {
                                        GroupIdentifier = actualGroupIdentifier,
                                        Type = actualCargoType.Value,
                                        CachedAt = DateTime.UtcNow
                                    };
                                }
                            }
                        }
                        else
                        {
                            // No BOE document found at all
                            _cargoGroupLoadFailed = true;
                            Console.WriteLine($"⚠️ [LoadCargoGroupForSummary] No BOE document found for container {containerNumber}");
                        }
                    }
                }
            }
            
            // Only attempt to load cargo group if we have a valid group identifier
            if (!string.IsNullOrEmpty(actualGroupIdentifier))
            {
                identifierResolutionStopwatch.Stop();
                Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] Group identifier resolution total: {identifierResolutionStopwatch.ElapsedMilliseconds}ms");
                Console.WriteLine($"🔍 [LoadCargoGroupForSummary] Loading cargo group - GroupIdentifier: {actualGroupIdentifier}, CargoType: {actualCargoType}, IsConsolidated: {IsConsolidated}");
                
                cargoGroupLoadStopwatch.Restart();
                // ✅ PERFORMANCE FIX: Load only ICUMS data for summary tab (saves 15-45 seconds)
                // Summary tab only displays ICUMS data, so skip loading scanner and image data
                _cargoGroupForSummary = await CargoGroupService.GetCargoGroupAsync(
                    actualGroupIdentifier, 
                    actualCargoType,
                    loadScannerData: false,  // ✅ Skip scanner data (not needed for summary)
                    loadImageData: false,    // ✅ Skip image data (not needed for summary)
                    loadICUMSData: true);    // ✅ Only load ICUMS data (needed for summary)
                cargoGroupLoadStopwatch.Stop();
                Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] GetCargoGroupAsync (first attempt) took: {cargoGroupLoadStopwatch.ElapsedMilliseconds}ms");
                
                if (_cargoGroupForSummary == null)
                {
                    // ✅ Try alternative cargo type if first attempt fails (container might be misclassified)
                    var alternativeType = actualCargoType == CargoType.Consolidated ? CargoType.NonConsolidated : CargoType.Consolidated;
                    Console.WriteLine($"⚠️ [LoadCargoGroupForSummary] Cargo group not found for {actualGroupIdentifier} as {actualCargoType}, trying {alternativeType}...");
                    cargoGroupLoadStopwatch.Restart();
                    _cargoGroupForSummary = await CargoGroupService.GetCargoGroupAsync(
                        actualGroupIdentifier, 
                        alternativeType,
                        loadScannerData: false,  // ✅ Skip scanner data
                        loadImageData: false,    // ✅ Skip image data
                        loadICUMSData: true);    // ✅ Only load ICUMS data
                    cargoGroupLoadStopwatch.Stop();
                    Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] GetCargoGroupAsync (alternative type) took: {cargoGroupLoadStopwatch.ElapsedMilliseconds}ms");
                    
                    if (_cargoGroupForSummary == null)
                    {
                        // ✅ Mark as failed - cargo group cannot be loaded
                        _cargoGroupLoadFailed = true;
                        Console.WriteLine($"❌ [LoadCargoGroupForSummary] Cargo group not found for summary: {actualGroupIdentifier} (tried both {actualCargoType} and {alternativeType})");
                        Console.WriteLine($"   Original GroupIdentifier: {GroupIdentifier}");
                        Console.WriteLine($"   IsConsolidated: {IsConsolidated}");
                        Console.WriteLine($"   Possible reasons:");
                        Console.WriteLine($"   - Cargo group service cannot find matching records for identifier '{actualGroupIdentifier}'");
                        Console.WriteLine($"   - BOE documents may exist but not be properly grouped");
                        Console.WriteLine($"   - Data may need to be reprocessed or synchronized");
                    }
                    else
                    {
                        Console.WriteLine($"✅ [LoadCargoGroupForSummary] Found cargo group as {alternativeType} (was initially classified as {actualCargoType})");
                        _cargoGroupLoadFailed = false; // Success - clear failure flag
                    }
                }
                else
                {
                    Console.WriteLine($"✅ [LoadCargoGroupForSummary] Loaded cargo group for summary: {actualGroupIdentifier}");
                    Console.WriteLine($"   Containers: {_cargoGroupForSummary.ContainerNumbers?.Count ?? 0}");
                    Console.WriteLine($"   ICUMS Records: {_cargoGroupForSummary.Data?.ICUMSData?.Count ?? 0}");
                    Console.WriteLine($"   Scanner Records: {_cargoGroupForSummary.Data?.ScannerData?.Count ?? 0}");
                    _cargoGroupLoadFailed = false; // Success - clear failure flag
                }
            }
            else
            {
                // No valid group identifier was determined
                _cargoGroupLoadFailed = true;
                Console.WriteLine($"⚠️ [LoadCargoGroupForSummary] Cannot load cargo group - no valid group identifier determined");
                Console.WriteLine($"   Original GroupIdentifier: {GroupIdentifier}");
                Console.WriteLine($"   IsConsolidated: {IsConsolidated}");
            }
        }
        catch (Exception ex)
        {
            _cargoGroupLoadFailed = true;
            Console.WriteLine($"❌ [LoadCargoGroupForSummary] Exception loading cargo group for summary: {ex.Message}");
            Console.WriteLine($"   Exception Type: {ex.GetType().Name}");
            Console.WriteLine($"   Stack Trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"   Inner Exception: {ex.InnerException.Message}");
            }
            Console.WriteLine($"   GroupIdentifier: {GroupIdentifier}");
            Console.WriteLine($"   IsConsolidated: {IsConsolidated}");
        }
        finally
        {
            totalStopwatch.Stop();
            _loadingCargoGroupForSummary = false;
            await InvokeAsync(StateHasChanged);
            
            Console.WriteLine($"⏱️ [LoadCargoGroupForSummary] COMPLETE - Total time: {totalStopwatch.ElapsedMilliseconds}ms ({totalStopwatch.Elapsed.TotalSeconds:F2}s)");
            Console.WriteLine($"   - Identifier resolution: {identifierResolutionStopwatch.ElapsedMilliseconds}ms");
            Console.WriteLine($"   - Cargo group loading: {cargoGroupLoadStopwatch.ElapsedMilliseconds}ms");
            Console.WriteLine($"   - Success: {_cargoGroupForSummary != null}");
        }
    }

