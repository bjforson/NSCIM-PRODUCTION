                        Snackbar.Add("No ICUMS data found for this declaration", Severity.Warning);
                        _allBOEData = new List<ICUMSDataRecordDto>();
                    }
                }
                else
                {
                    Console.WriteLine($"⚠️ [LoadBOEDetails] No containers available to load BOE details for declaration {GroupIdentifier}");
                    Snackbar.Add("No containers available to load ICUMS data", Severity.Warning);
                    _allBOEData = new List<ICUMSDataRecordDto>();
                }
            }
            else
            {
                Console.WriteLine($"⚠️ [LoadBOEDetails] No GroupIdentifier (declaration number) available");
                Snackbar.Add("No declaration number available", Severity.Warning);
                _allBOEData = new List<ICUMSDataRecordDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [LoadBOEDetails] Error loading BOE details: {ex.Message}");
            Console.WriteLine($"❌ [LoadBOEDetails] Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Error loading ICUMS data: {ex.Message}", Severity.Error);
            _allBOEData = new List<ICUMSDataRecordDto>();
        }
        finally
        {
            _loadingBOEDetails = false;
            await InvokeAsync(StateHasChanged); // Update UI after loading completes
        }
