    }

    // ✅ AUTO-PROGRESSION: Find first undecided container and expand it
    private async Task FindAndExpandFirstUndecidedContainer()
    {
        if (IsConsolidated || Containers == null || !Containers.Any())
        {
            return;
        }

        try
        {
            // Get all decisions for this group
            var overallDecision = await ApiService.GetAsync<OverallDecisionResponse>(
                $"/api/ImageAnalysisDecision/group/{GroupIdentifier}/overall");

            if (overallDecision == null)
            {
                // No decisions yet - find first container WITH IMAGES
                string? firstContainerWithImages = null;
                foreach (var container in Containers)
                {
                    var containerImages = await ContainerDetailsService.GetImageMetadataAsync(container);
                    if (containerImages != null && containerImages.Any())
                    {
                        firstContainerWithImages = container;
                        break;
                    }
                }
                
                if (firstContainerWithImages != null)
                {
                    _containerPanelsExpanded[firstContainerWithImages] = true;
                    _containerTabIndices[firstContainerWithImages] = 1; // Switch to Images tab
                    _containerImagesLoaded[firstContainerWithImages] = true;
                    _currentProcessingContainer = firstContainerWithImages;
                    Console.WriteLine($"✅ [ImageAnalysisViewDialog] Auto-expanded first container with images: {firstContainerWithImages}");
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] No containers with images found - all containers will be auto-marked by API");
                }
                return;
            }

            // Get decisions for each container to find undecided ones
            var decidedContainers = new HashSet<string>();
            var containersWithImages = new HashSet<string>();
            
            foreach (var container in Containers)
            {
                // Check if container has images (skip containers without images)
                var containerImages = await ContainerDetailsService.GetImageMetadataAsync(container);
                if (containerImages != null && containerImages.Any())
                {
                    containersWithImages.Add(container);
                    Console.WriteLine($"✅ [ImageAnalysisViewDialog] Container {container} has {containerImages.Count} image(s)");
                }
                else
                {
                    Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Container {container} has no images - will be skipped from auto-progression");
                }
                
                // Check if container has decisions
                var containerDecisions = await ApiService.GetAsync<List<ImageAnalysisDecisionDto>>(
                    $"/api/ImageAnalysisDecision/container/{container}");
                
                if (containerDecisions != null && containerDecisions.Any(d => 
                    d.Decision != "Pending" && !string.IsNullOrEmpty(d.Decision)))
                {
                    decidedContainers.Add(container);
                }
            }

            // ✅ FIX: Find first undecided container WITH IMAGES (skip containers without images)
            var undecidedContainersWithImages = containersWithImages
                .Where(c => !decidedContainers.Contains(c))
                .ToList();
            
            var firstUndecided = undecidedContainersWithImages.FirstOrDefault();
            if (firstUndecided != null)
            {
                _containerPanelsExpanded[firstUndecided] = true;
                _containerTabIndices[firstUndecided] = 1; // Switch to Images tab
                _containerImagesLoaded[firstUndecided] = true;
                _currentProcessingContainer = firstUndecided;
                Console.WriteLine($"✅ [ImageAnalysisViewDialog] Auto-expanded first undecided container with images: {firstUndecided}");
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                var containersWithoutImages = Containers.Where(c => !containersWithImages.Contains(c)).ToList();
                if (containersWithoutImages.Any())
                {
                    Console.WriteLine($"✅ [ImageAnalysisViewDialog] All containers with images have decisions. {containersWithoutImages.Count} container(s) without images will be auto-marked by API.");
                }
                else
                {
                    Console.WriteLine("✅ [ImageAnalysisViewDialog] All containers already have decisions");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Error finding undecided container: {ex.Message}");
            // Fallback: expand first container
            var firstContainer = Containers.First();
            _containerPanelsExpanded[firstContainer] = true;
            _containerTabIndices[firstContainer] = 1;
            _containerImagesLoaded[firstContainer] = true;
            _currentProcessingContainer = firstContainer;
            await InvokeAsync(StateHasChanged);
        }
    }

