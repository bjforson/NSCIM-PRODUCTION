    // Render the Cargo Info category as a line-item table (mirrors the
    // Summary tab's goods table). Used by both the House BL expansion
    // panel and the ICUMS Data tab so the layout is consistent.
    //
    // The API emits cargo info records as field/value pairs with the
    // format "Item {N}: {FieldName}" when there are multiple manifest
    // items, or just "{FieldName}" with no prefix when there's only one.
    // Known field names from ContainerDetailsController:
    //     "HS Code", "Item Description", "Quantity", "Weight",
    //     "FOB Value", "Duty Paid", "Item Country of Origin", "CPC"
    // Plus container-level (non-item-prefixed) fields:
    //     "Goods Description", "Country of Origin", "Container Weight",
    //     "Container Description", "Total Duty Paid"
    private RenderFragment RenderCargoInfoTable(List<ICUMSDataRecordDto> records) =>
        @<MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mt-1" Style="background:white;">
            <thead>
                <tr>
                    <th style="width:40px;">#</th>
                    <th>Description</th>
                    <th style="width:110px;">HS Code</th>
                    <th style="width:90px;">Quantity</th>
                    <th style="width:90px;">Weight</th>
                    <th style="width:110px;">FOB Value</th>
                    <th style="width:100px;">Duty Paid</th>
                    <th style="width:80px;">Origin</th>
                    <th style="width:60px;">CPC</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var itemGroups = GroupCargoInfoByItem(records);
                }
                @if (itemGroups.Count == 0)
                {
                    <tr>
                        <td colspan="9" style="text-align:center; color:#94a3b8; padding:8px;">
                            No line item details available
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var grp in itemGroups)
                    {
                        // Look up a field by trying multiple aliases (the API uses different
                        // names for the same logical column depending on the BOE shape).
                        string getField(params string[] aliases)
                        {
                            foreach (var alias in aliases)
                            {
                                var rec = grp.Value.FirstOrDefault(r =>
                                    string.Equals(r.Field, alias, StringComparison.OrdinalIgnoreCase));
                                if (rec != null && !string.IsNullOrWhiteSpace(rec.Value))
                                    return rec.Value;
                            }
                            return "-";
                        }
                        <tr>
                            <td style="color:#94a3b8;">@(grp.Key ?? "1")</td>
                            <td style="font-weight:500;">@getField("Item Description", "Description", "Goods Description", "Container Description")</td>
                            <td><code style="font-size:11px;">@getField("HS Code", "HSCode")</code></td>
                            <td>@getField("Quantity", "Qty")</td>
                            <td>@getField("Weight", "Container Weight")</td>
                            <td>@getField("FOB Value", "FOB", "FOBValue")</td>
                            <td>@getField("Duty Paid", "Total Duty Paid", "DutyPaid")</td>
                            <td>@getField("Item Country of Origin", "Country of Origin", "Origin")</td>
                            <td>@getField("CPC")</td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>;

    // Group raw ICUMS Cargo Info field/value records by their item number.
    //
    // The API uses two formats:
    //   1. "Item {N}: {FieldName}"   when there are multiple manifest items
    //   2. "{FieldName}"             when there's only one item (no prefix)
    //
    // We strip the "Item N: " prefix so the table renderer can look fields up
    // by their base name. Records WITHOUT a prefix are bucketed under item "1"
    // so the single-item case still produces one table row.
    private List<KeyValuePair<string?, List<ICUMSDataRecordDto>>> GroupCargoInfoByItem(List<ICUMSDataRecordDto> records)
    {
        var result = new Dictionary<string, List<ICUMSDataRecordDto>>();
        // "Item 1: Field Name", "Item 1 :Field Name", "Item 1 Field Name" — accept any
        var itemRegex = new System.Text.RegularExpressions.Regex(
            @"^Item\s+(\d+)\s*:?\s*(.*)$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        foreach (var r in records)
        {
            string itemKey;
            string baseField = (r.Field ?? string.Empty).Trim();
            var match = itemRegex.Match(baseField);
            if (match.Success && !string.IsNullOrEmpty(match.Groups[2].Value))
            {
                itemKey = match.Groups[1].Value;
                baseField = match.Groups[2].Value.Trim();
            }
            else
            {
                // No "Item N:" prefix → single-item BOE, bucket everything under "1"
                itemKey = "1";
            }

            if (!result.TryGetValue(itemKey, out var list))
            {
                list = new List<ICUMSDataRecordDto>();
                result[itemKey] = list;
            }
            list.Add(new ICUMSDataRecordDto
            {
                Field = baseField,
                Value = r.Value,
                Category = r.Category,
                IsRequired = r.IsRequired,
                HouseBL = r.HouseBL
            });
        }

        return result
            .OrderBy(kv => int.TryParse(kv.Key, out var n) ? n : int.MaxValue)
            .Select(kv => new KeyValuePair<string?, List<ICUMSDataRecordDto>>(kv.Key, kv.Value))
            .ToList();
    }

