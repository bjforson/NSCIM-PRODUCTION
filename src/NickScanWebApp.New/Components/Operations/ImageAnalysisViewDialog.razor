    private async Task LoadBOEDetails()
    {
        _loadingBOEDetails = true;
        await InvokeAsync(StateHasChanged); // Update UI to show loading spinner
        try
        {
            if (IsConsolidated)
            {
                // For consolidated cargo, GroupIdentifier = Container Number
                // Use the existing LoadBOEDetailsForConsolidated method
                await LoadBOEDetailsForConsolidated();
                return;
            }

            // ✅ FIX: For non-consolidated cargo, GroupIdentifier = Declaration Number
            // Query by declaration number to get ALL BOE fields for this declaration
            if (!string.IsNullOrEmpty(GroupIdentifier))
            {
                Console.WriteLine($"🔍 [LoadBOEDetails] Loading BOE details for declaration: {GroupIdentifier}");
                
                // For non-consolidated, query by declaration number using the first container as the route parameter
                // but pass declarationNumber as query parameter to get ALL BOE documents for this declaration
                if (Containers?.Any() == true)
                {
                    var firstContainer = Containers.First();
                    Console.WriteLine($"🔍 [LoadBOEDetails] Querying via container {firstContainer} for declaration {GroupIdentifier}");

                    // 6.01: routed through BuildContainerEndpointUrl helper (non-consolidated branch).
                    // Pass declarationNumber as query parameter to get all BOE documents for this declaration.
                    var icumsResponse = await ApiService.GetAsync<NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ICUMSDataRecord>>(
                        BuildContainerEndpointUrl("icums", GroupIdentifier, IsConsolidated, routeContainer: firstContainer));
                    
                    if (icumsResponse == null)
                    {
                        Console.WriteLine($"❌ [LoadBOEDetails] API returned null response for declaration {GroupIdentifier}");
                        Snackbar.Add("Failed to load ICUMS data: API returned null response", Severity.Error);
                        _allBOEData = new List<ICUMSDataRecordDto>();
                    }
                    else if (icumsResponse.Data?.Any() == true)
                    {
                        // Convert to DTO for display
                        _allBOEData = icumsResponse.Data.Select(r => new ICUMSDataRecordDto
                        {
                            Field = r.Field,
                            Value = r.Value,
                            Category = r.Category,
                            IsRequired = r.IsRequired,
                            HouseBL = r.HouseBL
                        }).ToList();
                        Console.WriteLine($"✅ [LoadBOEDetails] Loaded {_allBOEData.Count} BOE record(s) for declaration {GroupIdentifier} (Total: {icumsResponse.TotalCount})");
                        Snackbar.Add($"Loaded {_allBOEData.Count} ICUMS records", Severity.Success);
