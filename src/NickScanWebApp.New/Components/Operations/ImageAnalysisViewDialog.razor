@using MudBlazor
@using NickScanWebApp.New.Components.Containers
@using NickScanWebApp.New.Components.Operations
@using NickScanWebApp.New.Components.CargoGroup
@using NickScanWebApp.New.Components.ICUMS
@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using NickScanWebApp.New.Models
@using NickScanWebApp.New.Services
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject CargoGroupService CargoGroupService
@inject CargoSummaryService CargoSummaryService
@inject NickScanWebApp.New.Services.ImageAnalysisViewPreloader ImageAnalysisPreloader
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject NickScanWebApp.New.Services.SignedImageUrlBuilder UrlBuilder

        <MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.ImageSearch" Size="Size.Small" Class="mr-2" />
            Image Analysis View - @GroupIdentifier
        </MudText>
    </TitleContent>
    <DialogContent>
        @* The overall decision banner + cargo type header scroll naturally — only
           the MAIN TAB STRIP below it is sticky. Previously both elements were
           position:sticky;top:0 (header z-index 10, tabs z-index 9), so when the
           user scrolled, the tabs pinned to top:0 but the higher-z-index header
           covered them and the tab strip appeared to "disappear". Removing the
           sticky from the header lets it scroll out of view, leaving the tab
           strip pinned alone at the top of the viewport. *@
        <div style="padding: 0; display: flex; flex-direction: column; height: 100%;">
            <div style="background: var(--mud-palette-surface); padding: 16px; border-bottom: 2px solid var(--mud-palette-lines-default);">
            @* Overall Decision Banner *@
            <MudAlert Severity="@GetOverallSeverity()" Variant="Variant.Filled" Class="mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@GetOverallIcon()" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6">Overall Decision: @_overallDecision</MudText>
                        <MudText Typo="Typo.body2">
                            @_normalCount Normal | @_abnormalCount Abnormal | @_totalImages Total Images
                        </MudText>
                        @* ✅ PRIORITY 3.2: Progress indicator for multi-container records *@
                        @if (!IsConsolidated && Containers?.Count > 1 && !string.IsNullOrEmpty(_currentProcessingContainer))
                        {
                            var currentIndex = Containers.IndexOf(_currentProcessingContainer) + 1;
                            var totalContainers = Containers.Count;
                            <MudText Typo="Typo.body2" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Outlined.List" Size="Size.Small" /> 
                                Analyzing Container @currentIndex of @totalContainers
                            </MudText>
                        }
                        @* Display tags from all decisions *@
                        @if (_allDecisions.Any(d => !string.IsNullOrEmpty(d.Tags)))
                        {
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-2">
                                @foreach (var decision in _allDecisions.Where(d => !string.IsNullOrEmpty(d.Tags)))
                                {
                                    @foreach (var tag in decision.Tags!.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                            @tag (@decision.ScannerType)
                                        </MudChip>
                                    }
                                }
                            </MudStack>
                        }
                    </div>
                    <MudSpacer />
                    @if (!string.IsNullOrEmpty(_lastReviewedBy))
                    {
                        <MudText Typo="Typo.caption">
                            Last reviewed by <strong>@_lastReviewedBy</strong>
                        </MudText>
                    }
                </MudStack>
            </MudAlert>

            @* Wave Processing Banner *@
            @if (_waveContext != null && _waveContext.IsWave)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Outlined.Waves" Size="Size.Small" />
                        <MudText Typo="Typo.body2">
                            <strong>Wave @_waveContext.WaveNumber of @_waveContext.TotalWaves</strong>
                            — BOL: @_waveContext.ParentGroupIdentifier
                            — @_waveContext.ContainersInWaves/@_waveContext.TotalContainers containers in waves
                            — @_waveContext.DecidedContainers/@_waveContext.TotalContainers decided
                            @if (_waveContext.PendingContainers > 0)
                            {
                                <text> — @_waveContext.PendingContainers awaiting images (more waves expected)</text>
                            }
                        </MudText>
                    </MudStack>
                </MudAlert>
            }

            @* Cargo Type Header *@
            @if (IsConsolidated)
            {
                <MudText Typo="Typo.h6" Class="mb-0">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory" Color="Color.Info" />
                    Consolidated Cargo - Container: @GroupIdentifier
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="mb-0">
                    <MudIcon Icon="@Icons.Material.Outlined.Description" Color="Color.Success" />
                    Non-Consolidated Cargo - BOE: @GroupIdentifier
                </MudText>
            }
        </div>

        @* ✅ STATIC TABS: Sticky tab strip — pins to top of dialog viewport when
           the user scrolls within a tab panel. *@
        @* Legacy view *@
        @if (IsConsolidated)
        {
            <div style="position: sticky; top: 0; z-index: 10; background: var(--mud-palette-surface); border-bottom: 2px solid var(--mud-palette-lines-default);">
                @* CONSOLIDATED: Single Container → Show Scanner + Images + Multiple House BLs *@
                <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="false" PanelClass="" ActivePanelIndex="@_activeTabIndex" ActivePanelIndexChanged="@OnActiveTabChanged">
                <!-- Summary Tab -->
                <MudTabPanel Text="Summary" Icon="@Icons.Material.Outlined.Summarize">
                    <div @ref="_tabScrollRefSummary" style="height: calc(100vh - 300px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveScrollPosition(-1))">
                        @{
                            var summaryCargoGroup = _imageAnalysisContext?.CargoGroupContext?.Group ?? _cargoGroupForSummary;
                        }
                        @if (summaryCargoGroup != null)
                        {
                            <CargoGroupSummaryTab CargoGroup="@summaryCargoGroup" />
                        }
                        else if (_loadingCargoGroupForSummary || _isLoadingImageAnalysisContext)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                <MudText Typo="Typo.body2">Loading cargo summary...</MudText>
                            </MudStack>
                        }
                        else
                        {
                            @if (_cargoGroupLoadFailed)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.h6">Summary Not Available</MudText>
                                        <MudText Typo="Typo.body2">
                                            @if (IsConsolidated)
                                            {
                                                <text>Unable to load cargo summary for container <strong>@GroupIdentifier</strong>.</text>
                                            }
                                            else
                                            {
                                                <text>Unable to load cargo summary for declaration <strong>@GroupIdentifier</strong>.</text>
                                            }
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @if (IsConsolidated)
                                            {
                                                <text>The cargo summary requires a Master BL (Bill of Lading) number from the BOE document. The BOE document may exist but may be missing the BlNumber field, or the container may not have been processed through the customs system yet.</text>
                                            }
                                            else
                                            {
                                                <text>The cargo summary requires a Declaration Number from the BOE document. The BOE document may exist but may be missing the DeclarationNumber field, or the declaration may not have been processed through the customs system yet.</text>
                                            }
                                        </MudText>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => { _cargoGroupLoadFailed = false; _ = LoadCargoGroupForSummary(); })" StartIcon="@Icons.Material.Outlined.Refresh" Class="mt-2">
                                            Retry Loading Summary
                                        </MudButton>
                                    </MudStack>
                                </MudAlert>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">
                                    Cargo summary will be available once cargo group data is loaded.
                                </MudAlert>
                            }
                        }
                    </div>
                </MudTabPanel>
                
                <!-- Scanner Data Tab - ✅ FIX #2: Always load first tab -->
                <MudTabPanel Text="Scanner Data" Icon="@Icons.Material.Outlined.Scanner">
                    <div @ref="_tabScrollRef0" style="height: calc(100vh - 300px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveScrollPosition(0))">
                        @{
                            var consolidatedContainerCtx = _imageAnalysisContext?.GetConsolidatedContainerContext();
                        }
                        <ScannerDataTab ContainerNumber="@GroupIdentifier" 
                                       TotalRecords="@(consolidatedContainerCtx?.BasicInfo?.ScannerRecordCount ?? 0)"
                                       PreloadedData="@consolidatedContainerCtx?.ScannerData" />
                    </div>
                </MudTabPanel>

                <!-- Images Tab - With Decision Buttons -->
                <MudTabPanel Text="Images & Decisions" Icon="@Icons.Material.Outlined.Image">
                    <div @ref="_tabScrollRef1" style="height: calc(100vh - 300px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveScrollPosition(1))">
                        @* Split choice step: shown for 2-container scans before the normal viewer.
                           OnSplitChosen/Skipped bumps _splitResolveVersion which is part of
                           ImageDecisionView's @key, forcing it to re-mount and re-fetch the
                           image so the analyst sees the chosen crop (vs the unsplit image
                           it loaded on first render). *@
                        <SplitChoiceDialog ContainerNumber="@GroupIdentifier"
                                           OnSplitChosen="@OnSplitResolved"
                                           OnSplitSkipped="@OnSplitResolved" />
                        <ImageDecisionView @key="@($"{GroupIdentifier}_{_splitResolveVersion}")"
                                           ContainerNumber="@GroupIdentifier"
                                           GroupIdentifier="@GroupIdentifier"
                                           IsConsolidated="@IsConsolidated"
                                           OnDecisionChanged="@RefreshOverallDecision"
                                           OnDecisionSaved="@CloseDialogAfterSave"
                                           OnNextContainer="@HandleNextContainer"
                                           OnAllContainersDecided="@HandleAllContainersDecided" />
                    </div>
                </MudTabPanel>

                <!-- House BLs Tab — Expandable rows showing full HBL details + BOE fields per HBL -->
                <MudTabPanel Text="House BLs" Icon="@Icons.Material.Outlined.Description">
                    <div @ref="_tabScrollRef2" style="height: calc(100vh - 300px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveScrollPosition(3))">
                        @if (!_houseBLsLoaded)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { _houseBLsLoaded = true; await LoadHouseBLs(); })">
                                    Load House BLs
                                </MudButton>
                            </MudStack>
                        }
                        else if (_loadingHouseBLs)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (_houseBLDetails.Any())
                        {
                            <MudText Typo="Typo.subtitle1" Class="mb-3">
                                House Bills of Lading in this Container (@_houseBLDetails.Count)
                            </MudText>
                            <MudTable Items="_houseBLDetails" Dense="true" Hover="true" Bordered="true" Striped="true">
                                <HeaderContent>
                                    <MudTh Style="width:30px;"></MudTh>
                                    <MudTh>House BL</MudTh>
                                    <MudTh>Declaration</MudTh>
                                    <MudTh>Rotation</MudTh>
                                    <MudTh>Consignee</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh Style="width:90px;">Details</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        @if (_expandedHouseBLs.Contains(context.HouseBL))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                        }
                                    </MudTd>
                                    <MudTd Style="font-family: monospace;">@context.HouseBL</MudTd>
                                    <MudTd Style="font-family: monospace;">@context.DeclarationNumber</MudTd>
                                    <MudTd>@context.RotationNumber</MudTd>
                                    <MudTd>@context.ConsigneeName</MudTd>
                                    <MudTd><MudChip T="string" Size="Size.Small">@context.ClearanceType</MudChip></MudTd>
                                    <MudTd>
                                        @if (context.IsComplete)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" /> Complete
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                                <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small" /> Partial
                                            </MudChip>
                                        }
                                    </MudTd>
                                    <MudTd>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                                   Color="@(_expandedHouseBLs.Contains(context.HouseBL) ? Color.Default : Color.Primary)"
                                                   OnClick="@(() => ToggleHouseBLExpansion(context.HouseBL))">
                                            @(_expandedHouseBLs.Contains(context.HouseBL) ? "Hide" : "View")
                                        </MudButton>
                                    </MudTd>
                                </RowTemplate>
                                <ChildRowContent>
                                    @if (_expandedHouseBLs.Contains(context.HouseBL))
                                    {
                                        <MudTr>
                                            <td colspan="8" style="background: var(--mud-palette-background-grey); padding: 16px; border-left: 4px solid var(--mud-palette-primary);">
                                                @{
                                                    var hblBOEData = _allBOEData?.Where(r => r.HouseBL == context.HouseBL).ToList() ?? new List<ICUMSDataRecordDto>();
                                                }
                                                @if (hblBOEData.Any())
                                                {
                                                    var hblCategoryGroups = hblBOEData.GroupBy(r => r.Category ?? "Other").OrderBy(g => GetCategoryOrder(g.Key)).ToList();
                                                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                                                        Full BOE / ICUMS Details
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2">
                                                            @hblBOEData.Count field(s) across @hblCategoryGroups.Count category/categories
                                                        </MudChip>
                                                    </MudText>
                                                    @foreach (var categoryGroup in hblCategoryGroups)
                                                    {
                                                        <MudPaper Elevation="0" Class="pa-2 mb-2" Style="border: 1px solid var(--mud-palette-lines-default);">
                                                            <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight:600;">
                                                                <MudIcon Icon="@GetCategoryIcon(categoryGroup.Key)" Size="Size.Small" /> @categoryGroup.Key
                                                            </MudText>
                                                            @if (string.Equals(categoryGroup.Key, "Cargo Info", StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                @* Cargo Info — render as line-item table *@
                                                                @RenderCargoInfoTable(categoryGroup.ToList())
                                                            }
                                                            else
                                                            {
                                                                @* Generic field/value grid for other categories *@
                                                                <MudGrid Spacing="1" Class="mt-1">
                                                                    @foreach (var record in categoryGroup)
                                                                    {
                                                                        <MudItem xs="12" sm="6" md="4">
                                                                            <MudStack Row="true" Spacing="1">
                                                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight:600; min-width: 120px;">
                                                                                    @record.Field
                                                                                </MudText>
                                                                                <MudText Typo="Typo.caption">@(record.Value ?? "N/A")</MudText>
                                                                            </MudStack>
                                                                        </MudItem>
                                                                    }
                                                                </MudGrid>
                                                            }
                                                        </MudPaper>
                                                    }
                                                }
                                                else if (_allBOEData == null || !_allBOEData.Any())
                                                {
                                                    <MudAlert Severity="Severity.Info" Dense="true">
                                                        Open the <strong>ICUMS Data</strong> tab once to load full BOE details for each House BL.
                                                    </MudAlert>
                                                }
                                                else
                                                {
                                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                                        No BOE / ICUMS field data found for House BL <strong>@context.HouseBL</strong>.
                                                    </MudAlert>
                                                }
                                            </td>
                                        </MudTr>
                                    }
                                </ChildRowContent>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">No House BL details available</MudAlert>
                        }
                    </div>
                </MudTabPanel>
                
                <!-- ICUMS Data Tab (Shows BOE for IM/EX, CMR data for CMR clearance) - ✅ FIX: Lazy load like images -->
                <MudTabPanel Text="ICUMS Data" Icon="@Icons.Material.Outlined.ListAlt">
                    <div @ref="_tabScrollRef3" style="height: calc(100vh - 300px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveScrollPosition(3))">
                        @if (_icumsDataLoaded)
                    {
                        @if (_loadingBOEDetails)
                        {
                            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-8">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                <MudText Typo="Typo.body1">Loading ICUMS data...</MudText>
                            </MudStack>
                        }
                        else if (_allBOEData?.Any() == true)
                        {
                            <MudText Typo="Typo.h6" Class="mb-4">Complete ICUMS Details (BOE/CMR)</MudText>
                            
                            @* ✅ DYNAMIC: Consolidated cargo - Show House BLs in collapsible panels *@
                            @if (_allBOEData.Any(r => !string.IsNullOrEmpty(r.HouseBL)))
                            {
                                var houseBLGroups = _allBOEData.GroupBy(r => r.HouseBL ?? "N/A").OrderBy(g => g.Key).ToList();
                                var houseBLCount = houseBLGroups.Count();
                                
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory" Class="mr-2" />
                                    <strong>Consolidated Cargo:</strong> @houseBLCount House BL(s) for container @GroupIdentifier
                                </MudAlert>
                                
                                <MudExpansionPanels MultiExpansion="true" Class="mt-3">
                                    @foreach (var houseBLGroup in houseBLGroups)
                                    {
                                        var houseBLData = houseBLGroup.ToList();
                                        var categoryGroups = houseBLData.GroupBy(r => r.Category).OrderBy(g => GetCategoryOrder(g.Key)).ToList();
                                        var totalFields = houseBLData.Count;
                                        
                                        <MudExpansionPanel Text="@($"House BL: {houseBLGroup.Key}")" 
                                                           Icon="@Icons.Material.Outlined.Article"
                                                           IsExpanded="false">
                                            <MudStack Spacing="2" Class="pa-2">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                                    @totalFields field(s) across @categoryGroups.Count category/categories
                                                </MudChip>
                                                
                                                @* Display categories for this House BL - Now collapsible.
                                                   The "Cargo Info" category is rendered as a line-item TABLE
                                                   (matches the Summary tab), all others use a field/value grid. *@
                                                <MudExpansionPanels MultiExpansion="true" Class="mt-2">
                                                    @foreach (var categoryGroup in categoryGroups)
                                                    {
                                                        <MudExpansionPanel Text="@categoryGroup.Key"
                                                                           Icon="@GetCategoryIcon(categoryGroup.Key)"
                                                                           IsExpanded="@(string.Equals(categoryGroup.Key, "Cargo Info", StringComparison.OrdinalIgnoreCase))">
                                                            <MudStack Spacing="2" Class="pa-2">
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                                    @categoryGroup.Count() field(s)
                                                                </MudChip>

                                                                @if (string.Equals(categoryGroup.Key, "Cargo Info", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    @RenderCargoInfoTable(categoryGroup.ToList())
                                                                }
                                                                else
                                                                {
                                                                    <MudGrid Spacing="2">
                                                                        @foreach (var record in categoryGroup)
                                                                        {
                                                                            <MudItem xs="12" sm="6" md="4">
                                                                                <MudStack Spacing="0">
                                                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                                            <strong>@record.Field</strong>
                                                                                        </MudText>
                                                                                        @if (record.IsRequired)
                                                                                        {
                                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Style="height: 18px; font-size: 0.7rem;">Required</MudChip>
                                                                                        }
                                                                                    </MudStack>
                                                                                    <MudText Typo="Typo.body2">@(record.Value ?? "N/A")</MudText>
                                                                                </MudStack>
                                                                            </MudItem>
                                                                        }
                                                                    </MudGrid>
                                                                }
                                                            </MudStack>
                                                        </MudExpansionPanel>
                                                    }
                                                </MudExpansionPanels>
                                            </MudStack>
                                        </MudExpansionPanel>
                                    }
                                </MudExpansionPanels>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Warning">No ICUMS details with House BL grouping available</MudAlert>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning">No ICUMS data available</MudAlert>
                        }
                    }
                    </div>
                </MudTabPanel>
            </MudTabs>
            </div>
        }
        else
        {
            @* NON-CONSOLIDATED: Multiple Containers under one BOE *@
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Containers under this Bill of Entry:
            </MudText>

            @if (_loadingContainers)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (Containers?.Any() == true)
            {
                @* ✅ PRIORITY 3.2: Warning for containers without images *@
                @* Note: Full image check happens in backend, this is just for UI display *@
                
                @* Use existing ContainerDetailsModal pattern for each container *@
                @if (Containers?.Count > 1)
                {
                    <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Bulk Action:</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                   StartIcon="@Icons.Material.Outlined.CheckCircle"
                                   OnClick="@(() => BulkDecision("Normal"))"
                                   Disabled="@_bulkProcessing">
                            All Normal
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                   StartIcon="@Icons.Material.Outlined.Warning"
                                   OnClick="@(() => BulkDecision("Abnormal"))"
                                   Disabled="@_bulkProcessing">
                            All Abnormal
                        </MudButton>
                        @if (_bulkProcessing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <MudText Typo="Typo.caption">@_bulkProgressText</MudText>
                        }
                    </MudStack>
                }
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var container in Containers)
                    {
                        var containerIndex = Containers.IndexOf(container) + 1;
                        var totalContainers = Containers.Count;
                        var isExpanded = _containerPanelsExpanded.ContainsKey(container) && _containerPanelsExpanded[container];
                        <MudExpansionPanel IsExpanded="@isExpanded"
                                           IsExpandedChanged="@((bool expanded) => { 
                                               _containerPanelsExpanded[container] = expanded; 
                                               // ✅ Track current container when manually expanded
                                               if (expanded) _currentProcessingContainer = container;
                                           })">
                            <TitleContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" 
                                             Color="@GetContainerDecisionColor(container)" 
                                             Size="Size.Medium" />
                                    <MudText Typo="Typo.body1">
                                        @container (@containerIndex/@totalContainers)
                                    </MudText>
                                    @* ✅ PRIORITY 3.2: Warning icon for containers without images (if detected) *@
                                    @* Note: Full image check happens in backend, this is just visual indicator *@
                                </MudStack>
                            </TitleContent>
                            <ChildContent>
                                @* Each container gets its own tab view with Scanner, Images, and ICUMS data - ✅ FIX: Add tab change handler *@
                                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="false" PanelClass="" 
                                         ActivePanelIndex="@(_containerTabIndices.TryGetValue(container, out var idx) ? idx : 0)"
                                         ActivePanelIndexChanged="@((int newIdx) => OnNestedTabChanged(container, newIdx))">
                                    <!-- Summary Tab -->
                                    <MudTabPanel Text="Summary" Icon="@Icons.Material.Outlined.Summarize">
                                        <div style="height: calc(100vh - 400px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveNestedScrollPosition(container, -1))">
                                            @{
                                                var nestedSummaryCargoGroup = _imageAnalysisContext?.CargoGroupContext?.Group ?? _cargoGroupForSummary;
                                            }
                                            @if (nestedSummaryCargoGroup != null)
                                            {
                                                <CargoGroupSummaryTab CargoGroup="@nestedSummaryCargoGroup" />
                                            }
                                            else if (_loadingCargoGroupForSummary || _isLoadingImageAnalysisContext)
                                            {
                                                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                                    <MudText Typo="Typo.body2">Loading cargo summary...</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                @if (_cargoGroupLoadFailed)
                                                {
                                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                                                        <MudStack Spacing="2">
                                                            <MudText Typo="Typo.h6">Summary Not Available</MudText>
                                                            <MudText Typo="Typo.body2">
                                                                Unable to load cargo summary for container <strong>@container</strong>.
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                The cargo summary requires BOE data with a valid Declaration Number or Master BL. The BOE document may exist but may be missing required grouping fields, or the container may not have been processed through the customs system yet.
                                                            </MudText>
                                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => { _cargoGroupLoadFailed = false; _ = LoadCargoGroupForSummary(); })" StartIcon="@Icons.Material.Outlined.Refresh" Class="mt-2">
                                                                Retry Loading Summary
                                                            </MudButton>
                                                        </MudStack>
                                                    </MudAlert>
                                                }
                                                else
                                                {
                                                    <MudAlert Severity="Severity.Info">
                                                        Cargo summary will be available once cargo group data is loaded.
                                                    </MudAlert>
                                                }
                                            }
                                        </div>
                                    </MudTabPanel>
                                    
                                    <!-- Scanner Data Tab -->
                                    <MudTabPanel Text="Scanner Data" Icon="@Icons.Material.Outlined.Scanner">
                                        <div style="height: calc(100vh - 400px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveNestedScrollPosition(container, 0))">
                                            @{
                                                var containerCtx = _imageAnalysisContext?.GetContainerContext(container);
                                            }
                                            <ScannerDataTab ContainerNumber="@container" 
                                                           TotalRecords="@(containerCtx?.BasicInfo?.ScannerRecordCount ?? 0)"
                                                           PreloadedData="@containerCtx?.ScannerData" />
                                        </div>
                                    </MudTabPanel>

                                    <!-- Images Tab - With Decision Buttons -->
                                    <MudTabPanel Text="Images & Decisions" Icon="@Icons.Material.Outlined.Image">
                                        <div style="height: calc(100vh - 400px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveNestedScrollPosition(container, 1))">
                                            @* Split choice step: shown for 2-container scans before the normal viewer.
                                               Per-container resolve counter so picking a split on container A
                                               doesn't remount container B's view. *@
                                            <SplitChoiceDialog ContainerNumber="@container"
                                                               OnSplitChosen="@(() => OnContainerSplitResolved(container))"
                                                               OnSplitSkipped="@(() => OnContainerSplitResolved(container))" />
                                            <ImageDecisionView @key="@($"{container}_{(_perContainerSplitVersion.TryGetValue(container, out var v) ? v : 0)}")"
                                                               ContainerNumber="@container"
                                                               GroupIdentifier="@GroupIdentifier"
                                                               IsConsolidated="@IsConsolidated"
                                                               OnDecisionChanged="@RefreshOverallDecision"
                                                               OnDecisionSaved="@CloseDialogAfterSave"
                                                               OnNextContainer="@HandleNextContainer"
                                                               OnAllContainersDecided="@HandleAllContainersDecided"
                                                               AutoOpenImage="@(_containerAutoOpen.TryGetValue(container, out var ao) && ao)"
                                                               OnAutoOpenHandled="@(() => _containerAutoOpen[container] = false)" />
                                        </div>
                                    </MudTabPanel>

                                    <!-- ICUMS Data Tab (Shows BOE for IM/EX, CMR data for CMR clearance) - ✅ FIX: Lazy load like images -->
                                    <MudTabPanel Text="ICUMS Data" Icon="@Icons.Material.Outlined.Description">
                                        <div style="height: calc(100vh - 400px); overflow-y: auto; padding: 16px;" @onscroll="@(() => SaveNestedScrollPosition(container, 2))">
                                            @* ✅ FIX: ICUMS data is shared across all containers for non-consolidated cargo *@
                                            @if (_icumsDataLoaded)
                                        {
                                            @* ✅ DYNAMIC: Non-consolidated cargo - Show containers in collapsible panels with shared BOE data *@
                                            @if (_loadingBOEDetails)
                                            {
                                                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-8">
                                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                                    <MudText Typo="Typo.body1">Loading ICUMS data...</MudText>
                                                </MudStack>
                                            }
                                            else if (_allBOEData?.Any() == true && Containers?.Any() == true)
                                            {
                                                <MudText Typo="Typo.h6" Class="mb-4">Complete ICUMS Details (BOE/CMR)</MudText>
                                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Description" Class="mr-2" />
                                                    <strong>Declaration Number:</strong> @GroupIdentifier | <strong>Containers:</strong> @Containers.Count container(s) (shared BOE data)
                                                </MudAlert>
                                                
                                                <MudExpansionPanels MultiExpansion="true" Class="mt-3">
                                                    @foreach (var container in Containers)
                                                    {
                                                        var categoryGroups = _allBOEData.GroupBy(r => r.Category).OrderBy(g => GetCategoryOrder(g.Key)).ToList();
                                                        var totalFields = _allBOEData.Count;
                                                        
                                                        <MudExpansionPanel Text="@($"Container: {container}")" 
                                                                           Icon="@Icons.Material.Outlined.Inventory2"
                                                                           IsExpanded="false">
                                                            <MudStack Spacing="2" Class="pa-2">
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                                                    @totalFields field(s) across @categoryGroups.Count category/categories
                                                                </MudChip>
                                                                
                                                                @* Display categories (shared BOE data for all containers) - Now collapsible *@
                                                                <MudExpansionPanels MultiExpansion="true" Class="mt-2">
                                                                    @foreach (var categoryGroup in categoryGroups)
                                                                    {
                                                                        <MudExpansionPanel Text="@categoryGroup.Key" 
                                                                                           Icon="@GetCategoryIcon(categoryGroup.Key)"
                                                                                           IsExpanded="false">
                                                                            <MudStack Spacing="2" Class="pa-2">
                                                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                                                    @categoryGroup.Count() field(s)
                                                                                </MudChip>
                                                                                
                                                                                <MudGrid Spacing="2">
                                                                                    @foreach (var record in categoryGroup)
                                                                                    {
                                                                                        <MudItem xs="12" sm="6" md="4">
                                                                                            <MudStack Spacing="0">
                                                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                                                        <strong>@record.Field</strong>
                                                                                                    </MudText>
                                                                                                    @if (record.IsRequired)
                                                                                                    {
                                                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Style="height: 18px; font-size: 0.7rem;">Required</MudChip>
                                                                                                    }
                                                                                                </MudStack>
                                                                                                <MudText Typo="Typo.body2">@(record.Value ?? "N/A")</MudText>
                                                                                            </MudStack>
                                                                                        </MudItem>
                                                                                    }
                                                                                </MudGrid>
                                                                            </MudStack>
                                                                        </MudExpansionPanel>
                                                                    }
                                                                </MudExpansionPanels>
                                                            </MudStack>
                                                        </MudExpansionPanel>
                                                    }
                                                </MudExpansionPanels>
                                            }
                                            else if (_allBOEData?.Any() == true && (Containers == null || !Containers.Any()))
                                            {
                                                <MudAlert Severity="Severity.Warning">BOE data loaded but no containers found</MudAlert>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Warning">No ICUMS data available</MudAlert>
                                            }
                                        }
                                        </div>
                                    </MudTabPanel>
                                </MudTabs>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
            else
            {
                <MudAlert Severity="Severity.Warning">No containers found for this record</MudAlert>
            }
        }
        </div>
    </DialogContent>
    
</MudDialog>

@code {
