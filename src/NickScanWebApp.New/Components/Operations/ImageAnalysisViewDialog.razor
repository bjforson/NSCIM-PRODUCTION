    private async Task LoadContainers()
    {
        _loadingContainers = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            Console.WriteLine($"🔍 [LoadContainers] Loading containers for declaration: {GroupIdentifier}");
            Console.WriteLine($"🔍 [LoadContainers] Passed Containers parameter: {(Containers?.Any() == true ? string.Join(", ", Containers) : "None")}");
            
            // API returns List<string> - just container numbers
            var containerList = await ApiService.GetAsync<List<string>>(
                $"/api/consolidatedcargo/declaration/{GroupIdentifier}/containers") ?? new();
            
            Console.WriteLine($"🔍 [LoadContainers] API returned {containerList.Count} container(s)");
            
            if (!containerList.Any() && Containers?.Any() == true)
            {
                // Use the Containers parameter if API didn't return anything
                Console.WriteLine($"⚠️ [LoadContainers] API returned empty list, using passed Containers parameter ({Containers.Count} containers)");
                containerList = Containers;
            }
            
            Containers = containerList;
            
            Console.WriteLine($"✅ [LoadContainers] Final container list: {Containers?.Count ?? 0} container(s)");

            // ✅ AUTO-PROGRESSION: Find first undecided container and expand it
            await FindAndExpandFirstUndecidedContainer();

            // Also load BOE details for this declaration number
            await LoadBOEDetails();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [LoadContainers] Error loading containers: {ex.Message}");
            Console.WriteLine($"❌ [LoadContainers] Stack trace: {ex.StackTrace}");
            
            // ✅ FIX: If API fails, use the Containers parameter that was passed
            if (Containers?.Any() == true)
            {
                Console.WriteLine($"✅ [LoadContainers] Using passed Containers parameter as fallback ({Containers.Count} containers)");
                Snackbar.Add($"Using cached container list ({Containers.Count} containers)", Severity.Info);
            }
            else
            {
                Console.WriteLine($"⚠️ [LoadContainers] No containers available from API or parameter");
                Snackbar.Add($"Error loading container list: {ex.Message}", Severity.Warning);
            }
        }
        finally
        {
            _loadingContainers = false;
        }
    }

