    private bool _loadingHouseBLs = false;
    private bool _loadingContainers = false;
    private bool _loadingBOEDetails = false;
    private List<HouseBLDetailDto> _houseBLDetails = new();
    private List<ICUMSDataRecordDto>? _allBOEData = null;

    // House BL row expansion state — track which HBLs the user has clicked
