    private bool _isLoadingImageAnalysisContext = false;
    
    // ✅ PERFORMANCE FIX #3: Cache group identifier resolution to avoid repeated API calls
    private static readonly Dictionary<string, CachedGroupIdentifier> _groupIdentifierCache = new();
    private static readonly object _groupIdentifierCacheLock = new();
    private const int MaxGroupIdentifierCacheSize = 100;
    
    private class CachedGroupIdentifier
    {
        public string GroupIdentifier { get; set; } = string.Empty;
        public CargoType Type { get; set; }
        public DateTime CachedAt { get; set; }
    }

    /// <summary>
    /// 6.01 (Sprint 4 — frontend contract de-fragmentation): centralizes the
    /// "IsConsolidated => GroupIdentifier IS the container number" routing
    /// assumption that previously lived inline at every URL-construction site
    /// in this dialog.
    ///
    /// For consolidated cargo, GroupIdentifier IS the container number — pass
    /// it directly into the route. For non-consolidated cargo, GroupIdentifier
    /// is a declaration number, so we pass the first scanned container as the
    /// route key and tag the declaration via the ?declarationNumber query string.
    ///
    /// IMPORTANT: this helper does NOT fix the underlying assumption — it only
    /// makes it single-source-of-truth so the next mistag-class bug
    /// (e.g. 2026-05-04's MasterBlNumber regression) is a one-line fix here
    /// instead of touching N callsites. The proper fix is server-side
    /// disambiguation (one endpoint that takes (groupIdentifier, isConsolidated)
    /// and dispatches), which is L-effort and scoped to a future sprint.
    ///
    /// **If `IsConsolidated` is wrong (e.g. mistag at ingest), this URL still
    /// won't return correct data — fix the upstream tag, don't fight it
    /// client-side.**
    ///
    /// Used by 3 callsites in this file (LoadBOEDetailsForConsolidated /
    /// LoadBOEDetails / PreloadICUMSData) for the /api/containerdetails/{endpoint}
    /// family. The /api/consolidatedcargo/* and /api/ImageAnalysisDecision/* sites
    /// embody the same routing assumption but on different endpoint families;
    /// they are documented at their callsites and gated by the same
    /// IsConsolidated branch.
    /// </summary>
    /// <param name="endpoint">
    /// The /api/containerdetails sub-route (e.g. "icums", "scanner").
    /// </param>
    /// <param name="groupIdentifier">
    /// The dialog's GroupIdentifier — container number when consolidated,
    /// declaration number when non-consolidated.
    /// </param>
    /// <param name="isConsolidated">
    /// Routing flag from the assignment row. Drives whether the URL keys on
    /// container-number or declaration-number+route-container.
    /// </param>
    /// <param name="declarationNumber">
    /// Used in the non-consolidated branch as a query-string discriminator.
    /// When null and !isConsolidated, falls back to groupIdentifier.
    /// </param>
    /// <param name="page">Pagination page (default 1).</param>
    /// <param name="pageSize">Pagination size (default 1000).</param>
    /// <param name="routeContainer">
    /// Required for the non-consolidated branch — the container number to use as
    /// the route key (typically Containers.First()). Throws if null on that path.
    /// </param>
    private string BuildContainerEndpointUrl(
        string endpoint,
        string groupIdentifier,
        bool isConsolidated,
        string? declarationNumber = null,
        int page = 1,
        int pageSize = 1000,
        string? routeContainer = null)
    {
        if (string.IsNullOrWhiteSpace(endpoint))
        {
            throw new ArgumentException("endpoint must be non-empty", nameof(endpoint));
        }
        if (string.IsNullOrWhiteSpace(groupIdentifier))
        {
            throw new ArgumentException("groupIdentifier must be non-empty", nameof(groupIdentifier));
        }

        if (isConsolidated)
        {
            // Consolidated: GroupIdentifier IS the container number. Hit the route
            // directly; no declarationNumber discriminator needed.
            return $"/api/containerdetails/{endpoint}/{Uri.EscapeDataString(groupIdentifier)}?page={page}&pageSize={pageSize}";
        }

        // Non-consolidated: GroupIdentifier is a declaration number. Use a
        // representative container number as the route key, attach the declaration
        // as a query-string discriminator. The controller's declaration-keyed
        // branch then returns ALL BOE documents for that declaration regardless
        // of which container's BOEs were originally hit.
        var routeCn = routeContainer
            ?? throw new InvalidOperationException(
                "BuildContainerEndpointUrl: non-consolidated path requires a routeContainer (typically Containers.First()).");
        var decl = declarationNumber ?? groupIdentifier;
        return $"/api/containerdetails/{endpoint}/{Uri.EscapeDataString(routeCn)}?page={page}&pageSize={pageSize}&declarationNumber={Uri.EscapeDataString(decl)}";
    }

    // ✅ FIX #2: Handle tab changes for lazy loading (CONSOLIDATED view)
    private async Task OnActiveTabChanged(int newIndex)
    {
        Console.WriteLine($"🔄 [ImageAnalysisViewDialog] Tab changed from {_activeTabIndex} to {newIndex} (Consolidated)");
        
        // Save scroll position of previous tab
        SaveScrollPosition(_activeTabIndex);
        
        _activeTabIndex = newIndex;
        
        // Restore scroll position of new tab
        await RestoreScrollPosition(newIndex);
        
        // Load tab content when activated
        if (newIndex == 0 && _cargoGroupForSummary == null && !_loadingCargoGroupForSummary)
        {
            // Summary tab - load cargo group if not already loaded (or retry if it failed)
            Console.WriteLine($"📊 [ImageAnalysisViewDialog] Summary tab activated (consolidated), loading cargo group for {GroupIdentifier}");
            _cargoGroupLoadFailed = false; // Reset failure flag when retrying
            _ = LoadCargoGroupForSummary();
        }
        else if (newIndex == 1 && !_imagesTabLoaded)
        {
            Console.WriteLine($"🖼️ [ImageAnalysisViewDialog] Images & Decisions tab activated, loading images for {GroupIdentifier}");
            _imagesTabLoaded = true;
            // Force immediate UI update to show ImageDecisionView
            await InvokeAsync(StateHasChanged);
            // Small delay to ensure UI is updated before component renders
            await Task.Delay(50);
            await InvokeAsync(StateHasChanged);
        }
        else if (newIndex == 2 && !_houseBLsLoaded && IsConsolidated)
        {
            _houseBLsLoaded = true;
            await InvokeAsync(StateHasChanged);
            _ = LoadHouseBLs();
        }
        else if (newIndex == 3 && IsConsolidated)
        {
            // If data is already loaded, just show it
            if (_allBOEData != null && _allBOEData.Any())
            {
                Console.WriteLine($"✅ [ImageAnalysisViewDialog] ICUMS data already loaded ({_allBOEData.Count} records), displaying immediately");
                _icumsDataLoaded = true;
                await InvokeAsync(StateHasChanged);
                return;
            }
            
            // If not loaded yet, set flag and load
            if (!_icumsDataLoaded)
            {
                _icumsDataLoaded = true;
                await InvokeAsync(StateHasChanged); // Update UI immediately to show loading spinner
                await LoadBOEDetailsForConsolidated();
                await InvokeAsync(StateHasChanged); // Update UI after loading completes
            }
            else
            {
                // Data is loading, just wait for it
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    
    // ✅ FIX #1: Handle tab changes for nested tabs (NON-CONSOLIDATED view)
    private async Task OnNestedTabChanged(string containerNumber, int newIndex)
    {
        Console.WriteLine($"🔄 [ImageAnalysisViewDialog] Nested tab changed for container {containerNumber}: index {newIndex} (Non-Consolidated)");
        
        // Save scroll position of previous tab
        var oldIndex = _containerTabIndices.TryGetValue(containerNumber, out var idx) ? idx : 0;
        SaveNestedScrollPosition(containerNumber, oldIndex);
        
        _containerTabIndices[containerNumber] = newIndex;
        
        // Restore scroll position of new tab
        await RestoreNestedScrollPosition(containerNumber, newIndex);
        
        // Load tab content when activated
        if (newIndex == 0 && _cargoGroupForSummary == null && !_loadingCargoGroupForSummary)
        {
            // Summary tab - load cargo group if not already loaded (or retry if it failed)
            Console.WriteLine($"📊 [ImageAnalysisViewDialog] Summary tab activated, loading cargo group for {GroupIdentifier}");
            _cargoGroupLoadFailed = false; // Reset failure flag when retrying
            _ = LoadCargoGroupForSummary();
        }
        else if (newIndex == 1 && (!_containerImagesLoaded.ContainsKey(containerNumber) || !_containerImagesLoaded[containerNumber]))
        {
            Console.WriteLine($"🖼️ [ImageAnalysisViewDialog] Images & Decisions tab activated (non-consolidated) for container {containerNumber}");
            _containerImagesLoaded[containerNumber] = true;
            // Force immediate UI update to show ImageDecisionView
            await InvokeAsync(StateHasChanged);
            // Small delay to ensure UI is updated before component renders
            await Task.Delay(50);
            await InvokeAsync(StateHasChanged);
        }
        else if (newIndex == 2)
        {
            // ✅ FIX: ICUMS data is shared across all containers for non-consolidated, use shared flag
            Console.WriteLine($"✅ [ImageAnalysisViewDialog] ICUMS tab activated for non-consolidated cargo (BOE: {GroupIdentifier})");
            
            // If data is already loaded, just show it
            if (_allBOEData != null && _allBOEData.Any())
            {
                Console.WriteLine($"✅ [ImageAnalysisViewDialog] ICUMS data already loaded ({_allBOEData.Count} records), displaying immediately");
                _icumsDataLoaded = true;
                await InvokeAsync(StateHasChanged);
                return;
            }
            
            // If not loaded yet, set flag and load
            if (!_icumsDataLoaded)
            {
                _icumsDataLoaded = true;
                await InvokeAsync(StateHasChanged); // Update UI immediately to show loading spinner
                await LoadBOEDetails(); // Load BOE data (shared across all containers for this declaration)
                await InvokeAsync(StateHasChanged); // Update UI after loading completes
            }
            else
            {
                // Data is loading, just wait for it
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    
