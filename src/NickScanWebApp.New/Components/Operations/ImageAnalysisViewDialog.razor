    private async Task RefreshOverallDecision()
    {
        try
        {
            var response = await ApiService.GetAsync<OverallDecisionDto>(
                $"/api/ImageAnalysisDecision/group/{GroupIdentifier}/overall");
            
            if (response != null)
            {
                _overallDecision = response.OverallDecision;
                _totalImages = response.TotalImages;
                _normalCount = response.NormalCount;
                _abnormalCount = response.AbnormalCount;
                _lastReviewedBy = response.LastReviewedBy;
            }

            // Also load all decisions to get tags
            if (IsConsolidated)
            {
                // For consolidated, GroupIdentifier = Container Number
                _allDecisions = await ApiService.GetAsync<List<ImageAnalysisDecisionDto>>(
                    $"/api/ImageAnalysisDecision/container/{GroupIdentifier}") ?? new();
            }
            else
            {
                // For non-consolidated, load decisions for all containers in the group
                _allDecisions = new List<ImageAnalysisDecisionDto>();
                if (Containers?.Any() == true)
                {
                    foreach (var container in Containers)
                    {
                        var containerDecisions = await ApiService.GetAsync<List<ImageAnalysisDecisionDto>>(
                            $"/api/ImageAnalysisDecision/container/{container}") ?? new();
                        _allDecisions.AddRange(containerDecisions);
                    }
                }
            }
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading overall decision: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
