    // ✅ CONTAINER DECISION COLOR: Get decision status for a container
    private string GetContainerDecision(string containerNumber)
    {
        if (_allDecisions == null || !_allDecisions.Any())
            return "Pending";
        
        var containerDecisions = _allDecisions
            .Where(d => d.ContainerNumber == containerNumber && 
                        d.Decision != "Pending" && 
                        !string.IsNullOrEmpty(d.Decision))
            .ToList();
        
        // If any decision is Abnormal, return Abnormal (most severe)
        if (containerDecisions.Any(d => d.Decision == "Abnormal"))
            return "Abnormal";
        
        // If all decisions are Normal, return Normal
        if (containerDecisions.Any() && containerDecisions.All(d => d.Decision == "Normal"))
            return "Normal";
        
        return "Pending";
    }

    // ✅ CONTAINER DECISION COLOR: Get color based on decision status
    private Color GetContainerDecisionColor(string containerNumber)
    {
        var decision = GetContainerDecision(containerNumber);
        return decision switch
        {
            "Normal" => Color.Success,    // Green
            "Abnormal" => Color.Error,    // Red
            _ => Color.Default            // Default (no decision taken)
        };
    }

