    // ✅ AUTO-PROGRESSION: Handle next container
    private async Task HandleNextContainer(string? nextContainerNumber)
    {
        if (string.IsNullOrEmpty(nextContainerNumber))
            return;

        Console.WriteLine($"🔄 [ImageAnalysisViewDialog] Auto-progressing to next container: {nextContainerNumber}");

        if (IsConsolidated)
            return;

        // Check if nextContainer is in the Containers list.
        // For cross-record scans, the API may return comma-separated pairs (e.g. "CONT1, CONT2")
        // that don't match the individual entries in the Containers list.
        var isInList = Containers?.Contains(nextContainerNumber) == true;
        if (!isInList && Containers != null)
        {
            // Try to find a matching entry (partial match for comma-separated pairs)
            var match = Containers.FirstOrDefault(c =>
                nextContainerNumber.Contains(c, StringComparison.OrdinalIgnoreCase) ||
                c.Contains(nextContainerNumber, StringComparison.OrdinalIgnoreCase));
            if (match != null)
            {
                isInList = true;
            }
        }

        if (!isInList)
        {
            // Not in list at all — still allow opening directly (the API determined this is the next container)
            Console.WriteLine($"⚠️ [ImageAnalysisViewDialog] Container '{nextContainerNumber}' not in UI list — opening directly via fullscreen viewer");
            Snackbar.Add($"Loading next container: {nextContainerNumber}...", Severity.Info);
            await DirectOpenFullscreenViewer(nextContainerNumber);
            return;
        }

        var nextContainerIndex = Containers!.IndexOf(nextContainerNumber);
        if (nextContainerIndex < 0)
        {
            // Comma-separated pair — find by partial match
            nextContainerIndex = Containers.FindIndex(c =>
                nextContainerNumber.Contains(c, StringComparison.OrdinalIgnoreCase));
        }
        nextContainerIndex = Math.Max(0, nextContainerIndex) + 1;
        var totalContainers = Containers.Count;
        
        // Collapse current container
        string? containerToCollapse = _currentProcessingContainer;
        if (string.IsNullOrEmpty(containerToCollapse) && Containers != null)
        {
            containerToCollapse = Containers.FirstOrDefault(c => 
                _containerPanelsExpanded.ContainsKey(c) && _containerPanelsExpanded[c]);
        }
        
        if (!string.IsNullOrEmpty(containerToCollapse))
        {
            Console.WriteLine($"🔄 [ImageAnalysisViewDialog] Collapsing current container: {containerToCollapse}");
            _containerPanelsExpanded[containerToCollapse] = false;
            _containerAutoOpen[containerToCollapse] = false;
            _currentProcessingContainer = null;
        }
        
        // The API already determined the correct next undecided container — trust its response
        Console.WriteLine($"🔄 [ImageAnalysisViewDialog] Expanding next container: {nextContainerNumber} ({nextContainerIndex}/{totalContainers})");

        if (!_containerPanelsExpanded.ContainsKey(nextContainerNumber))
            _containerPanelsExpanded[nextContainerNumber] = false;
        if (!_containerTabIndices.ContainsKey(nextContainerNumber))
            _containerTabIndices[nextContainerNumber] = 0;
        if (!_containerImagesLoaded.ContainsKey(nextContainerNumber))
            _containerImagesLoaded[nextContainerNumber] = false;
        
        _containerPanelsExpanded[nextContainerNumber] = true;
        _containerTabIndices[nextContainerNumber] = 1; // Images tab
        _containerImagesLoaded[nextContainerNumber] = true;
        _currentProcessingContainer = nextContainerNumber;

        Console.WriteLine($"🔄 [ImageAnalysisViewDialog] State updated for {nextContainerNumber}: expanded=true, tab=Images");

        Snackbar.Add($"Loading container {nextContainerIndex} of {totalContainers}: {nextContainerNumber}...", Severity.Info);

        // Fire-and-forget transition animation
        _ = Task.Run(async () => {
            try { await JSRuntime.InvokeVoidAsync("DecisionTransitions.showNextImageTransition", nextContainerNumber, nextContainerIndex, totalContainers); }
            catch { }
        });

        await InvokeAsync(StateHasChanged);
        await Task.Delay(200);

        // Directly open fullscreen viewer for next container
        await DirectOpenFullscreenViewer(nextContainerNumber);
    }

    private async Task BulkDecision(string decision)
    {
        if (Containers == null || !Containers.Any()) return;
        _bulkProcessing = true;
        int saved = 0, skipped = 0, failed = 0;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name ?? "Unknown";

            for (int i = 0; i < Containers.Count; i++)
            {
                var container = Containers[i];
                _bulkProgressText = $"Processing {i + 1} of {Containers.Count}: {container}...";
                StateHasChanged();

                try
                {
                    var request = new
                    {
                        ContainerNumber = container,
                        ScannerType = "ASE",
                        Decision = decision,
                        Comments = $"Bulk decision: {decision}",
                        Tags = "",
                        ReviewedBy = username,
                        GroupIdentifier,
                        IsConsolidated
                    };

                    var response = await ApiService.PostAsync<object, ImageAnalysisViewer.DecisionSaveResponse>(
                        "/api/ImageAnalysisDecision", request);

                    if (response?.Success == true) saved++;
                    else skipped++;
                }
                catch { failed++; }
            }

            Snackbar.Add($"Bulk complete: {saved} saved, {skipped} skipped, {failed} failed",
                failed > 0 ? Severity.Warning : Severity.Success);

            // Fire-and-forget bulk animation
            _ = Task.Run(async () => {
                try { await JSRuntime.InvokeVoidAsync("DecisionTransitions.showBulkComplete", saved, decision); }
                catch { }
            });

            // Close dialog after successful bulk
            if (failed == 0)
            {
                await Task.Delay(500);
                await HandleAllContainersDecided();
            }
        }
        finally
        {
            _bulkProcessing = false;
            _bulkProgressText = "";
            StateHasChanged();
        }
    }

    private async Task DirectOpenFullscreenViewer(string containerNumber)
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var uid = authState.User.Identity?.Name ?? "anon";
            var imageUrl = UrlBuilder.Build(
                $"/api/ImageProcessing/container/{Uri.EscapeDataString(containerNumber)}/complete/image",
                uid);

            // Resolve scanner type from completeness data (don't hardcode)
            var scannerType = ScannerType;
            if (string.IsNullOrEmpty(scannerType))
                scannerType = "ASE"; // fallback

            IDialogReference? dialogRef = null;
            var parameters = new DialogParameters
            {
                ["ImageUrl"] = imageUrl,
                ["ContainerNumber"] = containerNumber,
                ["ScannerType"] = scannerType,
                ["ScanDate"] = DateTime.Now,
                ["GroupIdentifier"] = GroupIdentifier,
                ["IsConsolidated"] = IsConsolidated,
                ["OnClose"] = EventCallback.Factory.Create(this, () =>
                {
                    if (dialogRef != null)
                        dialogRef.Close(DialogResult.Ok(true));
                    return Task.CompletedTask;
                }),
                ["OnDecisionSaved"] = EventCallback.Factory.Create<ImageAnalysisViewer.DecisionSaveResponse?>(this, async (response) =>
                {
                    if (response == null || !response.Success || dialogRef == null)
                        return;

                    Console.WriteLine($"🔄 [DirectOpen] Decision saved for {containerNumber} - allDecided={response.AllContainersDecided}, next={response.NextContainerNumber ?? "null"}");
                    dialogRef.Close(DialogResult.Ok(true));
                    await Task.Delay(300);

                    if (response.AllContainersDecided)
                    {
                        await HandleAllContainersDecided();
                    }
                    else if (!string.IsNullOrEmpty(response.NextContainerNumber))
                    {
                        await HandleNextContainer(response.NextContainerNumber);
                    }
                })
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraExtraLarge,
                FullWidth = true,
                FullScreen = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };

            dialogRef = await DialogService.ShowAsync<ImageAnalysisViewer>(
                $"Image Analysis — {containerNumber}", parameters, options);

            await dialogRef.Result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error opening fullscreen viewer for {containerNumber}: {ex.Message}");
        }
    }

