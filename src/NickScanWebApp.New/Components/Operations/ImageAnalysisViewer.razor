    private async Task ApplyCanvasFilter(string category, string? value, object? parms = null)
    {
        await EnsureCanvasInitialized();
        if (!_canvasInitialized)
        {
            Snackbar.Add("Canvas not ready — wait for the image to finish loading.", Severity.Warning);
            return;
        }
        _canvasVisible = HasActiveCanvasFilters();
        await JS.InvokeVoidAsync("ImageCanvasProcessor.applyFilter", category, value, parms);
        if (_showHistogram) await RefreshHistogram();

        // Record into undo history after every filter change
        try
        {
            var snap = await JS.InvokeAsync<object>("ImageCanvasProcessor.getStateSnapshot");
            await JS.InvokeVoidAsync("ImageAnalysisTools.pushState", snap);
            await RefreshHistoryCountsAsync();
        }
        catch { }

        StateHasChanged();
    }

