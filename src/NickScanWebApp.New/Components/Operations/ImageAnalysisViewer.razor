    [JSInvokable]
    public void OnScrollZoom(double direction)
    {
        // Multiplicative zoom — 6% per wheel tick. Feels natural at all zoom
        // levels (same relative change whether at 0.3x or 4x).
        const double factor = 1.06;
        var newZoom = direction > 0 ? _zoom * factor : _zoom / factor;
        _zoom = Math.Clamp(newZoom, 0.25, 5.0);
        if (_zoom <= 1.0) { _panX = 0; _panY = 0; }
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnKeyboardAction(string action)
    {
        switch (action)
        {
            case "ZoomIn": ZoomIn(); break;
            case "ZoomOut": ZoomOut(); break;
            case "ResetZoom": ResetZoom(); break;
            case "RotateRight": RotateRight(); break;
            case "RotateLeft": RotateLeft(); break;
            case "ToggleGrayscale": ToggleGrayscale(); break;
            case "ToggleInvert": ToggleInvert(); break;
            case "DecisionNormal": _selectedDecision = AuditMode ? "Approved" : "Normal"; break;
            case "DecisionAbnormal": _selectedDecision = AuditMode ? "Rejected" : "Abnormal"; break;
            case "ToggleDrawMode": ToggleDrawMode(); break;
            case "ToggleEnhanced": ToggleEnhancement(); break;
            case "ToggleLoupe": await ToggleLoupe(); break;
            case "ToggleHistogram": await ToggleHistogram(); break;
            case "ToggleWindowLevel": await ToggleWindowLevel(); break;
            case "Fullscreen": await ToggleFullscreen(); break;
            case "Close": await CloseAsync(); break;
        }
        await InvokeAsync(StateHasChanged);
    }

