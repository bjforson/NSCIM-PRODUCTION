    /// <summary>
    /// Get current image URL (original or enhanced based on toggle)
    /// </summary>
    private string GetCurrentImageUrl()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
        string baseUrl;
        
        if (_useEnhancedImage && !string.IsNullOrEmpty(ContainerNumber))
        {
            // Use enhanced image endpoint (Phase 1). Signed URL — browser <img src>.
            baseUrl = UrlBuilder.Build(
                $"/api/image-analysis/{Uri.EscapeDataString(ContainerNumber)}/enhanced",
                _currentUsername);
        }
        else
        {
            // ImageUrl should already be a full URL (converted in OnInitializedAsync)
            // But handle edge cases - AND ensure we always request full-size, not thumbnail
            if (!string.IsNullOrEmpty(ImageUrl))
            {
                // If it's already a full URL, use it
                if (ImageUrl.StartsWith("http://") || ImageUrl.StartsWith("https://"))
                {
                    baseUrl = ImageUrl;
                }
                // If it's relative, prepend API base URL
                else if (ImageUrl.StartsWith("/"))
                {
                    baseUrl = $"{apiBaseUrl}{ImageUrl}";
                }
                // Relative without leading slash
                else
                {
                    baseUrl = $"{apiBaseUrl}/{ImageUrl}";
                }
                // ✅ FIX: Fullscreen viewer must show full-resolution. Replace size=thumbnail with size=full
                if (baseUrl.Contains("size=thumbnail", StringComparison.OrdinalIgnoreCase))
                {
                    baseUrl = baseUrl.Replace("size=thumbnail", "size=full", StringComparison.OrdinalIgnoreCase);
                }
            }
            // Final fallback - use unified endpoint (signed URL; browser <img src>).
            else if (!string.IsNullOrEmpty(ContainerNumber))
            {
                baseUrl = UrlBuilder.Build(
                    $"/api/ImageProcessing/container/{ContainerNumber}/complete/image?size=full",
                    _currentUsername);
            }
            else
            {
                return string.Empty;
            }

            // v2.10.0 — apply mode-catalog selection. Only on the default render
            // path (not the /enhanced endpoint, which is a separate pipeline).
            // _activeMode == "" means "server default", so no query param.
            if (!string.IsNullOrEmpty(_activeMode))
            {
                var sep = baseUrl.Contains("?") ? "&" : "?";
                baseUrl = $"{baseUrl}{sep}mode={Uri.EscapeDataString(_activeMode)}";
            }

            // v2.10.4 — apply window/level → loPct/hiPct. Only forwarded when the
            // sliders have been moved from their defaults, so the no-touch case
            // hits the server's natural percentile clip (1.0 / 99.5).
            var wl = ComputeLoHiPct();
            if (wl.HasValue)
            {
                var sep = baseUrl.Contains("?") ? "&" : "?";
                baseUrl = $"{baseUrl}{sep}loPct={wl.Value.Lo.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}&hiPct={wl.Value.Hi.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}";
            }
        }

        // ✅ FIX: Add cache buster to force browser to reload image when toggling
        if (!string.IsNullOrEmpty(_imageCacheBuster))
        {
            var separator = baseUrl.Contains("?") ? "&" : "?";
            return $"{baseUrl}{separator}v={_imageCacheBuster}";
        }

        return baseUrl;
    }

    /// <summary>
    /// Toggle between original and enhanced image
    /// </summary>
    private void ToggleEnhancement()
    {
        _useEnhancedImage = !_useEnhancedImage;
        
        // ✅ FIX: Add cache buster to force browser to reload image
        _imageCacheBuster = DateTime.UtcNow.Ticks.ToString();
        
        Console.WriteLine($"[ImageAnalysisViewer] Toggled enhancement: {(_useEnhancedImage ? "Enhanced" : "Original")}, URL: {GetCurrentImageUrl()}");
        
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ContainerNumber != _lastContainerNumber && !string.IsNullOrEmpty(ContainerNumber))
        {
            _lastContainerNumber = ContainerNumber;
            ResetAll();
            _canvasInitialized = false;
            _canvasVisible = false;
            _loupeVisible = false;
            _wlDragAttached = false;
            _canvasConvolution = null;
            _canvasColorMap = null;
            _canvasHistEq = false;
            _canvasWLActive = false;
            _canvasWLWindow = 255;
            _canvasWLLevel = 128;
            _loupeEnabled = false;
            _showHistogram = false;
            _tags.Clear();
            _selectedDecision = "Pending";
            _existingComments = null;
            _rectangles.Clear();
            _selectedRectIndex = -1;
            _ocrResult = null;
            _detectionResult = null;
            _qualityAssessment = null;
            _crossRecordInfo = null;
            _imageLoadRetries = 0;

            // v2.10.0 — container changed, so the scan variant may have changed too.
            // Drop the cached capability manifest and any selected mode; the next
            // OnInitializedAsync cycle (or explicit call below) will re-fetch.
            _activeMode = "";
            _scanVariant = "";
            _supportedModes = new List<string>();
            _modeCapabilitiesLoaded = false;

            // v2.10.4 — reset window/level to defaults for the new scan. Signal
            // ranges differ between scanners / containers so a good window on
            // the previous scan won't carry over meaningfully.
            _serverWindowPct = DefaultServerWindowPct;
            _serverLevelPct  = DefaultServerLevelPct;

            // v2.11.0 Phase 3 — drop the stale probe chip; coords from the
            // previous scan are meaningless against the new one.
            _probeData = null;

            // v2.12.0 Phase 4 — drop raw-mode state + flush JS buffer cache
            // so the next scan doesn't render from the previous scan's bytes.
            _rawMode = false;
            _rawPlane = "he";
            _rawGeometryLabel = "";
            _rawError = "";
            try { _ = JS.InvokeVoidAsync("Raw16BitViewer.clearCache", _lastContainerNumber); } catch { }

            // v2.13.0 Phase 5 — clear the ROI panel; rectangles from the old
            // scan have different pixel dimensions so cached stats don't apply.
            _roiData = null;
            _roiError = "";
            _lastRoiIdx = -1;

            await LoadExistingTags();
            await LoadExistingRectangles();
            await LoadModeCapabilitiesAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUsername = authState.User.Identity?.Name ?? "System";
        _lastContainerNumber = ContainerNumber;
        
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
        
        if (!string.IsNullOrEmpty(ImageUrl))
        {
            if (ImageUrl.StartsWith("http://") || ImageUrl.StartsWith("https://")) { }
            else if (ImageUrl.StartsWith("/"))
                ImageUrl = $"{apiBaseUrl}{ImageUrl}";
            else
                ImageUrl = $"{apiBaseUrl}/{ImageUrl}";

            if (ImageUrl.Contains("size=thumbnail", StringComparison.OrdinalIgnoreCase))
                ImageUrl = ImageUrl.Replace("size=thumbnail", "size=full", StringComparison.OrdinalIgnoreCase);
        }
        else if (!string.IsNullOrEmpty(ContainerNumber))
        {
            // Signed URL for browser <img src>; middleware validates before Authorize.
            ImageUrl = UrlBuilder.Build(
                $"/api/ImageProcessing/container/{ContainerNumber}/complete/image?size=full",
                _currentUsername);
        }
        
        // Load the controlled finding-category lookups once before LoadExistingTags
        // so that LoadExistingTags can resolve any pre-saved id against a populated
        // dropdown list.
        await LoadFindingCategoriesAsync();

        if (!string.IsNullOrEmpty(ContainerNumber))
        {
            await LoadExistingTags();
            await LoadExistingRectangles();
            await LoadCrossRecordInfo();
            await LoadOcrResult();
            await LoadObjectDetection();
            await LoadQualityAssessment();
            await LoadAiSuggestion();
            // v2.10.0 — load the mode-catalog manifest so the toolbar knows which
            // mode buttons to render for this scan's variant (FS6000 vs ASE
            // tri-panel vs ASE single-view). Soft-fails if the endpoint is down.
            await LoadModeCapabilitiesAsync();
        }
    }

    private async Task LoadFindingCategoriesAsync()
    {
        try
        {
            var threat = await ApiService.GetAsync<List<FindingCategoryDto>>(
                "/api/inspection-finding-categories/threat");
            _threatCategories = threat ?? new List<FindingCategoryDto>();

            var revenue = await ApiService.GetAsync<List<FindingCategoryDto>>(
                "/api/inspection-finding-categories/revenue-anomaly");
            _revenueAnomalyCategories = revenue ?? new List<FindingCategoryDto>();
        }
        catch (Exception ex)
        {
            // Best-effort: if the API is unavailable the dropdowns just stay empty.
            // The Save path still works because both ids are optional on the request.
            Console.WriteLine($"[LoadFindingCategoriesAsync] ERROR: {ex.GetType().Name}: {ex.Message}");
        }
    }

    /// <summary>
    /// v2.10.0 — fetch the mode-catalog capability manifest for this scan and
    /// render the mode toolbar. FS6000 always returns 9 modes; ASE tri-panel
    /// returns 9; ASE single-view returns 3 (bw/inverse/edge) because the
    /// other modes need two energy channels.
    ///
    /// Failure is soft: if the endpoint 404s (no scan yet) or 500s (old API),
    /// _supportedModes stays empty and the toolbar row simply doesn't render.
    /// Viewer still works on the default render path.
    /// </summary>
    private async Task LoadModeCapabilitiesAsync()
    {
        if (string.IsNullOrEmpty(ContainerNumber))
        {
            _modeCapabilitiesLoaded = true;
            return;
        }
        try
        {
            var caps = await ApiService.GetAsync<NickScanCentralImagingPortal.Core.Interfaces.ScanModeCapabilities>(
                $"/api/ImageProcessing/container/{ContainerNumber}/mode-capabilities");
            if (caps != null)
            {
                _scanVariant    = caps.Variant ?? "";
                _supportedModes = (caps.SupportedModes ?? Array.Empty<string>()).ToList();
            }
            else
            {
                _scanVariant    = "";
                _supportedModes = new List<string>();
            }
        }
        catch (Exception ex)
        {
            // Soft-fail — log and leave the toolbar empty. Operator still
            // gets the default render via the unified image endpoint.
            Console.WriteLine($"[LoadModeCapabilitiesAsync] {ex.GetType().Name}: {ex.Message}");
            _scanVariant    = "";
            _supportedModes = new List<string>();
        }
        finally
        {
            _modeCapabilitiesLoaded = true;
        }
    }

    /// <summary>
    /// Operator picked a mode from the toolbar. "" = default render (server
    /// chooses composite for dual-energy / bw for single-view). Non-empty =
    /// append ?mode=X to the image URL. Bumps the cache buster so the
    /// @key changes and the &lt;img&gt; element re-fetches.
    /// </summary>
    private void SelectMode(string mode)
    {
        if (mode == _activeMode) return;              // idempotent — no flicker
        _activeMode = mode ?? "";
        _imageCacheBuster = DateTime.UtcNow.Ticks.ToString();
        StateHasChanged();
    }

    /// <summary>
    /// v2.10.4 — fired on every window/level slider tick. Coalesces bursts
    /// of slider drags into one image refetch via a Timer: each tick resets
    /// the timer, and only after WindowLevelDebounceMs of silence do we
    /// actually bump the cache buster. Keeps the server from being pounded
    /// during drags (each refetch is ~40-80ms of decode + render work).
    /// </summary>
    private void OnWindowLevelSliderChanged()
    {
        _windowLevelDebounceTimer?.Dispose();
        _windowLevelDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (_rawMode)
                {
                    // v2.12.0 — client-side rerender from cached buffer. No
                    // server round-trip; pure JS window/level on the raw
                    // 16-bit array. ~20-60ms for a full re-render.
                    await RerenderRawFromCacheAsync();
                }
                else
                {
                    // JPEG path: bump cache buster so the <img> refetches
                    // with the new ?loPct=&hiPct= params.
                    _imageCacheBuster = DateTime.UtcNow.Ticks.ToString();
                    StateHasChanged();
                }
            });
        }, null, WindowLevelDebounceMs, System.Threading.Timeout.Infinite);
    }

    /// <summary>
    /// Reset window/level to defaults and refetch immediately.
    /// </summary>
    private void ResetWindowLevel()
    {
        if (_serverWindowPct == DefaultServerWindowPct && _serverLevelPct == DefaultServerLevelPct)
            return;
        _serverWindowPct  = DefaultServerWindowPct;
        _serverLevelPct   = DefaultServerLevelPct;
        _imageCacheBuster = DateTime.UtcNow.Ticks.ToString();
        StateHasChanged();
    }

    /// <summary>
    /// Translate the two slider values to (loPct, hiPct) percentile bounds
    /// that the backend's FS6000Compositor.NormalizeEnergyChannel understands.
    /// Returns null when the sliders are at their defaults — caller should
    /// then omit the query params so the server falls back to its own
    /// defaults (1.0 / 99.5), preserving pre-v2.10.4 visual behaviour.
    /// </summary>
    private (double Lo, double Hi)? ComputeLoHiPct()
    {
        if (_serverWindowPct == DefaultServerWindowPct && _serverLevelPct == DefaultServerLevelPct)
            return null;
        double half = _serverWindowPct / 2.0;
        double lo = Math.Max(0.0, _serverLevelPct - half);
        double hi = Math.Min(100.0, _serverLevelPct + half);
        if (hi - lo < 0.5) hi = Math.Min(100.0, lo + 0.5); // never invert / collapse
        return (lo, hi);
    }

    /// <summary>
    /// True when windowing actually affects the current mode. Composite (vendor
    /// LUT) bakes tone mapping into the LUT so window/level is a no-op there;
    /// the UI dims the sliders + shows an info icon instead of silently doing
    /// nothing.
    /// </summary>
    private bool IsWindowLevelEffective()
        => !(string.IsNullOrEmpty(_activeMode) || _activeMode == "composite");

