    private string GetCanvasProxyImageUrl()
    {
        var imageUrl = GetCurrentImageUrl();
        if (string.IsNullOrEmpty(imageUrl)) return "";
        var encoded = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(imageUrl));
        var baseUri = new Uri(Navigation.Uri).GetLeftPart(UriPartial.Authority);
        return $"{baseUri}/api/imageproxy?url={Uri.EscapeDataString(encoded)}";
    }

    private async Task EnsureCanvasInitialized()
    {
        if (_canvasInitialized) return;
        var proxyUrl = GetCanvasProxyImageUrl();
        Console.WriteLine($"[Canvas] ProxyUrl: {proxyUrl}");
        Console.WriteLine($"[Canvas] CurrentImageUrl: {GetCurrentImageUrl()}");
        Console.WriteLine($"[Canvas] Navigation.Uri: {Navigation.Uri}");
        if (string.IsNullOrEmpty(proxyUrl))
        {
            Console.WriteLine("[Canvas] No image URL for proxy");
            return;
        }
        try
        {
            // Pass _imageElement as the 4th arg so JS can reuse the already-loaded bitmap (no double fetch)
            var result = await JS.InvokeAsync<bool>("ImageCanvasProcessor.initWithUrl", _canvasElement, proxyUrl, _dotNetRef, _imageElement);
            if (result)
            {
                _canvasInitialized = true;
                await JS.InvokeVoidAsync("ImageCanvasProcessor.initLoupe", _loupeCanvas, 180, 3);
                if (!_wlDragAttached)
                {
                    await JS.InvokeVoidAsync("ImageCanvasProcessor.attachWindowLevelDrag", _imageContainer);
                    _wlDragAttached = true;
                }
            }
            else
            {
                Snackbar.Add("Canvas could not load image. Try again or use a different image.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Canvas] Init failed: {ex.Message}");
            Snackbar.Add($"Canvas error: {ex.Message}", Severity.Error);
        }
    }

    private bool HasActiveCanvasFilters()
    {
        return _canvasConvolution != null || _canvasColorMap != null || _canvasHistEq || _canvasWLActive;
