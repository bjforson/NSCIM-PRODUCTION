    private async Task LoadGoodsPanelData()
    {
        _goodsPanelLoading = true;
        StateHasChanged();
        try
        {
            var groupId = GroupIdentifier;
            if (string.IsNullOrEmpty(groupId))
                groupId = ContainerNumber;

            // Try cargo group API first (has structured line items)
            var cargoGroup = await ApiService.GetAsync<CargoGroupResponse>(
                $"/api/cargogroup/{Uri.EscapeDataString(groupId)}?loadICUMSData=true");

            if (cargoGroup?.Data?.ICUMSData != null)
            {
                // Extract CRMS Risk Level from any group
                foreach (var group in cargoGroup.Data.ICUMSData)
                {
                    if (string.IsNullOrEmpty(_crmsRiskLevel))
                    {
                        var riskRecord = group.Records?.FirstOrDefault(r =>
                            r.Field == "CRMS Risk Level" && !string.IsNullOrWhiteSpace(r.Value) && r.Value != "Not assessed");
                        if (riskRecord != null)
                            _crmsRiskLevel = riskRecord.Value;
                    }
                }

                foreach (var group in cargoGroup.Data.ICUMSData)
                {
                    var label = !string.IsNullOrEmpty(group.HouseBL) ? $"HBL: {group.HouseBL}"
                              : !string.IsNullOrEmpty(group.GroupKey) ? group.GroupKey
                              : !string.IsNullOrEmpty(group.ContainerNumber) ? group.ContainerNumber
                              : "BOE";

                    var panelGroup = new GoodsPanelGroup { Label = label };

                    // Primary path: structured ManifestItems on each BOE. Always present
                    // for any BOE with line items, irrespective of single vs. multi-item.
                    // This avoids the "Item N:" prefix parsing which silently drops
                    // single-item declarations (CargoGroupService only prefixes when
                    // count > 1).
                    if (group.BOEDetails != null)
                    {
                        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                        foreach (var boe in group.BOEDetails)
                        {
                            if (boe.ManifestItems == null) continue;
                            foreach (var mi in boe.ManifestItems
                                .Where(m => !string.IsNullOrWhiteSpace(m.Description))
                                .OrderBy(m => m.ItemNo ?? m.ItemIndex))
                            {
                                var dedupeKey = $"{mi.Description!.Trim()}|{mi.HsCode}|{mi.Quantity}|{mi.Unit}";
                                if (!seen.Add(dedupeKey)) continue;
                                var qty = mi.Quantity.HasValue && mi.Quantity.Value > 0
                                    ? $"{mi.Quantity.Value:N2} {mi.Unit ?? ""}".Trim()
                                    : null;
                                var item = new GoodsPanelItem
                                {
                                    ItemNo = mi.ItemNo ?? (panelGroup.Items.Count + 1),
                                    Description = mi.Description!.Trim(),
                                    HsCode = mi.HsCode,
                                    Quantity = qty
                                };
                                panelGroup.Items.Add(item);
                                _goodsPanelItems.Add(item);
                            }
                        }
                    }

                    // Fallback: parse "Item N:"-prefixed Records (multi-item BOEs only —
                    // CargoGroupService omits the prefix for single-item BOEs).
                    if (!panelGroup.Items.Any())
                    {
                        var cargo = group.Records?.Where(r => r.Category == "Cargo Info" && r.Field.Contains(":")) ?? Enumerable.Empty<CargoRecord>();
                        var itemGroups = cargo
                            .GroupBy(r =>
                            {
                                var match = System.Text.RegularExpressions.Regex.Match(r.Field, @"Item\s+(\d+):");
                                return match.Success ? int.Parse(match.Groups[1].Value) : 0;
                            })
                            .Where(g => g.Key > 0)
                            .OrderBy(g => g.Key);

                        foreach (var ig in itemGroups)
                        {
                            var desc = ig.FirstOrDefault(r => r.Field.Contains("Description", StringComparison.OrdinalIgnoreCase))?.Value;
                            if (string.IsNullOrWhiteSpace(desc)) continue;
                            var item = new GoodsPanelItem
                            {
                                ItemNo = ig.Key,
                                Description = desc.Trim(),
                                HsCode = ig.FirstOrDefault(r => r.Field.Contains("HS Code", StringComparison.OrdinalIgnoreCase))?.Value,
                                Quantity = ig.FirstOrDefault(r => r.Field.Contains("Quantity", StringComparison.OrdinalIgnoreCase))?.Value
                            };
                            panelGroup.Items.Add(item);
                            _goodsPanelItems.Add(item);
                        }
                    }

                    // Narrative Goods Description from the BOE — only show when there
                    // are no structured items, so multi-item declarations show every
                    // line instead of a one-liner summary.
                    if (!panelGroup.Items.Any())
                    {
                        var goodsDesc = group.Records?
                            .Where(r => r.Field == "Goods Description" && !string.IsNullOrWhiteSpace(r.Value))
                            .Select(r => r.Value!.Trim())
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();
                        if (goodsDesc?.Any() == true)
                            panelGroup.NarrativeText = string.Join("; ", goodsDesc);
                    }

                    if (panelGroup.Items.Any() || !string.IsNullOrEmpty(panelGroup.NarrativeText))
                        _goodsPanelGroups.Add(panelGroup);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[GoodsPanel] Error loading: {ex.Message}");
            _goodsPanelText = "Could not load goods description.";
        }
        finally
        {
            _goodsPanelLoading = false;
            StateHasChanged();
        }
    }

