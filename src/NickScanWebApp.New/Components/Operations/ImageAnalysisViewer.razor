    private void AddTag()
    {
        if (!string.IsNullOrWhiteSpace(_newTag) && !_tags.Contains(_newTag.Trim()))
        {
            _tags.Add(_newTag.Trim());
            _newTag = "";
            StateHasChanged();
        }
    }

    /// <summary>
    /// Commits any text still in the tag input to the tags list. Called at the top of
    /// every save path so a user who typed a tag but forgot to press Enter doesn't lose
    /// it on save. Idempotent — safe to call even when _newTag is empty.
    /// </summary>
    private void FlushPendingTag()
    {
        if (!string.IsNullOrWhiteSpace(_newTag))
        {
            var candidate = _newTag.Trim();
            if (!_tags.Contains(candidate))
            {
                _tags.Add(candidate);
                Console.WriteLine($"[FlushPendingTag] Auto-committed pending tag: '{candidate}'");
            }
            _newTag = "";
        }

        // ALSO commit any pending rectangle-tag text — but ONLY when we know exactly
        // which rectangle it belongs to (selected). Never guess at "last untagged"
        // because the tag would land on the wrong rectangle and the pin would appear
        // at the wrong location.
        if (!string.IsNullOrWhiteSpace(_selectedTagText)
            && _selectedRectIndex >= 0
            && _selectedRectIndex < _rectangles.Count)
        {
            var tagText = _selectedTagText.Trim();
            if (string.IsNullOrWhiteSpace(_rectangles[_selectedRectIndex].Tag))
            {
                _rectangles[_selectedRectIndex].Tag = tagText;
                Console.WriteLine($"[FlushPendingTag] Auto-committed rectangle tag to #{_selectedRectIndex}: '{tagText}'");
            }
        }
    }

    private void QuickAddTag(string tag)
    {
        if (!_tags.Contains(tag))
        {
            _tags.Add(tag);
            StateHasChanged();
        }
    }

    private void RemoveTag(string tag)
    {
        _tags.Remove(tag);
        StateHasChanged();
    }

    private Task HandleTagKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag();
        }
        return Task.CompletedTask;
    }

    // Response DTO for decision save
    public class DecisionSaveResponse
    {
        public bool Success { get; set; }
        public bool AdvancedToAudit { get; set; }
        public bool AllContainersDecided { get; set; }
        public string? NextContainerNumber { get; set; }
        public string? Message { get; set; }
    }

    private async Task SaveTagsAndDecision()
    {
        if (!PermissionGuard.CanAny(PermissionIds.Images.Annotate, PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to save decisions or tags.", Severity.Warning);
            return;
        }

        // Commit any tag text that's still in the input field but not yet added to the list
        FlushPendingTag();


        try
        {
            // ✅ FIX: Validate decision is selected (cannot be "Pending")
            var validDecisions = AuditMode
                ? new[] { "Approved", "Rejected" }
                : new[] { "Normal", "Abnormal" };
            if (string.IsNullOrEmpty(_selectedDecision) || string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase)
                || !validDecisions.Contains(_selectedDecision))
            {
                Snackbar.Add(AuditMode
                    ? "Please select a decision (Approve or Reject) before saving"
                    : "Please select a decision (Normal or Abnormal) before saving", Severity.Warning);
                return;
            }

            // ── AUDIT MODE: close dialog with result instead of API POST ──
            if (AuditMode)
            {
                var auditResult = new AuditDecisionResult
                {
                    ContainerNumber = ContainerNumber,
                    ImageIndex = ImageIndex,
                    ScannerType = ScannerType,
                    Decision = _selectedDecision,
                    Notes = _existingComments
                };

                Snackbar.Add($"Audit decision: {_selectedDecision}", Severity.Success);

                // Fire-and-forget transition animation
                _ = Task.Run(async () => {
                    try { await JS.InvokeVoidAsync("DecisionTransitions.showDecisionSaved", _selectedDecision); }
                    catch { }
                });

                // Close the dialog and return the audit result to the caller
                MudDialog?.Close(DialogResult.Ok(auditResult));
                return;
            }

            var tagsString = string.Join(", ", _tags);
            var rectanglesJson = _rectangles.Any() ? System.Text.Json.JsonSerializer.Serialize(_rectangles) : null;

            var request = new
            {
                ContainerNumber,
                ScannerType,
                Decision = _selectedDecision,
                Comments = _existingComments ?? "",
                Tags = tagsString,
                SuspiciousAreas = rectanglesJson,
                ReviewedBy = _currentUsername,
                GroupIdentifier,
                IsConsolidated,
                ThreatCategoryId = _selectedThreatCategoryId,
                RevenueAnomalyCategoryId = _selectedRevenueAnomalyCategoryId
            };

            var response = await ApiService.PostAsync<object, DecisionSaveResponse>("/api/ImageAnalysisDecision", request);
            
            // ✅ Verify the save was successful before closing
            // Response will be null if API threw an exception (caught in catch block below)
            // Response.Success will be false if API returned success:false in body
            if (response != null && response.Success == true)
            {
                // Mark all rectangles + final decision as persisted so the delete/remove
                // gate flips to "admin only" for this image.
                foreach (var r in _rectangles) r.IsPersisted = true;
                _hasSavedDecision = true;

                await LogToBrowserConsole($"✅ [ImageAnalysisViewer] Save successful - API Response:");
                await LogToBrowserConsole($"   - AllContainersDecided: {response.AllContainersDecided}");
                await LogToBrowserConsole($"   - NextContainerNumber: {response.NextContainerNumber ?? "null"}");
                await LogToBrowserConsole($"   - AdvancedToAudit: {response.AdvancedToAudit}");
                
                Console.WriteLine($"✅ [ImageAnalysisViewer] Save successful - closing dialog");
                Snackbar.Add($"Decision and tags saved for {ScannerType} image", Severity.Success);

                // Fire-and-forget transition animation (non-blocking)
                _ = Task.Run(async () => {
                    try { await JS.InvokeVoidAsync("DecisionTransitions.showDecisionSaved", _selectedDecision ?? "Normal"); }
                    catch { /* JS not available */ }
                });

                if (OnDecisionSaved.HasDelegate)
                {
                    await OnDecisionSaved.InvokeAsync(response);
                }
                else
                {
                    await OnClose.InvokeAsync();
                }
            }
            else
            {
                // Save failed or response indicates failure - show error and keep dialog open
                var errorMessage = response?.Message ?? "Failed to save decision and tags";
                Console.WriteLine($"❌ [ImageAnalysisViewer] Save failed or unsuccessful: {errorMessage} (Response null: {response == null}, Success: {response?.Success})");
                Snackbar.Add($"Error: {errorMessage}", Severity.Error);
                // Dialog stays open so user can retry
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving decision and tags: {ex.Message}");
            Snackbar.Add($"Error saving decision and tags: {ex.Message}", Severity.Error);
            // Don't close dialog on error - let user see the error and try again
        }
    }
    
    // ✅ Keep old SaveTags method for backward compatibility (auto-save on close)
    private async Task SaveTags()
    {
        if (!PermissionGuard.CanAny(PermissionIds.Images.Annotate, PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to save tags.", Severity.Warning);
            return;
        }

        // Commit any tag text still in the input before saving
        FlushPendingTag();

        // If decision is selected, save both; otherwise just save tags (if decision exists)
        if (!string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase))
        {
            await SaveTagsAndDecision();
        }
        else
        {
            // Tags-only save (preserves existing decision if it exists)
            try
            {
                var tagsString = string.Join(", ", _tags);
                
                // Get existing decision for this image
                var decisions = await ApiService.GetAsync<List<ImageDecisionDto>>(
                    $"/api/ImageAnalysisDecision/container/{ContainerNumber}");
                
                var existingDecision = decisions?.FirstOrDefault(d => d.ScannerType == ScannerType);

                if (existingDecision == null || string.IsNullOrEmpty(existingDecision.Decision))
                {
                    // No existing decision - cannot save tags only
                    Console.WriteLine("⚠️ Cannot save tags without a decision. Decision required.");
                    return;
                }

                var rectanglesJson = _rectangles.Any() ? System.Text.Json.JsonSerializer.Serialize(_rectangles) : existingDecision.SuspiciousAreas;

                var request = new
                {
                    ContainerNumber,
                    ScannerType,
                    Decision = existingDecision.Decision,
                    Comments = existingDecision.Comments ?? "",
                    Tags = tagsString,
                    SuspiciousAreas = rectanglesJson,
                    ReviewedBy = _currentUsername,
                    GroupIdentifier,
                    IsConsolidated,
                    // AI training flywheel — preserve current dropdown selections.
                    // Sending the local state means a user who picked a category and
                    // then triggered a tags-only auto-save still gets their pick saved.
                    ThreatCategoryId = _selectedThreatCategoryId,
                    RevenueAnomalyCategoryId = _selectedRevenueAnomalyCategoryId
                };

                await ApiService.PostAsync<object, object>("/api/ImageAnalysisDecision", request);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error saving tags: {ex.Message}");
            }
        }
    }

    // Rectangle Drawing Methods
    private async void ToggleDrawMode()
    {
        _drawMode = !_drawMode;
        if (_drawMode)
        {
            // Ensure we have image dimensions before any drawing
            await EnsureImageDimensions();
        }
        else
        {
            _isDrawing = false;
            _currentRect = null;
            _selectedRectIndex = -1;
        }
    }

    private async Task LoadExistingRectangles()
    {
        try
        {
            var decisions = await ApiService.GetAsync<List<ImageDecisionDto>>(
                $"/api/ImageAnalysisDecision/container/{ContainerNumber}");

            var decision = decisions?.FirstOrDefault(d => d.ScannerType == ScannerType);

            // Record whether a finalised decision is already on file — drives permission
            // logic for rectangle deletion (users can only delete their own rectangles
            // while no final decision exists).
            _hasSavedDecision = !string.IsNullOrWhiteSpace(decision?.Decision)
                             && !string.Equals(decision!.Decision, "Pending", StringComparison.OrdinalIgnoreCase);

            if (!string.IsNullOrEmpty(decision?.SuspiciousAreas))
            {
                _rectangles = System.Text.Json.JsonSerializer.Deserialize<List<SuspiciousAreaRect>>(decision.SuspiciousAreas) ?? new();

                // Anything that came from the server is already persisted.
                foreach (var r in _rectangles) r.IsPersisted = true;

                // Normalize legacy pixel coordinates to 0-1 fractions.
                // Legacy annotations have X/Y/Width/Height > 1.5 (raw CSS pixels).
                // New annotations are 0-1 fractions of the displayed image.
                if (_imgDisplayWidth > 0 && _imgDisplayHeight > 0)
                {
                    foreach (var rect in _rectangles)
                    {
                        if (IsLegacyPixelCoordinates(rect))
                        {
                            Console.WriteLine($"[Annotations] Normalizing legacy rect: ({rect.X},{rect.Y},{rect.Width},{rect.Height}) / display=({_imgDisplayWidth},{_imgDisplayHeight})");
                            rect.X /= _imgDisplayWidth;
                            rect.Y /= _imgDisplayHeight;
                            rect.Width /= _imgDisplayWidth;
                            rect.Height /= _imgDisplayHeight;
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading rectangles: {ex.Message}");
        }
    }

    // ═══════════════════════════════════════════════════════════════════════
    //  DRAW-OVERLAY HANDLERS — receive OffsetX/Y in image-local coord space
    // ═══════════════════════════════════════════════════════════════════════

    private async Task HandleDrawMouseDown(MouseEventArgs e)
    {
        if (!_drawMode) return;

        // Refresh dimensions in case the viewport resized between opens.
        // Also guards against coordinate division by zero before the img layout is ready.
        if (_imgDisplayWidth <= 0 || _imgDisplayHeight <= 0) await EnsureImageDimensions();
        if (_imgDisplayWidth <= 0 || _imgDisplayHeight <= 0) return;

        var (imgX, imgY) = ScreenToImageCoords(e.OffsetX, e.OffsetY);

        // Click inside an existing rectangle → move it; else start a new draw.
        var clickedRectIndex = FindRectangleAt(imgX, imgY);
        if (clickedRectIndex >= 0)
        {
            _selectedRectIndex = clickedRectIndex;
            _isMoving = true;
            _drawStartX = imgX;
            _drawStartY = imgY;
        }
        else
        {
            _isDrawing = true;
            _selectedRectIndex = -1;
            _drawStartX = imgX;
            _drawStartY = imgY;
            _currentRect = new SuspiciousAreaRect
            {
                X = imgX,
                Y = imgY,
                Width = 0,
                Height = 0,
                CreatedBy = _currentUsername,
                Tag = string.Empty,
                IsPersisted = false
            };
        }
        StateHasChanged();
    }

    private void HandleDrawMouseMove(MouseEventArgs e)
    {
        if (!_drawMode) return;
        if (_imgDisplayWidth <= 0 || _imgDisplayHeight <= 0) return;
        var (imgX, imgY) = ScreenToImageCoords(e.OffsetX, e.OffsetY);

        if (_isDrawing && _currentRect != null)
        {
            // Update current rectangle while drawing (image-local fractions)
            _currentRect.Width = imgX - _drawStartX;
            _currentRect.Height = imgY - _drawStartY;
            if (_currentRect.Width < 0) { _currentRect.X = imgX; _currentRect.Width = Math.Abs(_currentRect.Width); }
            else { _currentRect.X = _drawStartX; }
            if (_currentRect.Height < 0) { _currentRect.Y = imgY; _currentRect.Height = Math.Abs(_currentRect.Height); }
            else { _currentRect.Y = _drawStartY; }
            StateHasChanged();
        }
        else if (_isResizing && _selectedRectIndex >= 0)
        {
            HandleResize(e);
        }
        else if (_isMoving && _selectedRectIndex >= 0)
        {
            var deltaX = imgX - _drawStartX;
            var deltaY = imgY - _drawStartY;
            _rectangles[_selectedRectIndex].X += deltaX;
            _rectangles[_selectedRectIndex].Y += deltaY;
            _drawStartX = imgX;
            _drawStartY = imgY;
            StateHasChanged();
        }
    }

    private Task HandleDrawMouseUp(MouseEventArgs e) => HandleMouseUp(e);

    private async Task HandleDrawMouseLeave(MouseEventArgs e)
    {
        // End any in-progress draw/move when leaving the overlay (same semantics as
        // the old handler) so the user doesn't get stuck in a half-drawn state.
        await HandleMouseLeave(e);
    }

    // ═══════════════════════════════════════════════════════════════════════
    //  CONTAINER HANDLERS — pan only (draw-overlay catches anything else)
    // ═══════════════════════════════════════════════════════════════════════

    private void HandleContainerMouseDown(MouseEventArgs e)
    {
        // Draw-mode clicks are captured by the overlay (pointer-events: auto) and
        // never reach here. Everything else = pan.
        if (!_drawMode) StartPan(e);
    }

    private void HandleContainerMouseMove(MouseEventArgs e)
    {
        if (_isPanning) DoPan(e);
    }

    private void HandleContainerMouseUp(MouseEventArgs e) => EndPan(e);

    private void HandleContainerMouseLeave(MouseEventArgs e) => EndPan(e);

    private async Task HandleMouseUp(MouseEventArgs e)
    {
        if (_isDrawing && _currentRect != null)
        {
            // Finish drawing rectangle — minimum size 1% of image in each dimension
            var minSize = (_imgDisplayWidth > 0) ? 0.01 : 10;
            if (Math.Abs(_currentRect.Width) > minSize && Math.Abs(_currentRect.Height) > minSize)
            {
                _rectangles.Add(_currentRect);
                _selectedRectIndex = _rectangles.Count - 1;
                _selectedTagText = "";
                await SaveRectangles();
                // v2.13.0 Phase 5 — fire ROI inspector on draw-complete
                _ = FetchRoiForRectangleAsync(_selectedRectIndex);
            }
            _isDrawing = false;
            _currentRect = null;
        }
        else if (_isResizing)
        {
            _isResizing = false;
            await SaveRectangles();
        }
        else if (_isMoving)
        {
            _isMoving = false;
            await SaveRectangles();
        }
        else if (!_drawMode)
        {
            EndPan(e);
        }
    }

    private async Task HandleMouseLeave(MouseEventArgs e)
    {
        // Min size = 1% of image dimensions (coords are fractions 0..1)
        const double minFraction = 0.01;
        if (_isDrawing && _currentRect != null
            && _currentRect.Width > minFraction && _currentRect.Height > minFraction)
        {
            _rectangles.Add(_currentRect);
            await SaveRectangles();
        }
        if ((_isResizing || _isMoving) && _selectedRectIndex >= 0)
        {
            await SaveRectangles();
        }
        _isDrawing = false;
        _isResizing = false;
        _isMoving = false;
        _currentRect = null;
        if (!_drawMode)
        {
            EndPan(e);
        }
    }

    private int FindRectangleAt(double x, double y)
    {
        for (int i = _rectangles.Count - 1; i >= 0; i--)
        {
            var rect = _rectangles[i];
            if (x >= rect.X && x <= rect.X + rect.Width &&
                y >= rect.Y && y <= rect.Y + rect.Height)
            {
                return i;
            }
        }
        return -1;
    }

    private void StartResize(MouseEventArgs e, int index, ResizeHandle handle)
    {
        var (imgX, imgY) = ScreenToImageCoords(e.OffsetX, e.OffsetY);
        _selectedRectIndex = index;
        _isResizing = true;
        _currentResizeHandle = handle;
        _drawStartX = imgX;
        _drawStartY = imgY;
    }

    private void HandleResize(MouseEventArgs e)
    {
        if (_selectedRectIndex < 0 || _selectedRectIndex >= _rectangles.Count) return;

        var (imgX, imgY) = ScreenToImageCoords(e.OffsetX, e.OffsetY);
        var rect = _rectangles[_selectedRectIndex];
        var deltaX = imgX - _drawStartX;
        var deltaY = imgY - _drawStartY;

        switch (_currentResizeHandle)
        {
            case ResizeHandle.TopLeft:
                rect.X += deltaX;
                rect.Y += deltaY;
                rect.Width -= deltaX;
                rect.Height -= deltaY;
                break;
            case ResizeHandle.TopRight:
                rect.Y += deltaY;
                rect.Width += deltaX;
                rect.Height -= deltaY;
                break;
            case ResizeHandle.BottomLeft:
                rect.X += deltaX;
                rect.Width -= deltaX;
                rect.Height += deltaY;
                break;
            case ResizeHandle.BottomRight:
                rect.Width += deltaX;
                rect.Height += deltaY;
                break;
        }

        // Ensure minimum size
        if (rect.Width < 20) rect.Width = 20;
        if (rect.Height < 20) rect.Height = 20;

        _drawStartX = imgX;
        _drawStartY = imgY;
        StateHasChanged();
    }

    private async Task DeleteRectangle(int index)
    {
        if (index < 0 || index >= _rectangles.Count) return;
        var rect = _rectangles[index];

        // Permission rules:
        //   1. Admin (Images.Edit) can always delete.
        //   2. Otherwise, a non-admin user may delete a rectangle ONLY IF:
        //      - they created it (CreatedBy matches current user), AND
        //      - no final decision has been saved yet (i.e. still editable), AND
        //      - the rectangle has not been persisted OR the owning image decision
        //        is still Pending (they can clean up their own in-progress work).
        var isAdmin = PermissionGuard.Can(PermissionIds.Images.Edit);
        var isOwner = string.Equals(rect.CreatedBy, _currentUsername, StringComparison.OrdinalIgnoreCase);
        var decisionStillOpen = !_hasSavedDecision
            || string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase)
            || string.IsNullOrWhiteSpace(_selectedDecision);

        if (!isAdmin)
        {
            if (!isOwner)
            {
                Snackbar.Add("Only the user who added this mark (or an admin) can remove it.", Severity.Warning);
                return;
            }
            if (!decisionStillOpen)
            {
                Snackbar.Add("A final decision has been saved — only an admin can remove marks now.", Severity.Warning);
                return;
            }
        }

        _rectangles.RemoveAt(index);
        _selectedRectIndex = -1;

        // Only round-trip to the server if we had previously persisted the rectangle.
        // Rectangles the user just drew (IsPersisted = false) live only in memory and
        // are cleaned up by simply removing them from the list.
        if (rect.IsPersisted)
        {
            await SaveRectangles();
        }
        Snackbar.Add("Suspicious area removed", Severity.Info);
        StateHasChanged();
    }

    private void SelectRectangle(int index)
    {
        if (index >= 0 && index < _rectangles.Count)
        {
            _selectedRectIndex = index;
            _selectedTagText = _rectangles[index].Tag ?? "";
            StateHasChanged();
            // v2.13.0 Phase 5 — re-populate the ROI panel for the clicked rect.
            _ = FetchRoiForRectangleAsync(index);
        }
    }

    private async Task RemoveRectangle(int index)
    {
        await DeleteRectangle(index);
    }

    // Tag text for the selected rectangle — decoupled from the list to avoid binding issues
    private string _selectedTagText = "";

    private void OnTagTextChanged(string value)
    {
        _selectedTagText = value;
        if (_selectedRectIndex >= 0 && _selectedRectIndex < _rectangles.Count)
        {
            _rectangles[_selectedRectIndex].Tag = value;
        }
    }

    private async Task OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveTagAndRectangles();
        }
    }

    private async Task SaveTagAndRectangles()
    {
        // Ensure the tag text is committed to the rectangle (overrides any previous tag —
        // this is an explicit "save tag" action, so we always take the input value).
        if (_selectedRectIndex >= 0 && _selectedRectIndex < _rectangles.Count)
        {
            _rectangles[_selectedRectIndex].Tag = _selectedTagText?.Trim() ?? "";
        }
        // Also flush any pending _newTag text into the global tag list
        FlushPendingTag();
        await SaveRectangles();
        Snackbar.Add("Tag saved", Severity.Success);
    }

    private async Task TagSelectedRectangle(string tag)
    {
        if (_selectedRectIndex >= 0 && _selectedRectIndex < _rectangles.Count)
        {
            _rectangles[_selectedRectIndex].Tag = tag;
            _selectedTagText = tag;
            await SaveRectangles();
            Snackbar.Add($"Tagged as '{tag}'", Severity.Success);
        }
    }

    private async Task SaveRectangles()
    {
        if (!PermissionGuard.CanAny(PermissionIds.Images.Annotate, PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to save marked areas.", Severity.Warning);
            return;
        }

        // Commit any pending tag text (global list AND selected-rectangle tag) before serialising
        FlushPendingTag();

        try
        {
            var rectanglesJson = System.Text.Json.JsonSerializer.Serialize(_rectangles);

            var request = new
            {
                ContainerNumber,
                ScannerType,
                SuspiciousAreas = rectanglesJson,
                ReviewedBy = _currentUsername,
                GroupIdentifier,
                IsConsolidated
            };

            Console.WriteLine($"[SaveRectangles] Posting JSON ({rectanglesJson.Length} chars): {rectanglesJson.Substring(0, Math.Min(200, rectanglesJson.Length))}...");
            await ApiService.PostAsync<object, object>("/api/ImageAnalysisDecision/rectangles", request);

            // Mark every rectangle as persisted — from here on they require admin to delete
            foreach (var r in _rectangles) r.IsPersisted = true;
            Console.WriteLine("[SaveRectangles] Save successful");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SaveRectangles] ERROR: {ex.Message}");
            Snackbar.Add($"Error saving marked areas: {ex.Message}", Severity.Error);
        }
    }

    private int _imageLoadRetries = 0;
    private void HandleImageLoadError(string imageUrl)
    {
        if (_imageLoadRetries == 0)
        {
            _imageLoadRetries = 1;
            _imageCacheBuster = DateTime.UtcNow.Ticks.ToString();
            Console.WriteLine($"[ImageAnalysisViewer] Image failed — retrying with cache bust | Container: {ContainerNumber}");
            StateHasChanged();
            return;
        }
        Console.WriteLine($"[ImageAnalysisViewer] Image failed after retry | Container: {ContainerNumber} | URL: {imageUrl}");
        Snackbar.Add($"Image unavailable for {ContainerNumber}.", Severity.Info);
    }

    private async void HandleImageLoadSuccess(string imageUrl)
    {
        Console.WriteLine($"[ImageAnalysisViewer] Image loaded successfully: {imageUrl}");
        // Capture image dimensions for accurate annotation coordinate mapping
        await Task.Delay(50); // Brief delay to ensure browser has finalized layout
        await UpdateImageDimensions();
        Console.WriteLine($"[ImageAnalysisViewer] Image dims: natural={_imgNaturalWidth}x{_imgNaturalHeight}, display={_imgDisplayWidth}x{_imgDisplayHeight}");
    }

    private async Task CloseAsync()
    {
        // Commit any tag text still in the input BEFORE any save decisions
        FlushPendingTag();

        // Always save rectangles (annotations + tags) on close — they don't require a decision
        if (_rectangles.Any())
        {
            await SaveRectangles();
        }

        // Save decision + tags only if a decision has been made
        if ((_rectangles.Any() || _tags.Any()) && !string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase))
        {
            await SaveTagsAndDecision();
        }
        else if (_tags.Any() && string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Decision required before saving tags. Please select Normal or Abnormal.", Severity.Warning);
        }
        await OnClose.InvokeAsync();
    }

    // Cross-Record Helper Methods
    private Severity GetCrossRecordSeverity(string severity) => severity?.ToLower() switch
    {
        "high" => Severity.Error,
        "medium" => Severity.Warning,
        "low" => Severity.Info,
        _ => Severity.Normal
    };

    private Color GetCrossRecordTypeColor(string type) => type switch
    {
        "DifferentImporters" => Color.Default,
        "DifferentRiskLevels" => Color.Warning,
        "DifferentClearanceTypes" => Color.Info,
        _ => Color.Default
    };

    private Color GetCRMSColor(string? crms)
    {
        if (crms == "Current") return Color.Primary;
        
        return crms?.ToUpper() switch
        {
            "RED" or "H" or "HIGH" => Color.Error,
            "YELLOW" or "M" or "MEDIUM" => Color.Warning,
            "GREEN" or "L" or "LOW" => Color.Success,
            _ => Color.Default
        };
    }

    private string FormatCrossRecordType(string type) => type switch
    {
        "DifferentImporters" => "Different Importers",
        "DifferentRiskLevels" => "Mixed CRMS",
        "DifferentClearanceTypes" => "Import/Export Mix",
        "DifferentBOEs" => "Different BOEs",
        _ => type
    };

    private async Task NavigateToSibling()
    {
        if (_crossRecordInfo?.SiblingContainer != null)
        {
            Snackbar.Add($"Switching to {_crossRecordInfo.SiblingContainer}...", Severity.Info);
            await OnClose.InvokeAsync();
        }
    }

