    private void StartPan(MouseEventArgs e)
    {
        if (_zoom > 1.0)
        {
            _isPanning = true;
            _lastMouseX = e.ClientX;
            _lastMouseY = e.ClientY;
        }
    }

    private void DoPan(MouseEventArgs e)
    {
        if (_isPanning)
        {
            var deltaX = e.ClientX - _lastMouseX;
            var deltaY = e.ClientY - _lastMouseY;
            
            _panX += deltaX / _zoom;
            _panY += deltaY / _zoom;
            
            _lastMouseX = e.ClientX;
            _lastMouseY = e.ClientY;
        }
    }

    private void EndPan(MouseEventArgs e)
    {
        _isPanning = false;
    }

    private string GetContainerStyle()
    {
        var cursor = _drawMode ? "crosshair" : (_isPanning ? "grabbing" : (_zoom > 1.0 ? "grab" : "default"));
        return $"background-color: #1e1e2e; position: relative; overflow: hidden; cursor: {cursor};";
    }

    private string GetTransformContainerStyle()
    {
        var transform = $"scale({_zoom}) rotate({_rotation}deg) translateX({_panX}px) translateY({_panY}px)";
        // image-rendering: auto  — use browser's best quality resampling (bilinear/bicubic)
        //   on most browsers. Overrides any "pixelated" default that some browsers
        //   apply when images are transform-scaled.
        // transition: transform 0.15s ease-out — slightly longer than before, smoother
        //   motion between zoom states when using the scroll wheel.
        return $"position: relative; display: inline-block; transform: {transform}; transform-origin: center center; " +
               $"transition: transform 0.15s ease-out; image-rendering: auto; will-change: transform;";
    }

    // Cached image dimensions — updated on image load
    private double _imgNaturalWidth = 0;
    private double _imgNaturalHeight = 0;
    private double _imgDisplayWidth = 0;
    private double _imgDisplayHeight = 0;

    /// <summary>
    /// Capture the image's *layout* dimensions, which are what the draw overlay
    /// uses as the denominator for image-local fractions. Uses a JS helper that
    /// reads directly from the passed element reference (reliable even when
    /// multiple &lt;img&gt; tags exist on the page).
    /// </summary>
    private async Task UpdateImageDimensions()
    {
        try
        {
            // Read from the <img> element directly via its ElementReference.
            // naturalWidth/Height come from the decoded image; clientWidth/Height are
            // the post-CSS layout size (before transform). That's the exact frame our
            // draw overlay lives in — so using clientWidth/Height keeps OffsetX/Y
            // and the stored fractions perfectly aligned.
            var dims = await JS.InvokeAsync<double[]>("eval",
                @"(function(){
                    var el = document.activeElement;
                    var imgs = document.querySelectorAll('img[alt=""Container Scan""]');
                    el = imgs[imgs.length - 1];
                    if (!el || !el.clientWidth) return [0,0,0,0];
                    return [el.naturalWidth, el.naturalHeight, el.clientWidth, el.clientHeight];
                })()");
            if (dims != null && dims.Length == 4 && dims[2] > 0)
            {
                _imgNaturalWidth = dims[0];
                _imgNaturalHeight = dims[1];
                _imgDisplayWidth = dims[2];
                _imgDisplayHeight = dims[3];
                Console.WriteLine($"[Annotations] Dimensions captured: natural={_imgNaturalWidth}x{_imgNaturalHeight}, display={_imgDisplayWidth}x{_imgDisplayHeight}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Annotations] UpdateImageDimensions failed: {ex.Message}");
        }
    }

    /// <summary>
    /// Ensure we have image dimensions before any coordinate conversion.
    /// </summary>
    private async Task EnsureImageDimensions()
    {
        if (_imgDisplayWidth <= 0 || _imgDisplayHeight <= 0)
        {
            await UpdateImageDimensions();
        }
    }

    /// <summary>
    /// Convert an OffsetX/Y from the DRAW OVERLAY (sibling of &lt;img&gt; inside the transform wrapper)
    /// into a scale-invariant 0..1 fraction of the image's natural layout frame.
    ///
    /// Because the overlay is a child of the same transform wrapper as the &lt;img&gt;, and the
    /// browser reports OffsetX/Y in the event target's untransformed coordinate space,
    /// no zoom, rotation or pan math is required here — the browser has already inverted
    /// the CSS transform chain for us. The overlay's clientWidth/Height equal the image's
    /// pre-transform layout size, so offsetX / clientWidth is exactly the fraction of the
    /// natural image (same fraction regardless of any future viewport/zoom/rotation change).
    ///
    /// IMPORTANT: this function MUST only be called with OffsetX/Y from a draw-overlay
    /// event. Do not pass OffsetX/Y from the outer container — those are in a different
    /// coordinate space and will drift on letterbox/zoom/rotate.
    /// </summary>
    private (double x, double y) ScreenToImageCoords(double offsetX, double offsetY)
    {
        if (_imgDisplayWidth > 0 && _imgDisplayHeight > 0)
        {
            // Clamp to [0,1] so rectangles never escape the image frame.
            var fx = Math.Max(0.0, Math.Min(1.0, offsetX / _imgDisplayWidth));
            var fy = Math.Max(0.0, Math.Min(1.0, offsetY / _imgDisplayHeight));
            return (fx, fy);
        }
        // Before dimensions are captured we cannot safely convert — return 0 so no rectangle is
        // silently recorded in the wrong frame. HandleDrawMouseDown blocks this case anyway.
        return (0.0, 0.0);
    }

    /// <summary>
    /// Check if coordinates look like legacy pixel values (> 1.5) vs normalized fractions (0-1).
    /// Legacy annotations stored raw CSS pixels; new ones store 0-1 fractions.
    /// </summary>
    private bool IsLegacyPixelCoordinates(SuspiciousAreaRect rect)
    {
        return rect.X > 1.5 || rect.Y > 1.5 || rect.Width > 1.5 || rect.Height > 1.5;
    }

    private string GetImageStyle()
    {
        var filters = new List<string>();
        
        if (_brightness != 100) filters.Add($"brightness({_brightness}%)");
        if (_contrast != 100) filters.Add($"contrast({_contrast}%)");
        if (_saturation != 100) filters.Add($"saturate({_saturation}%)");
        if (_hue != 0) filters.Add($"hue-rotate({_hue}deg)");
        if (_blur > 0) filters.Add($"blur({_blur}px)");
        if (_grayscale) filters.Add("grayscale(100%)");
        if (_invertColors) filters.Add("invert(100%)");
        if (_sepia) filters.Add("sepia(100%)");
        if (_edgeDetect) { filters.Add("contrast(300%)"); filters.Add("brightness(120%)"); }
        
        var filter = filters.Any() ? string.Join(" ", filters) : "none";
        // image-rendering: auto - browser uses best-quality bilinear/bicubic scaling
        //   when image is zoomed via CSS transform (prevents pixelated appearance).
        return $"max-width: 100%; max-height: 500px; filter: {filter}; image-rendering: auto;";
    }

