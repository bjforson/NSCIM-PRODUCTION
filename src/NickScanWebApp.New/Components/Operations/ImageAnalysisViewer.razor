    private async Task ReloadActions()
    {
        // Replay: go back to earliest state, then undoAll->start, then redoAll to reapply everything
        await JS.InvokeVoidAsync("ImageAnalysisTools.undoAll");
        var s = await JS.InvokeAsync<object?>("ImageAnalysisTools.redoAll");
