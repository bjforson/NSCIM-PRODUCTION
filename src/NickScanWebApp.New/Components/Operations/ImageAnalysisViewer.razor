    /// <summary>
    /// Fire the ROI inspector for a rectangle. The rectangle's coordinates
    /// are stored as 0..1 fractions of the image; we multiply by the
    /// naturalWidth/Height of the currently loaded &lt;img&gt; to produce
    /// image-native pixel ints, which is what /api/.../roi expects.
    ///
    /// Fetching happens on draw-complete + rect-select; repeated calls
    /// for the same rect short-circuit so clicking the same ROI twice
    /// doesn't re-fetch.
    /// </summary>
    private async Task FetchRoiForRectangleAsync(int rectIdx)
    {
        if (rectIdx < 0 || rectIdx >= _rectangles.Count) return;
        if (rectIdx == _lastRoiIdx && _roiData != null) return; // already shown
        if (string.IsNullOrEmpty(ContainerNumber)) return;

        _roiLoading = true;
        _roiError = "";
        _lastRoiIdx = rectIdx;
        StateHasChanged();
        try
        {
            // Get image natural dimensions via JS. We do this every call
            // rather than caching because (a) it's cheap, and (b) container
            // changes reset the image and we want fresh dims.
            var dims = await JS.InvokeAsync<ImgDims>("Raw16BitViewer.getImageDims", _imageElement);
            int naturalW = dims?.NaturalWidth  ?? 0;
            int naturalH = dims?.NaturalHeight ?? 0;
            if (naturalW <= 0 || naturalH <= 0)
            {
                _roiError = "Image not loaded yet — try again";
                return;
            }

            var rect = _rectangles[rectIdx];
            int x = (int)Math.Round(rect.X      * naturalW);
            int y = (int)Math.Round(rect.Y      * naturalH);
            int w = (int)Math.Round(rect.Width  * naturalW);
            int h = (int)Math.Round(rect.Height * naturalH);
            if (w < 2 || h < 2)
            {
                _roiError = "Rectangle too small for meaningful stats";
                return;
            }

            var url = $"/api/ImageProcessing/container/{Uri.EscapeDataString(ContainerNumber)}/roi?x={x}&y={y}&w={w}&h={h}";
            var roi = await ApiService.GetAsync<NickScanCentralImagingPortal.Core.Interfaces.RoiInspectorResult>(url);
            _roiData = roi;
            if (roi == null)
            {
                _roiError = "ROI unavailable for this scan variant";
            }
            else
            {
                _roiPanelOpen = true; // auto-open on fresh data
            }
        }
        catch (Exception ex)
        {
            _roiError = ex.Message.Length > 180 ? ex.Message.Substring(0, 180) + "…" : ex.Message;
            Console.WriteLine($"[ROI] {ex.GetType().Name}: {ex.Message}");
        }
        finally
        {
            _roiLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>Shape matching Raw16BitViewer.getImageDims() JS output.</summary>
    public class ImgDims
    {
        public int NaturalWidth { get; set; }
        public int NaturalHeight { get; set; }
    }

    /// <summary>
    /// Render a 32-bucket normalised histogram as a small CSS bar chart.
    /// No chart library dependency — keeps the ROI panel lightweight.
    /// </summary>
    private RenderFragment RenderHistogram(double[] buckets, string color) => __builder =>
    {
        if (buckets == null || buckets.Length == 0) return;
        double max = 0;
        for (int i = 0; i < buckets.Length; i++) if (buckets[i] > max) max = buckets[i];
        if (max <= 0) max = 1;

        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "style", "display:flex; align-items:flex-end; gap:1px; height:32px; margin-top:4px;");
        for (int i = 0; i < buckets.Length; i++)
        {
            double hFrac = buckets[i] / max;
            int hPct = (int)Math.Round(hFrac * 100);
            __builder.OpenElement(2, "div");
            __builder.AddAttribute(3, "style",
                $"flex:1; height:{hPct}%; background:{color}; min-width:1px;");
            __builder.AddAttribute(4, "title",
                $"Bucket {i}: {buckets[i] * 100:F2}% of ROI");
            __builder.CloseElement();
        }
        __builder.CloseElement();
    };

