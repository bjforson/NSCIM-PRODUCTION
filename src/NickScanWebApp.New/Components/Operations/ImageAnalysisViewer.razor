    /// <summary>Switch plane (HE/LE/Material). Fetches + renders the new
    /// plane, caching per (container, plane).</summary>
    private async Task SelectRawPlane(string plane)
    {
        if (plane == _rawPlane) return;
        _rawPlane = plane;
        if (_rawMode)
        {
            await LoadAndRenderRawPlaneAsync();
        }
    }

    /// <summary>Fetch + render the current raw plane. Called on toggle,
    /// plane switch, or window/level change where the plane buffer isn't
    /// yet cached client-side.</summary>
    private async Task LoadAndRenderRawPlaneAsync()
    {
        if (!_rawMode || string.IsNullOrEmpty(ContainerNumber)) return;
        _rawLoading = true;
        _rawError = "";
        StateHasChanged();
        try
        {
            // Build a signed short-lived URL for the raw plane fetch. The JS
            // viewer no longer builds the URL itself because it has no access
            // to the signing key. Same UX as the JPEG path but now the tone
            // mapping runs in the browser instead of re-rendering on the server.
            var rawUrl = UrlBuilder.Build(
                $"/api/ImageProcessing/container/{Uri.EscapeDataString(ContainerNumber)}/raw?plane={Uri.EscapeDataString(_rawPlane)}",
                _currentUsername);
            var meta = await JS.InvokeAsync<RawPlaneMeta>(
                "Raw16BitViewer.loadAndRender",
                _rawCanvas, rawUrl, ContainerNumber, _rawPlane,
                _serverLevelPct, _serverWindowPct, /*invert*/ true);
            if (meta != null)
            {
                string sizeLabel = meta.Bytes > 1024 * 1024
                    ? $"{meta.Bytes / 1024.0 / 1024.0:F1} MB"
                    : $"{meta.Bytes / 1024.0:F0} KB";
                _rawGeometryLabel = $"{meta.Width}×{meta.Height} @ {meta.BitDepth}-bit · {sizeLabel}";
                _rawLastRenderAt = DateTime.UtcNow;
            }
        }
        catch (Exception ex)
        {
            _rawError = ex.Message.Length > 160 ? ex.Message.Substring(0, 160) + "…" : ex.Message;
            Console.WriteLine($"[Raw16] {ex.GetType().Name}: {ex.Message}");
        }
        finally
        {
            _rawLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>Re-run window/level on the already-cached plane buffer.
    /// This is the zero-server-round-trip hot path — every slider tick
    /// in raw mode calls this, not LoadAndRenderRawPlaneAsync.</summary>
    private async Task RerenderRawFromCacheAsync()
    {
        if (!_rawMode || string.IsNullOrEmpty(ContainerNumber)) return;
        try
        {
            bool ok = await JS.InvokeAsync<bool>(
                "Raw16BitViewer.rerenderFromCache",
                _rawCanvas, ContainerNumber, _rawPlane,
                _serverLevelPct, _serverWindowPct, /*invert*/ true);
            if (!ok)
            {
                // Cache miss — full load path
                await LoadAndRenderRawPlaneAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Raw16 rerender] {ex.GetType().Name}: {ex.Message}");
        }
    }

