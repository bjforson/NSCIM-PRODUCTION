@using MudBlazor
@using NickScanCentralImagingPortal.Core.Constants
@using NickScanWebApp.New.Services
@using NickScanWebApp.New.Services.Permissions
@using System
@using System.Linq
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionGuard PermissionGuard
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject NickScanWebApp.New.Services.SignedImageUrlBuilder UrlBuilder
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <div style="background: linear-gradient(135deg, #37474f 0%, #546e7a 100%); margin: -24px -24px 0 -24px; padding: 12px 24px; color: white;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.ImageSearch" Size="Size.Small" Style="color:#90caf9;" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:white;">@ContainerNumber</MudText>
                    @if (!string.IsNullOrEmpty(ScannerType))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@ScannerType</MudChip>
                    }
                </MudStack>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.6);">
                    [+/-] Zoom [R] Rotate [G] Gray [I] Invert @(AuditMode ? "[N] Approve [A] Reject" : "[N/A] Decision") [D] Draw
                </MudText>
            </MudStack>
        </div>
    </TitleContent>
    <DialogContent>
        <div style="display: flex; flex-direction: column; height: 100%; max-height: calc(100vh - 64px); overflow: hidden;">

            @* v2.11.0 Phase 3 — pixel probe floating chip. position:fixed so
               it tracks the cursor in screen space regardless of image zoom /
               rotate. Stays outside the transform wrapper so CSS transforms
               don't distort it. pointer-events:none so it never intercepts
               events going back to the probe overlay. *@
            @if (_pixelProbeEnabled && _probeData != null)
            {
                var chipStyle = $"position: fixed; left: {_probeClientX + 16}px; top: {_probeClientY + 16}px;" +
                                " background: rgba(15,20,30,0.92); color: #eceff1; padding: 6px 10px;" +
                                " border-radius: 4px; border: 1px solid rgba(255,255,255,0.15);" +
                                " font-family: 'Consolas','Courier New',monospace; font-size: 11px;" +
                                " line-height: 1.4; z-index: 9999; pointer-events: none;" +
                                " box-shadow: 0 4px 16px rgba(0,0,0,0.4); min-width: 180px;";
                <div style="@chipStyle">
                    <div style="color:#90caf9; font-weight:600; font-size:10px; letter-spacing:0.5px;">
                        @($"({_probeData.X}, {_probeData.Y})")
                    </div>
                    @if (_probeData.HighEnergy.HasValue)
                    {
                        <div>HE = <span style="color:#ffb74d">@_probeData.HighEnergy</span></div>
                    }
                    @if (_probeData.LowEnergy.HasValue)
                    {
                        <div>LE = <span style="color:#ffb74d">@_probeData.LowEnergy</span></div>
                    }
                    @if (_probeData.Material.HasValue)
                    {
                        <div>Mat = <span style="color:#ffb74d">@_probeData.Material</span>
                        @if (!string.IsNullOrEmpty(_probeData.MaterialCategory))
                        {
                            <span style="color:#81c784; margin-left:6px;">@_probeData.MaterialCategory</span>
                        }
                        </div>
                    }
                    @if (_probeData.Red.HasValue)
                    {
                        var rgbBox = $"display:inline-block; width:10px; height:10px; background:rgb({_probeData.Red},{_probeData.Green},{_probeData.Blue}); border:1px solid rgba(255,255,255,0.3); vertical-align:middle; margin-right:6px;";
                        <div>RGB <span style="@rgbBox"></span><span style="color:#ffb74d">@($"({_probeData.Red},{_probeData.Green},{_probeData.Blue})")</span></div>
                    }
                </div>
            }

            @* ═══ ROW 1: Compact Horizontal Toolbar ═══ *@
            <div style="background: linear-gradient(135deg, #455a64 0%, #607d8b 100%); padding: 6px 12px; display: flex; align-items: center; gap: 8px; overflow-x: auto; flex-shrink: 0; border-bottom: 2px solid #78909c;">
                @* Zoom Controls *@
                <MudButtonGroup Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Outlined.ZoomOut" OnClick="ZoomOut" Disabled="@(_zoom <= 0.25)" Style="color:white;" Title="Zoom Out" />
                    <MudButton Style="color:white; padding:4px 8px; min-width:50px; font-size:0.75rem;">@(_zoom.ToString("P0"))</MudButton>
                    <MudIconButton Icon="@Icons.Material.Outlined.ZoomIn" OnClick="ZoomIn" Disabled="@(_zoom >= 5.0)" Style="color:white;" Title="Zoom In" />
                    <MudIconButton Icon="@Icons.Material.Outlined.CenterFocusStrong" OnClick="ZoomTo1x" Style="color:white;" Title="Zoom 1x" />
                    <MudIconButton Icon="@Icons.Material.Outlined.FitScreen" OnClick="ResetZoom" Style="color:white;" Title="Fit / Zoom Reset" />
                </MudButtonGroup>

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Rotate Controls *@
                <MudButtonGroup Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Outlined.RotateLeft" OnClick="RotateLeft" Style="color:white;" Title="Rotate Left" />
                    <MudButton Style="color:white; padding:4px 8px; min-width:40px; font-size:0.75rem;">@(_rotation)°</MudButton>
                    <MudIconButton Icon="@Icons.Material.Outlined.RotateRight" OnClick="RotateRight" Style="color:white;" Title="Rotate Right" />
                </MudButtonGroup>

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Enhance Menu (sliders inside popover) *@
                <MudMenu Icon="@Icons.Material.Outlined.Tune" Label="Enhance" Color="Color.Inherit" Variant="Variant.Text" Size="Size.Small" Dense="true"
                         AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                    <div style="padding: 16px; min-width: 280px;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Image Enhancement</MudText>
                        <MudStack Spacing="2">
                            <div>
                                <MudText Typo="Typo.caption">Brightness: @_brightness%</MudText>
                                <MudSlider @bind-Value="_brightness" Min="0" Max="500" Step="10" Color="Color.Warning" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption">Contrast: @_contrast%</MudText>
                                <MudSlider @bind-Value="_contrast" Min="0" Max="500" Step="10" Color="Color.Info" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption">Saturation: @_saturation%</MudText>
                                <MudSlider @bind-Value="_saturation" Min="0" Max="500" Step="10" Color="Color.Success" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption">Hue: @_hue°</MudText>
                                <MudSlider @bind-Value="_hue" Min="0" Max="360" Step="15" Color="Color.Secondary" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption">Blur: @(_blur.ToString("F1"))px</MudText>
                                <MudSlider @bind-Value="_blur" Min="0" Max="10" Step="0.5" Color="Color.Default" Size="Size.Small" />
                            </div>
                        </MudStack>
                    </div>
                </MudMenu>

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Filter Chips (inline) *@
                <MudChip T="string" Size="Size.Small"
                         Color="@(_grayscale ? Color.Primary : Color.Default)"
                         Variant="@(_grayscale ? Variant.Filled : Variant.Outlined)"
                         Style="@(!_grayscale ? "color:white; border-color:rgba(255,255,255,0.3);" : "")"
                         OnClick="ToggleGrayscale">G</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_invertColors ? Color.Primary : Color.Default)"
                         Variant="@(_invertColors ? Variant.Filled : Variant.Outlined)"
                         Style="@(!_invertColors ? "color:white; border-color:rgba(255,255,255,0.3);" : "")"
                         OnClick="ToggleInvert">Inv</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_edgeDetect ? Color.Primary : Color.Default)"
                         Variant="@(_edgeDetect ? Variant.Filled : Variant.Outlined)"
                         Style="@(!_edgeDetect ? "color:white; border-color:rgba(255,255,255,0.3);" : "")"
                         OnClick="ToggleEdgeDetect">Edge</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_sepia ? Color.Primary : Color.Default)"
                         Variant="@(_sepia ? Variant.Filled : Variant.Outlined)"
                         Style="@(!_sepia ? "color:white; border-color:rgba(255,255,255,0.3);" : "")"
                         OnClick="ToggleSepia">Sepia</MudChip>

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Canvas Tools Menu *@
                <MudMenu Icon="@Icons.Material.Outlined.Layers" Label="Canvas" Color="Color.Inherit" Variant="Variant.Text" Size="Size.Small" Dense="true"
                         AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                    <div style="padding: 12px; min-width: 260px;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Convolution Filters</MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-3">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasConvolution == "sobel" ? Color.Tertiary : Color.Default)"
                                     Variant="@(_canvasConvolution == "sobel" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasConvolution("sobel"))">Sobel</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasConvolution == "laplacian" ? Color.Tertiary : Color.Default)"
                                     Variant="@(_canvasConvolution == "laplacian" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasConvolution("laplacian"))">Laplacian</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasConvolution == "sharpen" ? Color.Tertiary : Color.Default)"
                                     Variant="@(_canvasConvolution == "sharpen" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasConvolution("sharpen"))">Sharpen</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasConvolution == "emboss" ? Color.Tertiary : Color.Default)"
                                     Variant="@(_canvasConvolution == "emboss" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasConvolution("emboss"))">Emboss</MudChip>
                        </MudStack>

                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Pseudocolor Maps</MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-3">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasColorMap == "hot" ? Color.Error : Color.Default)"
                                     Variant="@(_canvasColorMap == "hot" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasColorMap("hot"))">Hot</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasColorMap == "jet" ? Color.Info : Color.Default)"
                                     Variant="@(_canvasColorMap == "jet" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasColorMap("jet"))">Jet</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasColorMap == "bone" ? Color.Default : Color.Default)"
                                     Variant="@(_canvasColorMap == "bone" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasColorMap("bone"))">Bone</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasColorMap == "rainbow" ? Color.Success : Color.Default)"
                                     Variant="@(_canvasColorMap == "rainbow" ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleCanvasColorMap("rainbow"))">Rainbow</MudChip>
                        </MudStack>

                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Special Tools</MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasHistEq ? Color.Warning : Color.Default)"
                                     Variant="@(_canvasHistEq ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleCanvasHistEq">Hist EQ</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_canvasWLActive ? Color.Warning : Color.Default)"
                                     Variant="@(_canvasWLActive ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleWindowLevel">W/L</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_loupeEnabled ? Color.Success : Color.Default)"
                                     Variant="@(_loupeEnabled ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleLoupe">Loupe</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_showHistogram ? Color.Info : Color.Default)"
                                     Variant="@(_showHistogram ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleHistogram">Histogram</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_autoEnhance ? Color.Success : Color.Default)"
                                     Variant="@(_autoEnhance ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleAutoEnhance">Auto Enhance</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_highContrastPreset ? Color.Warning : Color.Default)"
                                     Variant="@(_highContrastPreset ? Variant.Filled : Variant.Outlined)"
                                     OnClick="ToggleHighContrast">High Contrast</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                     OnClick="ResetCanvasTools">Reset</MudChip>
                        </MudStack>

                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2" Style="font-weight:600;">Density (Gamma)</MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@Icons.Material.Outlined.Remove" Size="Size.Small" OnClick="DecreaseDensity" Title="Decrease Density (lighter)" />
                            <MudText Typo="Typo.caption" Style="min-width:60px; text-align:center;">@($"γ {_density:F2}")</MudText>
                            <MudIconButton Icon="@Icons.Material.Outlined.Add" Size="Size.Small" OnClick="IncreaseDensity" Title="Increase Density (denser)" />
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                     OnClick="ResetDensity">Reset</MudChip>
                        </MudStack>

                        @if (_canvasWLActive)
                        {
                            <MudText Typo="Typo.caption" Style="color: #666; margin-top:8px;">
                                Right-click + drag on image: horizontal = window, vertical = level
                            </MudText>
                        }
                        @if (_showHistogram)
                        {
                            <div style="background: #1a1a1a; padding: 8px; border-radius: 4px; margin-top:8px;">
                                <MudText Typo="Typo.caption" Style="color: #aaa; margin-bottom: 4px;">Pixel Intensity Histogram</MudText>
                                <canvas @ref="_histogramCanvas" style="width: 100%; height: 80px; border: 1px solid #333;" />
                            </div>
                        }
                    </div>
                </MudMenu>

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Magnifier (standalone, no canvas required) *@
                <MudIconButton Icon="@Icons.Material.Outlined.Search"
                               OnClick="ToggleMagnifier"
                               Style="@(_magnifierEnabled ? "color:#ffb74d;" : "color:white;")"
                               Size="Size.Small" Title="@(_magnifierEnabled ? "Magnifier ON (hover image)" : "Magnifier")" />

                @* v2.11.0 Phase 3 — Pixel Probe hover chip toggle *@
                <MudIconButton Icon="@Icons.Material.Outlined.Colorize"
                               OnClick="TogglePixelProbe"
                               Style="@(_pixelProbeEnabled ? "color:#81c784;" : "color:white;")"
                               Size="Size.Small"
                               Title="@(_pixelProbeEnabled ? "Pixel Probe ON — hover for HE/LE/Material/RGB" : "Pixel Probe (hover chip)")" />

                @* Goods Description quick reference *@
                <MudIconButton Icon="@Icons.Material.Outlined.Description"
                               OnClick="ToggleGoodsPanel"
                               Style="@(_showGoodsPanel ? "color:#4fc3f7;" : "color:white;")"
                               Size="Size.Small" Title="Goods Description" />

                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>

                @* Action Icon Buttons *@
                <MudIconButton Icon="@Icons.Material.Outlined.Straighten"
                               OnClick="ToggleRuler"
                               Style="@(_rulerMode ? "color:#ffeb3b;" : "color:white;")"
                               Size="Size.Small" Title="@(_rulerMode ? "Ruler ON — click 2 points" : "Ruler (measure)")" />
                <MudIconButton Icon="@Icons.Material.Outlined.CropSquare"
                               OnClick="ToggleDrawMode"
                               Style="@(_drawMode ? "color:#ef5350;" : "color:white;")"
                               Size="Size.Small" Title="@(_drawMode ? "Drawing Mode ON" : "Mark Area / Add Annotation")" />
                <MudIconButton Icon="@(_hideAnnotations ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)"
                               OnClick="ToggleHideAnnotations"
                               Style="@(_hideAnnotations ? "color:#ffb74d;" : "color:white;")"
                               Size="Size.Small" Title="@(_hideAnnotations ? "Show Annotations" : "Hide Annotations")" />
                <MudIconButton Icon="@Icons.Material.Outlined.Palette"
                               OnClick="ToggleColorQuick"
                               Style="@(_canvasColorMap != null ? "color:#ff7043;" : "color:white;")"
                               Size="Size.Small" Title="@(_canvasColorMap != null ? $"Color: {_canvasColorMap}" : "Color (pseudocolor)")" />
                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>
                @* Undo / Redo cluster *@
                <MudIconButton Icon="@Icons.Material.Outlined.Undo" OnClick="Undo" Disabled="@(_undoCount <= 1)"
                               Style="color:white;" Size="Size.Small" Title="Undo" />
                <MudIconButton Icon="@Icons.Material.Outlined.Redo" OnClick="Redo" Disabled="@(_redoCount == 0)"
                               Style="color:white;" Size="Size.Small" Title="Redo" />
                <MudIconButton Icon="@Icons.Material.Outlined.FirstPage" OnClick="UndoAll" Disabled="@(_undoCount <= 1)"
                               Style="color:white;" Size="Size.Small" Title="Undo All" />
                <MudIconButton Icon="@Icons.Material.Outlined.LastPage" OnClick="RedoAll" Disabled="@(_redoCount == 0)"
                               Style="color:white;" Size="Size.Small" Title="Redo All" />
                <MudIconButton Icon="@Icons.Material.Outlined.History" OnClick="ReloadActions"
                               Style="color:white;" Size="Size.Small" Title="Reload Actions" />
                <div style="width:1px; height:24px; background:rgba(255,255,255,0.2);"></div>
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh" OnClick="ResetAll" Style="color:white;" Size="Size.Small" Title="Reset All" />
                <MudIconButton Icon="@(_useEnhancedImage ? Icons.Material.Outlined.AutoAwesome : Icons.Material.Outlined.Image)"
                               OnClick="ToggleEnhancement"
                               Style="@(_useEnhancedImage ? "color:#66bb6a;" : "color:white;")"
                               Size="Size.Small" Title="@(_useEnhancedImage ? "Enhanced" : "Original")" />
                <MudIconButton Icon="@(_showDetectionOverlays ? Icons.Material.Outlined.Visibility : Icons.Material.Outlined.VisibilityOff)"
                               OnClick="ToggleDetectionOverlays"
                               Style="@(_showDetectionOverlays ? "color:#66bb6a;" : "color:white;")"
                               Size="Size.Small" Title="@(_showDetectionOverlays ? "Hide Detections" : "Show Detections")" />
                <MudIconButton Icon="@Icons.Material.Outlined.Fullscreen" OnClick="ToggleFullscreen" Style="color:white;" Size="Size.Small" Title="Fullscreen" />
                <MudIconButton Icon="@Icons.Material.Outlined.Download" OnClick="DownloadImage" Style="color:white;" Size="Size.Small" Title="Download" />
                <MudIconButton Icon="@Icons.Material.Outlined.Print" OnClick="PrintImage" Style="color:white;" Size="Size.Small" Title="Print" />
                <MudIconButton Icon="@Icons.Material.Outlined.AutoAwesome"
                               OnClick="EnhanceSelectedRegion"
                               Disabled="@(_selectedRectIndex == -1)"
                               Style="color:white;" Size="Size.Small" Title="Enhance Selected Region" />
            </div>

            @* ═══ ROW 1b: Mode Catalog Toolbar (v2.10.0) ═══
               Vendor-vocabulary modes — composite / bw / inverse / high-pen / low-pen /
               organic / metal / edge / diff. Only the modes the server advertises as
               supported for this scan variant appear; single-view ASE scans only see
               bw/inverse/edge because the others need two energy channels.
               Hidden entirely until capabilities load, and if the scan has no
               modes at all (e.g. /mode-capabilities 404'd on an old API).
               _activeMode == "" means "server default"; clicking Default reverts. *@
            @if (_modeCapabilitiesLoaded && _supportedModes.Count > 0)
            {
                <div style="background: #263238; padding: 4px 12px; display: flex; align-items: center; gap: 6px; overflow-x: auto; flex-shrink: 0; border-bottom: 1px solid #37474f;">
                    <MudText Typo="Typo.caption" Style="color:#b0bec5; font-weight:600; min-width:90px;">RENDER MODE</MudText>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_activeMode == "" ? Color.Primary : Color.Default)"
                             Variant="@(_activeMode == "" ? Variant.Filled : Variant.Outlined)"
                             Style="@(_activeMode == "" ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                             OnClick="@(() => SelectMode(""))"
                             Title="Server default (composite for dual-energy, bw for single-view)">Default</MudChip>
                    @foreach (var mode in _supportedModes)
                    {
                        var label = ModeLabels.TryGetValue(mode, out var l) ? l : mode;
                        var isActive = _activeMode == mode;
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(isActive ? Color.Primary : Color.Default)"
                                 Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                 Style="@(isActive ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                                 OnClick="@(() => SelectMode(mode))"
                                 Title="@($"Render as {label}")">@label</MudChip>
                    }
                    <div style="width:1px; height:22px; background:rgba(255,255,255,0.15); margin:0 4px;"></div>

                    @* v2.10.4 Phase 2 — server-side Window/Level sliders.
                       Drives ?loPct=&hiPct= on the image URL with a ~180ms debounce
                       so drags coalesce into one refetch. Dimmed with an info
                       icon when the active mode is Composite (vendor LUT ignores
                       tone-curve params) or Default (the no-mode path). *@
                    @{
                        var wlEffective = IsWindowLevelEffective();
                        var wlDim = wlEffective ? "" : "opacity:0.45;";
                        var wlTooltip = wlEffective
                            ? "Drag to window the signal range. Reset reverts to server defaults (1% / 99.5%)."
                            : "Window/Level is ignored in Composite / Default mode (vendor LUT). Pick B/W, Inverse, High Pen, Low Pen, Organic, Metal, Edge, or Diff to activate.";
                    }
                    <MudText Typo="Typo.caption" Style="@($"color:#b0bec5; font-weight:600; min-width:44px; {wlDim}")">LEVEL</MudText>
                    <div style="width:110px; @wlDim">
                        <MudSlider T="double" @bind-Value="_serverLevelPct" @bind-Value:after="OnWindowLevelSliderChanged"
                                   Min="0" Max="100" Step="1" Color="Color.Info" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.caption" Style="@($"color:#b0bec5; min-width:34px; text-align:right; {wlDim}")">@($"{_serverLevelPct:F0}%")</MudText>

                    <MudText Typo="Typo.caption" Style="@($"color:#b0bec5; font-weight:600; min-width:56px; margin-left:8px; {wlDim}")">WINDOW</MudText>
                    <div style="width:110px; @wlDim">
                        <MudSlider T="double" @bind-Value="_serverWindowPct" @bind-Value:after="OnWindowLevelSliderChanged"
                                   Min="2" Max="100" Step="1" Color="Color.Info" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.caption" Style="@($"color:#b0bec5; min-width:34px; text-align:right; {wlDim}")">@($"{_serverWindowPct:F0}%")</MudText>

                    <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                                   Size="Size.Small"
                                   OnClick="ResetWindowLevel"
                                   Style="color:#b0bec5;"
                                   Title="Reset Window/Level" />

                    @if (!wlEffective)
                    {
                        <MudTooltip Text="@wlTooltip" Placement="Placement.Bottom">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Style="color:#78909c;" />
                        </MudTooltip>
                    }

                    @* v2.12.0 Phase 4 — raw 16-bit mode toggle + plane selector.
                       Only shown when the scan has structurally-rich content
                       (dual-energy OR single-view with at least one channel);
                       the same capability gate that enables _supportedModes
                       covers this. Toggling swaps <img> for a <canvas> whose
                       pixels are window/levelled entirely in JS. *@
                    <div style="width:1px; height:22px; background:rgba(255,255,255,0.15); margin:0 4px;"></div>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_rawMode ? Color.Success : Color.Default)"
                             Variant="@(_rawMode ? Variant.Filled : Variant.Outlined)"
                             Style="@(_rawMode ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                             OnClick="ToggleRawMode"
                             Title="Raw 16-bit client-side view \u2014 window/level runs in the browser for zero-latency contrast">
                        @(_rawMode ? "RAW 16-bit ON" : "Raw 16-bit")
                    </MudChip>
                    @if (_rawMode)
                    {
                        @* Plane selector: only offer planes the scan variant has *@
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_rawPlane == "he" ? Color.Info : Color.Default)"
                                 Variant="@(_rawPlane == "he" ? Variant.Filled : Variant.Outlined)"
                                 Style="@(_rawPlane == "he" ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                                 OnClick="@(() => SelectRawPlane("he"))">HE</MudChip>
                        @if (_scanVariant != "ase-single-view")
                        {
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_rawPlane == "le" ? Color.Info : Color.Default)"
                                     Variant="@(_rawPlane == "le" ? Variant.Filled : Variant.Outlined)"
                                     Style="@(_rawPlane == "le" ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                                     OnClick="@(() => SelectRawPlane("le"))">LE</MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_rawPlane == "material" ? Color.Info : Color.Default)"
                                     Variant="@(_rawPlane == "material" ? Variant.Filled : Variant.Outlined)"
                                     Style="@(_rawPlane == "material" ? "" : "color:white; border-color:rgba(255,255,255,0.3);")"
                                     OnClick="@(() => SelectRawPlane("material"))">MAT</MudChip>
                        }
                        @if (_rawLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                        }
                        @if (!string.IsNullOrEmpty(_rawGeometryLabel))
                        {
                            <MudText Typo="Typo.caption" Style="color:#81c784; font-family:monospace;">@_rawGeometryLabel</MudText>
                        }
                        @if (!string.IsNullOrEmpty(_rawError))
                        {
                            <MudText Typo="Typo.caption" Style="color:#ef5350; font-family:monospace;">@_rawError</MudText>
                        }
                    }

                    @if (!string.IsNullOrEmpty(_scanVariant))
                    {
                        <div style="flex:1"></div>
                        <MudText Typo="Typo.caption" Style="color:#78909c; font-style:italic;">@_scanVariant</MudText>
                    }
                </div>
            }

            @* ═══ ROW 2: Main 70/30 Content Area ═══ *@
            <div style="display: flex; flex-direction: row; flex: 1; overflow: hidden;">

                @* ═══ LEFT: Image Viewport (70%) ═══ *@
                <div class="ia-viewer-image" style="flex: 7; position: relative; overflow: hidden; background: #1e1e2e; @GetContainerStyle()">

                    @* Floating Goods Description Panel *@
                    @if (_showGoodsPanel)
                    {
                        <div style="position: absolute; top: 12px; right: 12px; z-index: 40; width: 420px; max-height: 60%;
                                    background: rgba(255,255,255,0.97); border-radius: 8px;
                                    box-shadow: 0 8px 32px rgba(0,0,0,0.3); overflow: hidden; display: flex; flex-direction: column;">
                            <div style="background: #546e7a; padding: 8px 14px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;">
                                <span style="color: white; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                                    Goods Description
                                    @if (_goodsPanelItems.Any())
                                    {
                                        <text> (@_goodsPanelItems.Count items across @_goodsPanelGroups.Count BOE@(_goodsPanelGroups.Count != 1 ? "s" : ""))</text>
                                    }
                                    @if (!string.IsNullOrEmpty(_crmsRiskLevel))
                                    {
                                        var riskColor = _crmsRiskLevel switch
                                        {
                                            "Red" => "#ef5350",
                                            "Yellow" => "#ffc107",
                                            "Green" => "#66bb6a",
                                            "Blue" => "#42a5f5",
                                            _ => "#90a4ae"
                                        };
                                        var riskTextColor = _crmsRiskLevel == "Yellow" ? "#333" : "white";
                                        <span style="background: @riskColor; color: @riskTextColor; padding: 1px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px;">
                                            @_crmsRiskLevel.ToUpper()
                                        </span>
                                    }
                                </span>
                                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                               Style="color: white; padding: 2px;" OnClick="ToggleGoodsPanel" />
                            </div>
                            <div style="overflow-y: auto; padding: 0; flex: 1;">
                                @if (_goodsPanelLoading)
                                {
                                    <div style="padding: 24px; text-align: center;">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        <div style="font-size: 12px; color: #999; margin-top: 8px;">Loading...</div>
                                    </div>
                                }
                                else if (_goodsPanelGroups.Any())
                                {
                                    @foreach (var grp in _goodsPanelGroups)
                                    {
                                        @if (_goodsPanelGroups.Count > 1)
                                        {
                                            <div style="background: #eceff1; padding: 5px 10px; font-size: 11px; font-weight: 700; color: #455a64; border-bottom: 1px solid #cfd8dc; position: sticky; top: 0; z-index: 1;">
                                                @grp.Label
                                                @if (grp.Items.Any())
                                                {
                                                    <span style="font-weight: 400; color: #78909c; margin-left: 6px;">(@grp.Items.Count items)</span>
                                                }
                                            </div>
                                        }
                                        @* Narrative summary from BOE goodsdescription — always shown first *@
                                        @if (!string.IsNullOrEmpty(grp.NarrativeText))
                                        {
                                            <div style="padding: 8px 12px; font-size: 13px; color: #1a237e; line-height: 1.5; background: #e8eaf6; border-bottom: 1px solid #c5cae9; font-weight: 500;">
                                                @grp.NarrativeText
                                            </div>
                                        }
                                        @* Structured line items from manifest — shown below narrative *@
                                        @if (grp.Items.Any())
                                        {
                                            <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
                                                <thead>
                                                    <tr style="background: #f5f5f5;">
                                                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; color: #666; border-bottom: 1px solid #e0e0e0;">#</th>
                                                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; color: #666; border-bottom: 1px solid #e0e0e0;">Description</th>
                                                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; color: #666; border-bottom: 1px solid #e0e0e0;">HS Code</th>
                                                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; color: #666; border-bottom: 1px solid #e0e0e0;">Qty</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in grp.Items)
                                                    {
                                                        <tr style="border-bottom: 1px solid #f0f0f0;">
                                                            <td style="padding: 5px 10px; color: #999;">@item.ItemNo</td>
                                                            <td style="padding: 5px 10px; font-weight: 500; color: #333;">@item.Description</td>
                                                            <td style="padding: 5px 10px; font-family: monospace; font-size: 11px; color: #666;">@(item.HsCode ?? "-")</td>
                                                            <td style="padding: 5px 10px; color: #666;">@(item.Quantity ?? "-")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    }
                                }
                                else
                                {
                                    <div style="padding: 16px; text-align: center; color: #999; font-size: 12px;">No goods description available</div>
                                }
                            </div>
                        </div>
                    }
                    @* OUTER CONTAINER — pan/zoom wheel events only. Draw/move events live on an
                       overlay INSIDE the transform wrapper so offsetX/Y are in image-local space. *@
                    <div style="position: relative; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; overflow: hidden;"
                         @onmousedown="HandleContainerMouseDown"
                         @onmousemove="HandleContainerMouseMove"
                         @onmouseup="HandleContainerMouseUp"
                         @onmouseleave="HandleContainerMouseLeave"
                         @ref="_imageContainer">
                    @if (!string.IsNullOrEmpty(GetCurrentImageUrl()))
                    {
                        var currentUrl = GetCurrentImageUrl();
                        @* Transform wrapper is display:inline-block so its box is sized to the <img>.
                           Every child at position:absolute; inset:0 therefore exactly matches the image
                           rect in the pre-transform frame — which is what we need for precise
                           image-local coordinates that are invariant to zoom/rotate/translate. *@
                        <div style="@GetTransformContainerStyle()">
                        <img src="@currentUrl"
                             alt="Container Scan"
                             style="@GetImageStyle()"
                             @ref="_imageElement"
                             @key="@($"{ContainerNumber}_{_useEnhancedImage}_{_imageCacheBuster}")"
                             draggable="false"
                             @onerror="@(() => HandleImageLoadError(currentUrl))"
                             @onload="@(() => HandleImageLoadSuccess(currentUrl))" />

                        @* Canvas overlay for advanced pixel processing *@
                        <canvas @ref="_canvasElement"
                                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: @(_canvasVisible ? "block" : "none"); z-index: 5; pointer-events: none;" />

                        @* v2.12.0 Phase 4 — raw 16-bit canvas. Rendered from a
                           cached ArrayBuffer by JS (Raw16BitViewer). Sits
                           above the <img> (z-index 6 > 0) and covers it when
                           raw mode is active; hidden otherwise so the JPEG
                           path is unaffected. *@
                        <canvas @ref="_rawCanvas"
                                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: @(_rawMode ? "block" : "none"); z-index: 6; pointer-events: none; background: #000;" />

                        @* Loupe (magnifying glass) overlay *@
                        <canvas @ref="_loupeCanvas"
                                style="position: absolute; display: @(_loupeVisible ? "block" : "none"); z-index: 30; pointer-events: none; border-radius: 50%; box-shadow: 0 0 10px rgba(0,0,0,0.5);" />

                        @* ═══ DRAW OVERLAY — captures draw-mode mouse events in IMAGE-LOCAL coords ═══
                           Positioned absolutely over the <img>, inside the same transform wrapper.
                           Because the browser reports OffsetX/Y in the event target's own
                           untransformed coordinate space, a click at visual position (cx,cy) with
                           the image scaled/rotated still arrives here as the correct
                           (offsetX,offsetY) in the image's natural layout frame. Divide by the
                           overlay's clientWidth/Height → scale-invariant 0..1 fraction. No zoom
                           or rotation math needed. *@
                        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 25; pointer-events: @(_drawMode ? "auto" : "none"); cursor: crosshair;"
                             @ref="_drawOverlay"
                             @onmousedown="HandleDrawMouseDown"
                             @onmousemove="HandleDrawMouseMove"
                             @onmouseup="HandleDrawMouseUp"
                             @onmouseleave="HandleDrawMouseLeave" />

                        @* v2.11.0 Phase 3 — pixel probe overlay. Sibling of draw
                           overlay; only intercepts events when _pixelProbeEnabled.
                           z-index 24 puts it just below draw overlay so draw wins
                           when both are on (draw mode is a deliberate action;
                           probe is always-on ambient telemetry). *@
                        <div @ref="_probeOverlay"
                             style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 24; pointer-events: @(_pixelProbeEnabled && !_drawMode ? "auto" : "none"); cursor: crosshair;"
                             @onmousemove="HandleProbeMouseMove"
                             @onmouseleave="HandleProbeMouseLeave"></div>

                    <!-- SVG Overlay for Object Detection -->
                    @if (_detectionResult != null && _detectionResult.Success && _showDetectionOverlays)
                    {
                        <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10;">
                            @foreach (var container in _detectionResult.ContainerRegions)
                            {
                                <g>
                                    <rect x="@container.X" y="@container.Y" 
                                          width="@container.Width" height="@container.Height"
                                          fill="none" stroke="green" stroke-width="2" opacity="0.8" />
                                    <text x="@(container.X + 5)" y="@(container.Y - 5)" 
                                          fill="green" font-size="12" font-weight="bold">Container</text>
                                </g>
                            }
                            @foreach (var vehicle in _detectionResult.VehicleRegions)
                            {
                                <g>
                                    <rect x="@vehicle.X" y="@vehicle.Y" 
                                          width="@vehicle.Width" height="@vehicle.Height"
                                          fill="none" stroke="blue" stroke-width="2" opacity="0.8" />
                                    <text x="@(vehicle.X + 5)" y="@(vehicle.Y - 5)" 
                                          fill="blue" font-size="12" font-weight="bold">Vehicle</text>
                                </g>
                            }
                            @foreach (var anomaly in _detectionResult.Anomalies)
                            {
                                <g>
                                    <rect x="@anomaly.X" y="@anomaly.Y" 
                                          width="@anomaly.Width" height="@anomaly.Height"
                                          fill="rgba(255,0,0,0.2)" stroke="red" stroke-width="3" opacity="0.9" />
                                    <text x="@(anomaly.X + 5)" y="@(anomaly.Y - 5)" 
                                          fill="red" font-size="14" font-weight="bold">⚠️ Anomaly</text>
                                </g>
                            }
                        </svg>
                    }

                    <!-- SVG Overlay for AI Suggestion ROIs -->
                    @if (_aiSuggestion != null && _showAiOverlays && _aiRois != null)
                    {
                        <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 15;">
                            @foreach (var roi in _aiRois)
                            {
                                <g>
                                    <rect x="@($"{roi.X * 100}%")" y="@($"{roi.Y * 100}%")"
                                          width="@($"{roi.W * 100}%")" height="@($"{roi.H * 100}%")"
                                          fill="rgba(255, 165, 0, 0.15)" stroke="#FF9800" stroke-width="2"
                                          stroke-dasharray="6,3" opacity="0.9" />
                                    <text x="@($"{(roi.X + 0.005) * 100}%")" y="@($"{(roi.Y - 0.01) * 100}%")"
                                          fill="#FF9800" font-size="11" font-weight="bold">
                                        AI: @roi.Label @(roi.Confidence.HasValue ? $"({roi.Confidence:P0})" : "")
                                    </text>
                                </g>
                            }
                        </svg>
                    }

                    <!-- SVG Overlay for Rectangles (User Annotations) -->
                    @* Coordinates stored as 0-1 fractions, rendered as percentages *@
                    <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 20; @(_hideAnnotations ? "display:none;" : "")">
                        @for (int i = 0; i < _rectangles.Count; i++)
                        {
                            var rectIndex = i;
                            var rect = _rectangles[i];
                            var rx = rect.X * 100;
                            var ry = rect.Y * 100;
                            var rw = rect.Width * 100;
                            var rh = rect.Height * 100;
                            <g>
                                <!-- Rectangle outline -->
                                <rect x="@(rx.ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                      y="@(ry.ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                      width="@(rw.ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                      height="@(rh.ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                      fill="none"
                                      stroke="red"
                                      stroke-width="3"
                                      opacity="0.8" />

                                <!-- Tag label -->
                                @if (!string.IsNullOrWhiteSpace(rect.Tag))
                                {
                                    <foreignObject x="@(rx.ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                                   y="@(Math.Max(ry - 4, 0).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                                   width="@(Math.Max(rw, 20).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                                   height="22">
                                        <div xmlns="http://www.w3.org/1999/xhtml"
                                             style="background: rgba(200,0,0,0.85); color: white; font-size: 12px; font-weight: bold;
                                                    padding: 2px 6px; border-radius: 3px; display: inline-block;
                                                    pointer-events: none; user-select: none; white-space: nowrap;">
                                            @rect.Tag
                                        </div>
                                    </foreignObject>
                                }
                                
                                <!-- Resize handles (corners) -->
                                @if (_selectedRectIndex == rectIndex)
                                {
                                    <!-- Top-left -->
                                    <circle cx="@(rx.ToString(System.Globalization.CultureInfo.InvariantCulture))%" cy="@(ry.ToString(System.Globalization.CultureInfo.InvariantCulture))%" r="6" fill="red" style="pointer-events: all; cursor: nwse-resize;" @onmousedown="@((e) => StartResize(e, rectIndex, ResizeHandle.TopLeft))" @onmousedown:stopPropagation="true" />
                                    <!-- Top-right -->
                                    <circle cx="@((rx + rw).ToString(System.Globalization.CultureInfo.InvariantCulture))%" cy="@(ry.ToString(System.Globalization.CultureInfo.InvariantCulture))%" r="6" fill="red" style="pointer-events: all; cursor: nesw-resize;" @onmousedown="@((e) => StartResize(e, rectIndex, ResizeHandle.TopRight))" @onmousedown:stopPropagation="true" />
                                    <!-- Bottom-left -->
                                    <circle cx="@(rx.ToString(System.Globalization.CultureInfo.InvariantCulture))%" cy="@((ry + rh).ToString(System.Globalization.CultureInfo.InvariantCulture))%" r="6" fill="red" style="pointer-events: all; cursor: nesw-resize;" @onmousedown="@((e) => StartResize(e, rectIndex, ResizeHandle.BottomLeft))" @onmousedown:stopPropagation="true" />
                                    <!-- Bottom-right -->
                                    <circle cx="@((rx + rw).ToString(System.Globalization.CultureInfo.InvariantCulture))%" cy="@((ry + rh).ToString(System.Globalization.CultureInfo.InvariantCulture))%" r="6" fill="red" style="pointer-events: all; cursor: nwse-resize;" @onmousedown="@((e) => StartResize(e, rectIndex, ResizeHandle.BottomRight))" @onmousedown:stopPropagation="true" />
                                    
                                    <!-- Delete button (admin only) -->
                                    <PermissionGate Permission="PermissionIds.Images.Edit">
                                        <g style="pointer-events: all; cursor: pointer;" @onclick="@(() => DeleteRectangle(rectIndex))" @onclick:stopPropagation="true">
                                            <circle cx="@((rx + rw).ToString(System.Globalization.CultureInfo.InvariantCulture))%" cy="@(ry.ToString(System.Globalization.CultureInfo.InvariantCulture))%" r="10" fill="darkred" stroke="white" stroke-width="1" />
                                            <text x="@((rx + rw).ToString(System.Globalization.CultureInfo.InvariantCulture))%" y="@((ry + 0.5).ToString(System.Globalization.CultureInfo.InvariantCulture))%" text-anchor="middle" fill="white" font-size="14" font-weight="bold" dominant-baseline="middle">X</text>
                                        </g>
                                    </PermissionGate>
                                }
                            </g>
                        }
                        
                        <!-- Current drawing rectangle -->
                        @if (_isDrawing && _currentRect != null)
                        {
                            <rect x="@((_currentRect.X * 100).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                  y="@((_currentRect.Y * 100).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                  width="@((_currentRect.Width * 100).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                  height="@((_currentRect.Height * 100).ToString(System.Globalization.CultureInfo.InvariantCulture))%"
                                  fill="none"
                                  stroke="red"
                                  stroke-width="3"
                                  stroke-dasharray="5,5"
                                  opacity="0.6" />
                        }
                    </svg>
                        </div> @* End transformed container *@
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                            <MudIcon Icon="@Icons.Material.Outlined.BrokenImage" Size="Size.Large" Color="Color.Error" />
                            <MudText Typo="Typo.h6" Color="Color.Error">Image URL not available</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Container: @ContainerNumber<br />
                                ImageUrl: @(ImageUrl ?? "null")<br />
                                ScannerType: @ScannerType
                            </MudText>
                        </MudStack>
                    }
                </div>
                </div> @* End LEFT image viewport *@

                @* ═══ RIGHT: Decision Panel (30%) ═══ *@
                <div class="ia-viewer-panel" style="flex: 3; min-width: 280px; max-width: 400px; background: var(--mud-palette-surface); border-left: 3px solid var(--mud-palette-primary); overflow-y: auto; padding: 16px;">

                    @* ── DECISION Section ── *@
                    @if (AuditMode)
                    {
                        <MudText Typo="Typo.overline" Style="color:#7B3FA8; font-weight:700; letter-spacing:2px;">AUDIT DECISION</MudText>

                        @* Original analyst decision banner *@
                        @if (!string.IsNullOrEmpty(OriginalAnalystDecision))
                        {
                            <MudPaper Elevation="0" Class="pa-2 mt-2 mb-2"
                                      Style="@($"background: {(OriginalAnalystDecision == "Abnormal" ? "#fff3e0" : "#f1f8e9")}; border-left: 3px solid {(OriginalAnalystDecision == "Abnormal" ? "#ff9800" : "#8bc34a")}; border-radius: 4px;")">
                                <MudText Typo="Typo.caption" Style="@($"color: {(OriginalAnalystDecision == "Abnormal" ? "#e65100" : "#33691e")}; font-weight: 600;")">
                                    Analyst: @OriginalAnalystDecision
                                </MudText>
                                @if (!string.IsNullOrEmpty(OriginalAnalystReviewedBy))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem;">by @OriginalAnalystReviewedBy</MudText>
                                }
                                @if (!string.IsNullOrEmpty(OriginalAnalystComments))
                                {
                                    <MudText Typo="Typo.caption" Style="font-size: 0.7rem;">@OriginalAnalystComments</MudText>
                                }
                                @if (!string.IsNullOrEmpty(OriginalAnalystTags))
                                {
                                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-1">
                                        @foreach (var tag in OriginalAnalystTags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-size: 0.65rem;">@tag</MudChip>
                                        }
                                    </MudStack>
                                }
                            </MudPaper>
                        }

                        <MudStack Spacing="2" Class="mt-2">
                            <MudButton Variant="@(_selectedDecision == "Approved" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Outlined.Verified"
                                       OnClick="@(() => { _selectedDecision = "Approved"; StateHasChanged(); })"
                                       Style="@(_selectedDecision == "Approved" ? "box-shadow: 0 0 12px rgba(76,175,80,0.4); border-radius:10px;" : "border-radius:10px;")"
                                       FullWidth="true" Size="Size.Large">
                                APPROVE
                            </MudButton>
                            <MudButton Variant="@(_selectedDecision == "Rejected" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Outlined.GppBad"
                                       OnClick="@(() => { _selectedDecision = "Rejected"; StateHasChanged(); })"
                                       Style="@(_selectedDecision == "Rejected" ? "box-shadow: 0 0 12px rgba(244,67,54,0.4); border-radius:10px;" : "border-radius:10px;")"
                                       FullWidth="true" Size="Size.Large">
                                REJECT
                            </MudButton>
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.overline" Style="color:#546e7a; font-weight:700; letter-spacing:2px;">DECISION</MudText>
                        <MudStack Spacing="2" Class="mt-2">
                            <MudButton Variant="@(_selectedDecision == "Normal" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Outlined.CheckCircle"
                                       OnClick="@(() => { _selectedDecision = "Normal"; StateHasChanged(); })"
                                       Style="@(_selectedDecision == "Normal" ? "box-shadow: 0 0 12px rgba(76,175,80,0.4); border-radius:10px;" : "border-radius:10px;")"
                                       FullWidth="true" Size="Size.Large">
                                NORMAL
                            </MudButton>
                            <MudButton Variant="@(_selectedDecision == "Abnormal" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Outlined.Warning"
                                       OnClick="@(() => { _selectedDecision = "Abnormal"; StateHasChanged(); })"
                                       Style="@(_selectedDecision == "Abnormal" ? "box-shadow: 0 0 12px rgba(244,67,54,0.4); border-radius:10px;" : "border-radius:10px;")"
                                       FullWidth="true" Size="Size.Large">
                                ABNORMAL
                            </MudButton>
                        </MudStack>
                    }

                    @* ── Controlled finding categories (AI training flywheel — Gap 1a) ── *@
                    @if (_threatCategories.Any() || _revenueAnomalyCategories.Any())
                    {
                        <MudStack Spacing="2" Class="mt-3">
                            @if (_threatCategories.Any())
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedThreatCategoryId"
                                           Label="Security finding (optional)"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true"
                                           HelperText="Weapons, drugs, contraband, hazmat">
                                    <MudSelectItem T="int?" Value="@((int?)null)">
                                        <em>None</em>
                                    </MudSelectItem>
                                    @foreach (var cat in _threatCategories)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)cat.Id)">
                                            @cat.DisplayName
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            @if (_revenueAnomalyCategories.Any())
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedRevenueAnomalyCategoryId"
                                           Label="Revenue finding (optional)"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Clearable="true"
                                           HelperText="Undeclared, undervalued, misclassified, transit diversion">
                                    <MudSelectItem T="int?" Value="@((int?)null)">
                                        <em>None</em>
                                    </MudSelectItem>
                                    @foreach (var cat in _revenueAnomalyCategories)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)cat.Id)">
                                            @cat.DisplayName
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </MudStack>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                               StartIcon="@Icons.Material.Outlined.Save"
                               OnClick="SaveTagsAndDecision"
                               FullWidth="true" Class="mt-3"
                               Style="white-space: nowrap;">
                        Save &amp; Next
                    </MudButton>

                    <MudDivider Class="my-3" />

                    @* ── AI Suggestion ── *@
                    @if (_aiSuggestion != null)
                    {
                        <MudAlert Severity="@(_aiSuggestion.SuggestedDecision == "Abnormal" ? Severity.Error : _aiSuggestion.SuggestedDecision == "Normal" ? Severity.Success : Severity.Info)"
                                  Class="mb-3" Variant="Variant.Outlined" Dense="true">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Outlined.SmartToy" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">
                                        AI: @(_aiSuggestion.SuggestedDecision ?? "N/A")
                                        @if (_aiSuggestion.Confidence.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-1">
                                                @($"{_aiSuggestion.Confidence:P0}")
                                            </MudChip>
                                        }
                                    </MudText>
                                    <MudSpacer />
                                    <MudToggleIconButton @bind-Toggled="_showAiOverlays"
                                                         Icon="@Icons.Material.Outlined.VisibilityOff"
                                                         ToggledIcon="@Icons.Material.Outlined.Visibility"
                                                         Size="Size.Small" Color="Color.Warning" ToggledColor="Color.Warning"
                                                         Title="Toggle AI ROI overlay" />
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(_aiReasoning))
                                {
                                    <MudText Typo="Typo.caption">@_aiReasoning</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Model: @_aiSuggestion.ModelId</MudText>
                            </MudStack>
                        </MudAlert>
                    }

                    @* ── Quality Assessment Badge ── *@
                    @if (_qualityAssessment != null && _qualityAssessment.Success)
                    {
                        <MudAlert Severity="@(_qualityAssessment.IsAcceptable ? Severity.Success : Severity.Warning)" Class="mb-3" Dense="true" Variant="Variant.Outlined">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Outlined.Assessment" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">Quality: @(_qualityAssessment.OverallScore.ToString("P0"))</MudText>
                                    @if (_qualityAssessment.IsAcceptable)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Low</MudChip>
                                    }
                                </MudStack>
                                <MudProgressLinear Value="@(_qualityAssessment.OverallScore * 100)"
                                                   Color="@(_qualityAssessment.IsAcceptable ? Color.Success : Color.Warning)"
                                                   Size="Size.Small" />
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.caption">Sharp: @(_qualityAssessment.Sharpness.ToString("P0"))</MudText>
                                    <MudText Typo="Typo.caption">Bright: @(_qualityAssessment.Brightness.ToString("P0"))</MudText>
                                    <MudText Typo="Typo.caption">Contrast: @(_qualityAssessment.Contrast.ToString("P0"))</MudText>
                                    <MudText Typo="Typo.caption">Noise: @(_qualityAssessment.NoiseLevel.ToString("P0"))</MudText>
                                </MudStack>
                                @if (!_qualityAssessment.IsAcceptable && _qualityAssessment.Recommendations.Any())
                                {
                                    <MudExpansionPanels>
                                        <MudExpansionPanel Text="Recommendations" Dense="true">
                                            <ul style="margin: 4px 0; padding-left: 16px;">
                                                @foreach (var rec in _qualityAssessment.Recommendations)
                                                {
                                                    <li><MudText Typo="Typo.caption">@rec</MudText></li>
                                                }
                                            </ul>
                                        </MudExpansionPanel>
                                    </MudExpansionPanels>
                                }
                            </MudStack>
                        </MudAlert>
                    }

                    @* ── Anomaly Detection Alert ── *@
                    @if (_detectionResult != null && _detectionResult.Success && _detectionResult.HasAnomalies)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3" Variant="Variant.Filled" Dense="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Style="font-weight:600;">Anomalies Detected</MudText>
                                <MudText Typo="Typo.caption">
                                    @_detectionResult.Anomalies.Count anomaly(ies) found. Review carefully.
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    Containers: @_detectionResult.ContainerRegions.Count |
                                    Vehicles: @_detectionResult.VehicleRegions.Count
                                </MudText>
                            </MudStack>
                        </MudAlert>
                    }

                    @* ── Cross-Record Warning ── *@
                    @if (_crossRecordInfo != null && _crossRecordInfo.IsCrossRecordImage)
                    {
                        <MudAlert Severity="@GetCrossRecordSeverity(_crossRecordInfo.Severity)" Class="mb-3" Variant="Variant.Filled" Dense="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Style="font-weight:600;">Cross-Record Image</MudText>
                                <MudText Typo="Typo.caption">
                                    Two containers from different records in this scan.
                                </MudText>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption">
                                        Pos 1: @(_crossRecordInfo.PositionInScan == 1 ? ContainerNumber : _crossRecordInfo.SiblingContainer)
                                        @if (_crossRecordInfo.PositionInScan == 1) { <MudChip T="string" Size="Size.Small" Color="Color.Primary">Current</MudChip> }
                                    </MudText>
                                    <MudText Typo="Typo.caption">
                                        Pos 2: @(_crossRecordInfo.PositionInScan == 2 ? ContainerNumber : _crossRecordInfo.SiblingContainer)
                                        @if (_crossRecordInfo.PositionInScan == 2) { <MudChip T="string" Size="Size.Small" Color="Color.Primary">Current</MudChip> }
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudChip T="string" Color="@GetCrossRecordTypeColor(_crossRecordInfo.CrossRecordType)" Size="Size.Small">
                                        @FormatCrossRecordType(_crossRecordInfo.CrossRecordType)
                                    </MudChip>
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Outlined.SwapHoriz"
                                               OnClick="@(() => NavigateToSibling())"
                                               Style="white-space: nowrap;">
                                        Switch
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudAlert>
                    }

                    <MudDivider Class="my-3" />

                    @* ── MARKED AREAS Section ── *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.CropFree" Style="color:#546e7a;" Size="Size.Small" />
                        <MudText Typo="Typo.overline" Style="color:#546e7a; font-weight:700; letter-spacing:2px;">MARKED AREAS</MudText>
                    </MudStack>

                    @if (_rectangles.Any())
                    {
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-2">
                            @for (int i = 0; i < _rectangles.Count; i++)
                            {
                                var rect = _rectangles[i];
                                var idx = i;
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                         OnClick="@(() => SelectRectangle(idx))"
                                         OnClose="@(() => RemoveRectangle(idx))">
                                    @(!string.IsNullOrEmpty(rect.Tag) ? rect.Tag : $"Area {idx + 1}") (@((int)(rect.X * 100))%,@((int)(rect.Y * 100))%)
                                </MudChip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color:#999;" Class="mb-2">
                            Use Mark Area (toolbar) to draw rectangles on suspicious regions
                        </MudText>
                    }

                    @if (_selectedRectIndex >= 0 && _selectedRectIndex < _rectangles.Count)
                    {
                        <MudStack Spacing="1" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Outlined.Label" Color="Color.Warning" Size="Size.Small" />
                                <MudText Typo="Typo.caption" Style="font-weight:600;">Tag Selected Area:</MudText>
                            </MudStack>
                            <MudTextField T="string"
                                          Value="@_selectedTagText"
                                          ValueChanged="@OnTagTextChanged"
                                          Placeholder="Type tag label and press Enter or click Save..."
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          OnKeyDown="@OnTagKeyDown" />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.Save"
                                       OnClick="SaveTagAndRectangles"
                                       FullWidth="true">
                                Save Tag
                            </MudButton>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Quick tags:</MudText>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Suspicious"))">Suspicious</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Weapons"))">Weapons</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Contraband"))">Contraband</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Narcotics"))">Narcotics</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Dense"))">Dense</MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TagSelectedRectangle("Clear"))">Clear</MudChip>
                            </MudStack>
                        </MudStack>
                    }

                    @* ═══ v2.13.0 Phase 5 — ROI Inspector Panel ═══
                       Fires when the operator draws or selects a rectangle.
                       Shows per-channel 16-bit stats, material-class
                       distribution, and 240px preview thumbnails. Powered by
                       GET /api/ImageProcessing/container/{id}/roi (shipped
                       in v2.10.0, routed through the unified pipeline in
                       v2.11.0). *@
                    <MudDivider Class="my-3" />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Analytics" Style="color:#546e7a;" Size="Size.Small" />
                        <MudText Typo="Typo.overline" Style="color:#546e7a; font-weight:700; letter-spacing:2px;">ROI INSPECTOR</MudText>
                        <div style="flex:1"></div>
                        @if (_roiData != null || _roiLoading || !string.IsNullOrEmpty(_roiError))
                        {
                            <MudIconButton Icon="@(_roiPanelOpen ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)"
                                           Size="Size.Small" OnClick="ToggleRoiPanel" />
                        }
                    </MudStack>
                    @if (_roiLoading)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                            <MudText Typo="Typo.caption" Style="color:#666;">Computing ROI stats…</MudText>
                        </MudStack>
                    }
                    else if (!string.IsNullOrEmpty(_roiError))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Text">@_roiError</MudAlert>
                    }
                    else if (_roiData == null)
                    {
                        <MudText Typo="Typo.caption" Style="color:#999;" Class="mb-2">
                            Draw or click a rectangle above to see per-channel stats + material breakdown.
                        </MudText>
                    }
                    else if (_roiPanelOpen)
                    {
                        var roi = _roiData;
                        string dominantColor = roi.Material.DominantCategory switch
                        {
                            "metal"   => "#4a90e2",
                            "organic" => "#ff9f43",
                            "noise"   => "#bdbdbd",
                            _          => "#90a4ae",
                        };
                        <MudStack Spacing="2" Class="mb-2">
                            @* ROI geometry + timing *@
                            <div style="font-family: monospace; font-size: 11px; color:#666;">
                                @($"({roi.X},{roi.Y})  {roi.Width}×{roi.Height} px  · {roi.ElapsedMs} ms")
                            </div>

                            @* Dominant material chip *@
                            @if (roi.Material.CategoryDistribution.Values.Any(v => v > 0))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <span style="@($"display:inline-block; width:10px; height:10px; background:{dominantColor}; border-radius:50%;")"></span>
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@roi.Material.DominantCategory</MudText>
                                    <MudText Typo="Typo.caption" Style="color:#666;">@($"({roi.Material.DominantPercent * 100:F1}% of ROI)")</MudText>
                                </MudStack>

                                @* Material distribution bars *@
                                <div style="padding: 6px 8px; background:#f5f5f5; border-radius:4px;">
                                    @foreach (var kv in roi.Material.CategoryDistribution.OrderByDescending(k => k.Value))
                                    {
                                        if (kv.Value <= 0) continue;
                                        string c = kv.Key switch
                                        {
                                            "metal"   => "#4a90e2",
                                            "organic" => "#ff9f43",
                                            "noise"   => "#bdbdbd",
                                            _          => "#90a4ae",
                                        };
                                        <div style="display:flex; align-items:center; gap:6px; margin:2px 0;">
                                            <span style="min-width:72px; font-size:11px; color:#555;">@kv.Key</span>
                                            <div style="flex:1; height:10px; background:#e0e0e0; border-radius:2px; overflow:hidden;">
                                                <div style="@($"width:{kv.Value * 100:F1}%; height:100%; background:{c};")"></div>
                                            </div>
                                            <span style="min-width:42px; font-size:10px; font-family:monospace; text-align:right; color:#555;">@($"{kv.Value * 100:F1}%")</span>
                                        </div>
                                    }
                                </div>
                            }

                            @* Channel stats: HE + LE min/median/max + 32-bucket histogram *@
                            <div style="padding: 6px 8px; background:#f5f5f5; border-radius:4px;">
                                <MudText Typo="Typo.caption" Style="color:#333; font-weight:600;">HE channel</MudText>
                                <div style="font-family:monospace; font-size:10px; color:#555; margin:2px 0;">
                                    @($"min={roi.HighEnergy.Min} med={roi.HighEnergy.Median:F0} max={roi.HighEnergy.Max} · p1={roi.HighEnergy.P01} p99={roi.HighEnergy.P99}")
                                </div>
                                @RenderHistogram(roi.HighEnergy.Histogram, "#546e7a")
                            </div>
                            @if (roi.LowEnergy.Max != roi.HighEnergy.Max || roi.LowEnergy.Min != roi.HighEnergy.Min)
                            {
                                @* Skip LE panel for single-view scans where HE == LE (backend mirrors for UI) *@
                                <div style="padding: 6px 8px; background:#f5f5f5; border-radius:4px;">
                                    <MudText Typo="Typo.caption" Style="color:#333; font-weight:600;">LE channel</MudText>
                                    <div style="font-family:monospace; font-size:10px; color:#555; margin:2px 0;">
                                        @($"min={roi.LowEnergy.Min} med={roi.LowEnergy.Median:F0} max={roi.LowEnergy.Max} · p1={roi.LowEnergy.P01} p99={roi.LowEnergy.P99}")
                                    </div>
                                    @RenderHistogram(roi.LowEnergy.Histogram, "#8e24aa")
                                </div>
                            }

                            @* Preview thumbnails (base64 JPEGs, capped at 240px long side by the backend) *@
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                @if (!string.IsNullOrEmpty(roi.HighEnergyPreviewB64))
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center;">
                                        <img src="data:image/jpeg;base64,@roi.HighEnergyPreviewB64" style="max-width:100px; max-height:80px; border:1px solid #ccc; border-radius:2px;" />
                                        <MudText Typo="Typo.caption" Style="font-size:10px; color:#666;">HE</MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(roi.LowEnergyPreviewB64))
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center;">
                                        <img src="data:image/jpeg;base64,@roi.LowEnergyPreviewB64" style="max-width:100px; max-height:80px; border:1px solid #ccc; border-radius:2px;" />
                                        <MudText Typo="Typo.caption" Style="font-size:10px; color:#666;">LE</MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(roi.MaterialPreviewB64))
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center;">
                                        <img src="data:image/jpeg;base64,@roi.MaterialPreviewB64" style="max-width:100px; max-height:80px; border:1px solid #ccc; border-radius:2px;" />
                                        <MudText Typo="Typo.caption" Style="font-size:10px; color:#666;">MAT</MudText>
                                    </div>
                                }
                            </MudStack>
                        </MudStack>
                    }

                </div> @* End RIGHT decision panel *@

            </div> @* End 70/30 flex row *@

            @* ═══ ROW 3: Status Bar ═══ *@
            <div style="background: linear-gradient(135deg, #546e7a 0%, #607d8b 100%); padding: 6px 16px; display: flex; align-items: center; gap: 16px; flex-shrink: 0;">
                <MudText Typo="Typo.caption" Style="color:#e0e0e0;">Container: <strong style="color:white;">@ContainerNumber</strong></MudText>
                <MudText Typo="Typo.caption" Style="color:#e0e0e0;">Scanner: <strong style="color:white;">@ScannerType</strong></MudText>
                <MudText Typo="Typo.caption" Style="color:#e0e0e0;">Zoom: <strong style="color:white;">@(_zoom.ToString("P0"))</strong></MudText>
                <MudText Typo="Typo.caption" Style="color:#e0e0e0;">Rotation: <strong style="color:white;">@(_rotation)°</strong></MudText>
                <MudSpacer />
                <MudText Typo="Typo.caption" Style="color:#e0e0e0;">@ScanDate.ToString("MMM dd, HH:mm")</MudText>
                <MudButton OnClick="CloseAsync" Color="Color.Inherit" Size="Size.Small" Variant="Variant.Text" Style="color:#e0e0e0;">Close</MudButton>
            </div>

        </div> @* End main 3-row column *@
    </DialogContent>
</MudDialog>

@* Enhanced Region Comparison Overlay (Phase 5) *@
@if (_showEnhancedRegionDialog && _enhancedRegionRect != null)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="10000" @onclick="CloseEnhancedRegionDialog">
        <MudPaper @onclick:stopPropagation="true" 
                  Elevation="24" 
                  Class="pa-4" 
                  Style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10001; background: #2b2b2b; max-width: 90vw; max-height: 90vh; overflow-y: auto;">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" Class="mr-2" />
                        Enhanced Region Comparison
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" OnClick="CloseEnhancedRegionDialog" Color="Color.Default" />
                </MudStack>
                
                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        Region: X=@((int)_enhancedRegionRect.X), Y=@((int)_enhancedRegionRect.Y), 
                        Width=@((int)_enhancedRegionRect.Width), Height=@((int)_enhancedRegionRect.Height)
                    </MudText>
                </MudAlert>
                
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.h6" Align="Align.Center">Enhanced Region</MudText>
                                @if (!string.IsNullOrEmpty(_enhancedRegionUrl))
                                {
                                    <div style="display: flex; justify-content: center; align-items: center; min-height: 300px; background-color: #1a1a1a;">
                                        <img src="@_enhancedRegionUrl" 
                                             alt="Enhanced Region" 
                                             style="max-width: 100%; max-height: 400px; border: 2px solid #4caf50;" />
                                    </div>
                                }
                                else
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                                    <MudText Typo="Typo.body2" Align="Align.Center">Loading enhanced region...</MudText>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.h6" Align="Align.Center">Original Region</MudText>
