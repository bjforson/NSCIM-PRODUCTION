    private async Task LoadExistingTags()
    {
        try
        {
            Console.WriteLine($"[LoadExistingTags] Loading for container={ContainerNumber}, scanner={ScannerType}");
            var decisions = await ApiService.GetAsync<List<ImageDecisionDto>>(
                $"/api/ImageAnalysisDecision/container/{ContainerNumber}");
            
            Console.WriteLine($"[LoadExistingTags] API returned {decisions?.Count ?? 0} decision(s)");
            if (decisions != null)
            {
                foreach (var d in decisions)
                    Console.WriteLine($"[LoadExistingTags]   - Scanner={d.ScannerType}, Decision={d.Decision}, Tags='{d.Tags}'");
            }

            var decision = decisions?.FirstOrDefault(d => d.ScannerType == ScannerType);
            if (decision != null)
            {
                Console.WriteLine($"[LoadExistingTags] Matched decision: Tags='{decision.Tags}', Decision='{decision.Decision}'");

                // Load tags
                if (!string.IsNullOrEmpty(decision.Tags))
                {
                    _tags = decision.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Select(t => t.Trim())
                        .ToList();
                    Console.WriteLine($"[LoadExistingTags] Loaded {_tags.Count} tag(s): {string.Join(", ", _tags)}");
                }
                else
                {
                    Console.WriteLine($"[LoadExistingTags] Tags field is null or empty");
                }
                
                // Load decision
                _selectedDecision = string.IsNullOrEmpty(decision.Decision) ? "Pending" : decision.Decision;

                // Load comments
                _existingComments = decision.Comments;

                // Load any previously saved finding category ids (AI training flywheel).
                _selectedThreatCategoryId = decision.ThreatCategoryId;
                _selectedRevenueAnomalyCategoryId = decision.RevenueAnomalyCategoryId;
            }
            else
            {
                Console.WriteLine($"[LoadExistingTags] No matching decision found for scanner '{ScannerType}'");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadExistingTags] ERROR: {ex.GetType().Name}: {ex.Message}");
        }
    }

