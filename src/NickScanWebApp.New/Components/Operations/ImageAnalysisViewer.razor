    /// <summary>
    /// Mouse-move on the probe overlay. OffsetX/Y on the overlay is in image-
    /// native pixel coords (the overlay lives inside the transform wrapper and
    /// has no CSS transform of its own, so offset is scale-invariant). ClientX/Y
    /// drives the floating chip's screen position via position:fixed so it
    /// tracks the cursor regardless of zoom/rotate.
    /// </summary>
    private void HandleProbeMouseMove(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (!_pixelProbeEnabled) return;
        _probeLastX = (int)e.OffsetX;
        _probeLastY = (int)e.OffsetY;
        _probeClientX = e.ClientX;
        _probeClientY = e.ClientY;

        // Coalesce bursts — mouse-move fires 100s of times/sec during a drag.
        _probeDebounceTimer?.Dispose();
        _probeDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (!_pixelProbeEnabled) return;
                try
                {
                    var probe = await ApiService.GetAsync<NickScanCentralImagingPortal.Core.Interfaces.PixelValueResult>(
                        $"/api/ImageProcessing/container/{Uri.EscapeDataString(ContainerNumber)}/pixel?x={_probeLastX}&y={_probeLastY}");
                    if (probe != null && _pixelProbeEnabled)
                    {
                        _probeData = probe;
                        StateHasChanged();
                    }
                }
                catch
                {
                    // Soft-fail — a transient 404 / 500 on a hover tick is
                    // non-critical; stale data stays visible until the next
                    // successful tick. Nothing to log at this level.
                }
            });
        }, null, ProbeDebounceMs, System.Threading.Timeout.Infinite);
    }

    /// <summary>Clear the chip when the cursor leaves the image.</summary>
    private void HandleProbeMouseLeave()
    {
        _probeData = null;
        StateHasChanged();
    }

