    private static bool IsLosslessImageUrl(string? url) =>
        !string.IsNullOrWhiteSpace(url)
        && url.Contains("/lossless/", StringComparison.OrdinalIgnoreCase);

    private ScanAssetResolution? ApplyChosenSplitToResolution(string resultId)
    {
        var resolution = _resolution ?? SourceScanResolution;
        if (resolution == null)
        {
            return null;
        }

        var selectedOption = _options.FirstOrDefault(option =>
            string.Equals(option.ResultId, resultId, StringComparison.OrdinalIgnoreCase));
        var side = selectedOption?.Side ?? _position ?? resolution.EffectiveSplitSide;
        var recordContainer = GetRecordContainerHint() ?? ContainerNumber;

        resolution.ContainerNumber = recordContainer;
        resolution.NormalizedContainerNumber = string.IsNullOrWhiteSpace(resolution.NormalizedContainerNumber)
            ? recordContainer
            : resolution.NormalizedContainerNumber;
        resolution.GroupIdentifier ??= GroupIdentifier;
        resolution.AnalysisRecordId ??= _analysisRecordId;
        resolution.Status = "Resolved";
        resolution.Found = true;
        resolution.IsResolved = true;
        resolution.Resolved = true;

        if (Guid.TryParse(_jobId, out var splitJobId))
        {
            resolution.SplitJobId = splitJobId;
        }

        if (Guid.TryParse(resultId, out var splitResultId))
        {
            resolution.SplitResultId = splitResultId;
        }

        if (!string.IsNullOrWhiteSpace(side))
        {
            resolution.SplitPosition = side;
            resolution.SplitSide = side;
            resolution.PositionHint = side;
        }

        resolution.SplitContext ??= new SplitOptionContext();
        resolution.SplitContext.ContainerNumber = recordContainer;
        resolution.SplitContext.GroupIdentifier ??= GroupIdentifier;
        resolution.SplitContext.IsMultiContainer = true;
        resolution.SplitContext.SplitStatus = "Chosen";
        resolution.SplitContext.SplitJobId = resolution.SplitJobId;
        resolution.SplitContext.SplitResultId = resolution.SplitResultId;
        resolution.SplitContext.SplitPosition = resolution.EffectiveSplitSide;
        resolution.SplitContext.SourceScanId ??= resolution.EffectiveSourceScanId;
        resolution.SplitContext.OriginalScanRecordId ??= resolution.OriginalScanRecordId;
        resolution.SplitContext.ScannerScanId ??= resolution.ScannerScanId;
        resolution.SplitContext.SourceScannerType ??= resolution.SourceScannerType;
        if (_analysisRecordId.HasValue)
        {
            resolution.SplitContext.AnalysisRecordId = _analysisRecordId.Value;
        }

        _resolution = resolution;
        return resolution;
    }

    private async Task ChooseOption(string resultId)
    {
        _submitting = true;
        _choosingResultId = resultId;
        StateHasChanged();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User?.Identity?.Name ?? "unknown";
            var recordContainer = GetRecordContainerHint();

            var request = new
            {
                resultId,
                approvedBy = userName,
                splitJobId = _jobId,
                sourceScanId = _resolution?.EffectiveSourceScanId,
                containerNumber = recordContainer
            };

            var saved = false;
            if (_analysisRecordId.HasValue)
            {
                saved = await ApiService.TryPostAsync(
                    $"/api/image-analysis/records/{_analysisRecordId.Value}/choose-split",
                    request);
            }

            if (!saved && Guid.TryParse(_jobId, out var splitJobId))
            {
                saved = await ApiService.TryPostAsync(
                    $"/api/image-splitter/jobs/{splitJobId}/choose-split",
                    request);
            }

            if (!saved)
            {
                var containerKey = recordContainer ?? GetSingleContainerHint(_resolution) ?? ContainerNumber;
                await ApiService.PostAsync<object, object>(
                    $"/api/image-splitter/container/{Uri.EscapeDataString(containerKey)}/choose-split",
                    request);
            }

            var chosenResolution = ApplyChosenSplitToResolution(resultId);
            ClearSplitRelatedCaches();
            _splitStatus = "Chosen";
            _options.Clear();
            Snackbar.Add($"Split image selected for {ContainerNumber}", Severity.Success);
            await OnSplitResolutionChanged.InvokeAsync(chosenResolution);
            await OnSplitChosen.InvokeAsync();
            await NotifySplitStateChangedAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save split choice: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
            _choosingResultId = null;
            StateHasChanged();
        }
    }

    private async Task SkipSplit()
    {
        _submitting = true;
        StateHasChanged();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User?.Identity?.Name ?? "unknown";
            var recordContainer = GetRecordContainerHint();

            var request = new
            {
                skippedBy = userName,
                splitJobId = _jobId,
                sourceScanId = _resolution?.EffectiveSourceScanId,
                containerNumber = recordContainer
            };

            var saved = false;
            if (_analysisRecordId.HasValue)
            {
                saved = await ApiService.TryPostAsync(
                    $"/api/image-analysis/records/{_analysisRecordId.Value}/skip-split",
                    request);
            }

            if (!saved && Guid.TryParse(_jobId, out var splitJobId))
            {
                saved = await ApiService.TryPostAsync(
                    $"/api/image-splitter/jobs/{splitJobId}/skip-split",
                    request);
            }

            if (!saved)
            {
                var containerKey = recordContainer ?? GetSingleContainerHint(_resolution) ?? ContainerNumber;
                await ApiService.PostAsync<object, object>(
                    $"/api/image-splitter/container/{Uri.EscapeDataString(containerKey)}/skip-split",
                    request);
            }

            ClearSplitRelatedCaches();
            _splitStatus = "Skipped";
            _options.Clear();
            Snackbar.Add($"Split skipped for {ContainerNumber} — using combined image", Severity.Info);
            await OnSplitSkipped.InvokeAsync();
            await NotifySplitStateChangedAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to skip split: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Returns true if this component needs to show a split choice UI
    /// (status is "Ready" with options), or a pending banner.
    /// Returns false if the normal viewer should take over.
    /// </summary>
    public bool NeedsSplitInteraction => StatusEquals("Ready") && _options.Count > 0;
    public bool IsPending => StatusEquals("Pending");
    public bool IsResolved => _splitStatus == null || StatusEquals("Chosen") || StatusEquals("Skipped") || IsTerminalNoChoice;

    private async Task NotifySplitStateChangedAsync()
    {
        if (!OnSplitStateChanged.HasDelegate)
        {
            return;
        }

        await OnSplitStateChanged.InvokeAsync(GetSplitInteractionState());
    }

    private string GetSplitInteractionState()
    {
        if (_loading)
        {
            return "Loading";
        }

        if (NeedsSplitInteraction || StatusEquals("Ready"))
        {
            return "ChoiceRequired";
        }

        if (IsPending)
        {
            return "Pending";
        }

        return "Resolved";
    }

    private void ClearSplitRelatedCaches()
    {
        ContainerDetailsService.ClearContainerCache(ContainerNumber);

        var containerHint = GetSingleContainerHint(_resolution);
        if (!string.IsNullOrWhiteSpace(containerHint)
            && !string.Equals(containerHint, ContainerNumber, StringComparison.OrdinalIgnoreCase))
        {
            ContainerDetailsService.ClearContainerCache(containerHint);
        }
    }

    private string? GetRecordContainerHint()
    {
        return _recordContainerHint
            ?? StrictSingleContainerToken(_resolution?.ContainerNumber)
            ?? StrictSingleContainerToken(_resolution?.RequestedContainerNumber)
            ?? StrictSingleContainerToken(_resolution?.NormalizedContainerNumber)
            ?? StrictSingleContainerToken(ContainerNumber);
    }

    private bool IsTerminalNoChoice =>
        StatusEquals("VisualSingle") || StatusEquals("Uncertain") || StatusEquals("NotApplicable");

    private Severity TerminalNoChoiceSeverity =>
        StatusEquals("Uncertain") ? Severity.Warning : Severity.Info;

    private string TerminalNoChoiceIcon =>
        StatusEquals("Uncertain")
            ? Icons.Material.Outlined.HelpOutline
            : Icons.Material.Outlined.ImageNotSupported;

    private string TerminalNoChoiceText
    {
        get
        {
            if (StatusEquals("VisualSingle"))
                return "Splitter classified this as visually single-container. Showing the original image.";
            if (StatusEquals("Uncertain"))
                return "Splitter could not identify a safe two-container split. Showing the original image.";
            if (StatusEquals("NotApplicable"))
                return "Split review is not applicable for this image. Showing the original image.";
            return "Split review is not required for this image. Showing the original image.";
        }
    }

    private bool StatusEquals(string status) =>
        string.Equals(_splitStatus, status, StringComparison.OrdinalIgnoreCase);
}
