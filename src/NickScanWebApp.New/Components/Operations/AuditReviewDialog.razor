@using MudBlazor
@using NickScanWebApp.New.Services
@using NickScanWebApp.New.Components.Containers
@using NickScanWebApp.New.Components.ICUMS
@using NickScanWebApp.New.Components.Operations
@using NickScanWebApp.New.Components.CargoGroup
@using NickScanWebApp.New.Models
@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using NickScanWebApp.Shared.Models
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService
@inject CargoGroupService CargoGroupService
@inject ILogger<AuditReviewDialog> Logger
@inject NickScanWebApp.New.Services.SignedImageUrlBuilder UrlBuilder

<MudDialog>
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: auto;">
            
            <!-- Overall Audit Decision Banner -->
            <MudAlert Severity="@GetOverallSeverity()" Variant="Variant.Filled" Class="mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@GetOverallIcon()" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6">Audit Decision: @GetOverallDecision()</MudText>
                        <MudText Typo="Typo.body2">
                            @_auditDecisions.Count(d => d.Value == ApprovedValue) Approved |
                            @_auditDecisions.Count(d => d.Value == RejectedValue) Rejected |
                            @_auditDecisions.Count(d => string.IsNullOrEmpty(d.Value)) Pending
                        </MudText>
                        <MudText Typo="Typo.caption">
                            @Record?.TotalContainers container(s) | @Record?.ScannerType Scanner |
                            @(Record?.IsConsolidated == true ? "Consolidated" : "Non-Consolidated")
                        </MudText>
                    </div>
                    <MudSpacer />
                    <MudText Typo="Typo.caption">
                        Original Analysis by <strong>@GetOriginalAnalystDisplay()</strong>
                        on @Record?.SubmittedAt.ToString("MMM dd, yyyy HH:mm")
                    </MudText>
                </MudStack>
            </MudAlert>

            <!-- Bulk Action Buttons (for multi-container non-consolidated) -->
            @if (Record?.ImageAnalysisDecisions?.Count > 1 && Record?.IsConsolidated != true)
            {
                <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bulk Action:</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                               StartIcon="@Icons.Material.Outlined.CheckCircle"
                               OnClick="@(() => BulkAuditDecision(ApprovedValue))" Disabled="@_submitting">
                        All Approved
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Outlined.Cancel"
                               OnClick="@(() => BulkAuditDecision(RejectedValue))" Disabled="@_submitting">
                        All Rejected
                    </MudButton>
                </MudStack>
            }

            <!-- Main Tabs: Summary and Container Tabs -->
            @if (Record?.ImageAnalysisDecisions != null && Record.ImageAnalysisDecisions.Any())
            {
                <MudTabs Elevation="2" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-4"
                         ActivePanelIndex="_activeMainTabIndex"
                         ActivePanelIndexChanged="OnMainTabChanged">
                    <!-- Summary Tab -->
                    <MudTabPanel Text="Summary" Icon="@Icons.Material.Outlined.Summarize">
                        <div style="height: calc(80vh - 200px); overflow-y: auto; padding: 16px;">
                            @if (_loadingCargoGroupForSummary)
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                    <MudText Typo="Typo.body2">Loading cargo group data...</MudText>
                                </MudStack>
                            }
                            else
                            {
                                <CargoGroupSummaryTab CargoGroup="@_cargoGroupForSummary" />
                            }
                        </div>
                    </MudTabPanel>
                    
                    <!-- Container Tabs -->
                    @foreach (var decision in Record.ImageAnalysisDecisions)
                    {
                        <MudTabPanel Text="@decision.ContainerNumber" Icon="@Icons.Material.Outlined.Inventory">
                            
                            <!-- Original Decision Alert -->
                            <MudAlert Severity="@(decision.Decision == "Abnormal" ? Severity.Error : Severity.Success)" 
                                     Variant="Variant.Filled" 
                                     Dense="true" 
                                     Class="mb-3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@(decision.Decision == "Abnormal" ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.CheckCircle)" 
                                            Size="Size.Medium" />
                                    <div>
                                        <MudText Typo="Typo.subtitle1"><strong>Original Image Analysis: @decision.Decision</strong></MudText>
                                        <MudText Typo="Typo.caption">@(decision.Comments ?? "No comments")</MudText>
                                    </div>
                                </MudStack>
                            </MudAlert>

                            <!-- Sub-Tabs: Scanner Data, Images, ICUMS Data, Audit Decision -->
                            <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
                                
                                <!-- Scanner Data Tab -->
                                <MudTabPanel Text="Scanner Data" Icon="@Icons.Material.Outlined.Scanner">
                                    <ScannerDataTab ContainerNumber="@decision.ContainerNumber" 
                                                   GroupIdentifier="@Record?.GroupIdentifier"
                                                   SourceScanResolution="@GetScanAssetResolution(decision.ContainerNumber)"
                                                   TotalRecords="1" 
                                                   PreloadedData="@(_preloadedScannerData.ContainsKey(decision.ContainerNumber) ? _preloadedScannerData[decision.ContainerNumber] : null)" />
                                </MudTabPanel>

                                <!-- Images & Decisions Tab (merged — image cards with inline audit verdicts) -->
                                <MudTabPanel Text="Images & Decisions" Icon="@Icons.Material.Outlined.Image">
                                    <div style="height: calc(100vh - 400px); overflow-y: auto;">
                                        @if (_containerImages.ContainsKey(decision.ContainerNumber)
                                             && _containerImages[decision.ContainerNumber].Any())
                                        {
                                            <!-- Container rollup bar -->
                                            <MudAlert Severity="@(GetRollupCounts(decision.ContainerNumber).AnyRejected ? Severity.Error : GetRollupCounts(decision.ContainerNumber).AllDecided ? Severity.Success : Severity.Normal)" Dense="true" Class="mb-3">
                                                <strong>Container rollup:</strong>
                                                @GetRollupCounts(decision.ContainerNumber).Approved approved,
                                                @GetRollupCounts(decision.ContainerNumber).Rejected rejected,
                                                @GetRollupCounts(decision.ContainerNumber).Pending pending
                                                @if (GetRollupCounts(decision.ContainerNumber).AnyRejected)
                                                {
                                                    <text> — container will be REJECTED</text>
                                                }
                                                else if (GetRollupCounts(decision.ContainerNumber).AllDecided)
                                                {
                                                    <text> — container will be APPROVED</text>
                                                }
                                            </MudAlert>

                                            <MudStack Spacing="4">
                                                @for (int idx = 0; idx < _containerImages[decision.ContainerNumber].Count; idx++)
                                                {
                                                    var imageIndex = idx;
                                                    var image = _containerImages[decision.ContainerNumber][imageIndex];
                                                    var currentVerdict = GetImageVerdict(decision.ContainerNumber, imageIndex);

                                                    <!-- Image Card — matching analyst ImageDecisionView chrome -->
                                                    <MudPaper Elevation="3" Class="pa-0" Style="overflow: hidden; border-radius: 8px;">
                                                        <!-- Header bar with verdict color -->
                                                        <MudToolBar Dense="true" Style="@GetImageHeaderStyle(currentVerdict)">
                                                            <MudIcon Icon="@GetScannerIcon(image.ImageType)" />
                                                            <MudText Typo="Typo.subtitle1" Class="ml-2">
                                                                <strong>@image.ImageType</strong> (image @(imageIndex + 1) of @_containerImages[decision.ContainerNumber].Count)
                                                            </MudText>
                                                            <MudSpacer />
                                                            <MudChip T="string" Size="Size.Small"
                                                                     Style="@GetVerdictChipStyle(currentVerdict)">
                                                                @(string.IsNullOrEmpty(currentVerdict) ? "Pending" : currentVerdict)
                                                            </MudChip>
                                                        </MudToolBar>

                                                        <!-- Image display area -->
                                                        <div style="background: #111; min-height: 350px; display:flex; align-items:center; justify-content:center; cursor: zoom-in;"
                                                             @onclick="@(() => OpenFullImage(image, decision.ContainerNumber, imageIndex))">
                                                            <img src="@GetAuditImageUrl(image, decision.ContainerNumber)" alt="@image.ImageType"
                                                                 style="max-width: 100%; max-height: 600px;" loading="lazy" />
                                                        </div>

                                                        <!-- Original analyst decision banner -->
                                                        <MudPaper Elevation="0" Class="pa-3"
                                                                  Style="@($"background: {(decision.Decision == "Abnormal" ? "#fff3e0" : "#f1f8e9")}; border-left: 4px solid {(decision.Decision == "Abnormal" ? "#ff9800" : "#8bc34a")};")">
                                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                                <MudIcon Icon="@(decision.Decision == "Abnormal" ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.CheckCircle)"
                                                                         Style="@($"color: {(decision.Decision == "Abnormal" ? "#ff9800" : "#8bc34a")};")" Size="Size.Medium" />
                                                                <div>
                                                                    <MudText Typo="Typo.subtitle2">
                                                                        Analyst Decision: <strong>@decision.Decision</strong>
                                                                    </MudText>
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                        By @GetAnalystName(decision) on @decision.ReviewedAt.ToString("MMM dd, yyyy HH:mm")
                                                                    </MudText>
                                                                    @if (!string.IsNullOrEmpty(decision.Comments))
                                                                    {
                                                                        <MudText Typo="Typo.caption">Comments: @decision.Comments</MudText>
                                                                    }
                                                                </div>
                                                                @if (!string.IsNullOrEmpty(decision.Tags))
                                                                {
                                                                    <MudSpacer />
                                                                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                                                        @foreach (var tag in decision.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@tag</MudChip>
                                                                        }
                                                                    </MudStack>
                                                                }
                                                            </MudStack>
                                                        </MudPaper>

                                                        <!-- Audit status + click to review prompt -->
                                                        <div class="pa-2" style="background: #fafafa; text-align: center;">
                                                            @if (!string.IsNullOrEmpty(currentVerdict))
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    Audit: <strong style="color: @(currentVerdict == ApprovedValue ? "#4caf50" : "#f44336")">@currentVerdict</strong>
                                                                    @if (!string.IsNullOrEmpty(GetImageNotes(decision.ContainerNumber, imageIndex)))
                                                                    {
                                                                        <text> — @GetImageNotes(decision.ContainerNumber, imageIndex)</text>
                                                                    }
                                                                </MudText>
                                                            }
                                                            else
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.TouchApp" Size="Size.Small" Class="mr-1" />
                                                                    Click image to open fullscreen viewer and make your audit decision
                                                                </MudText>
                                                            }
                                                        </div>
                                                    </MudPaper>
                                                }
                                            </MudStack>

                                            <!-- Container-level notes -->
                                            <MudTextField @bind-Value="@_auditNotes[decision.ContainerNumber]"
                                                         Label="Container-level audit notes"
                                                         Placeholder="Notes that apply to the whole container, not a specific image"
                                                         Variant="Variant.Outlined" Lines="3" Immediate="true" Class="mt-3" />
                                        }
                                        else
                                        {
                                            <!-- Fallback: no images loaded -->
                                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                                                No image list available — falling back to container-level decision.
                                            </MudAlert>
                                            <MudRadioGroup T="string"
                                                           Value="@GetFallbackVerdict(decision.ContainerNumber)"
                                                           ValueChanged="@((string v) => SetFallbackVerdict(decision.ContainerNumber, v))">
                                                <MudRadio T="string" Value="@ApprovedValue" Color="Color.Success">Approve</MudRadio>
                                                <MudRadio T="string" Value="@RejectedValue" Color="Color.Error" Class="mt-2">Reject</MudRadio>
                                            </MudRadioGroup>
                                        }
                                    </div>
                                </MudTabPanel>

                                <!-- ICUMS Data Tab -->
                                <MudTabPanel Text="ICUMS Data" Icon="@Icons.Material.Outlined.Description">
                                    <ICUMSDataTab ContainerNumber="@decision.ContainerNumber"
                                                 PreloadedData="@(_preloadedICUMSData.ContainsKey(decision.ContainerNumber) ? _preloadedICUMSData[decision.ContainerNumber] : null)" />
                                </MudTabPanel>

                            </MudTabs>
                        </MudTabPanel>
                    }
                </MudTabs>
            }

            <!-- Overall Decision Preview -->
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudAlert Severity="@GetOverallSeverity()" Dense="true">
                    <MudText Typo="Typo.subtitle1">
                        <strong>Overall Decision: @GetOverallDecision()</strong>
                    </MudText>
                    <MudText Typo="Typo.caption">
                        @GetOverallMessage()
                    </MudText>
                </MudAlert>
            </MudPaper>

            @if (_submitting)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-3" />
            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_submitting">Cancel</MudButton>
        @if (_submitting)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
            <MudText Typo="Typo.caption" Class="ml-2">Submitting audit decisions...</MudText>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public AuditGroupDto? Record { get; set; }
    [Parameter] public AuditReviewViewContext? PreloadedContext { get; set; }
    [Parameter] public EventCallback<bool> OnAuditComplete { get; set; }
    
    private const string ApprovedValue = "Approved";
    private const string RejectedValue = "Rejected";

    // Container-level rollup of per-image verdicts. The dictionary still exists so
    // the existing AllDecisionsMade / GetOverallDecision helpers keep working as a
    // single source of truth — but it's now derived from the per-image state in
    // _imageVerdicts on every change rather than being directly bound to a radio.
    private Dictionary<string, string> _auditDecisions = new(); // ContainerNumber -> rolled-up Decision
    private Dictionary<string, string> _auditNotes = new(); // ContainerNumber -> container-level notes
    private Dictionary<string, List<NickScanWebApp.Shared.Models.ImageMetadata>> _containerImages = new();
    private Dictionary<string, ScanAssetResolution> _scanAssetResolutions = new();

    // Per-image audit state (deferred plan request 1 — UI half).
    // ContainerNumber → (ImageIndex → "Approved"/"Rejected"). The container-level
    // _auditDecisions rollup is recomputed every time a per-image verdict changes:
    // any Rejected child → Rejected, all decided + none rejected → Approved,
    // anything pending → empty (treated as "not yet decided").
    private Dictionary<string, Dictionary<int, string>> _imageVerdicts = new();
    private Dictionary<string, Dictionary<int, string>> _imageNotes = new();
    // ScannerType per (container, imageIndex) — captured from the preloaded image
    // metadata at the moment the auditor first selects a verdict, so the
    // submission payload carries the scanner type the auditor actually saw.
    private Dictionary<string, Dictionary<int, string>> _imageScannerTypes = new();
    private bool _submitting = false;
    private string _currentUser = "Unknown";
    private int _activeMainTabIndex = 1; // 0=Summary, 1+=Container (start on first container)
    
    // Summary tab data (lazy-loaded when user switches to Summary tab)
    private CargoGroupDto? _cargoGroupForSummary = null;
    private bool _loadingCargoGroupForSummary = false;
    private bool _summaryLoadRequested = false; // Track if we've started/completed load to avoid duplicate requests
    
    // ✅ FIX: Preloaded data for tabs
    private Dictionary<string, NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ScannerDataRecord>> _preloadedScannerData = new(); // ContainerNumber -> ScannerData
    private Dictionary<string, NickScanWebApp.Shared.Models.PagedResult<NickScanWebApp.Shared.Models.ICUMSDataRecord>> _preloadedICUMSData = new(); // ContainerNumber -> ICUMSData

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("📂 [AuditReviewDialog] Opened for group {Group}, Containers={Count}, IsConsolidated={Consolidated}", 
            Record?.GroupIdentifier ?? "(null)", Record?.ImageAnalysisDecisions?.Count ?? 0, Record?.IsConsolidated ?? false);
        // Get current user
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User?.Identity?.Name ?? "Unknown";

        // Initialize audit decisions and notes for each container
        if (Record?.ImageAnalysisDecisions != null)
        {
            foreach (var decision in Record.ImageAnalysisDecisions)
            {
                _auditDecisions[decision.ContainerNumber] = ""; // Empty = not decided
                _auditNotes[decision.ContainerNumber] = "";
            }
        }

        // ✅ OPTIMIZATION: Summary tab is lazy-loaded when user switches to it (not on dialog open)
        
        ApplyPreloadedContext();

        // ✅ FIX: Preload all data for all containers (images, scanner data, ICUMS data)
        // Phase 4: when the page supplied a preloaded view context, only fetch gaps.
        await LoadMissingContainerData();
    }
    
    private void OnMainTabChanged(int newIndex)
    {
        _activeMainTabIndex = newIndex;
        // Lazy-load Summary tab when user switches to it (index 0)
        if (newIndex == 0 && !_summaryLoadRequested && !_loadingCargoGroupForSummary && _cargoGroupForSummary == null)
        {
            _summaryLoadRequested = true;
            _ = LoadCargoGroupForSummary();
        }
    }
    
    private async Task LoadCargoGroupForSummary()
    {
        if (Record == null || string.IsNullOrEmpty(Record.GroupIdentifier)) return;
        
        _loadingCargoGroupForSummary = true;
        StateHasChanged();
        
        try
        {
            // ✅ FIX: For consolidated cargo, GroupIdentifier is container number, but cargo group service needs Master BL
            // ✅ FIX: For non-consolidated cargo, GroupIdentifier is declaration number, which is correct
            string actualGroupIdentifier = Record.GroupIdentifier;
            CargoType? actualCargoType = Record.IsConsolidated ? CargoType.Consolidated : CargoType.NonConsolidated;
            
            // If consolidated, GroupIdentifier is container number - need to find Master BL
            if (Record.IsConsolidated)
            {
                var containerNumber = Record.GroupIdentifier; // For consolidated, GroupIdentifier = ContainerNumber
                var groupIdentifierInfo = await CargoGroupService.GetGroupIdentifierByContainerAsync(containerNumber);
                
                if (groupIdentifierInfo != null)
                {
                    actualGroupIdentifier = groupIdentifierInfo.GroupIdentifier;
                    actualCargoType = groupIdentifierInfo.Type;
                    Console.WriteLine($"🔍 [AuditReviewDialog] Resolved container {containerNumber} to group identifier: {actualGroupIdentifier} (Type: {actualCargoType})");
                }
                else
                {
                    Console.WriteLine($"⚠️ [AuditReviewDialog] Could not resolve group identifier for container {containerNumber}, using container number directly");
                }
            }
            
            Console.WriteLine($"📊 [AuditReviewDialog] Loading cargo group for summary (ICUMS only): {actualGroupIdentifier} (Type: {actualCargoType})");
            
            // ✅ OPTIMIZATION: Summary tab only needs ICUMS data - skip Scanner and Image to reduce payload and API time
            _cargoGroupForSummary = await CargoGroupService.GetCargoGroupAsync(
                actualGroupIdentifier, 
                actualCargoType,
                loadScannerData: false,
                loadImageData: false,
                loadICUMSData: true);
            
            if (_cargoGroupForSummary == null)
            {
                // Try alternative cargo type if first attempt fails
                var alternativeType = actualCargoType == CargoType.Consolidated ? CargoType.NonConsolidated : CargoType.Consolidated;
                Console.WriteLine($"⚠️ [AuditReviewDialog] Cargo group not found for {actualGroupIdentifier} as {actualCargoType}, trying {alternativeType}...");
                _cargoGroupForSummary = await CargoGroupService.GetCargoGroupAsync(
                    actualGroupIdentifier, 
                    alternativeType,
                    loadScannerData: false,
                    loadImageData: false,
                    loadICUMSData: true);
                
                if (_cargoGroupForSummary == null)
                {
                    Console.WriteLine($"⚠️ [AuditReviewDialog] Cargo group not found for summary: {actualGroupIdentifier} (tried both types)");
                    Console.WriteLine($"   Original GroupIdentifier: {Record.GroupIdentifier}");
                }
            }
            else
            {
                Console.WriteLine($"✅ [AuditReviewDialog] Loaded cargo group for summary: {actualGroupIdentifier}");
                Console.WriteLine($"   Containers: {_cargoGroupForSummary.ContainerNumbers?.Count ?? 0}");
                Console.WriteLine($"   ICUMS Records: {_cargoGroupForSummary.Data?.ICUMSData?.Count ?? 0}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [AuditReviewDialog] Error loading cargo group for summary: {ex.Message}");
            Console.WriteLine($"   Stack trace: {ex.StackTrace}");
        }
        finally
        {
            _loadingCargoGroupForSummary = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Apply page-level audit review preload data before falling back to direct
    /// container loads. This keeps old behavior for any missing context.
    /// </summary>
    private void ApplyPreloadedContext()
    {
        if (Record?.ImageAnalysisDecisions == null || PreloadedContext == null)
        {
            return;
        }

        var appliedContainers = 0;
        foreach (var decision in Record.ImageAnalysisDecisions)
        {
            var containerNumber = decision.ContainerNumber;
            var containerContext = PreloadedContext.GetContainerContext(containerNumber);
            if (containerContext == null)
            {
                continue;
            }

            if (containerContext.Images != null)
            {
                _containerImages[containerNumber] = containerContext.Images;
            }

            if (containerContext.ScanAssetResolution != null)
            {
                _scanAssetResolutions[containerNumber] = containerContext.ScanAssetResolution;
            }

            if (containerContext.ScannerData != null)
            {
                _preloadedScannerData[containerNumber] = containerContext.ScannerData;
            }

            if (containerContext.ICUMSData != null)
            {
                _preloadedICUMSData[containerNumber] = containerContext.ICUMSData;
            }

            appliedContainers++;
        }

        Logger.LogInformation(
            "📦 [AuditReviewDialog] Applied preloaded context for {Applied}/{Total} containers in group {Group}",
            appliedContainers,
            Record.ImageAnalysisDecisions.Count,
            Record.GroupIdentifier);
    }

    /// <summary>
    /// ✅ FIX: Preload missing data for all containers (images, scanner data, ICUMS data)
    /// This ensures tabs have data ready when clicked without reloading data supplied by the page preloader.
    /// </summary>
    private async Task LoadMissingContainerData()
    {
        if (Record?.ImageAnalysisDecisions == null) return;

        Console.WriteLine($"🚀 [AuditReviewDialog] Preloading missing data for {Record.ImageAnalysisDecisions.Count} container(s)");

        // Load missing data in parallel for better performance
        var loadTasks = new List<Task>();

        foreach (var decision in Record.ImageAnalysisDecisions)
        {
            var containerNumber = decision.ContainerNumber;
            
            if (!_containerImages.ContainsKey(containerNumber))
            {
                loadTasks.Add(LoadContainerImages(containerNumber));
            }

            if (!_preloadedScannerData.ContainsKey(containerNumber))
            {
                loadTasks.Add(LoadContainerScannerData(containerNumber));
            }

            if (!_preloadedICUMSData.ContainsKey(containerNumber))
            {
                loadTasks.Add(LoadContainerICUMSData(containerNumber));
            }
        }

        if (loadTasks.Count > 0)
        {
            await Task.WhenAll(loadTasks);
        }

        Console.WriteLine($"✅ [AuditReviewDialog] Finished preloading missing container data");
        StateHasChanged();
    }

    private async Task LoadContainerImages(string containerNumber)
    {
        try
        {
            var resolution = await GetOrResolveScanAssetAsync(containerNumber);
            var images = await ContainerDetailsService.GetImageMetadataForResolvedScanAsync(
                containerNumber,
                Record?.GroupIdentifier,
                resolution);
            if (images != null)
            {
                _containerImages[containerNumber] = images;
                Console.WriteLine($"✅ [AuditReviewDialog] Loaded {images.Count} images for {containerNumber}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [AuditReviewDialog] Error loading images for {containerNumber}: {ex.Message}");
        }
    }

    private async Task LoadContainerScannerData(string containerNumber)
    {
        try
        {
            var resolution = await GetOrResolveScanAssetAsync(containerNumber);
            var scannerData = await ContainerDetailsService.GetScannerDataForResolvedScanAsync(
                containerNumber,
                Record?.GroupIdentifier,
                page: 1,
                pageSize: 1000,
                resolution: resolution);
            if (scannerData != null)
            {
                _preloadedScannerData[containerNumber] = scannerData;
                Console.WriteLine($"✅ [AuditReviewDialog] Loaded {scannerData.Data?.Count ?? 0} scanner records for {containerNumber}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [AuditReviewDialog] Error loading scanner data for {containerNumber}: {ex.Message}");
        }
    }

    private async Task LoadContainerICUMSData(string containerNumber)
    {
        try
        {
            var icumsData = await ContainerDetailsService.GetICUMSDataAsync(containerNumber, 1, 1000);
            if (icumsData != null)
            {
                _preloadedICUMSData[containerNumber] = icumsData;
                Console.WriteLine($"✅ [AuditReviewDialog] Loaded {icumsData.Data?.Count ?? 0} ICUMS records for {containerNumber}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ [AuditReviewDialog] Error loading ICUMS data for {containerNumber}: {ex.Message}");
        }
    }

    private ScanAssetResolution? GetScanAssetResolution(string containerNumber)
    {
        return _scanAssetResolutions.TryGetValue(containerNumber, out var resolution)
            ? resolution
            : null;
    }

    private async Task<ScanAssetResolution?> GetOrResolveScanAssetAsync(string containerNumber)
    {
        if (_scanAssetResolutions.TryGetValue(containerNumber, out var existing))
        {
            return existing;
        }

        var resolution = await ContainerDetailsService.ResolveScanAssetAsync(
            containerNumber,
            Record?.GroupIdentifier);

        if (resolution != null)
        {
            _scanAssetResolutions[containerNumber] = resolution;
        }

        return resolution;
    }

    private string GetAuditImageUrl(NickScanWebApp.Shared.Models.ImageMetadata image, string containerNumber)
    {
        var resolution = image.Resolution ?? GetScanAssetResolution(containerNumber);
        var preferred = BuildPreferredImagePath(image, containerNumber, resolution);
        var url = preferred ?? image.FullImageUrl;

        if (string.IsNullOrWhiteSpace(url) || url.Contains("sig=", StringComparison.OrdinalIgnoreCase))
        {
            return url;
        }

        if (url.StartsWith("/api/", StringComparison.OrdinalIgnoreCase))
        {
            return UrlBuilder.Build(url, _currentUser);
        }

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri)
            && uri.AbsolutePath.StartsWith("/api/", StringComparison.OrdinalIgnoreCase))
        {
            return UrlBuilder.Build(uri.PathAndQuery, _currentUser);
        }

        return url;
    }

    private static string? BuildPreferredImagePath(
        NickScanWebApp.Shared.Models.ImageMetadata image,
        string containerNumber,
        ScanAssetResolution? resolution)
    {
        if (resolution?.HasUsableSourceScan != true)
        {
            return null;
        }

        var side = image.SplitSide ?? resolution.EffectiveSplitSide;
        var splitJobId = image.SplitJobId ?? resolution.SplitJobId;
        var splitResultId = image.SplitResultId ?? resolution.SplitResultId;
        if (splitJobId.HasValue && splitResultId.HasValue && !string.IsNullOrWhiteSpace(side))
        {
            return $"/api/image-splitter/jobs/{splitJobId.Value}/results/{splitResultId.Value}/lossless/{Uri.EscapeDataString(side)}";
        }

        var sourceScanId = image.SourceScanId ?? image.OriginalScanRecordId?.ToString() ?? resolution.EffectiveSourceScanId;
        return !string.IsNullOrWhiteSpace(sourceScanId)
            ? $"/api/scan-assets/{Uri.EscapeDataString(sourceScanId)}/image?size=full&containerNumber={Uri.EscapeDataString(containerNumber)}"
            : null;
    }

    private string GetOriginalAnalystDisplay()
    {
        var analysts = Record?.ImageAnalysisDecisions?
            .Select(decision => decision.ReviewedBy?.Trim())
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return analysts is { Count: > 0 } ? string.Join(", ", analysts) : "Unknown";
    }

    private static string GetAnalystName(NickScanWebApp.New.Models.ImageAnalysisDecisionSummary? decision)
    {
        return string.IsNullOrWhiteSpace(decision?.ReviewedBy)
            ? "Unknown"
            : decision.ReviewedBy.Trim();
    }

    private bool AllDecisionsMade()
    {
        return _auditDecisions.All(d => !string.IsNullOrEmpty(d.Value));
    }

    // ─── Per-image verdict helpers (deferred plan request 1, UI half) ───

    /// <summary>Set a single image's verdict and recompute the container rollup.</summary>
    private void SetImageVerdict(string containerNumber, int imageIndex, string scannerType, string verdict)
    {
        if (!_imageVerdicts.TryGetValue(containerNumber, out var verdicts))
        {
            verdicts = new Dictionary<int, string>();
            _imageVerdicts[containerNumber] = verdicts;
        }
        verdicts[imageIndex] = verdict;

        if (!_imageScannerTypes.TryGetValue(containerNumber, out var scanners))
        {
            scanners = new Dictionary<int, string>();
            _imageScannerTypes[containerNumber] = scanners;
        }
        scanners[imageIndex] = scannerType;

        RecomputeContainerRollup(containerNumber);
    }

    /// <summary>Bind a per-image notes textbox.</summary>
    private void SetImageNotes(string containerNumber, int imageIndex, string notes)
    {
        if (!_imageNotes.TryGetValue(containerNumber, out var notesByImage))
        {
            notesByImage = new Dictionary<int, string>();
            _imageNotes[containerNumber] = notesByImage;
        }
        notesByImage[imageIndex] = notes ?? string.Empty;
    }

    private string GetImageVerdict(string containerNumber, int imageIndex)
    {
        if (_imageVerdicts.TryGetValue(containerNumber, out var verdicts)
            && verdicts.TryGetValue(imageIndex, out var v))
        {
            return v ?? string.Empty;
        }
        return string.Empty;
    }

    private string GetImageNotes(string containerNumber, int imageIndex)
    {
        if (_imageNotes.TryGetValue(containerNumber, out var notesByImage)
            && notesByImage.TryGetValue(imageIndex, out var n))
        {
            return n ?? string.Empty;
        }
        return string.Empty;
    }

    /// <summary>
    /// Recompute the container-level <c>_auditDecisions</c> rollup from the per-image
    /// state. Rules: any Rejected → Rejected. All decided AND none rejected → Approved.
    /// Anything pending → empty (treated as undecided by AllDecisionsMade /
    /// CanSaveCurrentContainer).
    /// </summary>
    private void RecomputeContainerRollup(string containerNumber)
    {
        if (!_imageVerdicts.TryGetValue(containerNumber, out var verdicts))
        {
            _auditDecisions[containerNumber] = string.Empty;
            return;
        }

        var imageCount = _containerImages.TryGetValue(containerNumber, out var imgs) ? imgs.Count : 0;
        if (imageCount == 0)
        {
            // Fallback path used when image preload hasn't completed: a single
            // verdict at index 0 is enough to call the container decided.
            if (verdicts.TryGetValue(0, out var only) && !string.IsNullOrEmpty(only))
            {
                _auditDecisions[containerNumber] = only;
            }
            else
            {
                _auditDecisions[containerNumber] = string.Empty;
            }
            return;
        }

        var anyRejected = verdicts.Values.Any(v => v == RejectedValue);
        if (anyRejected)
        {
            _auditDecisions[containerNumber] = RejectedValue;
            return;
        }

        var decidedCount = Enumerable.Range(0, imageCount)
            .Count(i => verdicts.TryGetValue(i, out var v) && !string.IsNullOrEmpty(v));
        if (decidedCount == imageCount)
        {
            _auditDecisions[containerNumber] = ApprovedValue;
        }
        else
        {
            _auditDecisions[containerNumber] = string.Empty;
        }
    }

    /// <summary>Display data for the per-container rollup chip.</summary>
    private (int Approved, int Rejected, int Pending, bool AnyRejected, bool AllDecided) GetRollupCounts(string containerNumber)
    {
        var imageCount = _containerImages.TryGetValue(containerNumber, out var imgs) ? imgs.Count : 0;
        if (imageCount == 0) return (0, 0, 0, false, false);

        _imageVerdicts.TryGetValue(containerNumber, out var verdicts);
        verdicts ??= new Dictionary<int, string>();

        var approved = 0;
        var rejected = 0;
        for (var i = 0; i < imageCount; i++)
        {
            if (!verdicts.TryGetValue(i, out var v)) continue;
            if (v == ApprovedValue) approved++;
            else if (v == RejectedValue) rejected++;
        }
        var pending = imageCount - approved - rejected;
        return (approved, rejected, pending, rejected > 0, pending == 0);
    }

    /// <summary>
    /// Fallback path: when image preload hasn't given us a list yet, the auditor
    /// uses a single container-level radio. We store the result at imageIndex 0
    /// with the parent record's scanner type so the submission payload still
    /// carries one ImageDecisions[] entry, keeping the API contract uniform.
    /// </summary>
    private void SetFallbackVerdict(string containerNumber, string verdict)
    {
        var fallbackScanner = Record?.ScannerType ?? "";
        SetImageVerdict(containerNumber, 0, fallbackScanner, verdict);
    }

    private string GetFallbackVerdict(string containerNumber) => GetImageVerdict(containerNumber, 0);

    /// <summary>
    /// Build the wire-format ImageDecisions[] for one container, mirroring the
    /// API DTO at AuditReviewController.ImageAuditDecisionDto.
    /// </summary>
    private List<object> BuildImageDecisionsPayload(string containerNumber)
    {
        var rows = new List<object>();
        if (!_imageVerdicts.TryGetValue(containerNumber, out var verdicts))
        {
            return rows;
        }
        _imageScannerTypes.TryGetValue(containerNumber, out var scanners);
        _imageNotes.TryGetValue(containerNumber, out var notes);

        foreach (var kv in verdicts.OrderBy(k => k.Key))
        {
            if (string.IsNullOrEmpty(kv.Value)) continue;
            rows.Add(new
            {
                ImageIndex = kv.Key,
                ScannerType = scanners != null && scanners.TryGetValue(kv.Key, out var s)
                    ? s
                    : (Record?.ScannerType ?? ""),
                Decision = kv.Value,
                Notes = notes != null && notes.TryGetValue(kv.Key, out var n) ? n : null,
            });
        }
        return rows;
    }

    /// <summary>True when the currently active tab is a container tab and that container has a decision.</summary>
    private bool CanSaveCurrentContainer()
    {
        if (Record?.ImageAnalysisDecisions == null || _activeMainTabIndex < 1) return false;
        var containerIndex = _activeMainTabIndex - 1;
        if (containerIndex >= Record.ImageAnalysisDecisions.Count) return false;
        var containerNumber = Record.ImageAnalysisDecisions[containerIndex].ContainerNumber;
        return _auditDecisions.TryGetValue(containerNumber, out var decision) && !string.IsNullOrEmpty(decision);
    }

    /// <summary>Gets the container number for the currently active tab (null if Summary).</summary>
    private string? GetCurrentContainerNumber()
    {
        if (Record?.ImageAnalysisDecisions == null || _activeMainTabIndex < 1) return null;
        var containerIndex = _activeMainTabIndex - 1;
        if (containerIndex >= Record.ImageAnalysisDecisions.Count) return null;
        return Record.ImageAnalysisDecisions[containerIndex].ContainerNumber;
    }

    private string GetOverallDecision()
    {
        if (!AllDecisionsMade()) return "Pending";
        
        var anyRejected = _auditDecisions.Any(d => d.Value == RejectedValue);
        return anyRejected ? "REJECTED" : "APPROVED";
    }

    private Severity GetOverallSeverity()
    {
        if (!AllDecisionsMade()) return Severity.Normal;
        
        var decision = GetOverallDecision();
        return decision == "APPROVED" ? Severity.Success : Severity.Error;
    }

    private string GetOverallMessage()
    {
        if (!AllDecisionsMade())
        {
            var pending = _auditDecisions.Count(d => string.IsNullOrEmpty(d.Value));
            return $"{pending} container(s) pending audit decision";
        }
        
        var decision = GetOverallDecision();
        if (decision == "APPROVED")
        {
            return "All containers approved - Record will be marked as APPROVED";
        }
        else
        {
            var rejectedCount = _auditDecisions.Count(d => d.Value == RejectedValue);
            return $"{rejectedCount} container(s) rejected - Record will be marked as REJECTED";
        }
    }

    /// <summary>Save current container and auto-progress to next (or close when all done).</summary>
    private async Task SubmitSaveAndNext()
    {
        var containerNumber = GetCurrentContainerNumber();
        Logger.LogInformation("🔔 [AuditReviewDialog] SubmitSaveAndNext invoked, container={Container}, group={Group}", containerNumber ?? "(null)", Record?.GroupIdentifier ?? "(null)");
        if (string.IsNullOrEmpty(containerNumber))
        {
            Logger.LogWarning("[AuditReviewDialog] SubmitSaveAndNext early return: no container selected (activeTab={Tab})", _activeMainTabIndex);
            Snackbar.Add("Please select a container tab and make an audit decision", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            Logger.LogInformation("📤 [AuditReviewDialog] Submitting audit to API: Group={Group}, Container={Container}, Decision={Decision}", Record?.GroupIdentifier, containerNumber, _auditDecisions.TryGetValue(containerNumber, out var decVal) ? decVal : "(none)");
            // Per-image audit (deferred plan request 1): also pack the ImageDecisions[]
            // payload so the backend can persist child rows. The container-level
            // Decision below stays for legacy consumers (SubmissionWorker, dashboard)
            // and is computed by the rollup helper from the same per-image state.
            var request = new
            {
                GroupIdentifier = Record?.GroupIdentifier ?? "",
                ScannerType = Record?.ScannerType,
                AuditedBy = _currentUser,
                IsConsolidated = Record?.IsConsolidated ?? false,
                ContainerDecisions = new[]
                {
                    new
                    {
                        ContainerNumber = containerNumber,
                        Decision = _auditDecisions[containerNumber],
                        Notes = _auditNotes.ContainsKey(containerNumber) ? _auditNotes[containerNumber] : "",
                        ImageDecisions = BuildImageDecisionsPayload(containerNumber),
                    }
                }
            };

            var response = await ApiService.PostAsync<object, AuditSubmissionResponse>("/api/AuditReview/submit", request);

            Logger.LogInformation("📥 [AuditReviewDialog] SubmitSaveAndNext API response: Success={Success}, AuditedCount={Count}, AllDone={AllDone}, Message={Message}", 
                response?.Success, response?.AuditedCount ?? 0, response?.AllContainersAudited ?? false, response?.Message ?? "(null)");
            if (response == null)
            {
                Snackbar.Add("Error: No response from server. The decision may not have been saved.", Severity.Error);
                return;
            }
            if (response.Success)
            {
                if (response.AllContainersAudited)
                {
                    Snackbar.Add($"Audit completed: {response.OverallDecision}", 
                        response.OverallDecision == "Approved" ? Severity.Success : Severity.Warning);
                    await OnAuditComplete.InvokeAsync(true);
                }
                else if (!string.IsNullOrEmpty(response.NextContainerNumber))
                {
                    Snackbar.Add($"Saved. Loading next container: {response.NextContainerNumber}...", Severity.Info);
                    var nextIndex = Record?.ImageAnalysisDecisions?.FindIndex(d => d.ContainerNumber == response.NextContainerNumber) ?? -1;
                    if (nextIndex >= 0)
                        _activeMainTabIndex = nextIndex + 1; // +1 because tab 0 is Summary
                    StateHasChanged();
                }
                else
                {
                    Snackbar.Add($"Decision saved ({response.AuditedCount} container(s))", Severity.Success);
                    StateHasChanged();
                }
            }
            else
            {
                Snackbar.Add($"Error: {response.Message}", Severity.Error);
            }
        }
        catch (NickScanWebApp.Shared.Services.ApiException ex)
        {
            Logger.LogWarning(ex, "[AuditReviewDialog] SubmitSaveAndNext ApiException");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[AuditReviewDialog] SubmitSaveAndNext exception");
            Snackbar.Add($"Error submitting audit: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    /// <summary>Submit all container decisions at once (legacy/bulk flow).</summary>
    private async Task SubmitAuditAll()
    {
        Logger.LogInformation("🔔 [AuditReviewDialog] SubmitAuditAll invoked for group {Group}", Record?.GroupIdentifier ?? "(null)");
        if (!AllDecisionsMade())
        {
            Snackbar.Add("Please make audit decisions for all containers", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            Logger.LogInformation("📤 [AuditReviewDialog] Submitting all audit decisions to API: Group={Group}, Count={Count}", Record?.GroupIdentifier, _auditDecisions.Count);
            var containerDecisions = _auditDecisions.Select(d => new
            {
                ContainerNumber = d.Key,
                Decision = d.Value,
                Notes = _auditNotes.ContainsKey(d.Key) ? _auditNotes[d.Key] : "",
                // Per-image audit (deferred plan request 1) — pack the ImageDecisions[]
                // for each container. The backend uses these to write child rows AND
                // to enforce the rollup (any Rejected child → parent Rejected).
                ImageDecisions = BuildImageDecisionsPayload(d.Key),
            }).ToList();

            var request = new
            {
                GroupIdentifier = Record?.GroupIdentifier ?? "",
                ScannerType = Record?.ScannerType,
                AuditedBy = _currentUser,
                IsConsolidated = Record?.IsConsolidated ?? false,
                ContainerDecisions = containerDecisions
            };

            var response = await ApiService.PostAsync<object, AuditSubmissionResponse>("/api/AuditReview/submit", request);

            Logger.LogInformation("📥 [AuditReviewDialog] SubmitAuditAll API response: Success={Success}, AuditedCount={Count}, Message={Message}", 
                response?.Success, response?.AuditedCount ?? 0, response?.Message ?? "(null)");
            if (response == null)
            {
                Snackbar.Add("Error: No response from server. Decisions may not have been saved.", Severity.Error);
                return;
            }
            if (response.Success)
            {
                Snackbar.Add($"Audit completed: {response.OverallDecision}", 
                    response.OverallDecision == "Approved" ? Severity.Success : Severity.Warning);
                await OnAuditComplete.InvokeAsync(true);
            }
            else
            {
                Snackbar.Add($"Error: {response.Message}", Severity.Error);
            }
        }
        catch (NickScanWebApp.Shared.Services.ApiException ex)
        {
            Logger.LogWarning(ex, "[AuditReviewDialog] SubmitAuditAll ApiException");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[AuditReviewDialog] SubmitAuditAll exception");
            Snackbar.Add($"Error submitting audit: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task Cancel()
    {
        await OnAuditComplete.InvokeAsync(false);
    }

    private async Task OpenFullImage(NickScanWebApp.Shared.Models.ImageMetadata image, string containerNumber, int imageIndex = 0)
    {
        // Find the analyst decision for this container
        var analystDecision = Record?.ImageAnalysisDecisions
            ?.FirstOrDefault(d => d.ContainerNumber == containerNumber);

        var parameters = new DialogParameters
        {
            ["ImageUrl"] = image.FullImageUrl,
            ["ContainerNumber"] = containerNumber,
            ["ScannerType"] = image.ImageType,
            ["ScanDate"] = image.CreatedAt,
            ["GroupIdentifier"] = Record?.GroupIdentifier ?? "",
            ["IsConsolidated"] = Record?.IsConsolidated ?? false,
            ["SourceScanResolution"] = image.Resolution ?? GetScanAssetResolution(containerNumber),
            ["AuditMode"] = true,
            ["ImageIndex"] = imageIndex,
            ["OriginalAnalystDecision"] = analystDecision?.Decision,
            ["OriginalAnalystComments"] = analystDecision?.Comments,
            ["OriginalAnalystTags"] = analystDecision?.Tags,
            ["OriginalAnalystReviewedBy"] = GetAnalystName(analystDecision)
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            FullScreen = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialogRef = await DialogService.ShowAsync<ImageAnalysisViewer>(
            $"Audit Review - {image.ImageType} Scanner - {containerNumber}",
            parameters,
            options);

        var dialogResult = await dialogRef.Result;

        // Process the audit decision result
        if (dialogResult != null && !dialogResult.Canceled && dialogResult.Data is ImageAnalysisViewer.AuditDecisionResult result)
        {
            // Update per-image verdict in the dialog's state
            SetImageVerdict(result.ContainerNumber, result.ImageIndex, result.ScannerType, result.Decision);
            if (!string.IsNullOrEmpty(result.Notes))
                SetImageNotes(result.ContainerNumber, result.ImageIndex, result.Notes);
            StateHasChanged();

            // Auto-advance: find next undecided image
            // Use InvokeAsync to ensure clean dispatcher state after dialog close
            await InvokeAsync(async () =>
            {
                // 2026-05-09 (Phase B / B7 UX): removed 500/500/300 ms Task.Delay
                // calls between image and container advances. Those were pre-Sprint-5G2
                // race-workarounds when state writes were eventually-consistent; the
                // facade (AnalysisGroupStateMachine) now writes synchronously inside
                // SaveChangesAsync, so the auditor doesn't need to wait. Saves ~800-1300ms
                // per AG.
                //
                // First check remaining images in the same container
                if (_containerImages.TryGetValue(result.ContainerNumber, out var currentImages))
                {
                    for (int i = result.ImageIndex + 1; i < currentImages.Count; i++)
                    {
                        if (string.IsNullOrEmpty(GetImageVerdict(result.ContainerNumber, i)))
                        {
                            await OpenFullImage(currentImages[i], result.ContainerNumber, i);
                            return;
                        }
                    }
                }

                // All images in this container done — advance to next container
                if (Record?.ImageAnalysisDecisions != null)
                {
                    var currentContainerIdx = Record.ImageAnalysisDecisions
                        .FindIndex(d => d.ContainerNumber == result.ContainerNumber);

                    for (int ci = currentContainerIdx + 1; ci < Record.ImageAnalysisDecisions.Count; ci++)
                    {
                        var nextContainer = Record.ImageAnalysisDecisions[ci].ContainerNumber;
                        if (_containerImages.TryGetValue(nextContainer, out var nextImages))
                        {
                            for (int i = 0; i < nextImages.Count; i++)
                            {
                                if (string.IsNullOrEmpty(GetImageVerdict(nextContainer, i)))
                                {
                                    Snackbar.Add($"Container {result.ContainerNumber} complete — next: {nextContainer}", Severity.Info);
                                    await OpenFullImage(nextImages[i], nextContainer, i);
                                    return;
                                }
                            }
                        }
                    }
                }

                // All images in all containers are decided — auto-submit
                Snackbar.Add("All images audited — submitting...", Severity.Info);
                await SubmitAuditAll();
            });
        }
    }

