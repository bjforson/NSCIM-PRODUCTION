    {
        "Approved" => "background: #e8f5e9; border-bottom: 2px solid #4caf50;",
        "Rejected" => "background: #ffebee; border-bottom: 2px solid #f44336;",
        _ => "background: #f5f5f5; border-bottom: 2px solid #e0e0e0;"
    };

    private string GetVerdictChipStyle(string verdict) => verdict switch
    {
        "Approved" => "background: #4caf50; color: white;",
        "Rejected" => "background: #f44336; color: white;",
        _ => "background: #9e9e9e; color: white;"
    };

    private async Task BulkAuditDecision(string verdict)
    {
        if (Record?.ImageAnalysisDecisions == null) return;
        foreach (var decision in Record.ImageAnalysisDecisions)
        {
            if (_containerImages.TryGetValue(decision.ContainerNumber, out var imgs) && imgs.Any())
            {
                for (int i = 0; i < imgs.Count; i++)
                    SetImageVerdict(decision.ContainerNumber, i, imgs[i].ImageType, verdict);
            }
            else
            {
                SetFallbackVerdict(decision.ContainerNumber, verdict);
            }
        }
        StateHasChanged();

        // Auto-submit after bulk decision
        Snackbar.Add($"All images marked as {verdict} — submitting...", Severity.Info);
        await Task.Delay(300);
        await SubmitAuditAll();
    }

