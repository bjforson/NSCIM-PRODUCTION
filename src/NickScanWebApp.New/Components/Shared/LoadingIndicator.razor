<!-- Loading Indicator Component - Used throughout the application -->
<!-- Phase 2: Enhanced with modern styling and skeleton support -->

@if (FullPage)
{
    <div class="loading-state-modern" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;">
        <div class="loading-spinner-modern"></div>
        @if (!string.IsNullOrEmpty(Message))
        {
            <MudText Typo="Typo.h6" Class="loading-text-modern">@Message</MudText>
        }
    </div>
}
else if (UseSkeleton)
{
    <div class="pa-4">
        <div class="skeleton-card"></div>
    </div>
}
else
{
    <div class="loading-state-modern">
        <MudProgressCircular Color="@Color" Size="@Size" Indeterminate="true" Class="pulse" />
        @if (!string.IsNullOrEmpty(Message))
        {
            <MudText Typo="Typo.body2" Class="loading-text-modern">@Message</MudText>
        }
    </div>
}

@code {
    [Parameter] public bool FullPage { get; set; } = false;
    [Parameter] public string? Message { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public bool UseSkeleton { get; set; } = false; // Phase 2: Skeleton loading option
}

