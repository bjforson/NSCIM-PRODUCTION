@inherits Microsoft.AspNetCore.Components.Web.ErrorBoundary
@namespace NickScanWebApp.New.Components.Shared
@typeparam T

<!-- Custom Error Boundary with MudBlazor styling -->

@if (CurrentException != null)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        <MudPaper Elevation="4" Class="pa-8 rounded-lg">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" 
                         Size="Size.Large" 
                         Color="Color.Error" 
                         Style="font-size: 5rem;" />
                
                <MudText Typo="Typo.h4" Color="Color.Error" Align="Align.Center">
                    Something went wrong
                </MudText>
                
                <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
                    We're sorry, but something unexpected happened. Our team has been notified.
                </MudText>
                
                @if (ShowDetails)
                {
                    <MudExpansionPanels>
                        <MudExpansionPanel Text="Error Details (for developers)">
                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace; background: #f5f5f5; padding: 16px; border-radius: 4px;">
                                @CurrentException.ToString()
                            </MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
                
                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Refresh"
                               OnClick="Recover">
                        Try Again
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Outlined.Home"
                               Href="/dashboard">
                        Go Home
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool ShowDetails { get; set; } = false;
}

