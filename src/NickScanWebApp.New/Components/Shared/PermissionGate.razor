@using Microsoft.AspNetCore.Components
@using NickScanWebApp.New.Services.Permissions
@inject PermissionGuard Guard

@if (Guard.Can(Permission, Context))
{
    @ChildContent
}
else if (DeniedContent is not null)
{
    @DeniedContent
}

@code {
    [Parameter] public PermissionId Permission { get; set; }
    [Parameter] public string? Context { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? DeniedContent { get; set; }
}

