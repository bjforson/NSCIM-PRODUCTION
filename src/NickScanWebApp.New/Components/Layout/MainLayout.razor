@inherits LayoutComponentBase
@using NickScanWebApp.New.Components.Authentication
@using System.Security.Claims
@inject NavigationManager NavigationManager
@inject NickScanWebApp.New.Services.ThemeService ThemeService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ILogger<MainLayout> Logger
@implements IDisposable

<MudThemeProvider Theme="@_theme" IsDarkMode="@ThemeService.IsDarkMode" />
@* MudBlazor providers removed - they're in App.razor to prevent duplicates *@

@* Inactivity monitor for auto-logout *@
<InactivityMonitor />

<MudLayout>
    @* No MudAppBar — toolbar is integrated into the breadcrumb row (Option B) *@

    <!-- Navigation Drawer (Side Menu) - Domiex: Dark sidebar -->
    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               ClipMode="DrawerClipMode.Never"
               Variant="@DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <!-- Main Content Area -->
    <MudMainContent>
        @* Breadcrumb + Toolbar Row (replaces MudAppBar) *@
        <MudPaper Elevation="0" Class="px-4 py-2 glass-toolbar" Style="position: sticky; top: 0; z-index: 50;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @* Mobile hamburger *@
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudIconButton Icon="@Icons.Material.Outlined.Menu"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="@ToggleDrawer" />
                </MudHidden>

                @* Page title + breadcrumb *@
                <div style="min-width: 0;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 700; font-size: 15px; line-height: 1.2;">
                        @GetPageTitle()
                    </MudText>
                    <MudBreadcrumbs Items="@_breadcrumbs" Style="padding: 0; font-size: 12px;" Separator="/">
                        <ItemTemplate Context="item">
                            <MudLink Href="@item.Href" Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 11px;">@item.Text</MudLink>
                        </ItemTemplate>
                    </MudBreadcrumbs>
                </div>

                <MudSpacer />

                @* TopBar actions (search, dark mode, notifications, user pill) *@
                <TopBar />
            </MudStack>
        </MudPaper>

        @* Page content *@
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>

    <!-- Bottom Navigation for Mobile -->
    <BottomNavigation />

    <!-- Version footer -->
    <MudText Typo="Typo.caption" Style="position: fixed; bottom: 4px; left: 12px; opacity: 0.45; z-index: 1; pointer-events: none;">
        v@(NickScanWebApp.New.DeploymentInfo.Version)
    </MudText>
</MudLayout>

<RbacDebugOverlay />

@code {
    private ICUMSTheme _theme = new ICUMSTheme();
    private bool _drawerOpen = true;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _hasNudgedReadiness = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
                if (width < 960) // Breakpoint.Md = 960px
                {
                    _drawerOpen = false;
                    StateHasChanged();
                }
            }
            catch { /* JS not available during prerender */ }

            // T5 readiness UX nudge — fire once per session for Audit/Analyst users
            // who aren't currently flagged ready (or have a stale heartbeat).
            // Server-side never auto-flips IsReady; the user must navigate to
            // AuditReview/Workbench to do that explicitly.
            if (!_hasNudgedReadiness)
            {
                _hasNudgedReadiness = true;
                _ = TryShowReadinessNudgeAsync();
            }
        }
    }

    private async Task TryShowReadinessNudgeAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated != true) return;

            var roleClaim = user.FindFirst(ClaimTypes.Role) ?? user.FindFirst("role");
            var role = roleClaim?.Value;
            if (role is not ("Audit" or "Analyst")) return;

            var snap = await ApiService.GetAsync<UserReadinessSnapshot>(
                $"/api/image-analysis/user/readiness?role={role}");

            var stale = snap?.LastHeartbeat is null
                || (DateTime.UtcNow - snap.LastHeartbeat.Value).TotalMinutes > 60;
            var notReady = !(snap?.IsReady ?? false);

            if (notReady || stale)
            {
                var targetPage = role == "Audit" ? "Audit Review" : "Workbench";
                var targetRoute = role == "Audit" ? "/image-analysis/audit" : "/image-analysis/workbench";
                var message =
                    $"You're not currently flagged ready for {role} work. " +
                    $"Open the {targetPage} page to start receiving assignments.";

                await InvokeAsync(() =>
                {
                    Snackbar.Add(message, Severity.Info, cfg =>
                    {
                        cfg.Action = "Go";
                        cfg.ActionColor = Color.Primary;
                        cfg.OnClick = snackbar =>
                        {
                            NavigationManager.NavigateTo(targetRoute);
                            return Task.CompletedTask;
                        };
                        cfg.RequireInteraction = false;
                        cfg.VisibleStateDuration = 10000;
                    });
                });
            }
        }
        catch (Exception ex)
        {
            // Silently degrade — the nudge is non-critical UX. Log at debug
            // so a missing readiness record / API hiccup doesn't spam errors.
            Logger.LogDebug(ex, "Readiness nudge skipped (non-fatal)");
        }
    }

    private class UserReadinessSnapshot
    {
        public string Username { get; set; } = "";
        public string Role { get; set; } = "";
        public bool IsReady { get; set; }
        public DateTime? LastHeartbeat { get; set; }
        public DateTime? LastChangedAt { get; set; }
        public string? Message { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        // Initialize theme from localStorage
        await ThemeService.InitializeAsync();
        
        // Subscribe to theme changes
        ThemeService.OnThemeChanged += OnThemeChanged;
        
        UpdateBreadcrumbs();
        NavigationManager.LocationChanged += OnLocationChanged;
    }
    
    private void OnThemeChanged()
    {
        StateHasChanged();
    }
    
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateBreadcrumbs();
        StateHasChanged();
    }
    
    private void UpdateBreadcrumbs()
    {
        var uri = new Uri(NavigationManager.Uri);
        var path = uri.LocalPath;
        
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home)
        };
        
        // Add breadcrumbs based on current path
        if (!string.IsNullOrEmpty(path) && path != "/")
        {
            var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
            var currentPath = "";
            
            foreach (var segment in segments)
            {
                currentPath += $"/{segment}";
                var displayName = FormatBreadcrumbText(segment);
                _breadcrumbs.Add(new BreadcrumbItem(displayName, href: currentPath));
            }
        }
    }
    
    private string GetPageTitle()
    {
        if (_breadcrumbs.Count <= 1) return "Dashboard";
        return _breadcrumbs.Last().Text ?? "Dashboard";
    }

    private string FormatBreadcrumbText(string segment)
    {
        // Convert URL segment to readable text
        if (string.IsNullOrEmpty(segment)) return string.Empty;
        
        var formatted = segment.Replace("-", " ").Replace("_", " ");
        if (formatted.Length == 0) return string.Empty;
        if (formatted.Length == 1) return formatted.ToUpper();
        
        return char.ToUpper(formatted[0]) + formatted.Substring(1).ToLower();
    }
    
    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
    
    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }
}

