@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using NickScanWebApp.New.Services.Permissions
@inject NickScanWebApp.New.Services.CustomAuthStateProvider AuthStateProvider
@inject AuthenticationStateProvider BaseAuthStateProvider
@inject PermissionGuard Guard
@inject ILogger<NavMenu> Logger
@implements IDisposable

@* Sidebar brand + profile (Domiex style) *@
<div style="padding: 14px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div style="width: 32px; height: 32px; background: linear-gradient(135deg, #4facfe, #00f2fe); border-radius: 7px; display: flex; align-items: center; justify-content: center;">
        <MudIcon Icon="@Icons.Material.Outlined.Security" Style="color: white; font-size: 16px;" />
    </div>
    <MudText Style="font-size: 16px; font-weight: 700; color: white;">NSCIS</MudText>
</div>
<div style="padding: 12px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.06);">
    <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea, #764ba2); font-size: 12px; font-weight: 600; width: 34px; height: 34px;">
        @(_username?.Length >= 2 ? _username.Substring(0, 2).ToUpper() : "U")
    </MudAvatar>
    <div>
        <MudText Style="font-size: 12px; font-weight: 600; color: white;">@(_username ?? "User")</MudText>
        <MudText Style="font-size: 10px; color: rgba(255,255,255,0.4);">Nick TC-Scan Ltd</MudText>
    </div>
</div>

