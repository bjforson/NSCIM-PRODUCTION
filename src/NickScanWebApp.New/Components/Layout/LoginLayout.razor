@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />
@* MudBlazor providers removed - they're in App.razor to prevent duplicates *@

<div class="professional-login-layout">
	@Body
</div>

<style>
    .professional-login-layout {
        min-height: 100vh;
        background: #f8fafc;
        font-family: 'Inter', 'Roboto', 'Helvetica', 'Arial', sans-serif;
        overflow-x: hidden;
    }

    /* Global styles for better typography */
    .professional-login-layout * {
        box-sizing: border-box;
    }

    /* Ensure smooth scrolling */
    html {
        scroll-behavior: smooth;
    }

    /* Custom scrollbar for webkit browsers */
    .professional-login-layout ::-webkit-scrollbar {
        width: 8px;
    }

    .professional-login-layout ::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 4px;
    }

    .professional-login-layout ::-webkit-scrollbar-thumb {
        background: rgba(26, 35, 126, 0.3);
        border-radius: 4px;
    }

    .professional-login-layout ::-webkit-scrollbar-thumb:hover {
        background: rgba(26, 35, 126, 0.5);
    }

    /* Focus styles for accessibility */
    .professional-login-layout *:focus {
        outline: 2px solid #2563EB;
        outline-offset: 2px;
    }

    /* Print styles */
    @@media print {
        .professional-login-layout {
            background: white !important;
        }
    }
</style>

@code {
	private ICUMSTheme _theme = new ICUMSTheme();
}


