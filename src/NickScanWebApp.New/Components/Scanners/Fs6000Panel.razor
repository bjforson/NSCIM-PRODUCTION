@using NickScanWebApp.New.Components.Containers
@using MudBlazor
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NickScanWebApp.Shared.Services.FS6000Client FS6000Client


<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">FS6000 X-Ray Scanner</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Live scan history and service telemetry where reported by the API
                </MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudChip T="string" Size="Size.Large" Color="@GetStatusColor()" Icon="@GetStatusIcon()">
                    @GetStatusText()
                </MudChip>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Refresh" OnClick="LoadData">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Live service telemetry -->
    <MudAlert Severity="@GetServiceTelemetrySeverity()" Class="mb-4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 500;">FS6000 live service telemetry</MudText>
            <MudText Typo="Typo.body2">
                Ingestion: @FormatNullableHealth(_ingestionHealthy) | Sync: @FormatNullableHealth(_syncHealthy) | Pending ingestion: @_pendingIngestionCount | Failed ingestion: @_failedIngestionCount
            </MudText>
        </MudStack>
    </MudAlert>

    <!-- Service Health Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-info);">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Ingestion Service</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Loop" Color="Color.Success" />
                    </MudStack>
                    <MudChip T="string" Color="@GetNullableHealthColor(_ingestionHealthy)" Size="Size.Small" Icon="@GetNullableHealthIcon(_ingestionHealthy)">
                        @FormatNullableHealth(_ingestionHealthy)
                    </MudChip>
                    <MudText Typo="Typo.caption">Files processed: @_filesProcessed</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Watcher Telemetry</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.RemoveRedEye" Color="Color.Default" />
                    </MudStack>
                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Outlined.HelpOutline">
                        Not reported
                    </MudChip>
                    <MudText Typo="Typo.caption">No live watcher endpoint available</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Sync Service</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Sync" Color="@GetNullableHealthColor(_syncHealthy)" />
                    </MudStack>
                    <MudChip T="string" Color="@GetNullableHealthColor(_syncHealthy)" Size="Size.Small">
                        @FormatNullableHealth(_syncHealthy)
                    </MudChip>
                    <MudText Typo="Typo.caption">Pending: @_pendingSyncCount | Failed: @_failedSyncCount</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Container Cache</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Memory" Color="Color.Info" />
                    </MudStack>
                    <MudText Typo="Typo.h5">@_cachedContainers</MudText>
                    <MudText Typo="Typo.caption">Cached containers</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Statistics Overview -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Today's Scans</MudText>
                    <MudText Typo="Typo.h3">@_todayScans</MudText>
                    @if (_yesterdayScans > 0)
                    {
                        var percentChange = ((_todayScans - _yesterdayScans) / (double)_yesterdayScans) * 100;
                        var changeColor = percentChange >= 0 ? Color.Success : Color.Error;
                        var changeSymbol = percentChange >= 0 ? "+" : "";
                        <MudText Typo="Typo.caption" Color="@changeColor">
                            @changeSymbol@percentChange.ToString("F1")% from yesterday
                        </MudText>
                    }
                    else if (_yesterdayScans == 0 && _todayScans > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">New today</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No scans yesterday</MudText>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Scans</MudText>
                    <MudText Typo="Typo.h3">@_totalScans</MudText>
                    <MudText Typo="Typo.caption">All time</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Detection Speed</MudText>
                    <MudText Typo="Typo.h3">@FormatDetectionSpeed(_avgDetectionTimeSeconds)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Success">Average processing time</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Success Rate</MudText>
                    <MudText Typo="Typo.h3">@FormatPercent(_successRatePercent)</MudText>
                    <MudText Typo="Typo.caption">Completed scans / total scans</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- All Scans with Search -->
    <MudPaper Elevation="2" Class="pa-4">
        <MudStack Spacing="3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">All FS6000 Scans</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total: @_totalRecords.ToString("N0") records</MudText>
            </MudStack>
            
            <!-- Search Filters -->
            <MudPaper Elevation="1" Class="pa-3" Style="background-color: var(--mud-palette-background-grey);">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_searchContainerNumber" 
                                     Label="Container Number" 
                                     Variant="Variant.Outlined" 
                                     Dense="true"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Outlined.Search"
                                     Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker @bind-Date="_startDate" 
                                      Label="Start Date" 
                                      Variant="Variant.Outlined" 
                                      Dense="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker @bind-Date="_endDate" 
                                      Label="End Date" 
                                      Variant="Variant.Outlined" 
                                      Dense="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect @bind-Value="_filterSyncStatus" 
                                  Label="Sync Status" 
                                  Variant="Variant.Outlined" 
                                  Dense="true">
                            <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@("Synced")">Synced</MudSelectItem>
                            <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                            <MudSelectItem Value="@("Failed")">Failed</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" 
                                     Color="Color.Primary" 
                                     StartIcon="@Icons.Material.Outlined.Search"
                                     OnClick="SearchScans">
                                Search
                            </MudButton>
                            <MudButton Variant="Variant.Text" 
                                     Color="Color.Default" 
                                     StartIcon="@Icons.Material.Outlined.Clear"
                                     OnClick="ClearFilters">
                                Clear Filters
                            </MudButton>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
            
            <!-- Data Grid -->
            <MudDataGrid @ref="_dataGrid"
                        T="Fs6000ScanRecord" 
                        Loading="@_isLoading" 
                        Dense="true" 
                        Hover="true" 
                        Striped="true" 
                        Height="600px"
                        ServerData="@LoadServerData">
                <Columns>
                    <PropertyColumn Property="x => x.ContainerNumber" Title="Container Number" Sortable="true">
                        <CellTemplate>
                            <MudText Style="font-family: monospace; font-weight: 500;">@context.Item.ContainerNumber</MudText>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.PicNumber" Title="Pic Number" Sortable="true" />
                    <PropertyColumn Property="x => x.ScanDate" Title="Scan Date" Format="yyyy-MM-dd HH:mm:ss" Sortable="true" InitialDirection="SortDirection.Descending" />
                    <PropertyColumn Property="x => x.TruckPlate" Title="Truck Plate" Sortable="true" />
                    <PropertyColumn Property="x => x.ScanResult" Title="Result" Sortable="true" />
                    <TemplateColumn Title="Images">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="@(context.Item.HasImage ? Color.Success : Color.Warning)">
                                @(context.Item.HasImage ? $"{context.Item.ImageCount} image(s)" : "No image")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.SyncStatus" Title="Sync Status" Sortable="true">
                        <CellTemplate>
                            <MudChip T="string" 
                                   Size="Size.Small" 
                                   Color="@GetSyncStatusColor(context.Item.SyncStatus)">
                                @context.Item.SyncStatus
                            </MudChip>
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Actions">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Outlined.Visibility" 
                                         Size="Size.Small" 
                                         Color="Color.Info" 
                                         OnClick="@(() => ViewDetails(context.Item.ContainerNumber))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Fs6000ScanRecord" />
                </PagerContent>
            </MudDataGrid>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private MudDataGrid<Fs6000ScanRecord>? _dataGrid;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _isLoading = false;
    private List<Fs6000ScanRecord> _recentScans = new();
    
    // Search filters
    private string _searchContainerNumber = "";
    private DateTime? _startDate = DateTime.Today.AddDays(-30);
    private DateTime? _endDate = DateTime.Today;
    private string? _filterSyncStatus = null;
    
    // Pagination
    private int _totalRecords = 0;
    private int _currentPage = 1;
    private int _pageSize = 50;
    
    private int _todayScans = 0;
    private int _yesterdayScans = 0;
    private int _totalScans = 0;
    private int _filesProcessed = 0;
    private int _cachedContainers = 0;
    
    // Status and metrics
    private double _avgDetectionTimeSeconds = 0;
    private double? _successRatePercent;
    private bool? _ingestionHealthy;
    private bool? _syncHealthy;
    private int _pendingIngestionCount;
    private int _failedIngestionCount;
    private int _pendingSyncCount;
    private int _failedSyncCount;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home),
            new BreadcrumbItem("Scanners", href: "/scanners", icon: Icons.Material.Outlined.Scanner),
            new BreadcrumbItem("FS6000", href: null, disabled: true)
        };
        
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            Console.WriteLine("🔍 Loading FS6000 scanner data from API...");
            
            // Load FS6000 statistics
            var stats = await FS6000Client.GetStatisticsAsync<FS6000Statistics>();
            if (stats != null)
            {
                _totalScans = stats.Scans?.Total ?? 0;
                _filesProcessed = stats.FileProcessing?.Total ?? 0;
                _todayScans = stats.Scans?.Today ?? 0; // Use actual today's scans based on ScanTime
                Console.WriteLine($"✅ Loaded FS6000 stats: Total={_totalScans}, Files={_filesProcessed}, Today={_todayScans}");
            }

            var telemetry = await FS6000Client.GetTelemetryAsync<FS6000Telemetry>();
            if (telemetry != null)
            {
                _totalScans = telemetry.TotalScans;
                _todayScans = telemetry.TodayScans;
                _cachedContainers = telemetry.TotalScans;
                _lastScanTime = telemetry.LastScanTime;
                _avgDetectionTimeSeconds = telemetry.AverageProcessingSeconds ?? 0;
                _successRatePercent = telemetry.SuccessRatePercent;
                _ingestionHealthy = telemetry.IngestionHealthy;
                _syncHealthy = telemetry.SyncHealthy;
                _pendingIngestionCount = telemetry.PendingIngestionCount;
                _failedIngestionCount = telemetry.FailedIngestionCount;
                _pendingSyncCount = telemetry.PendingSyncCount;
                _failedSyncCount = telemetry.FailedSyncCount;
            }

            var ingestionStatus = await FS6000Client.GetIngestionStatusAsync<FS6000IngestionStatus>();
            if (ingestionStatus != null && telemetry == null)
            {
                _ingestionHealthy = ingestionStatus.IsHealthy;
                _pendingIngestionCount = ingestionStatus.PendingIngestionCount;
                _failedIngestionCount = ingestionStatus.FailedIngestionCount;
            }

            var syncStatus = await FS6000Client.GetSyncStatusAsync<FS6000SyncStatus>();
            if (syncStatus != null && telemetry == null)
            {
                _syncHealthy = syncStatus.IsHealthy;
                _pendingSyncCount = syncStatus.PendingSyncCount;
                _failedSyncCount = syncStatus.FailedSyncCount;
            }
            
            // Load recent scans from FS6000 API
            var scansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
            {
                PageSize = 20
            });
            if (scansResponse?.Data != null && scansResponse.Data.Any())
            {
                _lastScanTime = scansResponse.Data.OrderByDescending(s => s.ScanTime).First().ScanTime;
                _recentScans = scansResponse.Data.Select(s => new Fs6000ScanRecord
                {
                    ContainerNumber = s.ContainerNumber ?? "Unknown",
                    PicNumber = Display(s.PicNumber),
                    ScanDate = s.ScanTime,
                    TruckPlate = Display(s.TruckPlate),
                    ScanResult = Display(s.ScanResult),
                    HasImage = s.HasImage,
                    ImageCount = s.ImageCount,
                    SyncStatus = s.SyncStatus ?? "Unknown"
                }).ToList();
                
                Console.WriteLine($"✅ Loaded {_recentScans.Count} recent FS6000 scans");
            }
            
            // Estimate cached containers from total scans
            _cachedContainers = _totalScans;
            
            // Calculate average detection time from recent scans
            if (telemetry == null)
                await CalculateDetectionTime();
            
            // Calculate yesterday's scans
            var yesterday = DateTime.Today.AddDays(-1);
            var yesterdayStart = yesterday;
            var yesterdayEnd = yesterday.AddDays(1);
            
            try
            {
                // Query yesterday's scans directly from API or calculate from stats
                var yesterdayStats = await FS6000Client.GetStatsAsync<List<FS6000DailyStats>>(new NickScanWebApp.Shared.Services.ScannerDailyStatsQuery
                {
                    StartDate = yesterdayStart,
                    EndDate = yesterdayEnd
                });
                if (yesterdayStats != null && yesterdayStats.Any())
                {
                    _yesterdayScans = yesterdayStats.Sum(s => s.Count);
                }
                else
                {
                    // Fallback: query scans for yesterday date range
                    var yesterdayScansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
                    {
                        StartDate = yesterdayStart,
                        EndDate = yesterdayEnd
                    });
                    _yesterdayScans = yesterdayScansResponse?.TotalCount ?? 0;
                }
                Console.WriteLine($"✅ Calculated yesterday's FS6000 scans: {_yesterdayScans}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not calculate yesterday's scans: {ex.Message}");
                _yesterdayScans = 0;
            }
            
            Snackbar.Add("FS6000 scanner data loaded", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading FS6000 data: {ex.Message}");
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ViewDetails(string containerNumber)
    {
        var parameters = new DialogParameters<ContainerDetailsModal>
        {
            { x => x.ContainerNumber, containerNumber }
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.ExtraExtraLarge, 
            FullWidth = true,
            CloseButton = true,
            BackdropClick = true
        };

        await DialogService.ShowAsync<ContainerDetailsModal>(
            $"Container Details: {containerNumber}", 
            parameters, 
            options);
    }

    // Search and pagination methods
    private async Task<GridData<Fs6000ScanRecord>> LoadServerData(GridState<Fs6000ScanRecord> state)
    {
        _isLoading = true;
        try
        {
            var response = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
            {
                Page = state.Page + 1,
                PageSize = state.PageSize,
                ContainerNumber = _searchContainerNumber,
                SyncStatus = _filterSyncStatus,
                StartDate = _startDate,
                EndDate = _endDate
            });
            
            if (response != null)
            {
                _totalRecords = response.TotalCount;
                var items = response.Data?.Select(s => new Fs6000ScanRecord
                {
                    ContainerNumber = s.ContainerNumber ?? "Unknown",
                    PicNumber = Display(s.PicNumber),
                    ScanDate = s.ScanTime,
                    TruckPlate = Display(s.TruckPlate),
                    ScanResult = Display(s.ScanResult),
                    HasImage = s.HasImage,
                    ImageCount = s.ImageCount,
                    SyncStatus = s.SyncStatus ?? "Unknown"
                }).ToList() ?? new List<Fs6000ScanRecord>();
                
                return new GridData<Fs6000ScanRecord> { Items = items, TotalItems = _totalRecords };
            }
            
            return new GridData<Fs6000ScanRecord> { Items = new List<Fs6000ScanRecord>(), TotalItems = 0 };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading scans: {ex.Message}");
            Snackbar.Add($"Error loading scans: {ex.Message}", Severity.Error);
            return new GridData<Fs6000ScanRecord> { Items = new List<Fs6000ScanRecord>(), TotalItems = 0 };
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task SearchScans()
    {
        if (_dataGrid != null)
            await _dataGrid.ReloadServerData();
    }
    
    private async Task ClearFilters()
    {
        _searchContainerNumber = "";
        _startDate = DateTime.Today.AddDays(-30);
        _endDate = DateTime.Today;
        _filterSyncStatus = null;
        if (_dataGrid != null)
            await _dataGrid.ReloadServerData();
    }
    
    private Color GetSyncStatusColor(string? syncStatus)
    {
        if (string.IsNullOrEmpty(syncStatus))
            return Color.Default;
            
        return syncStatus switch
        {
            "Completed" => Color.Success,
            "Synced" => Color.Success,
            "Pending" => Color.Warning,
            "Failed" => Color.Error,
            _ => Color.Default
        };
    }
    
    // DTOs
    public class Fs6000ScanRecord
    {
        public string ContainerNumber { get; set; } = "";
        public string PicNumber { get; set; } = "";
        public DateTime ScanDate { get; set; }
        public string TruckPlate { get; set; } = "";
        public string ScanResult { get; set; } = "";
        public bool HasImage { get; set; }
        public int ImageCount { get; set; }
        public string SyncStatus { get; set; } = "";
    }
    
    public class FS6000ScanResponse
    {
        public List<FS6000ScanDto>? Data { get; set; }
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
    }
    
    public class FS6000ScanDto
    {
        public Guid Id { get; set; }
        public string? ContainerNumber { get; set; }
        public DateTime ScanTime { get; set; }
        public string? PicNumber { get; set; }
        public string? TruckPlate { get; set; }
        public string? OperatorId { get; set; }
        public string? ScanResult { get; set; }
        public string? GoodsDescription { get; set; }
        public bool HasImage { get; set; }
        public int ImageCount { get; set; }
        public string? SyncStatus { get; set; }
    }

    public class FS6000IngestionStatus
    {
        public bool IsHealthy { get; set; }
        public int PendingIngestionCount { get; set; }
        public int FailedIngestionCount { get; set; }
    }

    public class FS6000SyncStatus
    {
        public bool IsHealthy { get; set; }
        public int PendingSyncCount { get; set; }
        public int FailedSyncCount { get; set; }
    }

    public class FS6000Telemetry
    {
        public int TotalScans { get; set; }
        public int TodayScans { get; set; }
        public int ScansThisHour { get; set; }
        public int ScansWithImages { get; set; }
        public int CompletedScans { get; set; }
        public int FailedScans { get; set; }
        public double? SuccessRatePercent { get; set; }
        public DateTime? LastScanTime { get; set; }
        public string? LastScanContainerNumber { get; set; }
        public double? AverageProcessingSeconds { get; set; }
        public bool SyncHealthy { get; set; }
        public bool IngestionHealthy { get; set; }
        public int PendingSyncCount { get; set; }
        public int FailedSyncCount { get; set; }
        public int PendingIngestionCount { get; set; }
        public int FailedIngestionCount { get; set; }
    }
    
    public class FS6000Statistics
    {
        public FS6000ScanStats? Scans { get; set; }
        public FS6000ImageStats? Images { get; set; }
        public FS6000FileProcessingStats? FileProcessing { get; set; }
    }
    
    public class FS6000ScanStats
    {
        public int Total { get; set; }
        public int Completed { get; set; }
        public int Pending { get; set; }
        public int Failed { get; set; }
        public int Today { get; set; } // Added: actual scans today
    }
    
    public class FS6000ImageStats
    {
        public int Total { get; set; }
    }
    
    public class FS6000FileProcessingStats
    {
        public int Total { get; set; }
        public int Completed { get; set; }
        public int Failed { get; set; }
    }
    
    public class DatabaseStatistics
    {
        public int TotalContainers { get; set; }
        public int TotalContainerImages { get; set; }
        public int TotalFS6000Scans { get; set; }
        public int TotalFS6000Images { get; set; }
        public int TotalAseScans { get; set; }
        public RecentActivityData? RecentActivity { get; set; }
        public DateTime Timestamp { get; set; }
    }
    
    public class RecentActivityData
    {
        public Last24HoursData? Last24Hours { get; set; }
    }
    
    public class Last24HoursData
    {
        public int Containers { get; set; }
        public int FS6000Scans { get; set; }
    }
    
    public class FS6000DailyStats
    {
        public DateTime Date { get; set; }
        public int Count { get; set; }
    }
    
    private async Task CalculateDetectionTime()
    {
        try
        {
            // Get recent scans and calculate average time between consecutive scans
            // This approximates detection/processing speed
            var scansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
            {
                PageSize = 100
            });
            if (scansResponse?.Data != null && scansResponse.Data.Count > 1)
            {
                var sortedScans = scansResponse.Data.OrderBy(s => s.ScanTime).ToList();
                var timeDiffs = new List<double>();
                
                for (int i = 1; i < sortedScans.Count; i++)
                {
                    var diff = (sortedScans[i].ScanTime - sortedScans[i-1].ScanTime).TotalSeconds;
                    if (diff > 0 && diff < 300) // Only count reasonable intervals (less than 5 minutes)
                    {
                        timeDiffs.Add(diff);
                    }
                }
                
                if (timeDiffs.Any())
                {
                    _avgDetectionTimeSeconds = timeDiffs.Average();
                }
                else
                {
                    _avgDetectionTimeSeconds = 0;
                }
            }
            else
            {
                _avgDetectionTimeSeconds = 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not calculate detection time: {ex.Message}");
            _avgDetectionTimeSeconds = 0;
        }
    }
    
    private string GetStatusText()
    {
        if (_todayScans > 0 || (_lastScanTime.HasValue && (DateTime.Now - _lastScanTime.Value).TotalHours < 24))
            return "Online";
        return "Offline";
    }
    
    private Color GetStatusColor()
    {
        if (_todayScans > 0 || (_lastScanTime.HasValue && (DateTime.Now - _lastScanTime.Value).TotalHours < 24))
            return Color.Success;
        return Color.Error;
    }
    
    private string GetStatusIcon()
    {
        if (_todayScans > 0 || (_lastScanTime.HasValue && (DateTime.Now - _lastScanTime.Value).TotalHours < 24))
            return Icons.Material.Outlined.CheckCircle;
        return Icons.Material.Outlined.Error;
    }
    
    private string FormatDetectionSpeed(double seconds)
    {
        if (seconds <= 0)
            return "N/A";
        if (seconds < 1)
            return $"< 1s";
        if (seconds < 60)
            return $"{(int)seconds}s";
        
        var minutes = seconds / 60;
        return $"{minutes:F1} min";
    }
    
    private string FormatDetectionTime(double seconds)
    {
        if (seconds <= 0)
            return "Not reported";
        if (seconds < 1)
            return $"< 1 second";
        return $"< {(int)seconds} seconds";
    }

    private static string FormatPercent(double? value)
    {
        return value.HasValue ? $"{value.Value:F1}%" : "N/A";
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "N/A" : value;
    }

    private static string FormatNullableHealth(bool? value)
    {
        return value switch
        {
            true => "Healthy",
            false => "Unhealthy",
            _ => "Not reported"
        };
    }

    private static Color GetNullableHealthColor(bool? value)
    {
        return value switch
        {
            true => Color.Success,
            false => Color.Error,
            _ => Color.Default
        };
    }

    private static string GetNullableHealthIcon(bool? value)
    {
        return value switch
        {
            true => Icons.Material.Outlined.CheckCircle,
            false => Icons.Material.Outlined.Error,
            _ => Icons.Material.Outlined.HelpOutline
        };
    }

    private Severity GetServiceTelemetrySeverity()
    {
        if (_ingestionHealthy == false || _syncHealthy == false)
            return Severity.Error;

        if (_ingestionHealthy == true || _syncHealthy == true)
            return Severity.Success;

        return Severity.Info;
    }
    
    private DateTime? _lastScanTime = null;
}
