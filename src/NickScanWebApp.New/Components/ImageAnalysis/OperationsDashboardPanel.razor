    private async Task ExportCsv()
    {
        await ExportDashboard("csv", "text/csv");
    }

    private async Task ExportPdf()
    {
        await ExportDashboard("pdf", "application/pdf");
    }

    private async Task ExportDashboard(string format, string contentType)
    {
        try
        {
            _isExporting = true;
            StateHasChanged();

            var exportBytes = await DashboardClient.GetExportBytesAsync(format, _exportStartDate, _exportEndDate);

            if (exportBytes is { Length: > 0 })
            {
                var base64 = Convert.ToBase64String(exportBytes);
                var fileName = $"dashboard-export-{DateTime.UtcNow:yyyyMMdd-HHmmss}.{format}";
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, contentType);
                Snackbar.Add($"{format.ToUpper()} export downloaded", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Failed to export {format.ToUpper()}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting {Format}", format);
            Snackbar.Add($"Error exporting {format.ToUpper()}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }

