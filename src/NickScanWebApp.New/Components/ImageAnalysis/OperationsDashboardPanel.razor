    private async Task LoadSafeguardData()
    {
        try
        {
            var response = await DashboardClient.GetSafeguardSummaryAsync<SafeguardSummaryData>();

            if (response != null)
            {
                _safeguardData = response;
                StateHasChanged();
            }
        }
        catch (Exception ex)
