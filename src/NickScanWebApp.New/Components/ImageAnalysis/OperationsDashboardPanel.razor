@using Microsoft.AspNetCore.Authorization
@using NickScanCentralImagingPortal.Core.Constants
@using Microsoft.AspNetCore.SignalR.Client
@using NickScanWebApp.New.Services
@using NickScanWebApp.New.Components.Operations
@using NickScanWebApp.Shared.Models
@using NickScanCentralImagingPortal.Core.Models
@using MudBlazor
@inject NickScanWebApp.Shared.Services.ImageAnalysisDashboardClient DashboardClient
@inject NavigationManager Navigation
@inject ILogger<OperationsDashboardPanel> Logger
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@implements IAsyncDisposable


<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4">
    
    <!-- Header Section -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12">
            <MudPaper Elevation="0" Class="pa-4" Style="background: linear-gradient(135deg, #2563EB 0%, #60A5FA 100%);">
                <MudGrid>
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.h4" Color="Color.Surface" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Size="Size.Large" Class="mr-2" />
                            Image Analysis Operations Dashboard
                        </MudText>
                        <MudText Typo="Typo.body1" Color="Color.Surface">
                            Real-time monitoring of workflow status, assignments, and performance metrics
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudChip T="string" 
                                     Color="@(_isConnected ? Color.Success : Color.Error)" 
                                     Icon="@(_isConnected ? Icons.Material.Outlined.Cloud : Icons.Material.Outlined.CloudOff)"
                                     Size="Size.Medium">
                                @(_isConnected ? "Live" : "Offline")
                            </MudChip>
                            <MudChip T="string"
                                     Color="@(_autoRefreshEnabled ? Color.Success : Color.Default)"
                                     Icon="@Icons.Material.Outlined.Autorenew"
                                     Size="Size.Medium"
                                     OnClick="ToggleAutoRefresh"
                                     Style="cursor:pointer">
                                @(_autoRefreshEnabled ? "Auto 60s" : "Auto Off")
                            </MudChip>
                            <MudButton Variant="Variant.Outlined" 
                                      Color="Color.Surface" 
                                      StartIcon="@Icons.Material.Outlined.Refresh"
                                      OnClick="RefreshAllSections"
                                      Disabled="_isLoading">
                                Refresh
                            </MudButton>
                            <MudMenu Icon="@Icons.Material.Outlined.FileDownload" Color="Color.Surface" Variant="Variant.Outlined">
                                <MudMenuItem OnClick="ExportCsv" Icon="@Icons.Material.Outlined.InsertDriveFile">
                                    Export CSV
                                </MudMenuItem>
                                <MudMenuItem OnClick="ExportPdf" Icon="@Icons.Material.Outlined.PictureAsPdf">
                                    Export PDF
                                </MudMenuItem>
                            </MudMenu>
                            <MudMenu Icon="@Icons.Material.Outlined.ViewModule" Color="Color.Surface" Variant="Variant.Outlined">
                                <MudMenuItem OnClick="@(() => _showWorkflowStatus = !_showWorkflowStatus)">
                                    <MudIcon Icon="@(_showWorkflowStatus ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Workflow Status
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showAssignments = !_showAssignments)">
                                    <MudIcon Icon="@(_showAssignments ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Assignments
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showPerformance = !_showPerformance)">
                                    <MudIcon Icon="@(_showPerformance ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Performance
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showUserActivity = !_showUserActivity)">
                                    <MudIcon Icon="@(_showUserActivity ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    User Activity
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showQuality = !_showQuality)">
                                    <MudIcon Icon="@(_showQuality ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Quality & Audit
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showBottlenecks = !_showBottlenecks)">
                                    <MudIcon Icon="@(_showBottlenecks ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Bottlenecks
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showPredictive = !_showPredictive)">
                                    <MudIcon Icon="@(_showPredictive ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Predictive Analytics
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showAlerts = !_showAlerts)">
                                    <MudIcon Icon="@(_showAlerts ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    Alerts
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(() => _showSystemHealth = !_showSystemHealth)">
                                    <MudIcon Icon="@(_showSystemHealth ? Icons.Material.Outlined.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Class="mr-2" />
                                    System Health
                                </MudMenuItem>
                            </MudMenu>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_isLoading && _dashboardData == null)
    {
        <MudGrid>
            <MudItem xs="12" Class="text-center pa-8">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.h6" Class="mt-4">Loading dashboard data...</MudText>
            </MudItem>
        </MudGrid>
    }
    else if (_dashboardData != null)
    {
        <!-- SECTION 1: Workflow Status Overview -->
        @if (_showWorkflowStatus)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Class="mr-2" />
                        Workflow Status Overview
                    </MudText>
                    
                    <!-- Workflow Pipeline Visualization -->
                    <div style="display:flex; align-items:center; gap:4px; overflow-x:auto; padding-bottom:8px;" class="mb-4">
                        @foreach (var stage in _workflowStages)
                        {
                            var stageData = _dashboardData.WorkflowStatus.Stages.GetValueOrDefault(stage);
                            var count = stageData?.Count ?? 0;
                            var statusColor = GetStatusColor(stageData?.Status ?? "Normal");
                            
                            <MudCard Elevation="1" Class="text-center" Style="cursor:pointer; min-width:120px; flex:1 1 0;" @onclick="@(() => ShowStageDetails(stage))">
                                <MudCardContent Class="pa-2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:0.7rem;">@stage</MudText>
                                    <MudText Typo="Typo.h5" Color="@statusColor">@count</MudText>
                                    @if (stageData != null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:0.65rem;">
                                            @FormatTimeSpan(stageData.AverageAge)
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                            
                            @if (stage != _workflowStages.Last())
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.ArrowForward" Color="Color.Primary" Size="Size.Small" />
                            }
                        }
                    </div>

                    <!-- Stage Breakdown Cards -->
                    <MudGrid Spacing="2">
                        @foreach (var stage in _workflowStages)
                        {
                            var stageData = _dashboardData.WorkflowStatus.Stages.GetValueOrDefault(stage);
                            if (stageData != null)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.h6">@stage</MudText>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Count:</MudText>
                                                    <MudText Typo="Typo.body1" Color="@GetStatusColor(stageData.Status)">@stageData.Count</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Avg Age:</MudText>
                                                    <MudText Typo="Typo.body1">@FormatTimeSpan(stageData.AverageAge)</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Oldest:</MudText>
                                                    <MudText Typo="Typo.body1">@FormatTimeSpan(stageData.OldestAge)</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Incoming:</MudText>
                                                    <MudText Typo="Typo.body1">@stageData.IncomingRate.ToString("F1")/hr</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Outgoing:</MudText>
                                                    <MudText Typo="Typo.body1">@stageData.OutgoingRate.ToString("F1")/hr</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            }
                        }
                    </MudGrid>

                    <!-- WorkflowStage Distribution -->
                    <MudGrid Spacing="2" Class="mt-4">
                        <MudItem xs="12" md="6">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6" Class="mb-3">WorkflowStage Distribution</MudText>
                                    @if (_dashboardData.WorkflowStatus.Distribution.Any())
                                    {
                                        <MudSimpleTable Dense="true">
                                            <thead>
                                                <tr>
                                                    <th>Stage</th>
                                                    <th>Count</th>
                                                    <th>Percentage</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var dist in _dashboardData.WorkflowStatus.Distribution)
                                                {
                                                    <tr>
                                                        <td>@dist.StageName</td>
                                                        <td>@dist.Count</td>
                                                        <td>@dist.Percentage.ToString("F1")%</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 2: Assignment Management -->
        @if (_showAssignments)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Assignment" Class="mr-2" />
                        Assignment Management
                    </MudText>

                    <!-- Assignment Mode Status -->
                    <MudGrid Spacing="2" Class="mb-4">
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Assignment Mode</MudText>
                                        <MudChip T="string" Color="@GetAssignmentModeColor(_dashboardData.Assignments.AssignmentMode)" Size="Size.Medium">
                                            @_dashboardData.Assignments.AssignmentMode
                                        </MudChip>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Service Status</MudText>
                                        <MudChip T="string" Color="@(_dashboardData.Assignments.ServiceEnabled ? Color.Success : Color.Error)" Size="Size.Medium">
                                            @(_dashboardData.Assignments.ServiceEnabled ? "Enabled" : "Disabled")
                                        </MudChip>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Strategy</MudText>
                                        <MudText Typo="Typo.body1">@_dashboardData.Assignments.CurrentStrategy</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Balance Score</MudText>
                                        <MudText Typo="Typo.h6" Color="@GetBalanceScoreColor(_dashboardData.Assignments.BalanceScore)">
                                            @_dashboardData.Assignments.BalanceScore.ToString("F1")%
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>

                    <!-- Active Assignments Table -->
                    <MudText Typo="Typo.h6" Class="mb-2">
                        Active Assignments 
                        @if (_dashboardData.Assignments.UserAssignments != null)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@_dashboardData.Assignments.UserAssignments.Count</MudChip>
                        }
                    </MudText>
                    @if (_dashboardData.Assignments.UserAssignments == null || !_dashboardData.Assignments.UserAssignments.Any())
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            <MudText>No active assignments found. Users with active assignments will appear here.</MudText>
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="@_dashboardData.Assignments.UserAssignments" Dense="true" Hover="true" Bordered="true" Class="mb-4">
                        <HeaderContent>
                            <MudTh>User</MudTh>
                            <MudTh>Role</MudTh>
                            <MudTh>Active</MudTh>
                            <MudTh>Max</MudTh>
                            <MudTh>Utilization</MudTh>
                            <MudTh>Avg Age</MudTh>
                            <MudTh>Oldest</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Username</MudTd>
                            <MudTd>@context.Role</MudTd>
                            <MudTd>@context.ActiveAssignments</MudTd>
                            <MudTd>@context.MaxConcurrent</MudTd>
                            <MudTd>
                                <MudProgressLinear Color="@GetUtilizationColor(context.Utilization)" 
                                                  Value="@context.Utilization" 
                                                  Class="mt-2" />
                                <MudText Typo="Typo.caption">@context.Utilization.ToString("F1")%</MudText>
                            </MudTd>
                            <MudTd>@FormatTimeSpan(context.AverageAge)</MudTd>
                            <MudTd>@FormatTimeSpan(context.OldestAge)</MudTd>
                        </RowTemplate>
                    </MudTable>
                    }

                    <!-- Queue Status -->
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6" Class="mb-2">Analyst Queue</MudText>
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Ready for Assignment:</MudText>
                                            <MudText Typo="Typo.h6" Color="Color.Primary">@_dashboardData.Assignments.AnalystQueue.ReadyForAssignment</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Assignment Rate:</MudText>
                                            <MudText Typo="Typo.body1">@_dashboardData.Assignments.AnalystQueue.AssignmentRate.ToString("F1")/hr</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6" Class="mb-2">Audit Queue</MudText>
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Ready for Assignment:</MudText>
                                            <MudText Typo="Typo.h6" Color="Color.Primary">@_dashboardData.Assignments.AuditQueue.ReadyForAssignment</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Assignment Rate:</MudText>
                                            <MudText Typo="Typo.body1">@_dashboardData.Assignments.AuditQueue.AssignmentRate.ToString("F1")/hr</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 2.5: Real-Time Readiness Status -->
        @if (_showAssignments && _dashboardData?.RealTimeReadiness != null)
        {
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudText Typo="Typo.h5" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" Class="mr-2" />
                            Real-Time User Readiness
                        </MudText>

                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Ready Analysts</MudText>
                                            <MudText Typo="Typo.h4" Color="Color.Success">
                                                @_dashboardData.RealTimeReadiness.ReadyAnalysts / @_dashboardData.RealTimeReadiness.TotalAnalysts
                                            </MudText>
                                            <MudProgressLinear Color="Color.Success" 
                                                              Value="@_dashboardData.RealTimeReadiness.AnalystReadinessPercentage" 
                                                              Class="mt-2" />
                                            <MudText Typo="Typo.caption">@_dashboardData.RealTimeReadiness.AnalystReadinessPercentage.ToString("F1")% Ready</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Ready Auditors</MudText>
                                            <MudText Typo="Typo.h4" Color="Color.Success">
                                                @_dashboardData.RealTimeReadiness.ReadyAuditors / @_dashboardData.RealTimeReadiness.TotalAuditors
                                            </MudText>
                                            <MudProgressLinear Color="Color.Success" 
                                                              Value="@_dashboardData.RealTimeReadiness.AuditorReadinessPercentage" 
                                                              Class="mt-2" />
                                            <MudText Typo="Typo.caption">@_dashboardData.RealTimeReadiness.AuditorReadinessPercentage.ToString("F1")% Ready</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Total Ready Users</MudText>
                                            <MudText Typo="Typo.h4" Color="Color.Primary">
                                                @_dashboardData.RealTimeReadiness.ReadyUsers.Count
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Last Update: @_dashboardData.RealTimeReadiness.LastUpdate.ToString("HH:mm:ss")</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Data Source</MudText>
                                            <MudChip T="string" Color="Color.Info" Size="Size.Medium" Icon="@Icons.Material.Outlined.Cloud">
                                                SignalR Real-Time
                                            </MudChip>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        @if (_dashboardData.RealTimeReadiness.ReadyUsers != null && _dashboardData.RealTimeReadiness.ReadyUsers.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Ready Users</MudText>
                            <MudTable Items="@_dashboardData.RealTimeReadiness.ReadyUsers" Dense="true" Hover="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Username</MudTh>
                                    <MudTh>Role</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Last Heartbeat</MudTh>
                                    <MudTh>Time Since</MudTh>
                                    <MudTh>Source</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Username</MudTd>
                                    <MudTd>@context.Role</MudTd>
                                    <MudTd>
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Ready</MudChip>
                                    </MudTd>
                                    <MudTd>@context.LastHeartbeat.ToString("HH:mm:ss")</MudTd>
                                    <MudTd>@FormatTimeSpan(context.TimeSinceLastHeartbeat)</MudTd>
                                    <MudTd>
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.Source</MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">
                                <MudText>No users currently marked as ready. Users will appear here when they signal readiness via the Image Analysis page.</MudText>
                            </MudAlert>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <!-- SECTION 3: Performance Metrics -->
        @if (_showPerformance)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Speed" Class="mr-2" />
                        Performance Metrics
                    </MudText>

                    <!-- Throughput Metrics -->
                    <MudGrid Spacing="2" Class="mb-4">
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Containers/Hour</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Primary">
                                            @_dashboardData.Performance.Throughput.ContainersPerHour.ToString("F1")
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Groups/Hour</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Primary">
                                            @_dashboardData.Performance.Throughput.GroupsPerHour.ToString("F1")
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Decisions/Hour</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Primary">
                                            @_dashboardData.Performance.Throughput.DecisionsPerHour.ToString("F1")
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Performance vs Target</MudText>
                                        <MudText Typo="Typo.h4" Color="@GetPerformanceColor(_dashboardData.Performance.Throughput.PerformanceVsTarget)">
                                            @_dashboardData.Performance.Throughput.PerformanceVsTarget.ToString("F1")%
                                        </MudText>
                                        <MudProgressLinear 
                                            Color="@GetPerformanceColor(_dashboardData.Performance.Throughput.PerformanceVsTarget)" 
                                            Value="@Math.Min(100, _dashboardData.Performance.Throughput.PerformanceVsTarget)" 
                                            Class="mt-1" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Target: @_dashboardData.Performance.Throughput.TargetThroughput/hr
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>

                    <!-- Processing Time Metrics -->
                    <MudText Typo="Typo.h6" Class="mb-2">Processing Times</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Ready → Analyst Assigned</MudText>
                                        <MudText Typo="Typo.h6">@FormatTimeSpan(_dashboardData.Performance.ProcessingTimes.ReadyToAnalystAssigned)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Analyst Assigned → Completed</MudText>
                                        <MudText Typo="Typo.h6">@FormatTimeSpan(_dashboardData.Performance.ProcessingTimes.AnalystAssignedToCompleted)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Analyst Completed → Audit Assigned</MudText>
                                        <MudText Typo="Typo.h6">@FormatTimeSpan(_dashboardData.Performance.ProcessingTimes.AnalystCompletedToAuditAssigned)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Audit Assigned → Completed</MudText>
                                        <MudText Typo="Typo.h6">@FormatTimeSpan(_dashboardData.Performance.ProcessingTimes.AuditAssignedToCompleted)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total End-to-End</MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary">@FormatTimeSpan(_dashboardData.Performance.ProcessingTimes.TotalEndToEnd)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>

                    <!-- System Performance -->
                    <MudText Typo="Typo.h6" Class="mb-2 mt-4">System Performance</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">AssignmentWorker Cycle</MudText>
                                        <MudText Typo="Typo.body1">@FormatTimeSpan(_dashboardData.Performance.SystemPerformance.AssignmentWorkerCycleTime)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Avg DB Query Time</MudText>
                                        <MudText Typo="Typo.body1">@FormatTimeSpan(_dashboardData.Performance.SystemPerformance.AverageDatabaseQueryTime)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Avg API Response</MudText>
                                        <MudText Typo="Typo.body1">@FormatTimeSpan(_dashboardData.Performance.SystemPerformance.AverageApiResponseTime)</MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Error Rate</MudText>
                                        <MudText Typo="Typo.body1" Color="@(_dashboardData.Performance.SystemPerformance.ErrorRate > 1 ? Color.Error : Color.Success)">
                                            @_dashboardData.Performance.SystemPerformance.ErrorRate.ToString("F2")/1000
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 3.5: Historical Trends -->
        @if (_showPerformance)
        {
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h5">
                                <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Class="mr-2" />
                                Historical Trends
                            </MudText>
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudChipSet T="string" @bind-SelectedValue="_trendsPeriod" SelectionMode="SelectionMode.SingleSelection">
                                    <MudChip T="string" Value="@("24h")" Color="Color.Primary" Variant="Variant.Text">24h</MudChip>
                                    <MudChip T="string" Value="@("7d")" Color="Color.Primary" Variant="Variant.Text">7d</MudChip>
                                    <MudChip T="string" Value="@("30d")" Color="Color.Primary" Variant="Variant.Text">30d</MudChip>
                                </MudChipSet>
                                <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small" OnClick="LoadTrendsData" />
                            </MudStack>
                        </MudStack>

                        @if (_trendsData != null)
                        {
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6" Class="mb-2">Throughput Trend</MudText>
                                            @if (_trendsData.ThroughputTrend.Any())
                                            {
                                                <MudSimpleTable Dense="true">
                                                    <thead>
                                                        <tr>
                                                            <th>Time</th>
                                                            <th>Groups/hr</th>
                                                            <th>Decisions/hr</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var point in _trendsData.ThroughputTrend)
                                                        {
                                                            <tr>
                                                                <td>@point.Timestamp.ToString("MMM dd HH:mm")</td>
                                                                <td>@point.GroupsPerHour.ToString("F1")</td>
                                                                <td>@point.DecisionsPerHour.ToString("F1")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">No trend data available</MudText>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6" Class="mb-2">Stage Duration Trend</MudText>
                                            @if (_trendsData.StageDurationTrend.Any())
                                            {
                                                <MudSimpleTable Dense="true">
                                                    <thead>
                                                        <tr>
                                                            <th>Stage</th>
                                                            <th>Avg Duration</th>
                                                            <th>Median</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var point in _trendsData.StageDurationTrend)
                                                        {
                                                            <tr>
                                                                <td>@point.StageName</td>
                                                                <td>@FormatTimeSpan(point.AverageDuration)</td>
                                                                <td>@FormatTimeSpan(point.MedianDuration)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">No stage duration data available</MudText>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6" Class="mb-2">Assignment Efficiency</MudText>
                                            @if (_trendsData.AssignmentEfficiencyTrend.Any())
                                            {
                                                <MudSimpleTable Dense="true">
                                                    <thead>
                                                        <tr>
                                                            <th>Time</th>
                                                            <th>Rate/hr</th>
                                                            <th>Avg Wait</th>
                                                            <th>Success %</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var point in _trendsData.AssignmentEfficiencyTrend)
                                                        {
                                                            <tr>
                                                                <td>@point.Timestamp.ToString("MMM dd HH:mm")</td>
                                                                <td>@point.AssignmentRate.ToString("F1")</td>
                                                                <td>@FormatTimeSpan(point.AverageWaitTime)</td>
                                                                <td>@point.SuccessRate.ToString("F1")%</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">No assignment data available</MudText>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6" Class="mb-2">Quality Trend</MudText>
                                            @if (_trendsData.QualityTrend.Any())
                                            {
                                                <MudSimpleTable Dense="true">
                                                    <thead>
                                                        <tr>
                                                            <th>Time</th>
                                                            <th>Quality</th>
                                                            <th>Approval %</th>
                                                            <th>Discrepancy %</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var point in _trendsData.QualityTrend)
                                                        {
                                                            <tr>
                                                                <td>@point.Timestamp.ToString("MMM dd HH:mm")</td>
                                                                <td>@point.QualityScore.ToString("F1")%</td>
                                                                <td>@point.ApprovalRate.ToString("F1")%</td>
                                                                <td>@point.DiscrepancyRate.ToString("F1")%</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">No quality data available</MudText>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadTrendsData">
                                Load Historical Trends
                            </MudButton>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <!-- SECTION 3.5: Data Integrity Monitoring -->
        @if (_dashboardData?.DataIntegrity != null)
        {
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudText Typo="Typo.h5" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Class="mr-2" />
                            Data Integrity Monitoring
                        </MudText>

                        <!-- Integrity Overview -->
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Integrity Status</MudText>
                                            <MudChip T="string" 
                                                    Color="@GetIntegrityStatusColor(_dashboardData.DataIntegrity.IntegrityStatus)" 
                                                    Size="Size.Medium"
                                                    Icon="@GetIntegrityStatusIcon(_dashboardData.DataIntegrity.IntegrityStatus)">
                                                @_dashboardData.DataIntegrity.IntegrityStatus
                                            </MudChip>
                                            <MudText Typo="Typo.h4" Color="@GetIntegrityStatusColor(_dashboardData.DataIntegrity.IntegrityStatus)">
                                                @_dashboardData.DataIntegrity.IntegrityPercentage.ToString("F2")%
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Total Containers</MudText>
                                            <MudText Typo="Typo.h4" Color="Color.Primary">
                                                @_dashboardData.DataIntegrity.TotalContainers.ToString("N0")
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">NULL GroupIdentifier</MudText>
                                            <MudText Typo="Typo.h4" Color="@(_dashboardData.DataIntegrity.ContainersWithNullGroupIdentifier > 0 ? Color.Warning : Color.Success)">
                                                @_dashboardData.DataIntegrity.ContainersWithNullGroupIdentifier.ToString("N0")
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Missing BOEDocumentId</MudText>
                                            <MudText Typo="Typo.h4" Color="@(_dashboardData.DataIntegrity.ContainersWithMissingBOEDocumentId > 0 ? Color.Warning : Color.Success)">
                                                @_dashboardData.DataIntegrity.ContainersWithMissingBOEDocumentId.ToString("N0")
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        <!-- Preventive Fixes -->
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Preventive Fixes (Last 24h)</MudText>
                                            <MudText Typo="Typo.h5" Color="Color.Success">
                                                @_dashboardData.DataIntegrity.PreventiveFixesLast24h
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Preventive Fixes (Last Hour)</MudText>
                                            <MudText Typo="Typo.h5" Color="Color.Success">
                                                @_dashboardData.DataIntegrity.PreventiveFixesLastHour
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Last Fix Time</MudText>
                                            <MudText Typo="Typo.body1">
                                                @_dashboardData.DataIntegrity.LastPreventiveFixTime.ToString("yyyy-MM-dd HH:mm:ss")
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        @if (_dashboardData.DataIntegrity.RecentIssues != null && _dashboardData.DataIntegrity.RecentIssues.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Recent Issues</MudText>
                            <MudTable Items="@_dashboardData.DataIntegrity.RecentIssues" Dense="true" Hover="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Container</MudTh>
                                    <MudTh>Scanner</MudTh>
                                    <MudTh>Issue Type</MudTh>
                                    <MudTh>Detected At</MudTh>
                                    <MudTh>Status</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.ContainerNumber</MudTd>
                                    <MudTd>@context.ScannerType</MudTd>
                                    <MudTd>
                                        <MudChip T="string" 
                                                Color="@(context.IssueType == "NullGroupIdentifier" ? Color.Warning : Color.Error)" 
                                                Size="Size.Small">
                                            @context.IssueType
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>@context.DetectedAt.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                                    <MudTd>
                                        <MudChip T="string" 
                                                Color="@(context.IsFixed ? Color.Success : Color.Warning)" 
                                                Size="Size.Small">
                                            @(context.IsFixed ? "Fixed" : "Pending")
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <!-- SECTION 3.7: Container Completeness Safeguard Summary -->
        @if (_safeguardData != null)
        {
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h5">
                                <MudIcon Icon="@Icons.Material.Outlined.Shield" Class="mr-2" />
                                Container Completeness Safeguards
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small" OnClick="LoadSafeguardData" />
                        </MudStack>

                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Primary">@_safeguardData.TotalCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Complete</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Success">@_safeguardData.CompleteCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Missing</MudText>
                                        <MudText Typo="Typo.h4" Color="@(_safeguardData.MissingCount > 0 ? Color.Warning : Color.Success)">@_safeguardData.MissingCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Export-Pending</MudText>
                                        <MudText Typo="Typo.h4" Color="Color.Info">@_safeguardData.ExportPendingCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Location Mismatch</MudText>
                                        <MudText Typo="Typo.h4" Color="@(_safeguardData.LocationMismatchCount > 0 ? Color.Error : Color.Success)">@_safeguardData.LocationMismatchCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="2">
                                <MudCard Elevation="1">
                                    <MudCardContent Class="text-center">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Manual Review</MudText>
                                        <MudText Typo="Typo.h4" Color="@(_safeguardData.FlaggedForReviewCount > 0 ? Color.Warning : Color.Success)">@_safeguardData.FlaggedForReviewCount</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        @if (_safeguardData.StatusBreakdown.Any())
                        {
                            <MudSimpleTable Dense="true" Class="mt-3">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th>Count</th>
                                        <th>Percentage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _safeguardData.StatusBreakdown.OrderByDescending(s => s.Count))
                                    {
                                        <tr>
                                            <td>@item.Status</td>
                                            <td>@item.Count</td>
                                            <td>@(_safeguardData.TotalCount > 0 ? (item.Count * 100.0 / _safeguardData.TotalCount).ToString("F1") : "0")%</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <!-- SECTION 4: User Activity & Productivity (Phase 2) -->
        @if (_showUserActivity)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.People" Class="mr-2" />
                        User Activity & Productivity
                    </MudText>

                    @if (_userActivityData != null)
                    {
                        <!-- Active Users Panel -->
                        <MudText Typo="Typo.h6" Class="mb-2">Active Users</MudText>
                        <MudGrid Spacing="2" Class="mb-4">
                            @foreach (var user in _userActivityData.ActiveUsers)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudCard Elevation="1">
                                        <MudCardContent>
                                            <MudStack Spacing="1">
                                                <MudText Typo="Typo.h6">@user.Username</MudText>
                                                <MudChip T="string" Color="Color.Info" Size="Size.Small">@user.Role</MudChip>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    Last Activity: @FormatTimeSpan(user.TimeSinceLastActivity) ago
                                                </MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    Session: @FormatTimeSpan(user.SessionDuration)
                                                </MudText>
                                                <MudProgressLinear Color="Color.Success" Value="@user.ActivityLevel" Class="mt-2" />
                                            </MudStack>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>

                        <!-- User Productivity Leaderboard -->
                        <MudText Typo="Typo.h6" Class="mb-2">Productivity Leaderboard</MudText>
                        <MudTable Items="@_userActivityData.UserProductivity" Dense="true" Hover="true" Bordered="true" Class="mb-4">
                            <HeaderContent>
                                <MudTh>Rank</MudTh>
                                <MudTh>User</MudTh>
                                <MudTh>Role</MudTh>
                                <MudTh>Completed Today</MudTh>
                                <MudTh>Avg Time</MudTh>
                                <MudTh>Productivity</MudTh>
                                <MudTh>Quality Score</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@(Array.IndexOf(_userActivityData.UserProductivity.ToArray(), context) + 1)</MudTd>
                                <MudTd>@context.Username</MudTd>
                                <MudTd>@context.Role</MudTd>
                                <MudTd>@context.ContainersCompletedToday</MudTd>
                                <MudTd>@FormatTimeSpan(context.AverageTimePerContainer)</MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.body1" Color="Color.Primary">
                                        @context.ProductivityScore.ToString("F1")/hr
                                    </MudText>
                                </MudTd>
                                <MudTd>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body1" Color="@GetQualityColor(context.QualityScore)">
                                            @context.QualityScore.ToString("F1")%
                                        </MudText>
                                        <MudProgressLinear 
                                            Color="@GetQualityColor(context.QualityScore)" 
                                            Value="@context.QualityScore" 
                                            Size="Size.Small" />
                                    </MudStack>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadUserActivityData">
                            Load User Activity Data
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 5: Quality & Audit Metrics (Phase 2) -->
        @if (_showQuality)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Assessment" Class="mr-2" />
                        Quality & Audit Metrics
                    </MudText>

                    @if (_qualityMetricsData != null)
                    {
                        <!-- Decision Distribution -->
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Class="mb-2">Decision Distribution</MudText>
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Normal:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Success">@_qualityMetricsData.DecisionDistribution.NormalCount</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Abnormal:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Warning">@_qualityMetricsData.DecisionDistribution.AbnormalCount</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Not Clear:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Info">@_qualityMetricsData.DecisionDistribution.NotClearCount</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Total:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Primary">@_qualityMetricsData.DecisionDistribution.TotalCount</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>

                            <!-- Audit Outcomes -->
                            <MudItem xs="12" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Class="mb-2">Audit Outcomes</MudText>
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Total Audited:</MudText>
                                                <MudText Typo="Typo.body1">@_qualityMetricsData.AuditOutcomes.TotalAudited</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Approved:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Success">@_qualityMetricsData.AuditOutcomes.ApprovedCount (@_qualityMetricsData.AuditOutcomes.ApprovedRate.ToString("F1")%)</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">Rejected:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Error">@_qualityMetricsData.AuditOutcomes.RejectedCount (@_qualityMetricsData.AuditOutcomes.RejectionRate.ToString("F1")%)</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>

                            <!-- Quality Scores -->
                            <MudItem xs="12" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Class="mb-2">Quality Scores</MudText>
                                        <MudStack Spacing="3">
                                            <!-- Overall Quality with Progress Bar -->
                                            <div>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                                    <MudText Typo="Typo.body2">Overall Quality:</MudText>
                                                    <MudText Typo="Typo.h6" Color="@GetQualityColor(_qualityMetricsData.QualityScores.OverallQualityScore)">
                                                        @_qualityMetricsData.QualityScores.OverallQualityScore.ToString("F1")%
                                                    </MudText>
                                                </MudStack>
                                                <MudProgressLinear 
                                                    Color="@GetQualityColor(_qualityMetricsData.QualityScores.OverallQualityScore)" 
                                                    Value="@_qualityMetricsData.QualityScores.OverallQualityScore" 
                                                    Class="mt-1" />
                                            </div>
                                            <!-- Analyst Accuracy with Progress Bar -->
                                            <div>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                                    <MudText Typo="Typo.body2">Analyst Accuracy:</MudText>
                                                    <MudText Typo="Typo.body1">@_qualityMetricsData.QualityScores.AnalystAccuracy.ToString("F1")%</MudText>
                                                </MudStack>
                                                <MudProgressLinear 
                                                    Color="@GetQualityColor(_qualityMetricsData.QualityScores.AnalystAccuracy)" 
                                                    Value="@_qualityMetricsData.QualityScores.AnalystAccuracy" 
                                                    Class="mt-1" />
                                            </div>
                                            <!-- Discrepancy Rate (inverse - lower is better) -->
                                            <div>
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                                    <MudText Typo="Typo.body2">Discrepancy Rate:</MudText>
                                                    <MudText Typo="Typo.body1" Color="Color.Warning">@_qualityMetricsData.QualityScores.AverageDiscrepancyRate.ToString("F1")%</MudText>
                                                </MudStack>
                                                <MudProgressLinear 
                                                    Color="Color.Warning" 
                                                    Value="@_qualityMetricsData.QualityScores.AverageDiscrepancyRate" 
                                                    Class="mt-1" />
                                            </div>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        <!-- Audit Discrepancies -->
                        @if (_qualityMetricsData.Discrepancies.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Audit Discrepancies</MudText>
                            <MudTable Items="@_qualityMetricsData.Discrepancies" Dense="true" Hover="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Container</MudTh>
                                    <MudTh>Group</MudTh>
                                    <MudTh>Analyst Decision</MudTh>
                                    <MudTh>Audit Decision</MudTh>
                                    <MudTh>Analyst</MudTh>
                                    <MudTh>Auditor</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.ContainerNumber</MudTd>
                                    <MudTd>@context.GroupIdentifier</MudTd>
                                    <MudTd><MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.AnalystDecision</MudChip></MudTd>
                                    <MudTd><MudChip T="string" Color="Color.Error" Size="Size.Small">@context.AuditDecision</MudChip></MudTd>
                                    <MudTd>@context.AnalystUsername</MudTd>
                                    <MudTd>@context.AuditorUsername</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadQualityMetricsData">
                            Load Quality Metrics Data
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 6: Bottleneck Analysis (Phase 2) -->
        @if (_showBottlenecks)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Class="mr-2" />
                        Bottleneck Analysis
                    </MudText>

                    @if (_bottleneckData != null)
                    {
                        @if (_bottleneckData.DetectedBottlenecks.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Detected Bottlenecks</MudText>
                            <MudGrid Spacing="2" Class="mb-4">
                                @foreach (var bottleneck in _bottleneckData.DetectedBottlenecks)
                                {
                                    var severityColor = bottleneck.Severity == "Critical" ? Color.Error :
                                                         bottleneck.Severity == "High" ? Color.Warning :
                                                         bottleneck.Severity == "Medium" ? Color.Info : Color.Default;

                                    <MudItem xs="12" md="6">
                                        <MudCard Elevation="1" Style="@($"border-left: 4px solid {GetSeverityColorHex(bottleneck.Severity)};")">
                                            <MudCardContent>
                                                <MudStack Spacing="2">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                        <MudText Typo="Typo.h6">@bottleneck.StageName</MudText>
                                                        <MudChip T="string" Color="@severityColor" Size="Size.Small">@bottleneck.Severity</MudChip>
                                                    </MudStack>
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Queue Size:</MudText>
                                                        <MudText Typo="Typo.body1">@bottleneck.QueueSize</MudText>
                                                    </MudStack>
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Avg Wait:</MudText>
                                                        <MudText Typo="Typo.body1">@FormatTimeSpan(bottleneck.AverageWaitTime)</MudText>
                                                    </MudStack>
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Longest Wait:</MudText>
                                                        <MudText Typo="Typo.body1">@FormatTimeSpan(bottleneck.LongestWait)</MudText>
                                                    </MudStack>
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Throughput Impact:</MudText>
                                                        <MudText Typo="Typo.body1" Color="Color.Error">-@bottleneck.ThroughputImpact.ToString("F1")%</MudText>
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Root Cause: @bottleneck.RootCause</MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                }
                            </MudGrid>

                            <!-- Resolution Suggestions -->
                            @if (_bottleneckData.SuggestedResolutions.Any())
                            {
                                <MudText Typo="Typo.h6" Class="mb-2">Suggested Resolutions</MudText>
                                <MudList T="string">
                                    @foreach (var resolution in _bottleneckData.SuggestedResolutions)
                                    {
                                        <MudListItem T="string">
                                            <MudStack Spacing="1">
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body1">@resolution.Description</MudText>
                                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@resolution.Priority Priority</MudChip>
                                                </MudStack>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    Expected Impact: +@resolution.ExpectedImpact.ToString("F1")% improvement
                                                </MudText>
                                            </MudStack>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4">
                                <MudText>✅ No bottlenecks detected. System is operating smoothly.</MudText>
                            </MudAlert>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadBottleneckData">
                            Load Bottleneck Analysis
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 7: Predictive Analytics (Phase 3) -->
        @if (_showPredictive)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Class="mr-2" />
                        Predictive Analytics
                    </MudText>

                    @if (_predictiveData != null)
                    {
                        <!-- Workload Forecast -->
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" md="6">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Class="mb-2">Workload Forecast</MudText>
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Expected Peak Load:</MudText>
                                                <MudText Typo="Typo.body1" Color="Color.Primary">@_predictiveData.WorkloadForecast.ExpectedPeakLoad.ToString("F1") containers/hr</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Peak Time:</MudText>
                                                <MudText Typo="Typo.body1">@(_predictiveData.WorkloadForecast.ExpectedPeakTime?.ToString("HH:mm") ?? "N/A")</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Confidence:</MudText>
                                                <MudText Typo="Typo.body1">@_predictiveData.WorkloadForecast.ConfidenceLevel.ToString("F0")%</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>

                            <!-- Capacity Planning -->
                            <MudItem xs="12" md="6">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Class="mb-2">Capacity Planning</MudText>
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Current Capacity:</MudText>
                                                <MudText Typo="Typo.body1">@_predictiveData.CapacityPlanning.CurrentCapacity containers/hr</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Required Capacity:</MudText>
                                                <MudText Typo="Typo.body1" Color="@(_predictiveData.CapacityPlanning.CapacityGap > 0 ? Color.Warning : Color.Success)">
                                                    @_predictiveData.CapacityPlanning.RequiredCapacity containers/hr
                                                </MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Capacity Gap:</MudText>
                                                <MudText Typo="Typo.body1" Color="@(_predictiveData.CapacityPlanning.CapacityGap > 0 ? Color.Error : Color.Success)">
                                                    @_predictiveData.CapacityPlanning.CapacityGap containers/hr
                                                </MudText>
                                            </MudStack>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Utilization:</MudText>
                                                <MudText Typo="Typo.body1">@_predictiveData.CapacityPlanning.UtilizationRate.ToString("F1")%</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        <!-- Resource Needs -->
                        <MudText Typo="Typo.h6" Class="mb-2">Resource Needs</MudText>
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Required Analysts</MudText>
                                            <MudText Typo="Typo.h5" Color="@(_predictiveData.ResourceNeeds.RequiredAnalysts > _predictiveData.ResourceNeeds.CurrentAnalysts ? Color.Warning : Color.Success)">
                                                @_predictiveData.ResourceNeeds.RequiredAnalysts
                                            </MudText>
                                            <MudText Typo="Typo.caption">Current: @_predictiveData.ResourceNeeds.CurrentAnalysts</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Required Auditors</MudText>
                                            <MudText Typo="Typo.h5" Color="@(_predictiveData.ResourceNeeds.RequiredAuditors > _predictiveData.ResourceNeeds.CurrentAuditors ? Color.Warning : Color.Success)">
                                                @_predictiveData.ResourceNeeds.RequiredAuditors
                                            </MudText>
                                            <MudText Typo="Typo.caption">Current: @_predictiveData.ResourceNeeds.CurrentAuditors</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Analyst Utilization</MudText>
                                            <MudText Typo="Typo.h5">@_predictiveData.ResourceNeeds.AnalystUtilization.ToString("F1")%</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Auditor Utilization</MudText>
                                            <MudText Typo="Typo.h5">@_predictiveData.ResourceNeeds.AuditorUtilization.ToString("F1")%</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        <!-- Bottleneck Predictions -->
                        @if (_predictiveData.BottleneckPredictions.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Bottleneck Predictions</MudText>
                            <MudTable Items="@_predictiveData.BottleneckPredictions" Dense="true" Hover="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Stage</MudTh>
                                    <MudTh>Predicted Time</MudTh>
                                    <MudTh>Probability</MudTh>
                                    <MudTh>Severity</MudTh>
                                    <MudTh>Reason</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.StageName</MudTd>
                                    <MudTd>@context.PredictedTime.ToString("g")</MudTd>
                                    <MudTd>
                                        <MudProgressLinear Color="@GetSeverityColor(context.Severity)" Value="@context.Probability" />
                                        <MudText Typo="Typo.caption">@context.Probability.ToString("F0")%</MudText>
                                    </MudTd>
                                    <MudTd><MudChip T="string" Color="@GetSeverityColor(context.Severity)" Size="Size.Small">@context.Severity</MudChip></MudTd>
                                    <MudTd>@context.Reason</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadPredictiveData">
                            Load Predictive Analytics
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        <!-- SECTION 8: Alerts & Notifications (Phase 3) -->
        @if (_showAlerts)
        {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h5">
                            <MudIcon Icon="@Icons.Material.Outlined.Notifications" Class="mr-2" />
                            Alerts & Notifications
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="LoadAlertsData">
                            Refresh Alerts
                        </MudButton>
                    </MudStack>

                    @if (_alertsData != null)
                    {
                        @if (_alertsData.ActiveAlerts.Any())
                        {
                            <MudText Typo="Typo.h6" Class="mb-2">Active Alerts (@_alertsData.ActiveAlerts.Count)</MudText>
                            <MudList T="string">
                                @foreach (var alert in _alertsData.ActiveAlerts.OrderByDescending(a => a.CreatedAt))
                                {
                                    var severityColor = GetSeverityColor(alert.Severity);
                                    <MudListItem T="string">
                                        <MudCard Elevation="1" Style="@($"width: 100%; border-left: 4px solid {GetSeverityColorHex(alert.Severity)};")">
                                            <MudCardContent>
                                                <MudStack Spacing="2">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                            <MudChip T="string" Color="@severityColor" Size="Size.Small">@alert.Severity</MudChip>
                                                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@alert.AlertType</MudChip>
                                                            <MudText Typo="Typo.h6">@alert.Title</MudText>
                                                        </MudStack>
                                                        @if (!alert.IsAcknowledged)
                                                        {
                                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => AcknowledgeAlert(alert.Id))">
                                                                Acknowledge
                                                            </MudButton>
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.body2">@alert.Message</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        Created: @alert.CreatedAt.ToString("g")
                                                        @if (alert.IsAcknowledged)
                                                        {
                                                            <span> | Acknowledged by @alert.AcknowledgedBy at @alert.AcknowledgedAt?.ToString("g")</span>
                                                        }
                                                    </MudText>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4">
                                <MudText>✅ No active alerts. System is operating normally.</MudText>
                            </MudAlert>
                        }
                    }
                    else
