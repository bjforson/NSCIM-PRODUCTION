        <!-- SECTION 9: Export (Phase 3) -->
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-3">
