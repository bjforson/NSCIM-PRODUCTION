</MudContainer>

@code {
    private ImageAnalysisDashboardData? _dashboardData;
    private UserActivityData? _userActivityData;
    private QualityMetricsData? _qualityMetricsData;
    private BottleneckAnalysisData? _bottleneckData;
    private PredictiveAnalyticsData? _predictiveData;
    private DashboardAlertsData? _alertsData;
    private SystemHealthData? _systemHealthData;
    private HistoricalTrendsData? _trendsData;
    private SafeguardSummaryData? _safeguardData;
    private bool _isLoading = false;
    private bool _isConnected = false;
    private bool _isExporting = false;
    private bool _autoRefreshEnabled = false;
    private System.Threading.Timer? _autoRefreshTimer;
    private string _trendsPeriod = "24h";
    
    // Section visibility toggles for customization
    private bool _showWorkflowStatus = true;
    private bool _showAssignments = true;
    private bool _showPerformance = true;
    private bool _showUserActivity = true;
    private bool _showQuality = true;
    private bool _showBottlenecks = true;
    private bool _showPredictive = true;
    private bool _showAlerts = true;
    private bool _showSystemHealth = true;
    private HubConnection? _hubConnection;
    private DateTime? _exportStartDate = DateTime.UtcNow.AddDays(-7);
    private DateTime? _exportEndDate = DateTime.UtcNow;
    
    private readonly string[] _workflowStages = new[]
    {
        "Ready",
        "AnalystAssigned",
        "AnalystCompleted",
        "AuditAssigned",
        "AuditCompleted",
        "PartiallyCompleted",
        "Submitted",
        "Completed"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
        await InitializeSignalR();
        
        await Task.WhenAll(
            LoadUserActivityData(),
            LoadQualityMetricsData(),
            LoadBottleneckData(),
            LoadPredictiveData(),
            LoadAlertsData(),
            LoadSystemHealthData(),
            LoadTrendsData(),
            LoadSafeguardData()
        );
    }

    private async Task LoadDashboardData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var response = await DashboardClient.GetOverviewAsync<ImageAnalysisDashboardData>();

            if (response != null)
            {
                _dashboardData = response;
                Logger.LogInformation("Dashboard data loaded successfully");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
            Snackbar.Add($"Error loading dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            var hubUrl = $"{apiBaseUrl}/hubs/imageAnalysisDashboard";

            // Get token for SignalR authentication
            string? token = null;
            try
            {
                var method = AuthStateProvider.GetType().GetMethod("GetTokenAsync", System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
                if (method != null)
                {
                    var task = method.Invoke(AuthStateProvider, null) as Task<string?>;
                    if (task != null)
                    {
                        token = await task;
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error retrieving token for SignalR connection");
            }

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    if (!string.IsNullOrEmpty(token))
                    {
                        options.AccessTokenProvider = () => Task.FromResult<string?>(token);
                    }
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<ImageAnalysisDashboardData>("DashboardUpdate", (data) =>
            {
                _dashboardData = data;
                StateHasChanged();
            });

            // Listen for real-time alert notifications
            _hubConnection.On<DashboardAlert>("NewAlert", (alert) =>
            {
                // Add to alerts list if not already present
                if (_alertsData != null && !_alertsData.ActiveAlerts.Any(a => a.Id == alert.Id))
                {
                    _alertsData.ActiveAlerts.Add(alert);
                    StateHasChanged();
                    
                    // Show notification snackbar
                    var severity = alert.Severity switch
                    {
                        "Critical" => Severity.Error,
                        "High" => Severity.Warning,
                        "Medium" => Severity.Info,
                        _ => Severity.Info
                    };
                    Snackbar.Add($"🚨 {alert.Title}: {alert.Message}", severity);
                }
            });

            // Listen for alert updates (acknowledgment, resolution)
            _hubConnection.On<int>("AlertAcknowledged", (alertId) =>
            {
                if (_alertsData != null)
                {
                    var alert = _alertsData.ActiveAlerts.FirstOrDefault(a => a.Id == alertId);
                    if (alert != null)
                    {
                        alert.IsAcknowledged = true;
                        StateHasChanged();
                    }
                }
            });

            _hubConnection.Reconnecting += error =>
            {
                _isConnected = false;
                StateHasChanged();
                return Task.CompletedTask;
            };

            _hubConnection.Reconnected += connectionId =>
            {
                _isConnected = true;
                StateHasChanged();
                return Task.CompletedTask;
            };

            _hubConnection.Closed += error =>
            {
                _isConnected = false;
                StateHasChanged();
                return Task.CompletedTask;
            };

            await _hubConnection.StartAsync();
            _isConnected = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing SignalR connection");
            _isConnected = false;
        }
    }

    private Color GetStatusColor(string? status)
    {
        return status switch
        {
            "Normal" => Color.Success,
            "Warning" => Color.Warning,
            "Critical" => Color.Error,
            _ => Color.Default
        };
    }

    private Color GetAssignmentModeColor(string mode)
    {
        return mode switch
        {
            "Auto" => Color.Success,
            "Manual" => Color.Warning,
            "UserClaim" => Color.Info,
            _ => Color.Default
        };
    }

    private Color GetBalanceScoreColor(double score)
    {
        if (score >= 80) return Color.Success;
        if (score >= 50) return Color.Warning;
        return Color.Error;
    }

    private Color GetUtilizationColor(double utilization)
    {
        if (utilization >= 90) return Color.Error;
        if (utilization >= 70) return Color.Warning;
        return Color.Success;
    }

    private Color GetPerformanceColor(double performance)
    {
        if (performance >= 100) return Color.Success;
        if (performance >= 80) return Color.Warning;
        return Color.Error;
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalDays >= 1)
            return $"{(int)timeSpan.TotalDays}d {timeSpan.Hours}h";
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        if (timeSpan.TotalMinutes >= 1)
            return $"{(int)timeSpan.TotalMinutes}m {timeSpan.Seconds}s";
        return $"{timeSpan.TotalSeconds:F0}s";
    }

    private Color GetIntegrityStatusColor(string status)
    {
        return status switch
        {
            "Healthy" => Color.Success,
            "Warning" => Color.Warning,
            "Critical" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetIntegrityStatusIcon(string status)
    {
        return status switch
        {
            "Healthy" => Icons.Material.Outlined.CheckCircle,
            "Warning" => Icons.Material.Outlined.Warning,
            "Critical" => Icons.Material.Outlined.Error,
            _ => Icons.Material.Outlined.Info
        };
    }

    private async Task ShowStageDetails(string stage)
    {
        if (_dashboardData?.WorkflowStatus?.Stages == null)
            return;

        var stageData = _dashboardData.WorkflowStatus.Stages.GetValueOrDefault(stage);
        if (stageData == null)
        {
            Snackbar.Add($"No data available for stage: {stage}", Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            ["StageName"] = stage,
            ["StageData"] = stageData
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<StageDetailsDialog>("Stage Details", parameters, options);
    }

    private async Task LoadUserActivityData()
    {
        try
        {
            var response = await DashboardClient.GetUserProductivityAsync<UserActivityData>();

            if (response != null)
            {
                _userActivityData = response;
                StateHasChanged();
