    private async Task DownloadRaw16()
    {
        if (_selectedScan is null) return;
        await DownloadImageAsync($"?channel={_channel}&transform=raw&colormap=none", $"{_selectedScan.ContainerNumber}_{_channel}.raw16.png");
    }

    private async Task DownloadCookedPng()
    {
        if (_selectedScan is null) return;
        var qs = $"?channel={_channel}&transform={_transform}&colormap={_colormap}&invert={(_invert ? "true" : "false")}";
        await DownloadImageAsync(qs, $"{_selectedScan.ContainerNumber}_{_channel}_{_transform}.png");
    }

    private async Task DownloadVendorJpeg()
    {
        if (_selectedScan is null) return;
        try
        {
            var bytes = await XrayClient.GetVendorJpegBytesAsync(_selectedScan.Scanner, _selectedScan.Id);
            if (bytes is null) return;
            await JS.InvokeVoidAsync("XrayInspector.downloadBlob", bytes, $"{_selectedScan.ContainerNumber}_vendor.jpg", "image/jpeg");
        }
        catch (Exception ex) { Snackbar.Add("Download failed: " + ex.Message, Severity.Error); }
    }

    private async Task DownloadImageAsync(string qs, string filename)
    {
        if (_selectedScan is null) return;
        try
        {
            var bytes = await XrayClient.GetImageBytesAsync(_selectedScan.Scanner, _selectedScan.Id, qs);
            if (bytes is null) return;
            await JS.InvokeVoidAsync("XrayInspector.downloadBlob", bytes, filename, "image/png");
        }
        catch (Exception ex) { Snackbar.Add("Download failed: " + ex.Message, Severity.Error); }
    }

    private async Task DownloadRoiCsv()
    {
        if (_selectedScan is null) return;
        var rois = await JS.InvokeAsync<JsonElement[]>("XrayInspector.getRois", "xray-canvas-host");
        if (rois is null || rois.Length == 0)
        {
            Snackbar.Add("No ROIs to export. Draw at least one.", Severity.Info);
            return;
        }
        try
        {
            var req = new
            {
                scanner = _selectedScan.Scanner,
                id = _selectedScan.Id,
                channel = _channel,
                rois = rois
            };
            var bytes = await XrayClient.ExportRoiCsvAsync(req);
            if (bytes is { Length: > 0 })
            {
                await JS.InvokeVoidAsync("XrayInspector.downloadBlob", bytes, $"{_selectedScan.ContainerNumber}_rois.csv", "text/csv");
            }
            else
            {
                Snackbar.Add("CSV export failed", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add("CSV export error: " + ex.Message, Severity.Error); }
    }

    private async Task DownloadPdfReport()
    {
        if (_selectedScan is null) return;
        var rois = await JS.InvokeAsync<JsonElement[]>("XrayInspector.getRois", "xray-canvas-host");
        try
        {
            var req = new
            {
                scanner = _selectedScan.Scanner,
                id = _selectedScan.Id,
                title = $"X-Ray scan report — {_selectedScan.ContainerNumber}",
                channel = _channel,
                rois = rois,
                include_composite = true
            };
            var bytes = await XrayClient.ExportPdfReportAsync(req);
            if (bytes is { Length: > 0 })
            {
                await JS.InvokeVoidAsync("XrayInspector.downloadBlob", bytes, $"{_selectedScan.ContainerNumber}_report.pdf", "application/pdf");
            }
            else
            {
                Snackbar.Add("PDF export failed", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add("PDF export error: " + ex.Message, Severity.Error); }
    }

