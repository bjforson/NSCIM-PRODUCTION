    // ── JS → C# callbacks ──────────────────────────────────────────

    [JSInvokable]
    public Task OnHover(int x, int y)
    {
        _hoverText = $"x={x}, y={y}";
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnWindowLevelChanged(double lo, double hi)
    {
        _windowLo = lo;
        _windowHi = hi;
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnRoiCommitted(string roiJson)
    {
        _roiCount++;
        if (_selectedScan is null) return;
        try
        {
            var roi = JsonDocument.Parse(roiJson).RootElement;
            if (roi.TryGetProperty("kind", out var kindEl) && kindEl.GetString() == "line")
            {
                // Line: request line profile
                var x0 = roi.GetProperty("x0").GetDouble();
                var y0 = roi.GetProperty("y0").GetDouble();
                var x1 = roi.GetProperty("x1").GetDouble();
                var y1 = roi.GetProperty("y1").GetDouble();
                var req = new
                {
                    scanner = _selectedScan.Scanner,
                    id = _selectedScan.Id,
                    channel = _channel,
                    x0, y0, x1, y1,
                    samples = 512
                };
                var resp = await XrayClient.AnalyzeLineProfileAsync<JsonElement>(req);
                if (resp.ValueKind == JsonValueKind.Object)
                {
                    var mean = resp.GetProperty("mean").GetDouble();
                    var mn = resp.GetProperty("min").GetDouble();
                    var mx = resp.GetProperty("max").GetDouble();
                    Snackbar.Add($"Line profile: {(int)mn}..{(int)mx} (mean {mean:0})", Severity.Info);
                }
            }
            else
            {
                // Rect / Ellipse / Polygon: request ROI stats
                var req = new
                {
                    scanner = _selectedScan.Scanner,
                    id = _selectedScan.Id,
                    channel = _channel,
                    roi = JsonSerializer.Deserialize<object>(roi.GetRawText()),
                    bins = 64
                };
                var resp = await XrayClient.AnalyzeRoiStatsAsync<RoiStatsDto>(req);
                if (resp is not null)
                {
                    _latestRoiStats = resp;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ROI stats request failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    // ── Analysis overlays ─────────────────────────────────────────

    private async Task RunAnalysisOverlayAsync(string op)
    {
        if (_selectedScan is null || !_viewerInitialized) return;
        _imageLoading = true;
        StateHasChanged();
        try
        {
            byte[]? bytes = null;
            switch (op)
            {
                case "edge-canny":
                    {
                        var req = new { scanner = _selectedScan.Scanner, id = _selectedScan.Id, channel = _channel, method = "canny", low = 50.0, high = 150.0 };
                        bytes = await XrayClient.AnalyzeEdgeBytesAsync(req);
                        break;
                    }
                case "edge-sobel":
                    {
                        var req = new { scanner = _selectedScan.Scanner, id = _selectedScan.Id, channel = _channel, method = "sobel", ksize = 5 };
                        bytes = await XrayClient.AnalyzeEdgeBytesAsync(req);
                        break;
                    }
                case "threshold":
                    {
                        var lo = _windowLo ?? 0;
                        var hi = _windowHi ?? 65535;
                        var mid = (lo + hi) / 2.0;
                        var req = new { scanner = _selectedScan.Scanner, id = _selectedScan.Id, channel = _channel, low = mid, high = (double?)null };
                        bytes = await XrayClient.AnalyzeThresholdBytesAsync(req);
                        break;
                    }
                case "dual-energy-diff":
                    {
                        bytes = await XrayClient.AnalyzeDualEnergyDiffBytesAsync(_selectedScan.Scanner, _selectedScan.Id);
                        break;
                    }
                case "composite":
                    {
                        // Composite is a GET — stream via ImageProxyController instead of base64
                        var proxyUrl = SignedImageUrlBuilder.BuildImageProxyUrl(NickScanWebApp.Shared.Services.XrayInspectorClient.BuildCompositePath(_selectedScan.Scanner, _selectedScan.Id));
                        await JS.InvokeVoidAsync("XrayInspector.loadImage", "xray-canvas-host", proxyUrl,
                            new { width = GetMetaInt("width"), height = GetMetaInt("height") });
                        Snackbar.Add("composite applied — use Analyze → Restore original view to revert", Severity.Info);
                        return;
                    }
            }
            if (bytes is null || bytes.Length == 0)
            {
                Snackbar.Add("Analysis failed or returned empty", Severity.Warning);
                return;
            }
            var dataUrl = "data:image/png;base64," + Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("XrayInspector.loadImage", "xray-canvas-host", dataUrl,
                new { width = GetMetaInt("width"), height = GetMetaInt("height") });
            Snackbar.Add($"{op} applied — use Analyze → Restore original view to revert", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Analysis {Op} failed", op);
            Snackbar.Add("Analysis error: " + ex.Message, Severity.Error);
        }
        finally
        {
            _imageLoading = false;
            StateHasChanged();
        }
    }

    private async Task RunObjectsAsync()
    {
        if (_selectedScan is null) return;
        _objectsBusy = true;
        StateHasChanged();
        try
        {
            var lo = _windowLo ?? 0;
            var hi = _windowHi ?? 65535;
            var mid = (lo + hi) / 2.0;
            var req = new
            {
                scanner = _selectedScan.Scanner,
                id = _selectedScan.Id,
                channel = _channel,
                low = mid,
                high = (double?)null,
                min_area = 100,
                max_objects = 200
            };
            var resp = await XrayClient.AnalyzeObjectsAsync<DetectedObjectsResponseDto>(req);
            if (resp is null)
            {
                Snackbar.Add("Object detection returned no response", Severity.Warning);
                return;
            }
            _detectedObjects = resp.Objects ?? new List<DetectedObjectDto>();
            _focusedObjectIndex = -1;

            // Push bounding boxes to the canvas overlay
            if (_viewerInitialized)
            {
                await JS.InvokeVoidAsync("XrayInspector.setDetectedObjects",
                    "xray-canvas-host",
                    _detectedObjects.Select((o, i) => new
                    {
                        index = i,
                        bbox = o.Bbox,
                        area = o.Area,
                        centroid = o.Centroid
                    }).ToArray());
            }
            Snackbar.Add($"Found {_detectedObjects.Count} candidate objects above threshold {mid:0}", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Object detection failed");
            Snackbar.Add("Object detection failed: " + ex.Message, Severity.Error);
        }
        finally
        {
            _objectsBusy = false;
            StateHasChanged();
        }
    }

    private async Task FocusObjectAsync(int index)
    {
        _focusedObjectIndex = index;
        if (_viewerInitialized)
        {
            await JS.InvokeVoidAsync("XrayInspector.focusDetectedObject", "xray-canvas-host", index);
        }
        StateHasChanged();
    }

    private async Task ClearDetectedObjectsAsync()
    {
        _detectedObjects = null;
        _focusedObjectIndex = -1;
        if (_viewerInitialized)
        {
            await JS.InvokeVoidAsync("XrayInspector.clearDetectedObjects", "xray-canvas-host");
        }
        StateHasChanged();
    }

