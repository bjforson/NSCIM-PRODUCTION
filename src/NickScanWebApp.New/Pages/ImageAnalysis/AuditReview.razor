        public string? Message { get; set; }
    }

    // 🔔 [AUDIT] DTO mirroring the API's TransitionEventDto (ModuleQueuesController) and
    // the LivePipelinePanel's TransitionRow. SignalR JSON serializer maps camelCase wire
    // payloads to these PascalCase C# props. Used by the AnalysisGroupTransition handler
    // wired in InitializeDashboardHub() to splice completed AGs out of _myAssignments.
    private sealed record AgTransitionEvent(
        long Id,
        DateTime OccurredAtUtc,
        Guid GroupId,
        string? GroupIdentifier,
        string? FromStatus,
        string ToStatus,
        string? TriggerName,
        string Actor,
        string? Reason,
        string? CorrelationId);

