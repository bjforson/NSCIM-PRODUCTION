    // ── Helper methods for table styling ──

    private string? _statusFilter;
    private string? _scannerFilter;

    private List<MyAssignmentDto> FilteredAssignments => _myAssignments
        .Where(a => _statusFilter == null || a.Status == _statusFilter)
        .Where(a => _scannerFilter == null || a.ScannerType == _scannerFilter)
        .ToList();

    private Color GetStatusColor(string status) => status switch
    {
        "AuditAssigned" => Color.Info,
        "AuditCompleted" => Color.Success,
        "PartiallyCompleted" => Color.Warning,
        "AnalystCompleted" => Color.Default,
        _ => Color.Default
    };

    private Color GetProgressColor(double percent) => percent switch
    {
        >= 100 => Color.Success,
        >= 50 => Color.Info,
        > 0 => Color.Warning,
        _ => Color.Default
    };

