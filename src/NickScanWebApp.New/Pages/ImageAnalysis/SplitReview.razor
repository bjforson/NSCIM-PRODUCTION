@page "/operations/image-split-review"
@page "/image-analysis/split"
@attribute [Authorize(Policy = Permissions.PagesCrossRecordScans)]
@using NickScanWebApp.Shared.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Globalization
@using System.Text.Json.Serialization
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject ILogger<SplitReview> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject NickScanWebApp.New.Services.SignedImageUrlBuilder UrlBuilder
@implements IDisposable

<PageTitle>Image Split Review</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Style="gap: 12px; flex-wrap: wrap;">
    <MudText Typo="Typo.h4">
        <MudIcon Icon="@Icons.Material.Outlined.CallSplit" Color="Color.Primary" Class="mr-2" />
        Image Split Review
    </MudText>
    <MudSpacer />
    <MudChip T="string" Color="@(_serviceHealthy ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Filled">
        @(_serviceHealthy ? "Splitter Online" : "Splitter Offline")
    </MudChip>
    <MudButton OnClick="RefreshQueue" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.Refresh" Disabled="@(_loading || _queueRefreshing)" Size="Size.Small">
        @((_loading || _queueRefreshing) ? "Loading..." : "Refresh")
    </MudButton>
</MudStack>

<MudPaper Elevation="1" Class="pa-3 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 10px; flex-wrap: wrap;">
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
            Reviewable: @ReviewableJobs.Count
        </MudChip>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
            Processing: @_jobs.Count(j => IsStatus(j, "pending") || IsStatus(j, "processing"))
        </MudChip>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error">
            Failed: @_jobs.Count(j => IsStatus(j, "failed"))
        </MudChip>
        @if (ActiveIndex > 0)
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">
                Active @ActiveIndex of @ReviewableJobs.Count
            </MudChip>
        }
    </MudStack>
</MudPaper>

@if (_loading && !_jobs.Any())
{
    <MudPaper Class="pa-8" Elevation="1">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Loading split jobs...</MudText>
        </MudStack>
    </MudPaper>
}
else if (!_serviceHealthy)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        The image splitter service is not responding. Ensure it is running on port 5320.
    </MudAlert>
}
else if (!ReviewableJobs.Any())
{
    <MudAlert Severity="Severity.Info">No split jobs awaiting review.</MudAlert>
}
else
{
    var activeJob = ActiveJob;
    var activeState = activeJob is null ? null : GetJobState(activeJob.Id);

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="3">
            <MudPaper Elevation="1" Class="pa-3" Style="position: sticky; top: 76px; max-height: calc(100vh - 110px); overflow-y: auto;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle1"><b>Queue</b></MudText>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ReviewableJobs.Count ready</MudText>
                </MudStack>

                <MudStack Spacing="1">
                    @foreach (var job in ReviewableJobs)
                    {
                        var isActive = activeJob?.Id == job.Id;
                        <MudButton Variant="Variant.Text" FullWidth="true"
                                   Color="@(isActive ? Color.Primary : Color.Default)"
                                   Style="@GetQueueButtonStyle(isActive)"
                                   OnClick="@(() => SelectJobAsync(job))">
                            <MudStack Style="width: 100%; text-align: left;">
                                <MudText Typo="Typo.body2" Style="font-family: monospace; line-height: 1.25;">
                                    @job.ContainerNumbers
                                </MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 6px; flex-wrap: wrap;">
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(job.Status)" Variant="Variant.Outlined">
                                        @job.Status
                                    </MudChip>
                                    @if (!string.IsNullOrWhiteSpace(job.BestStrategy))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@job.BestStrategy</MudText>
                                    }
                                    @if (job.BestScore.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatConfidence(job.BestScore)</MudText>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="9">
            @if (activeJob is null || activeState is null)
            {
                <MudAlert Severity="Severity.Info">Select a split job to review.</MudAlert>
            }
            else
            {
                var state = activeState;
                var candidates = GetVisibleCandidates(activeJob, state);
                var containers = GetContainers(activeJob);

                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Style="gap: 12px; flex-wrap: wrap;">
                        <div>
                            <MudText Typo="Typo.h5" Style="font-family: monospace;">@activeJob.ContainerNumbers</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Created @activeJob.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm", CultureInfo.InvariantCulture)
                            </MudText>
                        </div>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Outlined.ChevronLeft"
                                       Color="Color.Primary"
                                       Disabled="@(!CanSelectPrevious)"
                                       OnClick="@(() => SelectRelativeJob(-1))" />
                        <MudIconButton Icon="@Icons.Material.Outlined.ChevronRight"
                                       Color="Color.Primary"
                                       Disabled="@(!CanSelectNext)"
                                       OnClick="@(() => SelectRelativeJob(1))" />
                    </MudStack>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Style="gap: 8px; flex-wrap: wrap;">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(activeJob.Status)" Variant="Variant.Filled">
                            @activeJob.Status
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            Best: @(activeJob.BestStrategy ?? "-")
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            Confidence: @FormatConfidence(activeJob.BestScore)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            Split x: @(activeJob.SplitX?.ToString(CultureInfo.InvariantCulture) ?? "-")
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                            Results: @activeJob.ResultCount
                        </MudChip>
                    </MudStack>

                    <MudPaper Elevation="0" Class="pa-3 mb-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;">
                        <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Confirm Container Sides</b></MudText>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Value="@state.ContainerLeft"
                                           ValueChanged="@(v => state.ContainerLeft = v)"
                                           Label="Left Container" Variant="Variant.Outlined" Dense="true">
                                    @foreach (var c in containers)
                                    {
                                        <MudSelectItem Value="@c">@c</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="1" Class="d-flex align-center justify-center">
                                <MudIconButton Icon="@Icons.Material.Outlined.SwapHoriz"
                                               OnClick="@(() => SwapContainers(activeJob.Id))"
                                               Color="Color.Primary" Size="Size.Large" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Value="@state.ContainerRight"
                                           ValueChanged="@(v => state.ContainerRight = v)"
                                           Label="Right Container" Variant="Variant.Outlined" Dense="true">
                                    @foreach (var c in containers)
                                    {
                                        <MudSelectItem Value="@c">@c</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="string" Value="@state.RejectLabel"
                                           ValueChanged="@(v => state.RejectLabel = v)"
                                           Label="Reject / Label As" Variant="Variant.Outlined" Dense="true">
                                    <MudSelectItem Value="@SplitLabelRejected">Wrong split</MudSelectItem>
                                    <MudSelectItem Value="@SplitLabelSingleContainer">Single container</MudSelectItem>
                                    <MudSelectItem Value="@SplitLabelBadImage">Bad image / decode failure</MudSelectItem>
                                    <MudSelectItem Value="@SplitLabelUncertain">Uncertain</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    @if (state.LoadingImage)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Color="Color.Primary">Loading split images...</MudText>
                        </MudStack>
                    }
                    else
                    {
                        @if (HasConsensus(state))
                        {
                            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3" Icon="@Icons.Material.Outlined.Verified">
                                <strong>Consensus:</strong> @GetConsensusText(state)
                            </MudAlert>
                        }

                        @if (!candidates.Any())
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-3">
                                No split crop images are available for this job.
                            </MudAlert>
                        }
                        else
                        {
                            <MudStack Spacing="3">
                                @for (var i = 0; i < candidates.Count; i++)
                                {
                                    var candidate = candidates[i];
                                    var selected = state.SelectedResultId == candidate.Id;

                                    <MudPaper Elevation="0" Class="pa-3" Style="@GetCandidateStyle(selected)">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Style="gap: 8px; flex-wrap: wrap;">
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(selected ? Color.Success : Color.Primary)"
                                                     Variant="Variant.Filled">
                                                @GetCandidateLabel(i)
                                            </MudChip>
                                            <MudText Typo="Typo.subtitle1"><b>@candidate.StrategyName</b></MudText>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                x=@candidate.SplitX
                                            </MudChip>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                @FormatConfidence(candidate.Confidence)
                                            </MudChip>
                                            @if (candidate.ProcessingMs.HasValue)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    @candidate.ProcessingMs ms
                                                </MudChip>
                                            }
                                            <MudSpacer />
                                            @if (selected)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                                    Selected
                                                </MudChip>
                                            }
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Success"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Outlined.CheckCircle"
                                                       OnClick="@(() => ApproveJob(activeJob, candidate.Id))"
                                                       Disabled="@(state.ActionBusy || string.IsNullOrWhiteSpace(state.ContainerLeft) || string.IsNullOrWhiteSpace(state.ContainerRight))">
                                                Approve @GetCandidateLabel(i) &amp; Next
                                            </MudButton>
                                        </MudStack>

                                        <MudGrid Spacing="2">
                                            <MudItem xs="12" md="6">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                                    Left: @(state.ContainerLeft ?? containers.ElementAtOrDefault(0) ?? "-")
                                                </MudText>
                                                @if (!string.IsNullOrEmpty(candidate.LeftPreviewDataUrl))
                                                {
                                                    <img src="@candidate.LeftPreviewDataUrl"
                                                         alt="Left split crop"
                                                         style="width: 100%; min-height: 260px; max-height: 58vh; object-fit: contain; background: #111; border: 1px solid var(--mud-palette-lines-default);" />
                                                }
                                                else
                                                {
                                                    <MudPaper Elevation="0" Class="pa-8 d-flex justify-center align-center" Style="min-height: 260px; background: #111;">
                                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                                                    </MudPaper>
                                                }
                                            </MudItem>
                                            <MudItem xs="12" md="6">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                                    Right: @(state.ContainerRight ?? containers.ElementAtOrDefault(1) ?? "-")
                                                </MudText>
                                                @if (!string.IsNullOrEmpty(candidate.RightPreviewDataUrl))
                                                {
                                                    <img src="@candidate.RightPreviewDataUrl"
                                                         alt="Right split crop"
                                                         style="width: 100%; min-height: 260px; max-height: 58vh; object-fit: contain; background: #111; border: 1px solid var(--mud-palette-lines-default);" />
                                                }
                                                else
                                                {
                                                    <MudPaper Elevation="0" Class="pa-8 d-flex justify-center align-center" Style="min-height: 260px; background: #111;">
                                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                                                    </MudPaper>
                                                }
                                            </MudItem>
                                        </MudGrid>

                                        @if (!string.IsNullOrWhiteSpace(GetCandidateNote(candidate)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                                                @GetCandidateNote(candidate)
                                            </MudText>
                                        }
                                    </MudPaper>
                                }
                            </MudStack>
                        }

                        <MudExpansionPanels Class="mt-4" Elevation="0">
                            <MudExpansionPanel Text="Manual correction / original image" Icon="@Icons.Material.Outlined.Edit">
                                @if (!string.IsNullOrWhiteSpace(state.OriginalImageUrl))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Style="gap: 8px; flex-wrap: wrap;">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                            Auto x: @(activeJob.SplitX?.ToString(CultureInfo.InvariantCulture) ?? "-")
                                        </MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                            Manual x: @(state.ManualSplitX?.ToString(CultureInfo.InvariantCulture) ?? "-")
                                        </MudChip>
                                    </MudStack>

                                    <div style="overflow: auto; background: #111; border: 1px solid var(--mud-palette-lines-default);">
                                        <div style="position: relative; display: inline-block;">
                                            <img src="@state.OriginalImageUrl"
                                                 alt="Original combined scan"
                                                 style="@GetOriginalImageStyle(state)"
                                                 @onclick="@(args => OnOriginalImageClicked(activeJob.Id, args))" />
                                            @if (activeJob.SplitX.HasValue)
                                            {
                                                <div style="@GetSplitLineStyle(activeJob.SplitX.Value, "cyan")"></div>
                                            }
                                            @if (state.ManualSplitX.HasValue)
                                            {
                                                <div style="@GetSplitLineStyle(state.ManualSplitX.Value, "#ff8a00")"></div>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Warning">Could not load original image.</MudAlert>
                                }
                            </MudExpansionPanel>
                        </MudExpansionPanels>

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 10px; flex-wrap: wrap;">
                            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                       StartIcon="@Icons.Material.Outlined.Edit"
                                       OnClick="@(() => SubmitManualSplit(activeJob))"
                                       Disabled="@(state.ActionBusy || !state.ManualSplitX.HasValue)">
                                Create Manual Candidate
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Outlined.Cancel"
                                       OnClick="@(() => RejectJob(activeJob))"
                                       Disabled="@state.ActionBusy">
                                Reject / Label &amp; Next
                            </MudButton>
                            @if (state.ActionBusy)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                            }
                        </MudStack>
                    }
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private bool _queueRefreshing;
    private bool _serviceHealthy;
    private List<SplitJobDto> _jobs = new();
    private Guid? _activeJobId;
    private string _currentUser = "unknown";
    private Timer? _refreshTimer;
    private const string SplitLabelRejected = "rejected";
    private const string SplitLabelSingleContainer = "single_container";
    private const string SplitLabelBadImage = "bad_image";
    private const string SplitLabelUncertain = "uncertain";

    private readonly Dictionary<Guid, JobReviewState> _jobStates = new();

    private List<SplitJobDto> ReviewableJobs =>
        _jobs.Where(IsReviewable).ToList();

    private SplitJobDto? ActiveJob =>
        _activeJobId.HasValue
            ? _jobs.FirstOrDefault(j => j.Id == _activeJobId.Value)
            : null;

    private int ActiveIndex
    {
        get
        {
            if (!_activeJobId.HasValue) return 0;
            var reviewable = ReviewableJobs;
            var index = reviewable.FindIndex(j => j.Id == _activeJobId.Value);
            return index >= 0 ? index + 1 : 0;
        }
    }

    private bool CanSelectPrevious => ActiveIndex > 1;

    private bool CanSelectNext =>
        ActiveIndex > 0 && ActiveIndex < ReviewableJobs.Count;

    private sealed class JobReviewState
    {
        public bool DetailsLoaded { get; set; }
        public bool LoadingImage { get; set; }
        public bool ActionBusy { get; set; }
        public string? OriginalImageUrl { get; set; }
        public List<SplitResultDto> Results { get; set; } = new();
        public Guid? SelectedResultId { get; set; }
        public int? ManualSplitX { get; set; }
        public int ImageWidth { get; set; }
        public string? ContainerLeft { get; set; }
        public string? ContainerRight { get; set; }
        public string RejectLabel { get; set; } = SplitLabelRejected;
    }

    private JobReviewState GetJobState(Guid jobId)
    {
        if (!_jobStates.TryGetValue(jobId, out var state))
        {
            state = new JobReviewState();
            _jobStates[jobId] = state;
        }

        return state;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User?.Identity?.Name ?? "unknown";
        await LoadJobs(preserveActive: false, showLoading: true);

        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (!_jobStates.Values.Any(s => s.ActionBusy || s.LoadingImage))
                {
                    await LoadJobs(preserveActive: true, showLoading: false);
                    StateHasChanged();
                }
            });
        }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }

    private Task RefreshQueue() => LoadJobs(preserveActive: true, showLoading: true);

    private async Task LoadJobs(bool preserveActive, bool showLoading)
    {
        if (showLoading)
            _loading = true;
        else
            _queueRefreshing = true;

        try
        {
            try
            {
                var health = await ApiService.GetAsync<SplitterHealthDto>("/api/image-splitter/health");
                _serviceHealthy = health?.Status == "healthy";
            }
            catch
            {
                _serviceHealthy = false;
            }

            if (_serviceHealthy)
            {
                _jobs = await ApiService.GetAsync<List<SplitJobDto>>(
                    "/api/image-splitter/jobs/pending?mode=recent&since_hours=72&limit=50") ?? new();
            }

            var activeStillPresent = preserveActive
                && _activeJobId.HasValue
                && _jobs.Any(j => j.Id == _activeJobId.Value && IsReviewable(j));

            if (!activeStillPresent)
            {
                _activeJobId = null;
                var next = ReviewableJobs.FirstOrDefault();
                if (next != null)
                {
                    await SelectJobAsync(next);
                }
            }
            else if (_activeJobId.HasValue)
            {
                var active = _jobs.First(j => j.Id == _activeJobId.Value);
                var state = GetJobState(active.Id);
                if (!state.DetailsLoaded && !state.LoadingImage)
                {
                    await LoadJobDetailsAsync(active, state);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading split jobs");
            Snackbar.Add("Error loading split jobs", Severity.Error);
        }
        finally
        {
            _loading = false;
            _queueRefreshing = false;
        }
    }

    private async Task SelectJobAsync(SplitJobDto job)
    {
        _activeJobId = job.Id;
        var state = GetJobState(job.Id);
        InitializeDefaultAssignment(job, state);

        if (!state.DetailsLoaded)
        {
            await LoadJobDetailsAsync(job, state);
        }

        StateHasChanged();
    }

    private async Task SelectRelativeJob(int offset)
    {
        var reviewable = ReviewableJobs;
        if (!reviewable.Any())
            return;

        var index = _activeJobId.HasValue
            ? reviewable.FindIndex(j => j.Id == _activeJobId.Value)
            : -1;

        var nextIndex = Math.Clamp(index + offset, 0, reviewable.Count - 1);
        await SelectJobAsync(reviewable[nextIndex]);
    }

    private async Task LoadJobDetailsAsync(SplitJobDto job, JobReviewState state)
    {
        state.LoadingImage = true;
        StateHasChanged();

        try
        {
            state.Results = (await ApiService.GetAsync<List<SplitResultDto>>($"/api/image-splitter/jobs/{job.Id}/results") ?? new())
                .OrderByDescending(r => string.Equals(r.StrategyName, job.BestStrategy, StringComparison.OrdinalIgnoreCase))
                .ThenByDescending(r => r.Confidence ?? 0)
                .ToList();

            state.OriginalImageUrl = UrlBuilder.Build(
                $"/api/image-splitter/jobs/{job.Id}/original",
                _currentUser);

            state.ImageWidth = job.ImageWidth > 0 ? job.ImageWidth : 1621;

            foreach (var r in state.Results.Where(r => r.HasLeftImage && r.HasRightImage))
            {
                r.LeftPreviewDataUrl = GetResultImageUrl(job.Id, r.Id, "left");
                r.RightPreviewDataUrl = GetResultImageUrl(job.Id, r.Id, "right");
            }

            var preferred = state.Results.FirstOrDefault(r =>
                                r.HasLeftImage
                                && r.HasRightImage
                                && string.Equals(r.StrategyName, job.BestStrategy, StringComparison.OrdinalIgnoreCase))
                            ?? state.Results.FirstOrDefault(r => r.HasLeftImage && r.HasRightImage)
                            ?? state.Results.FirstOrDefault();

            state.SelectedResultId = preferred?.Id;
            state.DetailsLoaded = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading job details for {JobId}", job.Id);
            Snackbar.Add("Error loading job details", Severity.Error);
        }
        finally
        {
            state.LoadingImage = false;
            StateHasChanged();
        }
    }

    private static void InitializeDefaultAssignment(SplitJobDto job, JobReviewState state)
    {
        if (state.ContainerLeft is not null || state.ContainerRight is not null)
            return;

        var containers = GetContainers(job);
        state.ContainerLeft = containers.ElementAtOrDefault(0);
        state.ContainerRight = containers.ElementAtOrDefault(1);
    }

    private static List<string> GetContainers(SplitJobDto job) =>
        (job.ContainerNumbers ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .ToList();

    private List<SplitResultDto> GetVisibleCandidates(SplitJobDto job, JobReviewState state)
    {
        var candidates = state.Results
            .Where(r => r.HasLeftImage && r.HasRightImage)
            .OrderByDescending(r => string.Equals(r.StrategyName, job.BestStrategy, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(r => r.Confidence ?? 0)
            .Take(2)
            .ToList();

        if (state.SelectedResultId.HasValue && candidates.All(c => c.Id != state.SelectedResultId.Value))
        {
            var selected = state.Results.FirstOrDefault(r => r.Id == state.SelectedResultId.Value);
            if (selected != null && selected.HasLeftImage && selected.HasRightImage)
            {
                if (candidates.Count == 2)
                    candidates[^1] = selected;
                else
                    candidates.Add(selected);
            }
        }

        return candidates;
    }

    private void OnOriginalImageClicked(Guid jobId, MouseEventArgs e)
    {
        var state = GetJobState(jobId);
        if (state.ImageWidth <= 2)
            return;

        state.ManualSplitX = Math.Clamp((int)Math.Round(e.OffsetX), 1, state.ImageWidth - 1);
        StateHasChanged();
    }

    private void SwapContainers(Guid jobId)
    {
        var state = GetJobState(jobId);
        (state.ContainerLeft, state.ContainerRight) = (state.ContainerRight, state.ContainerLeft);
        StateHasChanged();
    }

    private async Task ApproveJob(SplitJobDto job, Guid? resultId = null)
    {
        var state = GetJobState(job.Id);
        if (string.IsNullOrWhiteSpace(state.ContainerLeft) || string.IsNullOrWhiteSpace(state.ContainerRight))
            return;

        var selectedResultId = resultId ?? state.SelectedResultId;
        var selected = selectedResultId.HasValue
            ? state.Results.FirstOrDefault(r => r.Id == selectedResultId.Value)
            : null;

        if (selected == null)
        {
            Snackbar.Add("Select a split candidate first", Severity.Warning);
            return;
        }

        state.SelectedResultId = selected.Id;

        state.ActionBusy = true;
        try
        {
            await ApiService.PostAsync<object, object>($"/api/image-splitter/jobs/{job.Id}/approve", new
            {
                result_id = selected.Id,
                container_left = state.ContainerLeft,
                container_right = state.ContainerRight,
                approved_by = _currentUser
            });

            Snackbar.Add($"Split approved for {job.ContainerNumbers}. Loading next...", Severity.Success);
            await AdvanceToNextJobAsync(job.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error approving split for {JobId}", job.Id);
            Snackbar.Add("Error approving split", Severity.Error);
        }
        finally
        {
            state.ActionBusy = false;
        }
    }

    private async Task SubmitManualSplit(SplitJobDto job)
    {
        var state = GetJobState(job.Id);
        if (!state.ManualSplitX.HasValue)
            return;

        state.ActionBusy = true;
        try
        {
            await ApiService.PostAsync<object, object>($"/api/image-splitter/jobs/{job.Id}/manual", new
            {
                split_x = state.ManualSplitX.Value,
                submitted_by = _currentUser
            });

            job.BestStrategy = "manual";
            job.BestScore = 1.0;
            job.SplitX = state.ManualSplitX.Value;
            state.DetailsLoaded = false;
            state.Results.Clear();

            await LoadJobDetailsAsync(job, state);
            var manual = state.Results.FirstOrDefault(r => string.Equals(r.StrategyName, "manual", StringComparison.OrdinalIgnoreCase));
            if (manual != null)
                state.SelectedResultId = manual.Id;

            Snackbar.Add($"Manual candidate created at x={state.ManualSplitX}", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting manual split for {JobId}", job.Id);
            Snackbar.Add("Error submitting manual split", Severity.Error);
        }
        finally
        {
            state.ActionBusy = false;
        }
    }

    private async Task RejectJob(SplitJobDto job)
    {
        var state = GetJobState(job.Id);
        state.ActionBusy = true;
        try
        {
            await ApiService.PostAsync<object, object>($"/api/image-splitter/jobs/{job.Id}/reject", new
            {
                correct_split_x = state.RejectLabel == SplitLabelRejected ? state.ManualSplitX : null,
                rejected_by = _currentUser,
                reason = $"Rejected from review page: {GetReviewLabelText(state.RejectLabel)}",
                review_label = state.RejectLabel,
                split_outcome = state.RejectLabel
            });

            Snackbar.Add($"{GetReviewLabelText(state.RejectLabel)} recorded for {job.ContainerNumbers}. Loading next...", Severity.Info);
            await AdvanceToNextJobAsync(job.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error rejecting split for {JobId}", job.Id);
            Snackbar.Add("Error rejecting split", Severity.Error);
        }
        finally
        {
            state.ActionBusy = false;
        }
    }

    private async Task AdvanceToNextJobAsync(Guid completedJobId)
    {
        var next = GetNextReviewableAfter(completedJobId);
        _jobStates.Remove(completedJobId);
        _jobs.RemoveAll(j => j.Id == completedJobId);

        if (next != null && next.Id != completedJobId)
        {
            await SelectJobAsync(next);
            await LoadJobs(preserveActive: true, showLoading: false);
            return;
        }

        _activeJobId = null;
        await LoadJobs(preserveActive: false, showLoading: false);
    }

    private SplitJobDto? GetNextReviewableAfter(Guid currentJobId)
    {
        var reviewable = ReviewableJobs;
        var currentIndex = reviewable.FindIndex(j => j.Id == currentJobId);

        if (currentIndex >= 0)
        {
            for (var i = currentIndex + 1; i < reviewable.Count; i++)
            {
                if (reviewable[i].Id != currentJobId)
                    return reviewable[i];
            }

            for (var i = 0; i < currentIndex; i++)
            {
                if (reviewable[i].Id != currentJobId)
                    return reviewable[i];
            }
        }

        return reviewable.FirstOrDefault(j => j.Id != currentJobId);
    }

    private static bool IsReviewable(SplitJobDto job) =>
        IsStatus(job, "completed") && string.IsNullOrWhiteSpace(job.AnalystVerdict);

    private static bool IsStatus(SplitJobDto job, string status) =>
        string.Equals(job.Status, status, StringComparison.OrdinalIgnoreCase);

    private static string GetReviewLabelText(string? label) => label switch
    {
        SplitLabelSingleContainer => "Single container",
        SplitLabelBadImage => "Bad image / decode failure",
        SplitLabelUncertain => "Uncertain",
        _ => "Rejected split"
    };

    private string GetResultImageUrl(Guid jobId, Guid resultId, string side) =>
        UrlBuilder.Build(
            $"/api/image-splitter/jobs/{jobId}/results/{resultId}/image/{side}",
            _currentUser);

    private static string GetCandidateLabel(int index) =>
        index == 0 ? "Candidate A" : "Candidate B";

    private static string FormatConfidence(double? value) =>
        value.HasValue ? value.Value.ToString("P0", CultureInfo.InvariantCulture) : "-";

    private static string GetCandidateNote(SplitResultDto result)
    {
        if (!string.IsNullOrWhiteSpace(result.VerifierReasoning))
            return result.VerifierReasoning!;

        if (!string.IsNullOrWhiteSpace(result.Reasoning))
            return result.Reasoning!;

        if (string.Equals(result.StrategyName, "inner_casting_pair", StringComparison.OrdinalIgnoreCase))
            return $"peaks: {result.C1RightPeakX?.ToString(CultureInfo.InvariantCulture) ?? "-"}, {result.C2LeftPeakX?.ToString(CultureInfo.InvariantCulture) ?? "-"} | gap: {result.GapWidthPx?.ToString(CultureInfo.InvariantCulture) ?? "-"} px";

        return string.Empty;
    }

    private bool HasConsensus(JobReviewState state)
    {
        var icp = state.Results.FirstOrDefault(r => r.StrategyName == "inner_casting_pair");
        var sw = state.Results.FirstOrDefault(r => r.StrategyName == "steel_wall_midpoint");
        return icp != null && sw != null && Math.Abs(icp.SplitX - sw.SplitX) <= 10;
    }

    private string GetConsensusText(JobReviewState state)
    {
        var icp = state.Results.FirstOrDefault(r => r.StrategyName == "inner_casting_pair");
        var sw = state.Results.FirstOrDefault(r => r.StrategyName == "steel_wall_midpoint");
        if (icp == null || sw == null) return "";
        return $"inner_casting_pair ({icp.SplitX}) and steel_wall_midpoint ({sw.SplitX}) agree within 10 px";
    }

    private static Color GetStatusColor(string status) => status.ToLowerInvariant() switch
    {
        "completed" => Color.Success,
        "pending" => Color.Warning,
        "processing" => Color.Info,
        "failed" => Color.Error,
        _ => Color.Default
    };

    private static string GetQueueButtonStyle(bool isActive) =>
        isActive
            ? "text-transform: none; justify-content: flex-start; padding: 10px; border: 2px solid var(--mud-palette-primary); border-radius: 6px;"
            : "text-transform: none; justify-content: flex-start; padding: 10px; border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;";

    private static string GetCandidateStyle(bool selected) =>
        selected
            ? "border: 2px solid var(--mud-palette-success); border-radius: 6px; background: rgba(76, 175, 80, 0.06);"
            : "border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;";

    private static string GetOriginalImageStyle(JobReviewState state)
    {
        var width = state.ImageWidth > 0 ? state.ImageWidth : 1600;
        return $"width: {width}px; max-width: none; height: auto; display: block; cursor: crosshair;";
    }

    private static string GetSplitLineStyle(int splitX, string color) =>
        $"position: absolute; top: 0; bottom: 0; left: {splitX.ToString(CultureInfo.InvariantCulture)}px; width: 2px; background: {color}; pointer-events: none; z-index: 2;";

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

