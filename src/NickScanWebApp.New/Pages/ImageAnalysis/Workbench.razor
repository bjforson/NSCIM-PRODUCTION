    private async Task ViewDetails(MyAssignmentDto assignment)
    {
        Console.WriteLine($"🔵 [ImageAnalysis.ViewDetails] Opening dialog for {assignment.GroupIdentifier}");

        // 6.01 (Sprint 4): this is the canonical handoff point of the
        // (GroupIdentifier, IsConsolidated) tuple from the queue table to the
        // dialog. The dialog now delegates image-analysis ICUMS route selection
        // to IContainerDetailsService, but the upstream assignment tag still has
        // to be correct. If IsConsolidated is wrong here (e.g. mistag at ingest),
        // fix the queue-entry tag rather than adding another dialog branch.
        IDialogReference? dialogRef = null;
        var parameters = new DialogParameters
        {
            ["GroupIdentifier"] = assignment.GroupIdentifier,
            ["IsConsolidated"] = assignment.IsConsolidated,
            ["Containers"] = assignment.Containers,
            ["RecordCompletenessStatusId"] = assignment.RecordCompletenessStatusId,
            ["ClearanceType"] = assignment.ClearanceType,
            ["OnDecisionSaved"] = EventCallback.Factory.Create(this, async () =>
            {
                // 2026-05-09 (Phase B / B7 UX): close dialog instantly, refresh in
                // background. Removed the Task.Delay(500) — that was added pre-Sprint-5G2
                // when state-machine writes were eventually-consistent; now they're
                // synchronous within SaveChangesAsync, so the delay just hurt UX.
                Console.WriteLine("🔄 [ImageAnalysis] OnDecisionSaved called - refreshing assignments list");
                if (dialogRef != null)
                {
                    dialogRef.Close(DialogResult.Ok(true));
                }

                // 🔁 [ANALYST KEEPALIVE 2026-05-09] Explicit heartbeat on save so the
                // orchestrator's 60-min idle window resets to "now". Otherwise the worst
                // case is: analyst saves, doesn't navigate, the 30s timer happens to be
                // 28s away, the idle window slowly creeps. Failure-isolated.
                QueueHeartbeatAfterSubmit("decision save");

                _ = InvokeAsync(RefreshAssignmentsOnly); // background reconcile, fire-and-forget
            }),
            ["OnAllContainersDecided"] = EventCallback.Factory.Create(this, async () =>
            {
                Console.WriteLine("✅ [ImageAnalysis] OnAllContainersDecided called - all containers in group completed");
                // 2026-05-09 (Phase B / B7 UX): optimistic remove + close-first + parallel refresh.
                // Previously did `await Task.Delay(1000); await LoadData();` — analyst stared at the
                // dialog for ~1.7s. Now the AG vanishes from the list in the same frame the dialog
                // closes; RefreshAssignmentsOnly reconciles in the background. AG.GroupIdentifier is the dedup key.
                if (dialogRef != null)
                {
                    dialogRef.Close(DialogResult.Ok(true));
                }

                _myAssignments = _myAssignments
                    .Where(a => a.GroupIdentifier != assignment.GroupIdentifier)
                    .ToList();
                StateHasChanged();

                // 🔁 [ANALYST KEEPALIVE 2026-05-09] Explicit heartbeat on group completion so
                // the orchestrator's 60-min idle window resets to "now". Mirrors the per-container
                // OnDecisionSaved heartbeat above — fires once more on the AG-level finish.
                // Failure-isolated.
                QueueHeartbeatAfterSubmit("group completion");

                _ = InvokeAsync(RefreshAssignmentsOnly); // background reconcile, fire-and-forget
            })
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.ExtraLarge, 
            FullWidth = true,
            CloseButton = true
        };

        dialogRef = await DialogService.ShowAsync<Components.Operations.ImageAnalysisViewDialog>(
            $"{(assignment.IsConsolidated ? "Container" : "BOE")}: {assignment.GroupIdentifier}", 
            parameters, 
            options);
        
        await dialogRef.Result;
    }

    // ✅ NEW: Helper methods for status display
    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Ready" => Color.Info,
            "AnalystAssigned" => Color.Warning,
            "AnalystCompleted" => Color.Success,
            "AuditAssigned" => Color.Secondary,
            "AuditCompleted" => Color.Tertiary,
            "PartiallyCompleted" => Color.Warning,
            "Submitted" => Color.Dark,
            "Completed" => Color.Success,
            _ => Color.Default
        };
    }

    private string GetStatusIcon(string status)
    {
        return status switch
        {
            "Ready" => Icons.Material.Outlined.Assignment,
            "AnalystAssigned" => Icons.Material.Outlined.Person,
            "AnalystCompleted" => Icons.Material.Outlined.CheckCircle,
            "AuditAssigned" => Icons.Material.Outlined.VerifiedUser,
            "AuditCompleted" => Icons.Material.Outlined.Verified,
            "PartiallyCompleted" => Icons.Material.Outlined.HourglassEmpty,
            "Submitted" => Icons.Material.Outlined.Send,
            "Completed" => Icons.Material.Outlined.Done,
            _ => Icons.Material.Outlined.Help
        };
    }

    private Color GetProgressColor(double percent)
    {
        if (percent >= 100) return Color.Success;
        if (percent >= 75) return Color.Info;
        if (percent >= 50) return Color.Warning;
        return Color.Error;
    }

