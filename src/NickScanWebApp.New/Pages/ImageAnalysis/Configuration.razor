    private void OnAssignmentModeChanged(string? newValue)
    {
        var oldValue = _assignmentMode;
        var updatedValue = newValue ?? "Manual";
        
        Console.WriteLine($"🔄 Assignment mode dropdown changed: '{oldValue}' → '{updatedValue}'");
        Console.WriteLine($"   oldValue == updatedValue: {oldValue == updatedValue}");
        Console.WriteLine($"   oldValue.Equals(updatedValue): {oldValue?.Equals(updatedValue) ?? false}");
        
        // ✅ CRITICAL: Update the value immediately
        _assignmentMode = updatedValue;
        
        Console.WriteLine($"✅ Assignment mode updated in UI: _assignmentMode = '{_assignmentMode}'");
        Console.WriteLine($"   _assignmentMode == 'UserClaim': {_assignmentMode == "UserClaim"}");
        Console.WriteLine($"   _assignmentMode == 'Manual': {_assignmentMode == "Manual"}");
        Console.WriteLine($"   _assignmentMode == 'Auto': {_assignmentMode == "Auto"}");
        
        // ✅ CRITICAL: Force UI update and verify the value is actually set
        StateHasChanged();
        
        // ✅ VERIFY: Check again after StateHasChanged
        Task.Delay(100).ContinueWith(_ => {
            Console.WriteLine($"🔍 Verification after StateHasChanged: _assignmentMode = '{_assignmentMode}'");
            if (_assignmentMode != updatedValue)
            {
                Console.WriteLine($"⚠️ WARNING: Value changed after StateHasChanged! Expected '{updatedValue}', got '{_assignmentMode}'");
            }
        });
    }

