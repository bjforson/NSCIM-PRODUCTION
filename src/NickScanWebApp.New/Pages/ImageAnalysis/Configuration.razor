@page "/validation/image-analysis-management"
@page "/image-analysis/config"
@attribute [Authorize(Policy = Permissions.PagesImageAnalysisManagement)]
@implements IDisposable
@using MudBlazor
@inject ISnackbar Snackbar
@inject NickScanWebApp.New.Services.DualNotificationService DualNotification
@inject NavigationManager Nav
@inject NickScanWebApp.Shared.Services.ApiService ApiService

<MudPaper Class="pa-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h5">Image Analysis Management</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudChip T="string" Size="Size.Small" Color="@(_serviceEnabled ? Color.Success : Color.Error)">
                @(_serviceEnabled ? "Service Active" : "Service Disabled")
            </MudChip>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Queue: @_readyGroups.Count | Assigned: @_activeAssignments.Count | Completed: @_stats.Completed
            </MudText>
        </MudStack>
    </MudStack>

    <MudExpansionPanels MultiExpansion="true" Elevation="2">
        <!-- PANEL 1: SETTINGS -->
        <MudExpansionPanel IsInitiallyExpanded="true">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Settings" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Settings</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_serviceEnabled ? Color.Success : Color.Error)">
                        @(_serviceEnabled ? "Active" : "Disabled")
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="4" Class="pa-2">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-3">Service Control</MudText>
                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                            <MudSwitch T="bool" @bind-Value="_serviceEnabled" Color="Color.Primary" Disabled="_busy">Enable Service</MudSwitch>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SyncStages" Disabled="_busy">Sync Stages</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RebuildIntake" Disabled="_busy">Rebuild Intake</MudButton>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-3">Assignment Settings</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField @bind-Value="_leaseMinutes" Label="Lease TTL (minutes)" InputType="InputType.Number" Disabled="_busy" />
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField @bind-Value="_maxConcurrent" Label="Max concurrent per user" InputType="InputType.Number" Disabled="_busy" />
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSelect T="string" @bind-Value="_assignmentMode" Label="Assignment Mode" Disabled="_busy">
                                    <MudSelectItem Value="@("Auto")">Auto</MudSelectItem>
                                    <MudSelectItem Value="@("Manual")">Manual</MudSelectItem>
                                    <MudSelectItem Value="@("UserClaim")">UserClaim</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            @if (_assignmentMode == "Auto")
                            {
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="string" @bind-Value="_autoAssignStrategy" Label="Strategy" Disabled="_busy">
                                        <MudSelectItem Value="@("RoundRobin")">RoundRobin</MudSelectItem>
                                        <MudSelectItem Value="@("LeastLoaded")">LeastLoaded</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                            }
                        </MudGrid>

                        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Wave Processing (Partial BOL)</MudText>
                        <MudSwitch T="bool" @bind-Value="_enableWaveProcessing" Label="Enable Wave Processing" Color="Color.Primary" />
                        @if (_enableWaveProcessing)
                        {
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="4"><MudNumericField T="int" @bind-Value="_waveMinBatchSize" Label="Min Batch Size" Min="1" Max="50" /></MudItem>
                                <MudItem xs="4"><MudNumericField T="int" @bind-Value="_waveTimeoutHours" Label="Timeout (hours)" Min="1" Max="168" /></MudItem>
                                <MudItem xs="4"><MudNumericField T="int" @bind-Value="_waveAutoCloseDays" Label="Auto-close (days)" Min="1" Max="90" /></MudItem>
                            </MudGrid>
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@OnSaveClicked" Disabled="_busy" Class="mt-4">Save Settings</MudButton>
                    </MudPaper>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- PANEL 2: QUEUES & ASSIGNMENTS -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Queue" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Queues &amp; Assignments</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_readyGroups.Count ready</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@_activeAssignments.Count assigned</MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.h6" Class="mb-3">Ready Queue</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3" Elevation="1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Image Analysis</MudText>
                            <MudText Typo="Typo.h4">@_stats.ImageAnalysis</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3" Elevation="1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Audit</MudText>
                            <MudText Typo="Typo.h4">@_stats.Audit</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3" Elevation="1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Completed</MudText>
                            <MudText Typo="Typo.h4">@_stats.Completed</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudTabs @bind-ActivePanelIndex="_readyQueueTabIndex" Class="mt-4">
                    <MudTabPanel Text="@($"Consolidated ({_readyGroupsConsolidated.Count})")">
                        <MudTextField T="string" @bind-Value="_readyConsolidatedFilter"
                                      Placeholder="Filter by group or scanner…"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true"
                                      Class="mb-2" />
                        <MudTable Items="@FilterReadyGroups(_readyGroupsConsolidated, _readyConsolidatedFilter)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.ScannerType ?? string.Empty)">Scanner</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.ContainerCount)">Count</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Group">@context.GroupIdentifier</MudTd>
                                <MudTd DataLabel="Scanner">@context.ScannerType</MudTd>
                                <MudTd DataLabel="Count">@context.ContainerCount</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Primary" OnClick="() => GetNextForSelf(context.GroupIdentifier)" Disabled="_busy">Get Next</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenManualAssign(context.GroupIdentifier)" Disabled="_busy">Assign…</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Non-Consolidated ({_readyGroupsNonConsolidated.Count})")">
                        <MudTextField T="string" @bind-Value="_readyNonConsolidatedFilter"
                                      Placeholder="Filter by group or scanner…"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Small"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Clearable="true"
                                      Class="mb-2" />
                        <MudTable Items="@FilterReadyGroups(_readyGroupsNonConsolidated, _readyNonConsolidatedFilter)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.ScannerType ?? string.Empty)">Scanner</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ReadyGroup, object>(x => x.ContainerCount)">Count</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Group">@context.GroupIdentifier</MudTd>
                                <MudTd DataLabel="Scanner">@context.ScannerType</MudTd>
                                <MudTd DataLabel="Count">@context.ContainerCount</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Primary" OnClick="() => GetNextForSelf(context.GroupIdentifier)" Disabled="_busy">Get Next</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenManualAssign(context.GroupIdentifier)" Disabled="_busy">Assign…</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                </MudTabs>

                <MudText Typo="Typo.h6" Class="mt-4 mb-3">Active Assignments</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudTextField T="string" @bind-Value="_assignmentsFilter"
                                  Placeholder="Filter by group or assignee…"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Clearable="true"
                                  Style="max-width: 320px;" />
                    <MudSwitch T="bool" @bind-Value="_showOnlyExpiringSoon" Color="Color.Warning" Label="Expiring &lt; 15 min" />
                </MudStack>
                <MudTabs @bind-ActivePanelIndex="_assignmentsTabIndex">
                    <MudTabPanel Text="@($"Analyst - Consolidated ({_activeAssignmentsConsolidated.Count})")">
                        <MudTable Items="@FilterAssignments(_activeAssignmentsConsolidated)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.AssignedTo ?? string.Empty)">Analyst</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.LeaseUntilUtc ?? DateTime.MaxValue)">LeaseUntil</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.GroupIdentifier</MudTd>
                                <MudTd>@context.AssignedTo</MudTd>
                                <MudTd>@context.LeaseUntilUtc?.ToLocalTime().ToString("g")</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Default" OnClick="() => Release(context.GroupIdentifier)" Disabled="_busy">Release</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenReassign(context.GroupIdentifier)" Disabled="_busy">Reassign…</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Primary" OnClick="() => OpenGroup(context.GroupIdentifier)" Disabled="_busy">Open</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Analyst - Non-Consolidated ({_activeAssignmentsNonConsolidated.Count})")">
                        <MudTable Items="@FilterAssignments(_activeAssignmentsNonConsolidated)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.AssignedTo ?? string.Empty)">Analyst</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.LeaseUntilUtc ?? DateTime.MaxValue)">LeaseUntil</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.GroupIdentifier</MudTd>
                                <MudTd>@context.AssignedTo</MudTd>
                                <MudTd>@context.LeaseUntilUtc?.ToLocalTime().ToString("g")</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Default" OnClick="() => Release(context.GroupIdentifier)" Disabled="_busy">Release</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenReassign(context.GroupIdentifier)" Disabled="_busy">Reassign…</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Primary" OnClick="() => OpenGroup(context.GroupIdentifier)" Disabled="_busy">Open</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Audit - Consolidated ({_auditAssignmentsConsolidated.Count})")">
                        <MudTable Items="@FilterAssignments(_auditAssignmentsConsolidated)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.AssignedTo ?? string.Empty)">Auditor</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.LeaseUntilUtc ?? DateTime.MaxValue)">LeaseUntil</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.GroupIdentifier</MudTd>
                                <MudTd>@context.AssignedTo</MudTd>
                                <MudTd>@context.LeaseUntilUtc?.ToLocalTime().ToString("g")</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Default" OnClick="() => Release(context.GroupIdentifier)" Disabled="_busy">Release</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenReassign(context.GroupIdentifier)" Disabled="_busy">Reassign…</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Primary" OnClick="() => OpenGroup(context.GroupIdentifier)" Disabled="_busy">Open</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Audit - Non-Consolidated ({_auditAssignmentsNonConsolidated.Count})")">
                        <MudTable Items="@FilterAssignments(_auditAssignmentsNonConsolidated)"
                                  Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm"
                                  RowsPerPage="25">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.GroupIdentifier ?? string.Empty)">Group</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.AssignedTo ?? string.Empty)">Auditor</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<ActiveAssignment, object>(x => x.LeaseUntilUtc ?? DateTime.MaxValue)">LeaseUntil</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.GroupIdentifier</MudTd>
                                <MudTd>@context.AssignedTo</MudTd>
                                <MudTd>@context.LeaseUntilUtc?.ToLocalTime().ToString("g")</MudTd>
                                <MudTd>
                                    <MudButton Size="Size.Small" Color="Color.Default" OnClick="() => Release(context.GroupIdentifier)" Disabled="_busy">Release</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Secondary" OnClick="() => OpenReassign(context.GroupIdentifier)" Disabled="_busy">Reassign…</MudButton>
                                    <MudButton Size="Size.Small" Class="ml-2" Color="Color.Primary" OnClick="() => OpenGroup(context.GroupIdentifier)" Disabled="_busy">Open</MudButton>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                        </MudTable>
                    </MudTabPanel>
                </MudTabs>
            </ChildContent>
        </MudExpansionPanel>

        <!-- PANEL 3: ASSIGNMENT METRICS -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Assessment" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Assignment Metrics</MudText>
                    @if (_assignmentMetrics != null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@_assignmentMetrics.TotalAssignments total</MudChip>
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                @if (_assignmentMetrics != null)
                {
                    <MudGrid Class="mb-4">
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Assignments</MudText>
                                <MudText Typo="Typo.h5">@_assignmentMetrics.TotalAssignments</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3" Elevation="2" Style="@GetMetricsCardStyle(_assignmentMetrics.ActiveAssignments > 0, true)">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Active</MudText>
                                <MudText Typo="Typo.h5">@_assignmentMetrics.ActiveAssignments</MudText>
                                @if (_assignmentMetrics.ExpiredButActive > 0)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small" /> @_assignmentMetrics.ExpiredButActive expired but active
                                    </MudText>
                                }
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Expired</MudText>
                                <MudText Typo="Typo.h5">@_assignmentMetrics.ExpiredAssignments</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Released</MudText>
                                <MudText Typo="Typo.h5">@_assignmentMetrics.ReleasedAssignments</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.subtitle1" Class="mb-3">By Role</MudText>
                                <MudProgressLinear Color="Color.Primary" Value="@GetRolePercentage(_assignmentMetrics.ByRole, "Analyst")" Class="mb-2" />
                                <MudText>Analyst: @(_assignmentMetrics.ByRole?.GetValueOrDefault("Analyst") ?? 0)</MudText>
                                <MudProgressLinear Color="Color.Secondary" Value="@GetRolePercentage(_assignmentMetrics.ByRole, "Audit")" Class="mb-2" />
                                <MudText>Audit: @(_assignmentMetrics.ByRole?.GetValueOrDefault("Audit") ?? 0)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.subtitle1" Class="mb-3">Status Indicators</MudText>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText>Expiring Soon (&lt;5min)</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@(_assignmentMetrics.ExpiringSoon > 0 ? Color.Warning : Color.Success)">@_assignmentMetrics.ExpiringSoon</MudChip>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText>Recently Accessed (30min)</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@_assignmentMetrics.RecentlyAccessed</MudChip>
                                </MudStack>
                                @if (_assignmentMetrics.ExpiredButActive > 0)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">@_assignmentMetrics.ExpiredButActive assignment(s) expired but still marked Active</MudAlert>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.subtitle1" Class="mb-3">Last 24 Hours</MudText>
                                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Created</MudText><MudText Typo="Typo.h6" Color="Color.Success">@_assignmentMetrics.CreatedLast24Hours</MudText></MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Expired</MudText><MudText Typo="Typo.h6" Color="Color.Default">@_assignmentMetrics.ExpiredLast24Hours</MudText></MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-3" Elevation="2">
                                <MudText Typo="Typo.subtitle1" Class="mb-3">Group Status</MudText>
                                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Ready</MudText><MudText Typo="Typo.h6">@_assignmentMetrics.GroupsReady</MudText></MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Analyst Assigned</MudText><MudText Typo="Typo.h6" Color="Color.Primary">@_assignmentMetrics.GroupsAnalystAssigned</MudText></MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Audit Assigned</MudText><MudText Typo="Typo.h6" Color="Color.Secondary">@_assignmentMetrics.GroupsAuditAssigned</MudText></MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @if (_assignmentMetrics.ByUser != null && _assignmentMetrics.ByUser.Any())
                    {
                        <MudPaper Class="pa-3 mb-4" Elevation="2">
                            <MudText Typo="Typo.subtitle1" Class="mb-3">Top Users (by Active Assignments)</MudText>
                            <MudTable Items="_assignmentMetrics.ByUser" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                                <HeaderContent><MudTh>User</MudTh><MudTh>Active Assignments</MudTh></HeaderContent>
                                <RowTemplate><MudTd>@context.Key</MudTd><MudTd>@context.Value</MudTd></RowTemplate>
                            </MudTable>
                        </MudPaper>
                    }

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Last updated: @_assignmentMetrics.Timestamp.ToLocalTime().ToString("g")
                            @if (_metricsLastUpdated.HasValue)
                            {
                                var secondsAgo = GetSecondsSinceLastUpdate();
                                <text> (@secondsAgo second@(secondsAgo != 1 ? "s" : "") ago)</text>
                            }
                        </MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                                <MudIcon Icon="@Icons.Material.Outlined.Circle" Size="Size.Small" Class="mr-1" Style="font-size: 8px;" />
                                Auto-refreshing every 60s
                            </MudChip>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick="LoadMetrics" Disabled="_busy || _loadingMetrics">
                                <MudIcon Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small" Class="mr-1" />
                                Refresh
                            </MudButton>
                        </MudStack>
                    </MudStack>
                }
                else if (_loadingMetrics)
                {
                    <MudProgressCircular Indeterminate="true" Class="my-4" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Loading metrics...</MudText>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Metrics will load automatically.</MudAlert>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadMetrics" Disabled="_busy || _loadingMetrics" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Refresh" Class="mr-2" />
                        Load Metrics
                    </MudButton>
                }
            </ChildContent>
        </MudExpansionPanel>

        <!-- PANEL: AUTONOMOUS DECISION AGENT -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.SmartToy" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Autonomous Decision Agent</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_agentEnabled ? (_agentShadowMode ? Color.Warning : Color.Success) : Color.Default)">
                        @(_agentEnabled ? (_agentShadowMode ? "Shadow Mode" : "Active") : "Disabled")
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="4" Class="pa-2">
                    <!-- Master Controls -->
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-3">Agent Controls</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSwitch T="bool" @bind-Value="_agentEnabled" Color="Color.Primary" Disabled="_busy">Enable Agent</MudSwitch>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSwitch T="bool" @bind-Value="_agentShadowMode" Color="Color.Warning" Disabled="_busy">Shadow Mode</MudSwitch>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSwitch T="bool" @bind-Value="_agentAllowNormal" Color="Color.Success" Disabled="_busy">Allow Normal Decisions</MudSwitch>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSwitch T="bool" @bind-Value="_agentAllowAbnormal" Color="Color.Error" Disabled="_busy">Allow Abnormal Decisions</MudSwitch>
                            </MudItem>
                        </MudGrid>
                        <MudGrid Class="mt-2">
                            <MudItem xs="12" sm="4">
                                <MudNumericField @bind-Value="_agentNormalThreshold" Label="Normal Threshold (<=)" Min="0.0" Max="1.0" Step="0.05" Format="F2" Disabled="_busy" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudNumericField @bind-Value="_agentAbnormalThreshold" Label="Abnormal Threshold (>=)" Min="0.0" Max="1.0" Step="0.05" Format="F2" Disabled="_busy" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudNumericField @bind-Value="_agentMaxGroupsPerCycle" Label="Max Groups Per Cycle" Min="1" Max="500" Disabled="_busy" />
                            </MudItem>
                        </MudGrid>
                        <!-- Score zone visualization -->
                        <MudPaper Class="pa-2 mt-3" Elevation="0" Style="background: #f5f5f5; border-radius: 4px;">
                            <MudStack Row="true" Spacing="0" Style="height: 28px; border-radius: 4px; overflow: hidden;">
                                <div style="width:@(_agentNormalThreshold * 100)%; background: #4caf50; display:flex; align-items:center; justify-content:center;">
                                    <MudText Typo="Typo.caption" Style="color:white; font-weight:600;">Normal</MudText>
                                </div>
                                <div style="width:@((_agentAbnormalThreshold - _agentNormalThreshold) * 100)%; background: #9e9e9e; display:flex; align-items:center; justify-content:center;">
                                    <MudText Typo="Typo.caption" Style="color:white; font-weight:600;">Human Review</MudText>
                                </div>
                                <div style="width:@((1.0 - _agentAbnormalThreshold) * 100)%; background: #f44336; display:flex; align-items:center; justify-content:center;">
                                    <MudText Typo="Typo.caption" Style="color:white; font-weight:600;">Abnormal</MudText>
                                </div>
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                Score 0.0–@(_agentNormalThreshold.ToString("F2")) = Normal | @(_agentNormalThreshold.ToString("F2"))–@(_agentAbnormalThreshold.ToString("F2")) = Human Review | @(_agentAbnormalThreshold.ToString("F2"))–1.0 = Abnormal
                            </MudText>
                        </MudPaper>
                    </MudPaper>

                    <!-- Processing Depth -->
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-3">Processing Depth</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">How far should the agent progress decisions through the pipeline?</MudText>
                        <MudStack Row="true" Spacing="4">
                            <MudCheckBox T="bool" Value="true" Disabled="true" Color="Color.Primary">Stage 1: Image Analysis Decision</MudCheckBox>
                            <MudCheckBox T="bool" @bind-Value="_agentDepthAudit" Color="Color.Primary" Disabled="_busy">Stage 2: Through Audit</MudCheckBox>
                            <MudCheckBox T="bool" @bind-Value="_agentDepthSubmission" Color="Color.Primary" Disabled="_busy">Stage 3: Through ICUMS Submission</MudCheckBox>
                        </MudStack>
                    </MudPaper>

                    <!-- Risk Conditions & Weights -->
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h6">Risk Scoring Conditions</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="AddDynamicCondition" Disabled="_busy" Size="Size.Small">Add Condition</MudButton>
                        </MudStack>
                        <MudTable Items="_agentConditions" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Enabled</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh Style="width:200px;">Weight</MudTh>
                                <MudTh>Description</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><MudSwitch T="bool" @bind-Value="context.Enabled" Color="Color.Primary" /></MudTd>
                                <MudTd><MudText Typo="Typo.body2">@context.Name</MudText></MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@(context.EvaluatorType == "BuiltIn" ? Color.Info : Color.Tertiary)">
                                        @context.EvaluatorType
                                    </MudChip>
                                </MudTd>
                                <MudTd>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudSlider T="double" @bind-Value="context.Weight" Min="0" Max="1" Step="0.01" Style="width:120px;" />
                                        <MudText Typo="Typo.caption" Style="width:40px;">@context.Weight.ToString("F2")</MudText>
                                    </MudStack>
                                </MudTd>
                                <MudTd><MudText Typo="Typo.caption">@(context.Description?.Length > 60 ? context.Description.Substring(0, 60) + "..." : context.Description)</MudText></MudTd>
                                <MudTd>
                                    @if (context.EvaluatorType == "Dynamic")
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteCondition(context))" />
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>

                    <!-- Save Button -->
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAgentSettings" Disabled="_busy" FullWidth="true">
                        @(_busy ? "Saving..." : "Save Agent Settings")
                    </MudButton>

                    <!-- Agent Activity / Audit Log -->
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h6">Agent Activity</MudText>
                            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Refresh" OnClick="LoadAgentData" Size="Size.Small">Refresh</MudButton>
                        </MudStack>

                        <!-- Stats chips -->
                        <MudStack Row="true" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Total: @_agentStats.totalProcessed</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Normal: @_agentStats.normalDecisions</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Abnormal: @_agentStats.abnormalDecisions</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Skipped: @_agentStats.skippedForHuman</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Shadow: @_agentStats.shadowModeOnly</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">Reversed: @_agentStats.reversed</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Avg Score: @_agentStats.averageScore.ToString("F3")</MudChip>
                        </MudStack>

                        <!-- Audit log table -->
                        <MudTable Items="_agentAuditLogs" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Time</MudTh>
                                <MudTh>Group</MudTh>
                                <MudTh>Score</MudTh>
                                <MudTh>Decision</MudTh>
                                <MudTh>Shadow</MudTh>
                                <MudTh>Depth</MudTh>
                                <MudTh>Containers</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><MudText Typo="Typo.caption">@context.CreatedAtUtc.ToLocalTime().ToString("MMM dd HH:mm")</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption">@context.GroupIdentifier</MudText></MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                        Color="@(context.TotalScore <= _agentNormalThreshold ? Color.Success : context.TotalScore >= _agentAbnormalThreshold ? Color.Error : Color.Default)">
                                        @context.TotalScore.ToString("F3")
                                    </MudChip>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                        Color="@(context.Decision == "Normal" ? Color.Success : context.Decision == "Abnormal" ? Color.Error : Color.Default)">
                                        @context.Decision
                                    </MudChip>
                                </MudTd>
                                <MudTd><MudText Typo="Typo.caption">@(context.IsShadowMode ? "Yes" : "No")</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption">@context.ProcessingDepthReached</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption">@context.ContainerCount</MudText></MudTd>
                                <MudTd>
                                    @if (context.Decision != "Skipped" && !context.IsShadowMode && context.ReversedAtUtc == null)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                            OnClick="@(() => ReverseAgentDecision(context.Id))">Reverse</MudButton>
                                    }
                                    else if (context.ReversedAtUtc != null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Reversed</MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- PANEL 3.5: WAVE PROCESSING MONITOR (Wave #3, 1.11.0) -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Waves" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Wave Processing Monitor</MudText>
                    @if (_waveMonitor != null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="@(_waveMonitor.WaveProcessingEnabled ? Color.Success : Color.Default)">
                            @(_waveMonitor.WaveProcessingEnabled ? "Enabled" : "Disabled")
                        </MudChip>
                        @if (_waveMonitor.StuckPendingOver24hCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Outlined.Warning">
                                @_waveMonitor.StuckPendingOver24hCount stuck > 24h
                            </MudChip>
                        }
                    }
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="3" Class="pa-2">
                    @if (_waveMonitorLoading)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    }
                    else if (_waveMonitor == null)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No wave monitor data loaded yet.
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="LoadWaveMonitor">Load</MudButton>
                        </MudAlert>
                    }
                    else
                    {
                        @* ── Settings summary ── *@
                        <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Settings</MudText>
                            <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Enabled</MudText>
                                    <MudText Typo="Typo.body2"><strong>@_waveMonitor.WaveProcessingEnabled</strong></MudText>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Min batch size</MudText>
                                    <MudText Typo="Typo.body2"><strong>@_waveMonitor.WaveMinBatchSize</strong></MudText>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Timeout (hours)</MudText>
                                    <MudText Typo="Typo.body2"><strong>@_waveMonitor.WaveTimeoutHours</strong></MudText>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Auto-close (days)</MudText>
                                    <MudText Typo="Typo.body2"><strong>@_waveMonitor.WaveAutoCloseDays</strong></MudText>
                                </div>
                                <MudSpacer />
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Outlined.Refresh"
                                           OnClick="LoadWaveMonitor">
                                    Refresh
                                </MudButton>
                            </MudStack>
                        </MudPaper>

                        @* ── Counts row ── *@
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudPaper Class="pa-3" Elevation="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Parent groups by status</MudText>
                                    @if (_waveMonitor.ParentGroupCounts.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Class="mt-2" Style="font-style: italic;">No parent groups</MudText>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-2">
                                            @foreach (var kv in _waveMonitor.ParentGroupCounts)
                                            {
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="@(kv.Key == "Active" ? Color.Primary : Color.Default)">
                                                    @kv.Key: @kv.Value
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudPaper Class="pa-3" Elevation="1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pending containers by status</MudText>
                                    @if (_waveMonitor.PendingContainerCounts.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Class="mt-2" Style="font-style: italic;">Queue is empty</MudText>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-2">
                                            @foreach (var kv in _waveMonitor.PendingContainerCounts)
                                            {
                                                var color = kv.Key switch
                                                {
                                                    "Ready" => Color.Success,
                                                    "Pending" => Color.Info,
                                                    "NoImageAvailable" => Color.Warning,
                                                    _ => Color.Default
                                                };
                                                <MudChip T="string" Size="Size.Small" Color="@color">
                                                    @kv.Key: @kv.Value
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        @* ── Stuck containers ── *@
                        @if (_waveMonitor.OldestPending != null || _waveMonitor.OldestReady != null || _waveMonitor.StuckPendingOver24hCount > 0)
                        {
                            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Stuck / long-waiting containers</MudText>
                                @if (_waveMonitor.StuckPendingOver24hCount > 0)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                                        <strong>@_waveMonitor.StuckPendingOver24hCount container(s)</strong> have been in Pending status for over 24 hours (no images ever arrived).
                                        These will only be auto-closed after the @_waveMonitor.WaveAutoCloseDays-day retention window.
                                    </MudAlert>
                                }
                                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                    <thead>
                                        <tr>
                                            <th>What</th>
                                            <th>Container</th>
                                            <th>Scanner</th>
                                            <th>Age (hours)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (_waveMonitor.OldestPending != null)
                                        {
                                            <tr>
                                                <td>Oldest <strong>Pending</strong> (no images yet)</td>
                                                <td>@_waveMonitor.OldestPending.ContainerNumber</td>
                                                <td>@(_waveMonitor.OldestPending.ScannerType ?? "—")</td>
                                                <td>@_waveMonitor.OldestPending.AgeHours.ToString("F1")</td>
                                            </tr>
                                        }
                                        @if (_waveMonitor.OldestReady != null)
                                        {
                                            <tr>
                                                <td>Oldest <strong>Ready</strong> (waiting on wave timeout / batch size)</td>
                                                <td>@_waveMonitor.OldestReady.ContainerNumber</td>
                                                <td>@(_waveMonitor.OldestReady.ScannerType ?? "—")</td>
                                                <td>@_waveMonitor.OldestReady.AgeHours.ToString("F1")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudPaper>
                        }

                        @* ── Recent parent groups ── *@
                        <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Recent parent groups (last 20)</MudText>
                            @if (_waveMonitor.RecentParents.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Style="font-style: italic;">No parent groups yet.</MudText>
                            }
                            else
                            {
                                <MudTable T="WaveMonitorParentDto"
                                          Items="_waveMonitor.RecentParents"
                                          Dense="true" Hover="true" Bordered="true"
                                          Breakpoint="Breakpoint.Sm">
                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel SortBy="new Func<WaveMonitorParentDto, object>(x => x.GroupIdentifier)">Group</MudTableSortLabel></MudTh>
                                        <MudTh>Scanner</MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<WaveMonitorParentDto, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<WaveMonitorParentDto, object>(x => x.TotalExpectedContainers)">Expected</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<WaveMonitorParentDto, object>(x => x.CompletedWaveCount)">Completed waves</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<WaveMonitorParentDto, object>(x => x.AgeHours)">Age (h)</MudTableSortLabel></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Group">@context.GroupIdentifier</MudTd>
                                        <MudTd DataLabel="Scanner">@(context.ScannerType ?? "—")</MudTd>
                                        <MudTd DataLabel="Status">
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(context.Status == "Active" ? Color.Primary : context.Status == "Complete" ? Color.Success : Color.Default)">
                                                @context.Status
                                            </MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Expected">@context.TotalExpectedContainers</MudTd>
                                        <MudTd DataLabel="Completed waves">@context.CompletedWaveCount</MudTd>
                                        <MudTd DataLabel="Age (h)">@context.AgeHours.ToString("F1")</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>

                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Generated at @_waveMonitor.GeneratedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                        </MudText>
                    }
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- PANEL 4: MAINTENANCE -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Build" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Maintenance</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Actions</MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="3" Class="pa-2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Administrative maintenance actions for the image analysis pipeline.</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SyncStages" Disabled="_busy" StartIcon="@Icons.Material.Outlined.Sync">Sync Stages</MudButton>
