            {
                Console.WriteLine($"⚠️ Could not verify settings after save");
                Snackbar.Add("Settings saved, but could not verify the change", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            // ✅ Use DualNotification for errors - saves to database AND shows Snackbar
            Console.WriteLine($"❌❌❌ ERROR IN SaveSettings: {ex.Message}");
            Console.WriteLine($"❌ Stack trace: {ex.StackTrace}");
            Console.Error.WriteLine($"❌❌❌ ERROR IN SaveSettings: {ex.Message}");
            System.Diagnostics.Debug.WriteLine($"❌❌❌ ERROR IN SaveSettings: {ex.Message}");
            
            await DualNotification.ShowErrorAsync($"Error saving settings: {ex.Message}", title: "Settings Error");
            
            // Try to get more details about the error
            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized"))
            {
                Snackbar.Add("⚠️ Authentication error. Please confirm you are logged in.", Severity.Warning);
            }
            else if (ex.Message.Contains("403") || ex.Message.Contains("Forbid"))
            {
                Snackbar.Add("⚠️ Permission denied. You need the 'controllers.imageanalysis.management.settings' permission to update these settings.", Severity.Warning);
            }
        }
        finally 
        { 
            Console.WriteLine($"✅ SaveSettings finally block - setting _busy = false and _isSaving = false");
            _busy = false;
            _isSaving = false; // ✅ CRITICAL: Clear flag after save completes
        }
    }

