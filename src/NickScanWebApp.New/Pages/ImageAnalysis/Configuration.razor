    private double GetRolePercentage(Dictionary<string, int>? byRole, string role)
    {
        if (byRole == null || !byRole.ContainsKey(role)) return 0;
        var analystCount = byRole.GetValueOrDefault("Analyst", 0);
        var auditCount = byRole.GetValueOrDefault("Audit", 0);
        var total = analystCount + auditCount;
        if (total == 0) return 0;
        return (byRole[role] / (double)total) * 100;
    }

    private async Task<T?> SafeGet<T>(string endpoint)
    {
        try { return await ApiService.GetAsync<T>(endpoint); }
        catch (Exception ex) { 
            Console.WriteLine($"❌ Error calling {endpoint}: {ex.Message}");
            Snackbar.Add($"Error loading {endpoint}: {ex.Message}", Severity.Error); 
            return default; 
        }
    }

    private async Task<T?> SafeGetWithTimeout<T>(string endpoint, TimeSpan timeout)
    {
        try 
        { 
            using var cts = new CancellationTokenSource(timeout);
            var apiTask = ApiService.GetAsync<T>(endpoint);
            var delayTask = Task.Delay(timeout, cts.Token);
            
            var completedTask = await Task.WhenAny(apiTask, delayTask);
            
            if (completedTask == apiTask)
            {
                // API call completed before timeout
                cts.Cancel(); // Cancel the delay task
                return await apiTask;
            }
            else
            {
                // Timeout occurred
                Console.WriteLine($"⏱️ Timeout calling {endpoint} after {timeout.TotalSeconds}s");
                Snackbar.Add($"Timeout loading {endpoint} (>{timeout.TotalSeconds}s)", Severity.Warning);
                return default;
            }
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine($"⏱️ Timeout calling {endpoint}");
            Snackbar.Add($"Timeout loading {endpoint}", Severity.Warning);
            return default;
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"❌ Error calling {endpoint}: {ex.Message}");
            Snackbar.Add($"Error loading {endpoint}: {ex.Message}", Severity.Error); 
            return default; 
        }
    }

