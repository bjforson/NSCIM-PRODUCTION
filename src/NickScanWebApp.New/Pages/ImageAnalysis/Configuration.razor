    // Agent settings fields
    private bool _agentEnabled;
    private bool _agentShadowMode = true;
    private bool _agentAllowNormal = true;
    private bool _agentAllowAbnormal;
    private double _agentNormalThreshold = 0.2;
    private double _agentAbnormalThreshold = 0.7;
    private bool _agentDepthAudit;
    private bool _agentDepthSubmission;
    private int _agentMaxGroupsPerCycle = 50;

    private List<AgentConditionDto> _agentConditions = new();
    private List<AgentAuditLogDto> _agentAuditLogs = new();
    private AgentStatsDto _agentStats = new();

    private async Task LoadAgentData()
    {
        try
        {
            var settingsResult = await SafeGetWithTimeout<AgentSettingsResponse>("/api/image-analysis-management/agent/settings", TimeSpan.FromSeconds(10));
            if (settingsResult != null)
            {
                _agentEnabled = settingsResult.settings?.Enabled ?? false;
                _agentShadowMode = settingsResult.settings?.ShadowMode ?? true;
                _agentAllowNormal = settingsResult.settings?.AllowNormalDecisions ?? true;
                _agentAllowAbnormal = settingsResult.settings?.AllowAbnormalDecisions ?? false;
                _agentNormalThreshold = settingsResult.settings?.NormalThreshold ?? 0.2;
                _agentAbnormalThreshold = settingsResult.settings?.AbnormalThreshold ?? 0.7;
                _agentDepthAudit = settingsResult.settings?.ProcessingDepthAudit ?? false;
                _agentDepthSubmission = settingsResult.settings?.ProcessingDepthSubmission ?? false;
                _agentMaxGroupsPerCycle = settingsResult.settings?.MaxGroupsPerCycle ?? 50;
                _agentConditions = settingsResult.conditions ?? new();
            }

            var auditResult = await SafeGetWithTimeout<AgentAuditLogResponse>("/api/image-analysis-management/agent/audit-log?pageSize=20", TimeSpan.FromSeconds(10));
            if (auditResult?.items != null) _agentAuditLogs = auditResult.items;

            _agentStats = await SafeGetWithTimeout<AgentStatsDto>("/api/image-analysis-management/agent/stats", TimeSpan.FromSeconds(10)) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading agent data: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task SaveAgentSettings()
    {
        if (_agentNormalThreshold >= _agentAbnormalThreshold)
        {
            Snackbar.Add("Normal threshold must be less than abnormal threshold", Severity.Error);
            return;
        }

        _busy = true;
        try
        {
            // Save settings
            await ApiService.PostAsync<object, object>("/api/image-analysis-management/agent/settings", new
            {
                enabled = _agentEnabled,
                shadowMode = _agentShadowMode,
                allowNormalDecisions = _agentAllowNormal,
                allowAbnormalDecisions = _agentAllowAbnormal,
                normalThreshold = _agentNormalThreshold,
                abnormalThreshold = _agentAbnormalThreshold,
                processingDepthAudit = _agentDepthAudit,
                processingDepthSubmission = _agentDepthSubmission,
                maxGroupsPerCycle = _agentMaxGroupsPerCycle
            });

            // Save each condition
            foreach (var c in _agentConditions)
            {
                await ApiService.PostAsync<object, object>("/api/image-analysis-management/agent/conditions", new
                {
                    id = c.Id,
                    name = c.Name,
                    conditionKey = c.ConditionKey,
                    weight = c.Weight,
                    enabled = c.Enabled,
                    dynamicFieldPath = c.DynamicFieldPath,
                    dynamicOperator = c.DynamicOperator,
                    dynamicValue = c.DynamicValue,
                    description = c.Description
                });
            }

            Snackbar.Add("Agent settings saved", Severity.Success);
            await LoadAgentData();
        }
        catch (Exception ex)
        {
            await DualNotification.ShowErrorAsync($"Error saving agent settings: {ex.Message}", title: "Agent Settings Error");
        }
        finally { _busy = false; }
    }

    private void AddDynamicCondition()
    {
        _agentConditions.Add(new AgentConditionDto
        {
            Name = "New Condition",
            ConditionKey = "dynamic_" + Guid.NewGuid().ToString("N").Substring(0, 8),
            EvaluatorType = "Dynamic",
            Weight = 0.1,
            Enabled = true,
            DynamicOperator = "Contains"
        });
    }

    private async Task DeleteCondition(AgentConditionDto condition)
    {
        if (condition.EvaluatorType == "BuiltIn") return;

        if (condition.Id > 0)
        {
            try
            {
                await ApiService.GetAsync<object>($"/api/image-analysis-management/agent/conditions/{condition.Id}");
            }
            catch { /* may not have DELETE via GET - handled by controller */ }

            try
            {
                // Use POST to a delete endpoint pattern
                var response = await ApiService.PostAsync<object, object>($"/api/image-analysis-management/agent/conditions", new
                {
                    id = condition.Id,
                    name = condition.Name,
                    conditionKey = condition.ConditionKey,
                    weight = 0,
                    enabled = false
                });
            }
            catch { }
        }

        _agentConditions.Remove(condition);
        StateHasChanged();
    }

    private async Task ReverseAgentDecision(long auditLogId)
    {
        _busy = true;
        try
        {
            await ApiService.PostAsync<object, object>($"/api/image-analysis-management/agent/reverse/{auditLogId}", new { reason = "Manual reversal from UI" });
            Snackbar.Add("Decision reversed — group returned to Ready", Severity.Success);
            await LoadAgentData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error reversing: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }

