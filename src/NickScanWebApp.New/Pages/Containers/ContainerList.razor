@page "/containers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesContainersView)]
@using NickScanWebApp.New.Components.Containers
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject NavigationManager NavigationManager

<PageTitle>NICKSCAN ERP — NSCIS — Containers</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <!-- Header with gradient -->
    <MudPaper Elevation="3" Class="pa-4 mb-4" Style="background: linear-gradient(135deg, #2563EB 0%, #3B82F6 50%, #60A5FA 100%); border-radius: 12px;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h5" Style="color:white; font-weight:700;">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory" Class="mr-2" Style="color:#90caf9;" />
                    Containers
                </MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.7);">
                    View all cargo groups with analysis progress, assignments, and decision status
                </MudText>
            </div>
            <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Color="Color.Inherit" Style="color:white;" OnClick="@LoadData" />
        </MudStack>
    </MudPaper>

    <!-- KPI Summary Cards -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" md="2">
            <MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid #2563EB;">
                <MudText Typo="Typo.overline" Style="text-transform:uppercase; letter-spacing:1px; color:#9e9e9e;">Total Records</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#2563EB;">@_kpis.TotalGroups</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid #e65100;">
                <MudText Typo="Typo.overline" Style="text-transform:uppercase; letter-spacing:1px; color:#9e9e9e;">In Analysis</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#e65100;">@_kpis.InAnalysis</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid #6a1b9a;">
                <MudText Typo="Typo.overline" Style="text-transform:uppercase; letter-spacing:1px; color:#9e9e9e;">In Audit</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#6a1b9a;">@_kpis.InAudit</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid #2e7d32;">
                <MudText Typo="Typo.overline" Style="text-transform:uppercase; letter-spacing:1px; color:#9e9e9e;">Completed</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#2e7d32;">@_kpis.Completed</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid #0277bd;">
                <MudText Typo="Typo.overline" Style="text-transform:uppercase; letter-spacing:1px; color:#9e9e9e;">Pending Submit</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#0277bd;">@_kpis.PendingSubmit</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Filters -->
    <MudPaper Elevation="2" Class="pa-3 mb-4 rounded-lg">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_search" Label="Search" Placeholder="BOE, BL, Container..."
                             Variant="Variant.Outlined" Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Outlined.Search"
                             Immediate="true" DebounceInterval="500"
                             OnDebounceIntervalElapsed="@(() => LoadData())" />
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" @bind-Value="_stageFilter" Label="Stage" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem T="string" Value="@("")">All Stages</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Ready")">Ready</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AnalystAssigned")">Analyst Assigned</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AnalystCompleted")">Analyst Completed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AuditAssigned")">Audit Assigned</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" @bind-Value="_cargoTypeFilter" Label="Type" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem T="string" Value="@("")">All Types</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Consolidated")">Consolidated</MudSelectItem>
                    <MudSelectItem T="string" Value="@("NonConsolidated")">Non-Consolidated</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" @bind-Value="_clearanceFilter" Label="Clearance" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem T="string" Value="@("")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("IM")">Import</MudSelectItem>
                    <MudSelectItem T="string" Value="@("EX")">Export</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CMR")">CMR</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@LoadData" Class="mr-2">Apply</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="@ClearFilters">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Data Table -->
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }

    <MudTable T="EnrichedGroup" Items="@_groups" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm"
              Loading="@_loading" Elevation="2" Class="rounded-lg"
              RowStyleFunc="@((row, i) => "cursor: pointer;")"
              OnRowClick="@(args => NavigateToGroup(args.Item))">
        <HeaderContent>
            <MudTh>Record / Group</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Containers</MudTh>
            <MudTh>Stage</MudTh>
            <MudTh>Decision Progress</MudTh>
            <MudTh>Assigned To</MudTh>
            <MudTh Class="mobile-hide-col">Clearance</MudTh>
            <MudTh Class="mobile-hide-col">Updated</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Record">
                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.GroupIdentifier</MudText>
            </MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.CargoType == "Consolidated" ? Color.Success : Color.Info)"
                         Variant="Variant.Filled">
                    @(context.CargoType == "Consolidated" ? "CON" : "NON")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Containers">@context.ContainerCount</MudTd>
            <MudTd DataLabel="Stage">
                <MudChip T="string" Size="Size.Small" Color="@GetStageColor(context.Status)" Variant="Variant.Filled">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Decisions">
                @if (context.ContainerCount > 0)
                {
                    var pct = context.ContainerCount > 0 ? (double)context.DecisionCount / context.ContainerCount * 100 : 0;
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption">@context.DecisionCount / @context.ContainerCount</MudText>
                        <MudProgressLinear Value="@pct" Color="@(pct >= 100 ? Color.Success : Color.Primary)" Size="Size.Small" Rounded="true" />
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Assigned">
                @if (!string.IsNullOrEmpty(context.AssignedTo))
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width:24px; height:24px; font-size:0.7rem;">
                            @context.AssignedTo[0]
                        </MudAvatar>
                        <MudText Typo="Typo.caption">@context.AssignedTo</MudText>
                        @if (!string.IsNullOrEmpty(context.AssignedRole))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@(context.AssignedRole == "Audit" ? Color.Secondary : Color.Primary)">
                                @context.AssignedRole
                            </MudChip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">Unassigned</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Clearance" Class="mobile-hide-col">
                @if (!string.IsNullOrEmpty(context.ClearanceType))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ClearanceType</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Updated" Class="mobile-hide-col">
                <MudText Typo="Typo.caption">@(context.UpdatedAt?.ToString("MMM dd HH:mm") ?? "—")</MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info">No records found matching your filters.</MudAlert>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>

    @if (_totalPages > 1)
    {
        <MudPagination Count="@_totalPages" Selected="@_currentPage" SelectedChanged="@OnPageChanged" Class="mt-4 d-flex justify-center" />
    }
</MudContainer>

@code {
    private bool _loading = false;
    private string? _error = null;
    private string _search = "";
    private string _stageFilter = "";
    private string _cargoTypeFilter = "";
    private string _clearanceFilter = "";
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalPages = 1;
    private List<EnrichedGroup> _groups = new();
    private KpiData _kpis = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var queryParams = new List<string> { $"page={_currentPage}", $"pageSize={_pageSize}" };
            if (!string.IsNullOrWhiteSpace(_search)) queryParams.Add($"search={Uri.EscapeDataString(_search)}");
            if (!string.IsNullOrWhiteSpace(_stageFilter)) queryParams.Add($"stage={Uri.EscapeDataString(_stageFilter)}");
            if (!string.IsNullOrWhiteSpace(_cargoTypeFilter)) queryParams.Add($"cargoType={Uri.EscapeDataString(_cargoTypeFilter)}");
            if (!string.IsNullOrWhiteSpace(_clearanceFilter)) queryParams.Add($"clearanceType={Uri.EscapeDataString(_clearanceFilter)}");

            var result = await ApiService.GetAsync<EnrichedResponse>($"/api/containers/enriched?{string.Join("&", queryParams)}");
            if (result != null)
            {
                _groups = result.Groups ?? new();
                _totalPages = result.TotalPages;
                _kpis = result.Kpis ?? new();
            }
        }
        catch (Exception ex)
        {
            _error = $"Error loading containers: {ex.Message}";
            if (ex.InnerException != null)
                _error += $" | Inner: {ex.InnerException.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        _search = ""; _stageFilter = ""; _cargoTypeFilter = ""; _clearanceFilter = "";
        _currentPage = 1;
        await LoadData();
    }

    private void NavigateToGroup(EnrichedGroup group)
    {
        if (!string.IsNullOrEmpty(group.GroupIdentifier))
            NavigationManager.NavigateTo($"/containers/details?groupIdentifier={Uri.EscapeDataString(group.GroupIdentifier)}&type={group.CargoType}");
    }

    private Color GetStageColor(string? status) => status switch
    {
        "Ready" => Color.Info,
        "AnalystAssigned" => Color.Warning,
        "AnalystCompleted" => Color.Primary,
        "AuditAssigned" => Color.Secondary,
        "Completed" => Color.Success,
        "PendingSubmission" => Color.Tertiary,
        _ => Color.Default
    };

    // DTOs matching the enriched API response
    public class EnrichedResponse
    {
        public List<EnrichedGroup> Groups { get; set; } = new();
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
        public KpiData Kpis { get; set; } = new();
    }

    public class EnrichedGroup
    {
        public string? Id { get; set; }
        public string GroupIdentifier { get; set; } = "";
        public string? CargoType { get; set; }
        public string? Status { get; set; }
        public string? ClearanceType { get; set; }
        public int ContainerCount { get; set; }
        public DateTime? CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
        public long DecisionCount { get; set; }
        public long NormalCount { get; set; }
        public long AbnormalCount { get; set; }
        public string? AssignedTo { get; set; }
        public string? AssignedRole { get; set; }
    }

    public class KpiData
    {
        public int TotalGroups { get; set; }
        public int InAnalysis { get; set; }
        public int InAudit { get; set; }
        public int Completed { get; set; }
        public int PendingSubmit { get; set; }
    }
}
