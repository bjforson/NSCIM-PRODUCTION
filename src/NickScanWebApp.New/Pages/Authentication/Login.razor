@page "/"
@page "/login"
@page "/authentication/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authentication
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@using System.Net.Http.Headers
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject NickScanWebApp.New.Services.SimpleAuthStateProvider AuthProvider
@inject NickScanWebApp.New.Services.CustomAuthStateProvider CustomAuthProvider
@inject AuthBootstrapper AuthBootstrapper
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Login> Logger
@inject IJSRuntime JSRuntime

<PageTitle>NICKSCAN ERP — NSCIS — Login</PageTitle>

@*
    NSCIM Login — v2.9.8 layout redesign.

    Two-panel split — slate sidebar #1B2537 (matches post-login NavMenu.DrawerBackground)
    on the left with cyan accents (#4facfe → #00f2fe, same gradient used on the sidebar
    logo tile), white form card on the right. Ported from NickHR login pattern with the
    violet gradient swapped for NSCIM's sidebar slate for visual continuity across
    pre- and post-login screens.

    Auth flow is unchanged from v2.9.7 — all the Username/Password → /api/Authentication/login
    → JWT → PopulatePermissionClaimsAsync → /dashboard logic lives in the @@code block
    below and was carried over verbatim.
*@

<!-- Inline SVG symbol library — avoids a second font-load round-trip -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <symbol id="nsc-i-security" viewBox="0 0 24 24"><path fill="currentColor" d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></symbol>
    <symbol id="nsc-i-scanner" viewBox="0 0 24 24"><path fill="currentColor" d="M6 4v2H2v14h20V6h-4V4H6zm2 2h8v2H8V6zm-4 4h16v8H4v-8zm2 1v2h12v-2H6zm0 3v2h12v-2H6z"/></symbol>
    <symbol id="nsc-i-hub" viewBox="0 0 24 24"><path fill="currentColor" d="M21 6.5a2.5 2.5 0 0 0-5 0c0 .48.15.93.4 1.3l-3.2 3.21A2.5 2.5 0 0 0 11 12a2.5 2.5 0 0 0-1.6-2.3L8 8.13a2.5 2.5 0 1 0-1.88.78l.03 1.6a2.5 2.5 0 0 0 .83 4.85c.67 0 1.28-.27 1.73-.7L10 15.87V18.5a2.5 2.5 0 1 0 2 0V15.8l1.66-1.21a2.5 2.5 0 1 0 .14-4.05l3.2-3.2c.33.11.7.17 1 .17a2.5 2.5 0 0 0 3-2.5z"/></symbol>
    <symbol id="nsc-i-ai" viewBox="0 0 24 24"><path fill="currentColor" d="M20 9V7c0-1.1-.9-2-2-2h-3c0-1.66-1.34-3-3-3S9 3.34 9 5H6c-1.1 0-2 .9-2 2v2c-1.66 0-3 1.34-3 3s1.34 3 3 3v4c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-4c1.66 0 3-1.34 3-3s-1.34-3-3-3zm-2 10H6V7h12v12zM9 12a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm6 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm-6 4h6v-2H9v2z"/></symbol>
    <symbol id="nsc-i-person" viewBox="0 0 24 24"><path fill="currentColor" d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-4 0-8 2-8 6v2h16v-2c0-4-4-6-8-6z"/></symbol>
    <symbol id="nsc-i-lock" viewBox="0 0 24 24"><path fill="currentColor" d="M18 8h-1V6a5 5 0 1 0-10 0v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zM9 6a3 3 0 0 1 6 0v2H9V6zm3 11a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/></symbol>
    <symbol id="nsc-i-eye" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></symbol>
    <symbol id="nsc-i-eye-off" viewBox="0 0 24 24"><path fill="currentColor" d="M12 7a5 5 0 0 1 5 5c0 .65-.13 1.26-.36 1.83l2.92 2.92A11.55 11.55 0 0 0 23 12c-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-4 .7l2.17 2.15C10.74 7.13 11.35 7 12 7zm-1.07 1.14L13 10.21V10a2 2 0 0 0-2-2l-.07.14zM2.71 3.16a1 1 0 0 0 0 1.41l1.97 1.97A11.73 11.73 0 0 0 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l2.73 2.73a1 1 0 0 0 1.41-1.41L4.13 3.16a1 1 0 0 0-1.42 0zM12 17a5 5 0 0 1-5-5c0-.77.18-1.5.5-2.16l1.53 1.53A2.99 2.99 0 0 0 12 15l1.63 1.63c-.5.23-1.07.37-1.63.37zm2.74-3.27-2.85-2.85a2.97 2.97 0 0 1 2.85 2.85z"/></symbol>
    <symbol id="nsc-i-alert" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 15h-2v-2h2zm0-4h-2V7h2z"/></symbol>
</svg>

<div class="nsc-login">
    <!-- LEFT: Branding -->
    <div class="nsc-login-left">
        <div class="nsc-login-left-inner">
            <div class="nsc-logo anim anim-1">
                <div class="nsc-logo-icon anim-logo">
                    <svg><use href="#nsc-i-security"/></svg>
                </div>
                <span class="nsc-logo-text">NSCIS</span>
            </div>

            <h1 class="nsc-headline anim anim-2">Every Container,<br/>Every Scan.</h1>
            <p class="nsc-subheadline anim anim-3">
                Central imaging, customs workflow, and AI-powered cargo analysis — one secure platform for the full inspection lifecycle.
            </p>

            <div class="nsc-stats-row anim anim-4">
                <div class="nsc-stat"><span class="nsc-stat-num">3,174</span><span class="nsc-stat-label">Containers</span></div>
                <div class="nsc-stat-divider"></div>
                <div class="nsc-stat"><span class="nsc-stat-num">130</span><span class="nsc-stat-label">Today's Scans</span></div>
                <div class="nsc-stat-divider"></div>
                <div class="nsc-stat"><span class="nsc-stat-num">74.7%</span><span class="nsc-stat-label">Completeness</span></div>
                <div class="nsc-stat-divider"></div>
                <div class="nsc-stat"><span class="nsc-stat-num">100%</span><span class="nsc-stat-label">Success</span></div>
            </div>

            <div class="nsc-features anim anim-5">
                <div class="nsc-feature"><div class="nsc-feature-icon"><svg><use href="#nsc-i-scanner"/></svg></div><span>Real-time FS6000, ASE &amp; Heimann scanning</span></div>
                <div class="nsc-feature"><div class="nsc-feature-icon"><svg><use href="#nsc-i-hub"/></svg></div><span>ICUMS integration with automated BOE matching</span></div>
                <div class="nsc-feature"><div class="nsc-feature-icon"><svg><use href="#nsc-i-ai"/></svg></div><span>AI image analysis &amp; autonomous decision support</span></div>
            </div>

            <div class="nsc-pills anim anim-6">
                <span class="nsc-pill">Image Review</span>
                <span class="nsc-pill">Completeness</span>
                <span class="nsc-pill">Analytics</span>
                <span class="nsc-pill">Audit</span>
                <span class="nsc-pill">ICUMS Sync</span>
                <span class="nsc-pill">Vehicles</span>
            </div>

            <p class="nsc-powered anim anim-7">Powered by Nick TC-Scan Ltd</p>
        </div>
    </div>

    <!-- RIGHT: Form card -->
    <div class="nsc-login-right">
        <div class="nsc-form-card anim-card">
            <div class="nsc-form-header">
                <div class="nsc-form-avatar"><svg><use href="#nsc-i-person"/></svg></div>
                <h2>Welcome Back</h2>
                <p>Sign in to continue to NSCIS</p>
            </div>

            <EditForm Model="@loginModel" OnSubmit="HandleLogin">
                <div class="nsc-field">
                    <label for="nsc-username">User ID</label>
                    <div class="nsc-input-wrap">
                        <svg><use href="#nsc-i-person"/></svg>
                        <input id="nsc-username"
                               @ref="_usernameInputRef"
                               type="text"
                               placeholder="your.username"
                               autocomplete="username"
                               disabled="@isLoading"
                               @bind-value="loginModel.Username"
                               @bind-value:event="oninput" />
                    </div>
                </div>

                <div class="nsc-field">
                    <label for="nsc-password">Password</label>
                    <div class="nsc-input-wrap">
                        <svg><use href="#nsc-i-lock"/></svg>
                        <input id="nsc-password"
                               type="@(_showPassword ? "text" : "password")"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               disabled="@isLoading"
                               @bind-value="loginModel.Password"
                               @bind-value:event="oninput" />
                        <button type="button"
                                class="nsc-pwd-toggle"
                                tabindex="-1"
                                aria-label="Toggle password visibility"
                                @onclick="TogglePasswordVisibility">
                            <svg><use href="@(_showPassword ? "#nsc-i-eye-off" : "#nsc-i-eye")"/></svg>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="nsc-error" role="alert">
                        <svg><use href="#nsc-i-alert"/></svg>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="nsc-options">
                    <label class="nsc-checkbox">
                        <input type="checkbox" @bind="loginModel.RememberMe" disabled="@isLoading" />
                        <span>Remember me</span>
                    </label>
                    <a class="nsc-forgot" href="#" @onclick:preventDefault @onclick="HandleForgotPassword">Forgot Password?</a>
                </div>

                <button type="submit" class="nsc-signin-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="nsc-spinner"></span>
                        <span>Authenticating…</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>

                <div class="nsc-form-footer">
                    <svg><use href="#nsc-i-lock"/></svg>
                    <span>SSL Secured Connection · v@(NickScanWebApp.New.DeploymentInfo.Version)</span>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<style>
    /* ============================================================
       NSCIM Login — Mockup C (flat slate + cyan pops)
       Left panel: solid #1B2537 (matches post-login DrawerBackground)
       Cyan accents: #4facfe → #00f2fe (same sidebar logo-tile gradient)
       ============================================================ */
    * { box-sizing: border-box; }

    .nsc-login {
        display: flex;
        min-height: 100vh;
        font-family: 'Inter', 'Roboto', 'Segoe UI', system-ui, -apple-system, sans-serif;
        color: #1E293B;
    }

    /* ── LEFT PANEL (branding) ───────────────────────────────── */
    .nsc-login-left {
        flex: 1;
        background: #1B2537;
        display: flex;
        align-items: center;
        padding: 48px 56px;
        position: relative;
        overflow: hidden;
    }
    .nsc-login-left::before {
        content: '';
        position: absolute;
        top: -30%; right: -20%;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(79, 172, 254, 0.10) 0%, rgba(79, 172, 254, 0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .nsc-login-left::after {
        content: '';
        position: absolute;
        bottom: -20%; left: -10%;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0, 242, 254, 0.08) 0%, rgba(0, 242, 254, 0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .nsc-login-left-inner { position: relative; z-index: 1; max-width: 480px; }

    .nsc-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 40px; }
    .nsc-logo-icon {
        width: 48px; height: 48px;
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 18px rgba(79, 172, 254, 0.35);
    }
    .nsc-logo-icon svg { width: 24px; height: 24px; color: #fff; }
    .nsc-logo-text { color: #fff; font-size: 24px; font-weight: 800; letter-spacing: 0.5px; }

    .nsc-headline {
        color: #fff;
        font-size: 2.4rem;
        font-weight: 800;
        line-height: 1.15;
        margin: 0 0 16px;
    }
    .nsc-subheadline {
        color: rgba(255, 255, 255, 0.7);
        font-size: 15px;
        line-height: 1.6;
        margin: 0 0 36px;
        max-width: 420px;
    }

    .nsc-stats-row {
        display: flex; align-items: center; gap: 20px;
        margin-bottom: 36px; flex-wrap: wrap;
    }
    .nsc-stat { text-align: center; }
    .nsc-stat-num {
        display: block;
        color: #4facfe;
        font-size: 1.8rem;
        font-weight: 800;
    }
    .nsc-stat-label {
        display: block;
        color: rgba(255, 255, 255, 0.5);
        font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 1px;
        margin-top: 2px;
    }
    .nsc-stat-divider { width: 1px; height: 36px; background: rgba(255, 255, 255, 0.1); }

    .nsc-features { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
    .nsc-feature {
        display: flex; align-items: center; gap: 12px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 14px; font-weight: 500;
    }
    .nsc-feature-icon {
        width: 32px; height: 32px;
        background: rgba(79, 172, 254, 0.14);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .nsc-feature-icon svg { width: 18px; height: 18px; color: #4facfe; }

    .nsc-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
    .nsc-pill {
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.85);
        padding: 6px 14px; border-radius: 20px;
        font-size: 12px; font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .nsc-powered { color: rgba(255, 255, 255, 0.3); font-size: 12px; margin: 0; }

    /* ── RIGHT PANEL (form card) ─────────────────────────────── */
    .nsc-login-right {
        width: 480px; min-width: 420px;
        background: #F8FAFC;
        display: flex; align-items: center; justify-content: center;
        padding: 40px;
    }
    .nsc-form-card {
        width: 100%; max-width: 380px;
        background: #fff;
        border-radius: 20px;
        padding: 40px 32px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    }

    .nsc-form-header { text-align: center; margin-bottom: 28px; }
    .nsc-form-avatar {
        width: 60px; height: 60px;
        background: #E0F2FE;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
    }
    .nsc-form-avatar svg { width: 32px; height: 32px; color: #0284C7; }
    .nsc-form-header h2 { color: #1E293B; font-size: 22px; font-weight: 700; margin: 0 0 4px; }
    .nsc-form-header p { color: #94A3B8; font-size: 14px; margin: 0; }

    .nsc-field { margin-bottom: 18px; }
    .nsc-field label {
        display: block; color: #475569;
        font-size: 13px; font-weight: 600;
        margin-bottom: 6px;
    }
    .nsc-input-wrap { position: relative; }
    .nsc-input-wrap > svg:first-child {
        position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
        width: 20px; height: 20px; color: #94A3B8;
        pointer-events: none;
    }
    .nsc-input-wrap input {
        width: 100%;
        padding: 12px 14px 12px 44px;
        font-family: inherit; font-size: 14px;
        color: #1E293B;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .nsc-input-wrap input::placeholder { color: #CBD5E1; }
    .nsc-input-wrap input:hover:not(:disabled) { border-color: #CBD5E1; }
    .nsc-input-wrap input:focus { border-color: #0284C7; box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.08); }
    .nsc-input-wrap input:disabled { background: #F8FAFC; color: #94A3B8; cursor: not-allowed; }
    /* Reserve space for the eye toggle on the password field */
    .nsc-input-wrap input[type="password"],
    .nsc-input-wrap input[autocomplete="current-password"] { padding-right: 44px; }

    .nsc-pwd-toggle {
        position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
        background: transparent; border: 0; cursor: pointer;
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        color: #94A3B8; border-radius: 6px;
        transition: color 0.15s, background 0.15s;
    }
    .nsc-pwd-toggle:hover { color: #475569; background: #F1F5F9; }
    .nsc-pwd-toggle svg { width: 18px; height: 18px; }

    .nsc-error {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 12px;
        background: #FEF2F2;
        color: #DC2626;
        border: 1px solid #FECACA;
        border-radius: 10px;
        font-size: 13px; font-weight: 500;
        margin-bottom: 16px;
    }
    .nsc-error svg { width: 18px; height: 18px; flex-shrink: 0; }

    .nsc-options {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 16px;
    }
    .nsc-checkbox {
        display: flex; align-items: center; gap: 6px;
        color: #64748B; font-size: 13px; cursor: pointer; user-select: none;
    }
    .nsc-checkbox input {
        appearance: none; -webkit-appearance: none;
        width: 16px; height: 16px;
        border: 1.5px solid #CBD5E1; border-radius: 4px;
        background: #fff; cursor: pointer;
        transition: all 0.15s;
        position: relative;
    }
    .nsc-checkbox input:checked {
        background: #0284C7; border-color: #0284C7;
    }
    .nsc-checkbox input:checked::after {
        content: ''; position: absolute;
        left: 4px; top: 1px;
        width: 4px; height: 8px;
        border: solid #fff; border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }
    .nsc-forgot {
        color: #0284C7; text-decoration: none;
        font-size: 13px; font-weight: 500;
    }
    .nsc-forgot:hover { color: #0369A1; text-decoration: underline; }

    .nsc-signin-btn {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #1B2537 0%, #4facfe 100%);
        color: #fff;
        font-family: inherit;
        font-weight: 700; font-size: 15px;
        border-radius: 12px;
        border: 0;
        cursor: pointer;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 14px rgba(79, 172, 254, 0.35);
        transition: transform 0.15s, box-shadow 0.25s;
    }
    .nsc-signin-btn:hover:not(:disabled) {
        box-shadow: 0 6px 22px rgba(79, 172, 254, 0.5);
        transform: translateY(-1px);
    }
    .nsc-signin-btn:disabled { opacity: 0.65; cursor: not-allowed; box-shadow: none; }

    .nsc-spinner {
        width: 16px; height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: nsc-spin 0.8s linear infinite;
        flex-shrink: 0;
    }
    @@keyframes nsc-spin { to { transform: rotate(360deg); } }

    .nsc-form-footer {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 20px;
        color: #9CA3AF; font-size: 12px;
    }
    .nsc-form-footer svg { width: 14px; height: 14px; color: #9CA3AF; }

    /* ── Entrance animations ─────────────────────────────────── */
    .anim { opacity: 0; transform: translateY(18px); animation: nsc-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .anim-1 { animation-delay: 0.08s; }
    .anim-2 { animation-delay: 0.18s; }
    .anim-3 { animation-delay: 0.28s; }
    .anim-4 { animation-delay: 0.38s; }
    .anim-5 { animation-delay: 0.48s; }
    .anim-6 { animation-delay: 0.58s; }
    .anim-7 { animation-delay: 0.68s; }
    .anim-card { opacity: 0; transform: translateX(32px) scale(0.97); animation: nsc-fade-card 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.25s; }
    .anim-logo { animation: nsc-logo-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; opacity: 0; transform: scale(0.6) rotate(-180deg); }
    @@keyframes nsc-fade-up { to { opacity: 1; transform: translateY(0); } }
    @@keyframes nsc-fade-card { to { opacity: 1; transform: translateX(0) scale(1); } }
    @@keyframes nsc-logo-in { to { opacity: 1; transform: scale(1) rotate(0deg); } }

    @@media (prefers-reduced-motion: reduce) {
        .anim, .anim-card, .anim-logo {
            opacity: 1 !important;
            transform: none !important;
            animation: none !important;
        }
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @@media (max-width: 900px) {
        .nsc-login { flex-direction: column; }
        .nsc-login-left { display: none; }
        .nsc-login-right {
            width: 100%; min-width: auto; min-height: 100vh;
            padding: 24px;
            background: linear-gradient(180deg, #E0F2FE 0%, #F8FAFC 100%);
        }
        .nsc-form-card { max-width: 100%; box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04); }
    }

    /* Chrome autofill — keep the slate-blue focus ring even when the field
       is pre-filled, and don't let the browser paint a yellow background. */
    .nsc-input-wrap input:-webkit-autofill,
    .nsc-input-wrap input:-webkit-autofill:hover,
    .nsc-input-wrap input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px #fff inset !important;
        -webkit-text-fill-color: #1E293B !important;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private bool _showPassword = false;
    private ElementReference _usernameInputRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await _usernameInputRef.FocusAsync(); }
            catch { /* ignore — autofocus is best-effort, non-critical */ }
        }
    }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Reason { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // If user is already authenticated, redirect to dashboard
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/dashboard", true);
            return;
        }

        // Show message if logged out due to inactivity or a server restart
        if (Reason == "inactivity")
        {
            errorMessage = "You have been logged out due to 15 minutes of inactivity. Please log in again.";
        }
        else if (Reason == "server_restart")
        {
            errorMessage = "Server restarted. Please log in again.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = false;
    }

    public class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
        public string RefreshToken { get; set; } = string.Empty;
        public int ExpiresIn { get; set; }
        public string TokenType { get; set; } = string.Empty;
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void HandleForgotPassword()
    {
        Snackbar.Add("Contact your administrator for password resets. Tel: +233 302 123456", Severity.Info);
    }

    private async Task HandleLogin()
    {
        Logger.LogInformation("Login button clicked for user: {Username}", loginModel.Username ?? "unknown");
        errorMessage = string.Empty;
        isLoading = true;
        StateHasChanged(); // Force UI update

        try
        {
            // Validate input
            if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
            {
                errorMessage = "Please enter username and password";
                Snackbar.Add(errorMessage, Severity.Warning);
                isLoading = false;
                return;
            }

            using var httpClient = HttpClientFactory.CreateClient("NickScanAPI");

            var loginRequest = new
            {
                Username = loginModel.Username,
                Password = loginModel.Password
            };

            var response = await httpClient.PostAsJsonAsync("/api/Authentication/login", loginRequest);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    try
                    {
                        Logger.LogInformation("Login successful for user: {Username}. Token received (length: {TokenLength})",
                            loginModel.Username, result.Token.Length);

                        await AuthProvider.LoginAsync(result.Token);
                        Logger.LogDebug("AuthProvider.LoginAsync completed for user: {Username}", loginModel.Username);

                        await PopulatePermissionClaimsAsync(httpClient, result.Token);

                        Logger.LogInformation("Navigating to dashboard for user: {Username}", loginModel.Username);
                        NavigationManager.NavigateTo("/dashboard", forceLoad: true);
                    }
                    catch (Exception navEx)
                    {
                        Logger.LogError(navEx, "Navigation error after successful login for user: {Username}", loginModel.Username);
                        Snackbar.Add($"Navigation failed: {navEx.Message}", Severity.Error);
                    }
                }
                else
                {
                    Logger.LogWarning("Login failed - no token in response for user: {Username}", loginModel.Username);
                    errorMessage = "Login failed. Invalid response from server.";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                var statusCode = response.StatusCode;
                Logger.LogWarning("Login API call failed with status {StatusCode} for user: {Username}",
                    statusCode, loginModel.Username);

                // Provide more specific error messages based on status code
                if (statusCode == System.Net.HttpStatusCode.Unauthorized ||
                    statusCode == System.Net.HttpStatusCode.Forbidden)
                {
                    errorMessage = "Invalid username or password. Please check your credentials and try again.";
                }
                else if (statusCode == System.Net.HttpStatusCode.ServiceUnavailable ||
                         statusCode == System.Net.HttpStatusCode.BadGateway)
                {
                    var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
                    errorMessage = $"⚠ API Service Unavailable (HTTP {statusCode}). " +
                                  $"The backend service at {apiUrl} may be temporarily down. " +
                                  $"Please try again in a few moments.";
                }
                else if (statusCode == System.Net.HttpStatusCode.InternalServerError)
                {
                    errorMessage = "Server Error (HTTP 500). The API server encountered an internal error. " +
                                  "Please contact support if this issue persists.";
                }
                else
                {
                    errorMessage = $"Login failed with error code {statusCode}. " +
                                  "Please try again or contact support if the problem continues.";
                }

                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (HttpRequestException httpEx)
        {
            // Check for connection refused errors
            var innerException = httpEx.InnerException;
            if (innerException is System.Net.Sockets.SocketException socketEx)
            {
                var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";

                // Socket error 10061 = Connection refused
                if (socketEx.SocketErrorCode == System.Net.Sockets.SocketError.ConnectionRefused)
                {
                    Logger.LogError(httpEx, "Connection refused to API server: {ApiUrl} for user: {Username}",
                        apiUrl, loginModel.Username ?? "unknown");

                    errorMessage = $"⚠ Cannot connect to API server at {apiUrl}. " +
                                  "The backend service may not be running. " +
                                  "Please verify the NickScan API service is started and accessible.";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
                else
                {
                    Logger.LogError(httpEx, "Network error connecting to API: {SocketError} for user: {Username}",
                        socketEx.SocketErrorCode, loginModel.Username ?? "unknown");

                    errorMessage = $"Network connection error: {socketEx.SocketErrorCode}. " +
                                  "Please check your network connection and ensure the API server is accessible.";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                // Other HTTP request exceptions
                Logger.LogError(httpEx, "HTTP request error for user: {Username}. Error: {ErrorMessage}",
                    loginModel.Username ?? "unknown", httpEx.Message);

                var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
                errorMessage = $"Connection error: {httpEx.Message}. " +
                              $"Unable to reach API server at {apiUrl}. " +
                              "Please verify the service is running and accessible.";
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (System.Net.Sockets.SocketException socketEx)
        {
            var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            Logger.LogError(socketEx, "Socket error connecting to API: {SocketError} at {ApiUrl} for user: {Username}",
                socketEx.SocketErrorCode, apiUrl, loginModel.Username ?? "unknown");

            if (socketEx.SocketErrorCode == System.Net.Sockets.SocketError.ConnectionRefused)
            {
                errorMessage = $"⚠ Connection Refused: Cannot reach API server at {apiUrl}. " +
                              "The backend service is not running or not accessible. " +
                              "Please start the NickScan Central Imaging Portal API service.";
            }
            else if (socketEx.SocketErrorCode == System.Net.Sockets.SocketError.TimedOut)
            {
                errorMessage = $"⏱ Connection Timeout: The API server at {apiUrl} did not respond in time. " +
                              "The service may be overloaded or unreachable.";
            }
            else
            {
                errorMessage = $"Network Error ({socketEx.SocketErrorCode}): Unable to connect to API server at {apiUrl}. " +
                              "Please check your network connection and firewall settings.";
            }

            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (TaskCanceledException timeoutEx)
        {
            var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            Logger.LogError(timeoutEx, "Request timeout connecting to API at {ApiUrl} for user: {Username}",
                apiUrl, loginModel.Username ?? "unknown");

            errorMessage = $"⏱ Request Timeout: The API server at {apiUrl} did not respond. " +
                          "The service may be busy or unreachable. Please try again in a moment.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected login error for user: {Username}. Error: {ErrorMessage}",
                loginModel.Username ?? "unknown", ex.Message);

            var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            errorMessage = $"Login failed: {ex.Message}. " +
                          $"If this persists, please verify the API server is running at {apiUrl}.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        finally
        {
            isLoading = false;
            Logger.LogDebug("Login handler finished for user: {Username}. isLoading = false", loginModel.Username ?? "unknown");
        }
    }

    private async Task PopulatePermissionClaimsAsync(HttpClient httpClient, string token)
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(token);

            var username = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value ?? loginModel.Username;
            var email = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value ?? string.Empty;
            var role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? string.Empty;

            var permissionClaims = jwt.Claims
                .Where(c => string.Equals(c.Type, "Permission", StringComparison.OrdinalIgnoreCase))
                .Select(c => c.Value)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            Logger.LogDebug("JWT parsed - Username: {Username}, Role: {Role}, Permission claims: {Count}",
                username, role, permissionClaims.Count);
            Logger.LogTrace("Permission claims for {Username}: {Permissions}",
                username, string.Join(", ", permissionClaims));

            if (permissionClaims.Count == 0)
            {
                try
                {
                    httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
                    var apiPermissions = await httpClient.GetFromJsonAsync<List<string>>("/api/permissions/my-permissions");
                    if (apiPermissions != null)
                    {
                        permissionClaims = apiPermissions
                            .Where(p => !string.IsNullOrWhiteSpace(p))
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();
                    }
                }
                catch (Exception permEx)
                {
                    Logger.LogWarning(permEx, "Unable to fetch permissions from API for user: {Username}", username);
                }
            }

            CustomAuthProvider.SetAuthenticatedUserWithPermissions(
                username,
                string.IsNullOrWhiteSpace(role) ? "Viewer" : role,
                email,
                permissionClaims);

            await AuthBootstrapper.RefreshAsync();
        }
        catch (Exception claimEx)
        {
            Logger.LogWarning(claimEx, "Permission claim processing failed for user: {Username}", loginModel.Username ?? "unknown");
            CustomAuthProvider.SetAuthenticatedUserWithPermissions(
                loginModel.Username ?? "unknown",
                "Viewer",
                string.Empty,
                new List<string>());

            await AuthBootstrapper.RefreshAsync();
        }
    }

    public class ServerLoginResponse
    {
        public bool Success { get; set; }
        public string Token { get; set; } = string.Empty;
        public object? User { get; set; }
    }
}
