    private void GoBack()
    {
        NavigationManager.NavigateTo($"/containers/{ContainerNumber}");
    }
    
    private void ZoomIn()
    {
        if (zoomLevel < 5.0) zoomLevel += 0.25;
    }
    
    private void ZoomOut()
    {
        if (zoomLevel > 0.25) zoomLevel -= 0.25;
    }
    
    private void ResetZoom()
    {
        zoomLevel = 1.0;
        panX = 0;
        panY = 0;
    }
    
    private void RotateLeft()
    {
        rotation = (rotation - 90) % 360;
        if (rotation < 0) rotation = 270;
    }
    
    private void RotateRight()
    {
        rotation = (rotation + 90) % 360;
    }
    
    private void ResetAll()
    {
        zoomLevel = 1.0;
        rotation = 0;
        _brightness = 100;
        _contrast = 100;
        _grayscale = false;
        _invertColors = false;
        _edgeDetect = false;
        panX = 0;
        panY = 0;
    }
    
    private void ToggleGrayscale()
    {
        _grayscale = !_grayscale;
    }
    
    private void ToggleInvert()
    {
        _invertColors = !_invertColors;
    }
    
    private void ToggleEdgeDetect()
    {
        _edgeDetect = !_edgeDetect;
        if (_edgeDetect)
        {
            _grayscale = true;
        }
    }
    
    private void ToggleEnhancement()
    {
        _useEnhancedImage = !_useEnhancedImage;
    }
    
    private string GetImageStyle()
    {
        var transform = $"scale({zoomLevel}) rotate({rotation}deg) translateX({panX}px) translateY({panY}px)";
        
        var filters = new List<string>();
        if (_brightness != 100) filters.Add($"brightness({_brightness}%)");
        if (_contrast != 100) filters.Add($"contrast({_contrast}%)");
        if (_grayscale) filters.Add("grayscale(100%)");
        if (_invertColors) filters.Add("invert(100%)");
        if (_edgeDetect)
        {
            filters.Add("contrast(300%)");
            filters.Add("brightness(120%)");
        }
        
        var filter = filters.Any() ? string.Join(" ", filters) : "none";
        
        return $"max-width: 100%; max-height: 100%; transform: {transform}; transition: transform 0.1s ease; filter: {filter}; user-select: none; pointer-events: none;";
    }
    
    private string GetImageUrl()
    {
        // Both branches use HMAC-signed short-lived URLs — the browser <img src>
        // tag that consumes GetImageUrl() cannot carry a JWT header, and the
        // cross-origin SameSite=Strict cookie does not flow. The API's
        // SignedImageUrlMiddleware validates on receipt.
        if (_useEnhancedImage && !string.IsNullOrEmpty(ContainerNumber))
        {
            return UrlBuilder.Build(
                NickScanWebApp.Shared.Services.ImageAnalysisWorkflowClient.BuildEnhancedImagePath(ContainerNumber),
                _currentUsername);
        }

        var sourcePath = ScanAssetClient.TryBuildImagePath(_sourceScanResolution, ContainerNumber, "full");
        return UrlBuilder.Build(
            sourcePath ?? NickScanWebApp.Shared.Services.ImageProcessingClient.BuildCompleteImagePath(ContainerNumber, size: "full"),
            _currentUsername);
    }
    
    private void HandleWheel(WheelEventArgs e)
    {
        if (e.DeltaY < 0)
            ZoomIn();
        else
            ZoomOut();
    }
    
    private void StartPan(MouseEventArgs e)
    {
        if (zoomLevel > 1.0 && !_drawMode)
        {
            isPanning = true;
            lastX = e.ClientX;
            lastY = e.ClientY;
        }
    }
    
    private void Pan(MouseEventArgs e)
    {
        if (isPanning && !_drawMode)
        {
            panX += e.ClientX - lastX;
            panY += e.ClientY - lastY;
            lastX = e.ClientX;
            lastY = e.ClientY;
        }
    }
    
    private void EndPan(MouseEventArgs e)
    {
        isPanning = false;
    }
    
    // Rectangle Drawing Methods
    private void ToggleDrawMode()
    {
        _drawMode = !_drawMode;
        if (!_drawMode)
        {
            _isDrawing = false;
            _currentRect = null;
            _selectedRectIndex = -1;
        }
    }
    
    private void HandleMouseDown(MouseEventArgs e)
    {
        if (_drawMode)
        {
            var clickedRectIndex = FindRectangleAt(e.OffsetX, e.OffsetY);
            if (clickedRectIndex >= 0)
            {
                _selectedRectIndex = clickedRectIndex;
                _isMoving = true;
                _drawStartX = e.OffsetX;
                _drawStartY = e.OffsetY;
            }
            else
            {
                _isDrawing = true;
                _selectedRectIndex = -1;
                _drawStartX = e.OffsetX;
                _drawStartY = e.OffsetY;
                _currentRect = new SuspiciousAreaRect
                {
                    X = e.OffsetX,
                    Y = e.OffsetY,
                    Width = 0,
                    Height = 0,
                    CreatedBy = _currentUsername
                };
            }
        }
        else
        {
            StartPan(e);
        }
    }
    
    private void HandleMouseMove(MouseEventArgs e)
    {
        if (_isDrawing && _currentRect != null)
        {
            _currentRect.Width = e.OffsetX - _drawStartX;
            _currentRect.Height = e.OffsetY - _drawStartY;
            
            if (_currentRect.Width < 0)
            {
                _currentRect.X = e.OffsetX;
                _currentRect.Width = Math.Abs(_currentRect.Width);
            }
            else
            {
                _currentRect.X = _drawStartX;
            }
            
            if (_currentRect.Height < 0)
            {
                _currentRect.Y = e.OffsetY;
                _currentRect.Height = Math.Abs(_currentRect.Height);
            }
            else
            {
                _currentRect.Y = _drawStartY;
            }
            
            StateHasChanged();
        }
        else if (_isResizing && _selectedRectIndex >= 0)
        {
            HandleResize(e);
        }
        else if (_isMoving && _selectedRectIndex >= 0)
        {
            var deltaX = e.OffsetX - _drawStartX;
            var deltaY = e.OffsetY - _drawStartY;
            _rectangles[_selectedRectIndex].X += deltaX;
            _rectangles[_selectedRectIndex].Y += deltaY;
            _drawStartX = e.OffsetX;
            _drawStartY = e.OffsetY;
            StateHasChanged();
        }
        else if (!_drawMode)
        {
            Pan(e);
        }
    }
    
    private async Task HandleMouseUp(MouseEventArgs e)
    {
        if (_isDrawing && _currentRect != null)
        {
            if (_currentRect.Width > 10 && _currentRect.Height > 10)
            {
                _rectangles.Add(_currentRect);
                await SaveRectangles();
            }
            _isDrawing = false;
            _currentRect = null;
        }
        else if (_isResizing)
        {
            _isResizing = false;
            await SaveRectangles();
        }
        else if (_isMoving)
        {
            _isMoving = false;
            await SaveRectangles();
        }
        else if (!_drawMode)
        {
            EndPan(e);
        }
    }
    
    private void HandleMouseLeave(MouseEventArgs e)
    {
        _isDrawing = false;
        _isResizing = false;
        _isMoving = false;
        _currentRect = null;
        if (!_drawMode)
        {
            EndPan(e);
        }
    }
    
    private int FindRectangleAt(double x, double y)
    {
        for (int i = _rectangles.Count - 1; i >= 0; i--)
        {
            var rect = _rectangles[i];
            if (x >= rect.X && x <= rect.X + rect.Width &&
                y >= rect.Y && y <= rect.Y + rect.Height)
            {
                return i;
            }
        }
        return -1;
    }
    
    private void StartResize(MouseEventArgs e, int index, ResizeHandle handle)
    {
        _selectedRectIndex = index;
        _isResizing = true;
        _currentResizeHandle = handle;
        _drawStartX = e.OffsetX;
        _drawStartY = e.OffsetY;
    }
    
    private void HandleResize(MouseEventArgs e)
    {
        if (_selectedRectIndex < 0 || _selectedRectIndex >= _rectangles.Count) return;
        
        var rect = _rectangles[_selectedRectIndex];
        var deltaX = e.OffsetX - _drawStartX;
        var deltaY = e.OffsetY - _drawStartY;

        switch (_currentResizeHandle)
        {
            case ResizeHandle.TopLeft:
                rect.X += deltaX;
                rect.Y += deltaY;
                rect.Width -= deltaX;
                rect.Height -= deltaY;
                break;
            case ResizeHandle.TopRight:
                rect.Y += deltaY;
                rect.Width += deltaX;
                rect.Height -= deltaY;
                break;
            case ResizeHandle.BottomLeft:
                rect.X += deltaX;
                rect.Width -= deltaX;
                rect.Height += deltaY;
                break;
            case ResizeHandle.BottomRight:
                rect.Width += deltaX;
                rect.Height += deltaY;
                break;
        }

        if (rect.Width < 20) rect.Width = 20;
        if (rect.Height < 20) rect.Height = 20;

        _drawStartX = e.OffsetX;
        _drawStartY = e.OffsetY;
        StateHasChanged();
    }
    
    private async Task DeleteRectangle(int index)
    {
        if (!PermissionGuard.Can(PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to remove annotations.", Severity.Warning);
            return;
        }

        if (index >= 0 && index < _rectangles.Count)
        {
            _rectangles.RemoveAt(index);
            _selectedRectIndex = -1;
            await SaveRectangles();
            Snackbar.Add("Annotation removed", Severity.Info);
        }
    }
    
    private async Task SaveRectangles()
    {
        if (!PermissionGuard.CanAny(PermissionIds.Images.Annotate, PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to save annotations.", Severity.Warning);
            return;
        }

        try
        {
            var rectanglesJson = System.Text.Json.JsonSerializer.Serialize(_rectangles);
            
            var request = new
            {
                ContainerNumber,
                ScannerType = _scannerType,
                SuspiciousAreas = rectanglesJson,
                ReviewedBy = _currentUsername
            };

            await DecisionClient.SaveRectanglesAsync(request);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving rectangles: {ex.Message}");
            Snackbar.Add("Error saving annotations", Severity.Error);
        }
    }
    
    // Tags and Decision Methods
    private void AddTag()
    {
        if (!string.IsNullOrWhiteSpace(_newTag) && !_tags.Contains(_newTag.Trim()))
        {
            _tags.Add(_newTag.Trim());
            _newTag = "";
            StateHasChanged();
        }
    }
    
    private void QuickAddTag(string tag)
    {
        if (!_tags.Contains(tag))
        {
            _tags.Add(tag);
            StateHasChanged();
        }
    }
    
    private void RemoveTag(string tag)
    {
        _tags.Remove(tag);
        StateHasChanged();
    }
    
    private Task HandleTagKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag();
        }
        return Task.CompletedTask;
    }
    
    private async Task SaveTagsAndDecision()
    {
        if (!PermissionGuard.CanAny(PermissionIds.Images.Annotate, PermissionIds.Images.Edit))
        {
            Snackbar.Add("You do not have permission to save decisions or tags.", Severity.Warning);
            return;
        }

        try
        {
            if (string.Equals(_selectedDecision, "Pending", StringComparison.OrdinalIgnoreCase))
            {
                Snackbar.Add("Please select a decision (Normal or Abnormal) before saving", Severity.Warning);
                return;
            }
            
            var tagsString = string.Join(", ", _tags);

            var request = new
            {
                ContainerNumber,
                ScannerType = _scannerType,
                Decision = _selectedDecision,
                Comments = "",
                Tags = tagsString,
                ReviewedBy = _currentUsername,
                // AI training flywheel — controlled finding categories. Either or
                // both may be null. Backend preserves prior values when null.
                ThreatCategoryId = _selectedThreatCategoryId,
                RevenueAnomalyCategoryId = _selectedRevenueAnomalyCategoryId
            };

            await DecisionClient.SaveDecisionAsync(request);
            Snackbar.Add("Decision and tags saved", Severity.Success);
            
            // Close the page after successful save
            await Task.Delay(500); // Brief delay to show success message
            GoBack();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving decision and tags: {ex.Message}");
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task DownloadImage()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", $@"
                fetch('{GetImageUrl()}')
                    .then(response => response.blob())
                    .then(blob => {{
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = '{ContainerNumber}_{_scannerType}_{DateTime.Now:yyyyMMdd}.jpg';
                        document.body.appendChild(a);
                        a.click();
                        document.body.removeChild(a);
                        window.URL.revokeObjectURL(url);
                    }});
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Download error: {ex.Message}");
            Snackbar.Add("Error downloading image", Severity.Error);
        }
    }
    
    private async Task PrintImage()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", $@"
                const printWindow = window.open('', '_blank');
                printWindow.document.write('<html><head><title>Print Image - {ContainerNumber}</title></head><body style=""margin:0;display:flex;justify-content:center;align-items:center;min-height:100vh;"">');
                printWindow.document.write('<img src=""{GetImageUrl()}"" style=""max-width:100%;max-height:100vh;"" />');
                printWindow.document.write('</body></html>');
                printWindow.document.close();
                printWindow.focus();
                setTimeout(() => printWindow.print(), 500);
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Print error: {ex.Message}");
            Snackbar.Add("Error printing image", Severity.Error);
        }
    }
    
