    private string TruncateValue(string? value, int maxLength = 50)
    {
        if (string.IsNullOrEmpty(value)) return "-";
        return value.Length > maxLength ? value.Substring(0, maxLength) + "..." : value;
    }

    // AppSettings.json methods
    private async Task LoadAppSettings()
    {
        try
        {
            isLoadingAppSettings = true;
            Snackbar.Add("Loading appsettings.json...", Severity.Info);
            
            appSettingsSections = await SettingsService.GetAppSettingsSectionsAsync();
            appSettingsData.Clear();
            appSettingsChanges.Clear();

            // Load all sections in parallel
            var tasks = appSettingsSections.Select(async section =>
            {
                try
                {
                    var data = await SettingsService.GetAppSettingsSectionAsync(section);
                    appSettingsData[section] = data;
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Error loading appsettings section {Section}", section);
                }
            });

            await Task.WhenAll(tasks);
            
            Snackbar.Add($"✅ Loaded {appSettingsSections.Count} appsettings.json sections", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error loading appsettings: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoadingAppSettings = false;
        }
    }

    private RenderFragment RenderAppSettingsSection(string sectionPath, Dictionary<string, object> data)
    {
        return builder =>
        {
            foreach (var kvp in data.OrderBy(x => x.Key))
            {
                var key = kvp.Key;
                var value = kvp.Value;

                // Handle nested objects
                if (value is Dictionary<string, object> nestedDict)
                {
                    builder.OpenComponent<MudExpansionPanel>(0);
                    builder.AddAttribute(1, "Text", key);
                    builder.AddAttribute(2, "IsExpanded", true);
                    builder.AddAttribute(3, "ChildContent", (RenderFragment)(builder2 => 
                    {
                        var nestedFragment = RenderAppSettingsSection($"{sectionPath}:{key}", nestedDict);
                        nestedFragment(builder2);
                    }));
                    builder.CloseComponent();
                }
                else if (value is JsonElement jsonElement)
                {
                    // Handle JSON elements
                    if (jsonElement.ValueKind == JsonValueKind.Object)
                    {
                        var nested = JsonSerializer.Deserialize<Dictionary<string, object>>(jsonElement.GetRawText());
                        if (nested != null)
                        {
                            builder.OpenComponent<MudExpansionPanel>(0);
                            builder.AddAttribute(1, "Text", key);
                            builder.AddAttribute(2, "IsExpanded", true);
                            builder.AddAttribute(3, "ChildContent", (RenderFragment)(builder2 => 
                            {
                                var nestedFragment = RenderAppSettingsSection($"{sectionPath}:{key}", nested);
                                nestedFragment(builder2);
                            }));
                            builder.CloseComponent();
                        }
                    }
                    else if (jsonElement.ValueKind == JsonValueKind.Array)
                    {
                        builder.OpenElement(0, "div");
                        builder.AddAttribute(1, "class", "ma-2");
                        builder.OpenComponent<MudTextField<string>>(2);
                        builder.AddAttribute(3, "Label", key);
                        builder.AddAttribute(4, "Value", jsonElement.GetRawText());
                        builder.AddAttribute(5, "Variant", Variant.Outlined);
                        builder.AddAttribute(6, "Lines", 3);
                        builder.AddAttribute(7, "ValueChanged", EventCallback.Factory.Create<string>(this, (val) =>
                        {
                            UpdateAppSettingsValue(sectionPath, key, val);
                        }));
                        builder.CloseComponent();
                        builder.CloseElement();
                    }
                    else
                    {
                        RenderSettingField(builder, sectionPath, key, jsonElement.GetRawText());
                    }
                }
                else
                {
                    RenderSettingField(builder, sectionPath, key, value?.ToString() ?? "");
                }
            }
        };
    }

    private void RenderSettingField(RenderTreeBuilder builder, string sectionPath, string key, string value)
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "ma-2");
        
        var isPassword = key.Contains("Password", StringComparison.OrdinalIgnoreCase) || 
                         key.Contains("Secret", StringComparison.OrdinalIgnoreCase) ||
                         key.Contains("Key", StringComparison.OrdinalIgnoreCase) && value?.Contains("***USE_ENV_VAR") != true;

        builder.OpenComponent<MudTextField<string>>(2);
        builder.AddAttribute(3, "Label", key);
        builder.AddAttribute(4, "Value", value);
        builder.AddAttribute(5, "Variant", Variant.Outlined);
        builder.AddAttribute(6, "ValueChanged", EventCallback.Factory.Create<string>(this, (val) =>
        {
            UpdateAppSettingsValue(sectionPath, key, val ?? "");
        }));
        
        if (isPassword && !value?.Contains("***USE_ENV_VAR") == true)
        {
            builder.AddAttribute(7, "InputType", InputType.Password);
            builder.AddAttribute(8, "Adornment", Adornment.End);
            builder.AddAttribute(9, "AdornmentIcon", Icons.Material.Outlined.Lock);
            builder.AddAttribute(10, "AdornmentColor", Color.Warning);
        }
        else if (value?.Contains("***USE_ENV_VAR") == true)
        {
            builder.AddAttribute(11, "HelperText", "This value uses an environment variable placeholder");
            builder.AddAttribute(12, "Disabled", true);
        }
        
        builder.CloseComponent();
        builder.CloseElement();
    }

    private void UpdateAppSettingsValue(string sectionPath, string key, string value)
    {
        var section = sectionPath.Split(':').First();
        if (!appSettingsChanges.ContainsKey(section))
        {
            appSettingsChanges[section] = new Dictionary<string, object>();
        }

        // Handle nested paths
        if (sectionPath.Contains(':'))
        {
            // For nested, we'll need to reconstruct the structure
            // For now, store with flattened key
            appSettingsChanges[section][key] = value;
        }
        else
        {
            appSettingsChanges[section][key] = value;
        }
    }

    private async Task SaveAppSettingsSection(string section)
    {
        try
        {
            isSaving = true;
            
            if (!appSettingsChanges.ContainsKey(section) || !appSettingsChanges[section].Any())
            {
                Snackbar.Add("No changes to save", Severity.Info);
                return;
            }

            var success = await SettingsService.UpdateAppSettingsSectionAsync(
                section, 
                appSettingsChanges[section], 
                currentUsername);

            if (success)
            {
                Snackbar.Add($"✅ Section '{section}' saved successfully. Application restart required.", Severity.Success);
                appSettingsChanges[section].Clear();
                await LoadAppSettings(); // Reload to show updated values
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving section: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleApiShutdown()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "This will gracefully shut down the API service.\n\nAll background tasks will complete before shutdown.\nThe WebApp will lose its backend until the API is restarted.\n\nContinue?");
        if (!confirmed) return;

        isApiShuttingDown = true; isShuttingDown = true;
        try
        {
            await SystemAdminClient.ShutdownAsync<object>();
            Snackbar.Add("API shutdown initiated. Background tasks are completing.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { isApiShuttingDown = false; isShuttingDown = false; }
    }

    private async Task HandleApiRestart()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "This will gracefully restart the API service.\n\nBackground tasks will complete, then the API will restart automatically.\n\nContinue?");
        if (!confirmed) return;

        isApiRestarting = true; isRestarting = true;
        try
        {
            await SystemAdminClient.RestartAsync<object>();
            Snackbar.Add("API restart initiated. It will be back in a few seconds.", Severity.Success);
            await Task.Delay(8000);
            isApiRestarting = false; isRestarting = false;
            Snackbar.Add("API should be back up now.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); isApiRestarting = false; isRestarting = false; }
    }

    private async Task HandleWebAppShutdown()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "This will shut down the Web Application.\n\nYou will lose your current session and this page will stop working.\n\nContinue?");
        if (!confirmed) return;

        isWebAppShuttingDown = true; isShuttingDown = true;
        try
        {
            await SystemAdminClient.ShutdownWebAppAsync<object>();
            Snackbar.Add("WebApp shutdown initiated.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); isWebAppShuttingDown = false; isShuttingDown = false; }
    }

    private async Task HandleWebAppRestart()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "This will restart the Web Application.\n\nYou will be briefly disconnected and the page will reload.\n\nContinue?");
        if (!confirmed) return;

        isWebAppRestarting = true; isRestarting = true;
        try
        {
            await SystemAdminClient.RestartWebAppAsync<object>();
            Snackbar.Add("WebApp restart initiated. Page will reload shortly.", Severity.Success);
            await Task.Delay(8000);
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); isWebAppRestarting = false; isRestarting = false; }
    }

    private async Task HandleRestartAll()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "This will restart BOTH the API and Web Application.\n\nAll services will go down briefly.\n\nContinue?");
        if (!confirmed) return;

        isRestartingAll = true; isRestarting = true;
        try
        {
            // Restart WebApp first (it depends on API), then API
            await SystemAdminClient.RestartWebAppAsync<object>();
            Snackbar.Add("WebApp restart initiated.", Severity.Info);
            await Task.Delay(2000);
            await SystemAdminClient.RestartAsync<object>();
            Snackbar.Add("API restart initiated. All services restarting.", Severity.Success);
            await Task.Delay(10000);
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); isRestartingAll = false; isRestarting = false; }
    }

