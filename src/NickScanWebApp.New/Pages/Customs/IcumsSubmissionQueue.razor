@page "/icums/submission-queue"
@page "/customs/icums/submissions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesIcumsSubmissionQueue)]
@using NickScanWebApp.New.Components.ICUMS
@using NickScanWebApp.New.Models.ICUMS
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.IcumsSubmissionQueueClient SubmissionQueueClient

<PageTitle>Submission Queue - ICUMS Integration</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="@breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Header -->
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h4">
                    <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Class="mr-2" />
                    ICUMS Submission Queue
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Monitor validation result submissions to ICUMS
                </MudText>
            </div>
            <MudButton Variant="Variant.Outlined" 
                      Color="Color.Default"
                      StartIcon="@Icons.Material.Outlined.Refresh"
                      OnClick="@RefreshQueue">
                Refresh
            </MudButton>
        </MudStack>
    </MudPaper>
    
    <!-- Stats -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Pending"
                     Value="@pendingCount.ToString()"
                     Icon="@Icons.Material.Outlined.PendingActions"
                     Color="@Color.Warning"
                     Trend="Queued for submission" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Submitting"
                     Value="@submittingCount.ToString()"
                     Icon="@Icons.Material.Outlined.CloudUpload"
                     Color="@Color.Info"
                     Trend="In progress" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Successful Today"
                     Value="@successfulToday.ToString()"
                     Icon="@Icons.Material.Outlined.CheckCircle"
                     Color="@Color.Success"
                     Trend="@GetSuccessfulTrendText()"
                     TrendDirection="@GetSuccessfulTrendDirection()" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Failed Today"
                     Value="@failedToday.ToString()"
                     Icon="@Icons.Material.Outlined.Error"
                     Color="@(failedToday > 0 ? Color.Error : Color.Success)"
                     Trend="@(failedToday > 0 ? "Needs retry" : "All good")" />
        </MudItem>
    </MudGrid>
    
    <!-- Filter Tabs -->
    <MudPaper Elevation="2" Class="rounded-lg">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">
            
            <!-- All Submissions -->
            <MudTabPanel Text="All" Icon="@Icons.Material.Outlined.List" BadgeData="@submissions.Count">
                <SubmissionTable Items="@submissions" OnRetry="@RetrySubmission" OnCancel="@CancelSubmission" />
            </MudTabPanel>
            
            <!-- Pending -->
            <MudTabPanel Text="Pending" Icon="@Icons.Material.Outlined.PendingActions" BadgeData="@pendingSubmissions.Count" BadgeColor="Color.Warning">
                <SubmissionTable Items="@pendingSubmissions" OnRetry="@RetrySubmission" OnCancel="@CancelSubmission" />
            </MudTabPanel>
            
            <!-- Submitting -->
            <MudTabPanel Text="Submitting" Icon="@Icons.Material.Outlined.CloudUpload" BadgeData="@submittingSubmissions.Count" BadgeColor="Color.Info">
                <SubmissionTable Items="@submittingSubmissions" OnRetry="@RetrySubmission" OnCancel="@CancelSubmission" />
            </MudTabPanel>
            
            <!-- Successful -->
            <MudTabPanel Text="Successful" Icon="@Icons.Material.Outlined.CheckCircle" BadgeData="@successfulSubmissions.Count" BadgeColor="Color.Success">
                <SubmissionTable Items="@successfulSubmissions" OnRetry="@RetrySubmission" OnCancel="@CancelSubmission" />
            </MudTabPanel>
            
            <!-- Failed -->
            <MudTabPanel Text="Failed" Icon="@Icons.Material.Outlined.Error" BadgeData="@failedSubmissions.Count" BadgeColor="Color.Error">
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                    @failedSubmissions.Count failed submission(s). Review errors and retry.
                </MudAlert>
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary"
                          StartIcon="@(_isRetryingAll ? Icons.Material.Outlined.HourglassTop : Icons.Material.Outlined.Replay)"
                          OnClick="@(async () => await RetryAllFailed())"
                          Class="mb-4"
                          Disabled="@(!failedSubmissions.Any() || _isRetryingAll)">
                    @if (_isRetryingAll)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @:Retrying...
                    }
                    else
                    {
                        @:Retry All Failed (@failedSubmissions.Count)
                    }
                </MudButton>
                <SubmissionTable Items="@failedSubmissions" OnRetry="@RetrySubmission" OnCancel="@CancelSubmission" ShowError="true" />
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudContainer>

@code {
    private List<BreadcrumbItem> breadcrumbs = new();
    
    private int pendingCount = 5;
    private int submittingCount = 2;
    private int successfulToday = 142;
    private int successfulYesterday = 0;
    private int failedToday = 2;
    
    private bool _isRetryingAll = false;
    
    private List<SubmissionQueueItem> submissions = new();
    private List<SubmissionQueueItem> pendingSubmissions => submissions.Where(x => x.Status == "Pending").ToList();
    private List<SubmissionQueueItem> submittingSubmissions => submissions.Where(x => x.Status == "Processing").ToList();
    private List<SubmissionQueueItem> successfulSubmissions => submissions.Where(x => x.Status == "Submitted").ToList();
    private List<SubmissionQueueItem> failedSubmissions => submissions.Where(x => x.Status == "Failed").ToList();
    
    protected override async Task OnInitializedAsync()
    {
        breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home),
            new BreadcrumbItem("ICUMS", href: "/icums", icon: Icons.Material.Outlined.Cloud),
            new BreadcrumbItem("Submission Queue", href: null, disabled: true)
        };
        
        await LoadQueueData();
        await LoadStatistics();
    }
    
    private async Task LoadQueueData()
    {
        try
        {
            var items = await SubmissionQueueClient.GetItemsAsync<SubmissionQueueItem>(limit: 100);
            submissions = items ?? new List<SubmissionQueueItem>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading queue data: {ex.Message}", Severity.Error);
            submissions = new List<SubmissionQueueItem>();
        }
    }

    private async Task LoadStatistics()
    {
        try
        {
            var stats = await SubmissionQueueClient.GetStatsAsync<SubmissionStats>();
            if (stats != null)
            {
                pendingCount = stats.Pending;
                submittingCount = stats.Submitting;
                successfulToday = stats.SuccessfulToday;
                failedToday = stats.FailedToday;
            }
            
            // Calculate yesterday's successful count
            var yesterday = DateTime.Today.AddDays(-1);
            var yesterdayStart = yesterday;
            var yesterdayEnd = yesterday.AddDays(1);
            
            try
            {
                // Get successful items from yesterday
                var yesterdayItems = await SubmissionQueueClient.GetItemsAsync<SubmissionQueueItem>(
                    status: "Submitted",
                    startDate: yesterdayStart,
                    endDate: yesterdayEnd);
                successfulYesterday = yesterdayItems?.Count ?? 0;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not calculate yesterday's successful count: {ex.Message}");
                successfulYesterday = 0;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading statistics: {ex.Message}", Severity.Error);
        }
    }
    
    private string GetSuccessfulTrendText()
    {
        if (successfulYesterday == 0)
        {
            return successfulToday > 0 ? "New today" : "No data yesterday";
        }
        
        var change = successfulToday - successfulYesterday;
        var changeSymbol = change >= 0 ? "+" : "";
        return $"{changeSymbol}{change} from yesterday";
    }
    
    private string? GetSuccessfulTrendDirection()
    {
        if (successfulYesterday == 0) return null;
        return successfulToday >= successfulYesterday ? "up" : "down";
    }
    
    private async Task RefreshQueue()
    {
        await LoadQueueData();
        await LoadStatistics();
        Snackbar.Add("Queue refreshed", Severity.Success);
    }
    
    private async Task RetrySubmission(int id)
    {
        try
        {
            await SubmissionQueueClient.RetryAsync(id);
            await LoadQueueData();
            Snackbar.Add("Retry initiated", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error retrying submission: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task CancelSubmission(int id)
    {
        try
        {
            await SubmissionQueueClient.CancelAsync(id);
            await LoadQueueData();
            Snackbar.Add("Submission cancelled", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cancelling submission: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task RetryAllFailed()
    {
        var itemsToRetry = failedSubmissions.ToList();
        if (!itemsToRetry.Any()) return;

        _isRetryingAll = true;
        StateHasChanged();

        int successCount = 0;
        int failCount = 0;

        foreach (var item in itemsToRetry)
        {
            try
            {
                await SubmissionQueueClient.RetryAsync(item.Id);
                successCount++;
            }
            catch
            {
                failCount++;
            }
        }

        _isRetryingAll = false;

        if (failCount == 0)
        {
            Snackbar.Add($"Successfully retried all {successCount} failed submission(s)", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Retried {successCount} of {itemsToRetry.Count} submissions ({failCount} failed)", Severity.Warning);
        }

        await LoadQueueData();
        await LoadStatistics();
    }
    
    public class SubmissionStats
    {
        public int Pending { get; set; }
        public int Submitting { get; set; }
        public int Successful { get; set; }
        public int Failed { get; set; }
        public int SuccessfulToday { get; set; }
        public int FailedToday { get; set; }
    }
}

