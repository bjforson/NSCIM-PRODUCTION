    // ✅ CONSOLIDATED CARGO MODEL - Load cargo groups
    private async Task LoadCargoGroups()
    {
        isLoadingCargoGroups = true;
        try
        {
            Logger.LogInformation("[ContainerCompleteness] Loading cargo groups from consolidated cargo API...");
            
            // ✅ PERFORMANCE FIX: Reduced pageSize from 100 to 25 for faster loading
            // Load non-consolidated cargo groups
            var nonConsolidatedResponse = await ApiService.GetAsync<List<NonConsolidatedCargoGroup>>("/api/consolidatedcargo/non-consolidated?pageSize=25");
            if (nonConsolidatedResponse != null)
            {
                nonConsolidatedGroups = nonConsolidatedResponse;
                Logger.LogInformation("[ContainerCompleteness] Loaded {Count} non-consolidated cargo groups", nonConsolidatedGroups.Count);
                Snackbar.Add($"Loaded {nonConsolidatedGroups.Count} non-consolidated cargo groups", Severity.Success);
            }
            else
            {
                nonConsolidatedGroups = new List<NonConsolidatedCargoGroup>();
                Logger.LogWarning("[ContainerCompleteness] No non-consolidated cargo groups returned from API");
            }
            
            // ✅ PERFORMANCE FIX: Reduced pageSize from 100 to 25 for faster loading
            // Load consolidated cargo groups
            var consolidatedResponse = await ApiService.GetAsync<List<ConsolidatedCargoGroup>>("/api/consolidatedcargo/consolidated?pageSize=25");
            if (consolidatedResponse != null)
            {
                consolidatedGroups = consolidatedResponse;
                Logger.LogInformation("[ContainerCompleteness] Loaded {Count} consolidated cargo groups", consolidatedGroups.Count);
                Snackbar.Add($"Loaded {consolidatedGroups.Count} consolidated cargo groups", Severity.Success);
            }
            else
            {
                consolidatedGroups = new List<ConsolidatedCargoGroup>();
                Logger.LogWarning("[ContainerCompleteness] No consolidated cargo groups returned from API");
            }
            
            StateHasChanged(); // Force UI update
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ContainerCompleteness] Error loading cargo groups: {Message}", ex.Message);
            Snackbar.Add($"Could not load cargo groups from API: {ex.Message}", Severity.Error);
            nonConsolidatedGroups = new List<NonConsolidatedCargoGroup>();
            consolidatedGroups = new List<ConsolidatedCargoGroup>();
        }
        finally
        {
            isLoadingCargoGroups = false;
        }
    }
    
