    protected override async Task OnInitializedAsync()
    {
        breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home),
            new BreadcrumbItem("Validation", href: "#", icon: Icons.Material.Outlined.FactCheck),
            new BreadcrumbItem("Container Completeness", href: null, disabled: true)
        };
        
        // ✅ Wait for authentication to be ready before making API calls
        await WaitForAuthenticationAsync();
        
        await LoadData();
        await LoadValidationData();
        await LoadCargoGroups();
        await LoadQueuePublishingHealth();
        await LoadRecordSummaryAsync();

        // ✅ AUTO-REFRESH: Refresh data every 30 seconds for real-time updates
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadData();
                await LoadValidationData();
                await LoadCargoGroups();
                await LoadRecordSummaryAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    // 1.15.0 — Record Completeness summary for the banner at the top of this page
    private RecordIntegritySummary? _recordSummary;

    private async Task LoadRecordSummaryAsync()
    {
