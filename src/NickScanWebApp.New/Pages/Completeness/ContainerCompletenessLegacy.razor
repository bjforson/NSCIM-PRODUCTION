    private void ApplyFilters()
    {
        filteredMissingData = allMissingData.Where(d =>
        {
            if (filterScanner != "All" && d.ScannerType != filterScanner)
                return false;
                
            if (!string.IsNullOrWhiteSpace(searchTerm) && !d.ContainerNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                return false;
                
            if (filterAge != "All")
            {
                var daysAgo = (DateTime.Now - d.ScanDate).Days;
                var match = filterAge switch
                {
                    "Today" => daysAgo == 0,
                    "Last7Days" => daysAgo <= 7,
                    "Last30Days" => daysAgo <= 30,
                    "Older" => daysAgo > 30,
                    _ => true
                };
                if (!match) return false;
            }
            
            return true;
        }).ToList();
        
        Snackbar.Add($"{filteredMissingData.Count} containers match filters", Severity.Info);
    }
    
