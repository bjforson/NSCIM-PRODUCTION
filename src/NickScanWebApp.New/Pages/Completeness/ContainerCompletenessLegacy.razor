@page "/validation"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesValidationCompleteness)]
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject NickScanWebApp.New.Services.ApiService ApiService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ContainerCompletenessLegacy> Logger
@implements IDisposable

<PageTitle>NICKSCAN ERP — NSCIS — Container Completeness</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="@breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Header -->
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h4">
                    <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Class="mr-2" />
                    Container Completeness Dashboard
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Monitor data completeness between scanner systems and ICUMS
                </MudText>
            </div>
            <MudStack Row="true" Spacing="2">
                <MudChip T="string" 
                         Size="Size.Medium" 
                         Color="@(serviceRunning ? Color.Success : Color.Error)" 
                         Icon="@(serviceRunning ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Error)">
                    Service: @(serviceRunning ? "Running" : "Stopped")
                </MudChip>
                <MudButton Variant="Variant.Outlined"
                          Color="Color.Primary"
                          StartIcon="@Icons.Material.Outlined.AccountTree"
                          Href="/validation/record-completeness">
                    Record Completeness
                </MudButton>
                <MudButton Variant="Variant.Filled"
                          Color="Color.Primary"
                          StartIcon="@Icons.Material.Outlined.PlayArrow"
                          OnClick="@TriggerManualCheck"
                          Disabled="@isChecking">
                    @if (isChecking)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Checking...</span>
                    }
                    else
                    {
                        <span>Check Now</span>
                    }
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @* ── 1.15.0 — Record Integrity Banner ───────────────────────────────── *@
    @* Shows the record-level integrity gap at a glance and routes operators to the
       new declaration-anchored view. Non-intrusive: sits above the existing
       container-grain overview and leaves all existing controls untouched. *@
    @if (_recordSummary != null && _recordSummary.TotalRecords > 0)
    {
        <MudPaper Elevation="0" Class="mb-4 pa-3" Outlined="true"
                  Style="@(_recordSummary.PartiallyReady > 0 || _recordSummary.IntegrityGapContainers > 0
                          ? "border-left: 4px solid var(--mud-palette-warning);"
                          : "border-left: 4px solid var(--mud-palette-success);")">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Large"
                         Color="@(_recordSummary.PartiallyReady > 0 ? Color.Warning : Color.Primary)" />
                <div>
                    <MudText Typo="Typo.subtitle1"><b>Record Completeness</b> — declaration-level view</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Proactive ICUMS reconciliation (1.14.0). Records with missing containers are now visible before they would have been missed.
                    </MudText>
                </div>
                <MudSpacer />
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Records</MudText>
                        <MudText Typo="Typo.h6">@_recordSummary.TotalRecords</MudText>
                    </MudStack>
                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Multi-container</MudText>
                        <MudText Typo="Typo.h6">@_recordSummary.TotalMultiContainer</MudText>
                    </MudStack>
                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Partially Ready</MudText>
                        <MudText Typo="Typo.h6" Color="@(_recordSummary.PartiallyReady > 0 ? Color.Warning : Color.Default)">
                            @_recordSummary.PartiallyReady
                        </MudText>
                    </MudStack>
                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Integrity gap</MudText>
                        <MudText Typo="Typo.h6" Color="@(_recordSummary.IntegrityGapContainers > 0 ? Color.Warning : Color.Success)">
                            @_recordSummary.IntegrityGapContainers containers
                        </MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               EndIcon="@Icons.Material.Outlined.ArrowForward"
                               Href="/validation/record-completeness?status=PartiallyReady">
                        View records
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    <!-- Overview Stats -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%); color: white;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Total Scanned</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Inventory" />
                    </MudStack>
                    <MudText Typo="Typo.h4">@totalContainers</MudText>
                    <MudText Typo="Typo.caption">All scanner records</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #388e3c 0%, #2e7d32 100%); color: white;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Complete</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                    </MudStack>
                    <MudText Typo="Typo.h4">@completeContainers</MudText>
                    <MudProgressLinear Color="Color.Success" Value="@completenessRate" Min="0" Max="100" Size="Size.Small" Rounded="true" Style="background: rgba(255,255,255,0.2);" />
                    <MudText Typo="Typo.caption">@completenessRate.ToString("F1")% Completeness</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #d32f2f 0%, #c62828 100%); color: white;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Missing ICUMS Data</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" />
                    </MudStack>
                    <MudText Typo="Typo.h4">@missingContainers</MudText>
                    <MudText Typo="Typo.caption">@criticalMissing critical</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #f57c00 0%, #ef6c00 100%); color: white;">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="opacity: 0.9;">Failed Requests</MudText>
                        <MudIcon Icon="@Icons.Material.Outlined.Error" />
                    </MudStack>
                    <MudText Typo="Typo.h4">@failedRequests</MudText>
                    <MudText Typo="Typo.caption">Need retry</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
    
    <!-- Scanner Breakdown -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Scanner" Color="Color.Primary" Class="mr-2" />
                        FS6000 Completeness
                    </MudText>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.End">
                        <div>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@fs6000Complete</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">of @fs6000Total containers</MudText>
                        </div>
                        <MudText Typo="Typo.h5" Color="@(fs6000Rate >= 95 ? Color.Success : fs6000Rate >= 85 ? Color.Warning : Color.Error)">
                            @fs6000Rate.ToString("F1")%
                        </MudText>
                    </MudStack>
                    <MudProgressLinear Color="@(fs6000Rate >= 95 ? Color.Success : fs6000Rate >= 85 ? Color.Warning : Color.Error)" 
                                      Value="@fs6000Rate" 
                                      Min="0" 
                                      Max="100" 
                                      Size="Size.Medium"
                                      Rounded="true" />
                    <MudText Typo="Typo.caption" Color="Color.Error">@fs6000Missing missing</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Scanner" Color="Color.Secondary" Class="mr-2" />
                        ASE Completeness
                    </MudText>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.End">
                        <div>
                            <MudText Typo="Typo.h4" Color="Color.Secondary">@aseComplete</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">of @aseTotal containers</MudText>
                        </div>
                        <MudText Typo="Typo.h5" Color="@(aseRate >= 95 ? Color.Success : aseRate >= 85 ? Color.Warning : Color.Error)">
                            @aseRate.ToString("F1")%
                        </MudText>
                    </MudStack>
                    <MudProgressLinear Color="@(aseRate >= 95 ? Color.Success : aseRate >= 85 ? Color.Warning : Color.Error)" 
                                      Value="@aseRate" 
                                      Min="0" 
                                      Max="100" 
                                      Size="Size.Medium"
                                      Rounded="true" />
                    <MudText Typo="Typo.caption" Color="Color.Error">@aseMissing missing</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Timer" Color="Color.Info" Class="mr-2" />
                        Service Status
                    </MudText>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr>
                                <td><MudText Typo="Typo.caption">Status</MudText></td>
                                <td><MudChip T="string" Size="Size.Small" Color="@(serviceRunning ? Color.Success : Color.Error)">@(serviceRunning ? "Running" : "Stopped")</MudChip></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption">Last Check</MudText></td>
                                <td><MudText Typo="Typo.caption">@lastCheckTime.ToString("HH:mm:ss")</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption">Next Check</MudText></td>
                                <td><MudText Typo="Typo.caption" Color="Color.Info">in @nextCheckIn</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption">Interval</MudText></td>
                                <td><MudText Typo="Typo.caption">Every 5 minutes</MudText></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
    
    <!-- Main Content -->
    <MudPaper Elevation="2" Class="rounded-lg">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">
            
            <!-- Cargo Groups Tab - Consolidated Model (FIRST TAB - PRIMARY VIEW) -->
            <MudTabPanel Text="Cargo Groups" Icon="@Icons.Material.Outlined.Inventory2" BadgeData="@(nonConsolidatedGroups.Count + consolidatedGroups.Count)" BadgeColor="Color.Info">
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" Color="Color.Info">
                    <!-- Non-Consolidated Sub-Tab -->
                    <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Outlined.LocalShipping" BadgeData="@nonConsolidatedGroups.Count" BadgeColor="Color.Primary">
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            <MudText>Non-Consolidated Cargo: One Master BL covers multiple containers. Expand to see all containers under each Master BL.</MudText>
                        </MudAlert>
                        
                        <MudTable Items="@nonConsolidatedGroups" 
                                 Dense="true" 
                                 Hover="true" 
                                 Breakpoint="Breakpoint.Sm"
                                 Loading="@isLoadingCargoGroups"
                                 ExpandableRows="true"
                                 @bind-ExpandedItems="expandedNonConsolidated">
                            <HeaderContent>
                                <MudTh>Declaration Number</MudTh>
                                <MudTh>Master BL</MudTh>
                                <MudTh>Containers</MudTh>
                                <MudTh>Consignee</MudTh>
                                <MudTh>Clearance Type</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Declaration">
                                    <MudText Typo="Typo.body2"><strong>@context.DeclarationNumber</strong></MudText>
                                </MudTd>
                                <MudTd DataLabel="Master BL">
                                    <MudText Typo="Typo.body2">@context.MasterBL</MudText>
                                </MudTd>
                                <MudTd DataLabel="Containers">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                        @context.Containers.Count / @context.NoOfContainers
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Consignee">
                                    <MudText Typo="Typo.caption">@context.ConsigneeName</MudText>
                                </MudTd>
                                <MudTd DataLabel="Clearance Type">
                                    <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(context.ClearanceType)">
                                        @context.ClearanceType
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                  Size="Size.Small"
                                                  Color="Color.Info"
                                                  Href="@($"/containers/{context.Containers.FirstOrDefault()}")"
                                                  Disabled="@(!context.Containers.Any())" />
                                </MudTd>
                            </RowTemplate>
                            <ChildRowContent>
                                <MudTd ColSpan="6">
                                    <MudCard Elevation="1" Class="ma-2">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudText Typo="Typo.h6">Containers under Declaration @context.DeclarationNumber</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Master BL: @context.MasterBL</MudText>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            <MudSimpleTable Dense="true">
                                                <thead>
                                                    <tr>
                                                        <th>Container Number</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var container in context.Containers)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <MudLink Href="@($"/containers/{container}")">
                                                                    <strong>@container</strong>
                                                                </MudLink>
                                                            </td>
                                                            <td>
                                                                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                              Size="Size.Small"
                                                                              Color="Color.Info"
                                                                              Href="@($"/containers/{container}")" />
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudCardContent>
                                    </MudCard>
                                </MudTd>
                            </ChildRowContent>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                            <NoRecordsContent>
                                <MudAlert Severity="Severity.Info">No non-consolidated cargo groups found.</MudAlert>
                            </NoRecordsContent>
                        </MudTable>
                    </MudTabPanel>
                    
                    <!-- Consolidated Sub-Tab -->
                    <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Outlined.Inventory" BadgeData="@consolidatedGroups.Count" BadgeColor="Color.Warning">
                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            <MudText>Consolidated Cargo: One Master BL has multiple House BLs (different consignees). A Master BL can span one or multiple containers. Expand to see all House BLs and containers under each Master BL.</MudText>
                        </MudAlert>
                        
                        <MudTable Items="@consolidatedGroups" 
                                 Dense="true" 
                                 Hover="true" 
                                 Breakpoint="Breakpoint.Sm"
                                 Loading="@isLoadingCargoGroups"
                                 ExpandableRows="true"
                                 @bind-ExpandedItems="expandedConsolidated">
                            <HeaderContent>
                                <MudTh>Master BL</MudTh>
                                <MudTh>Containers</MudTh>
                                <MudTh>House BLs</MudTh>
                                <MudTh>Clearance Type</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Master BL">
                                    <MudText Typo="Typo.body2"><strong>@context.MasterBL</strong></MudText>
                                </MudTd>
                                <MudTd DataLabel="Containers">
                                    @if (context.ContainerNumbers.Any())
                                    {
                                        <MudStack Spacing="1">
                                            @foreach (var container in context.ContainerNumbers.Take(3))
                                            {
                                                <MudLink Href="@($"/containers/{container}")" Typo="Typo.caption">
                                                    @container
                                                </MudLink>
                                            }
                                            @if (context.ContainerNumbers.Count > 3)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    +@(context.ContainerNumbers.Count - 3) more
                                                </MudText>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">No containers</MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="House BLs">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                        @context.HouseBLDetails.Count HBLs
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Clearance Type">
                                    @if (context.HouseBLDetails.Any())
                                    {
                                        var clearanceType = context.HouseBLDetails.First().ClearanceType;
                                        <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(clearanceType)">
                                            @clearanceType
                                        </MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    @if (context.ContainerNumbers.Any())
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                      Size="Size.Small"
                                                      Color="Color.Info"
                                                      Href="@($"/containers/{context.ContainerNumbers.First()}")" />
                                    }
                                </MudTd>
                            </RowTemplate>
                            <ChildRowContent>
                                <MudTd ColSpan="5">
                                    <MudCard Elevation="1" Class="ma-2">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudText Typo="Typo.h6">House BLs under Master BL: @context.MasterBL</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @context.ContainerNumbers.Count container(s): @string.Join(", ", context.ContainerNumbers)
                                                </MudText>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            <MudSimpleTable Dense="true" Striped="true">
                                                <thead>
                                                    <tr>
                                                        <th>House BL</th>
                                                        <th>Declaration</th>
                                                        <th>Consignee</th>
                                                        <th>Clearance Type</th>
                                                        <th>Container</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var hbl in context.HouseBLDetails)
                                                    {
                                                        <tr>
                                                            <td><strong>@hbl.HouseBL</strong></td>
                                                            <td>@hbl.DeclarationNumber</td>
                                                            <td>@hbl.ConsigneeName</td>
                                                            <td>
                                                                <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(hbl.ClearanceType)">
                                                                    @hbl.ClearanceType
                                                                </MudChip>
                                                            </td>
                                                            <td>
                                                                <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                    @hbl.ContainerNumber
                                                                </MudLink>
                                                            </td>
                                                            <td>
                                                                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                              Size="Size.Small"
                                                                              Color="Color.Info"
                                                                              Href="@($"/containers/{hbl.ContainerNumber}")" />
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudCardContent>
                                    </MudCard>
                                </MudTd>
                            </ChildRowContent>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                            </PagerContent>
                            <NoRecordsContent>
                                <MudAlert Severity="Severity.Info">No consolidated cargo groups found.</MudAlert>
                            </NoRecordsContent>
                        </MudTable>
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
            
            <!-- Missing Data Tab -->
            <MudTabPanel Text="Missing Data" Icon="@Icons.Material.Outlined.Warning" BadgeData="@missingContainers" BadgeColor="Color.Error">
                
                <!-- Filters -->
                <MudGrid Class="mb-4">
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" @bind-Value="filterScanner" Label="Scanner" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@("All")">All Scanners</MudSelectItem>
                            <MudSelectItem T="string" Value="@("FS6000")">FS6000</MudSelectItem>
                            <MudSelectItem T="string" Value="@("ASE")">ASE</MudSelectItem>
                            <MudSelectItem T="string" Value="@("HeimannSmith")">Heimann Smith</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" @bind-Value="filterAge" Label="Age" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@("All")">All Ages</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Today")">Today</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Last7Days")">Last 7 Days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Last30Days")">Last 30 Days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Older")">Older than 30 Days</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" @bind-Value="searchTerm" Label="Search" Placeholder="Container number..." Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Search" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="@ApplyFilters">Apply</MudButton>
                    </MudItem>
                </MudGrid>
                
                <!-- Bulk Actions for Selected -->
                @if (selectedMissing.Any())
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText><strong>@selectedMissing.Count</strong> container(s) selected</MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudButton Size="Size.Small" 
                                          Variant="Variant.Filled" 
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Outlined.CloudDownload"
                                          OnClick="@BulkRequestBOE">
                                    Request BOE for Selected
                                </MudButton>
                                <MudButton Size="Size.Small" 
                                          Variant="Variant.Outlined" 
                                          Color="Color.Default"
                                          StartIcon="@Icons.Material.Outlined.Download"
                                          OnClick="@ExportSelected">
                                    Export
                                </MudButton>
                                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="@ClearSelection" />
                            </MudStack>
                        </MudStack>
                    </MudAlert>
                }
                
                <!-- Missing Data Table -->
                <MudTable Items="@filteredMissingData" 
                         Dense="true" 
                         Hover="true" 
                         Breakpoint="Breakpoint.Sm"
                         MultiSelection="true"
                         @bind-SelectedItems="selectedMissing"
                         Loading="@isLoading">
                    <HeaderContent>
                        <MudTh>Container Number</MudTh>
                        <MudTh>Scanner</MudTh>
                        <MudTh>Scan Date</MudTh>
                        <MudTh>Days Missing</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Retries</MudTh>
                        <MudTh>Last Checked</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Container">
                            <MudLink Href="@($"/containers/{context.ContainerNumber}")">
                                <strong>@context.ContainerNumber</strong>
                            </MudLink>
                        </MudTd>
                        <MudTd DataLabel="Scanner">
                            <MudChip T="string" Size="Size.Small" Color="@GetScannerColor(context.ScannerType)">
                                @context.ScannerType
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Scan Date">
                            <MudText Typo="Typo.caption">@context.ScanDate.ToString("dd MMM yyyy")</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ScanDate.ToString("HH:mm")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Days Missing">
                            <MudChip T="string" 
                                     Size="Size.Small" 
                                     Color="@GetAgeColor(context.DaysMissing)">
                                @context.DaysMissing days
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" 
                                     Size="Size.Small" 
                                     Color="@GetStatusColor(context.Status)"
                                     Icon="@GetStatusIcon(context.Status)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Retries">
                            @if (context.RetryCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.RetryCount</MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">-</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Last Checked">
                            @if (context.LastChecked.HasValue)
                            {
                                <MudText Typo="Typo.caption">@context.LastChecked.Value.ToString("dd MMM HH:mm")</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Never</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Outlined.CloudDownload"
                                              Size="Size.Small"
                                              Color="Color.Primary"
                                              OnClick="@(() => RequestBOE(context.ContainerNumber))"
                                              title="Request BOE from ICUMS" />
                                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                              Size="Size.Small"
                                              Color="Color.Default"
                                              Href="@($"/containers/{context.ContainerNumber}")"
                                              title="View container details" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                    <NoRecordsContent>
                        <EmptyState Icon="@Icons.Material.Outlined.CheckCircle"
                                   Message="All containers are complete!"
                                   SubMessage="Every scanned container has corresponding ICUMS data"
                                   Height="300">
                            <ActionButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Outlined.Celebration">
                                    Excellent! 100% Complete
                                </MudButton>
                            </ActionButton>
                        </EmptyState>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>
            
            <!-- Complete Data Tab -->
            <MudTabPanel Text="Complete" Icon="@Icons.Material.Outlined.CheckCircle" BadgeData="@completeContainers" BadgeColor="Color.Success">
                <MudTable Items="@completeData" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading">
                    <HeaderContent>
                        <MudTh>Container Number</MudTh>
                        <MudTh>Scanner</MudTh>
                        <MudTh>Scan Date</MudTh>
                        <MudTh>ICUMS Data Date</MudTh>
                        <MudTh>Time to Complete</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Container">
                            <MudLink Href="@($"/containers/{context.ContainerNumber}")">
                                @context.ContainerNumber
                            </MudLink>
                        </MudTd>
                        <MudTd DataLabel="Scanner">
                            <MudChip T="string" Size="Size.Small" Color="@GetScannerColor(context.ScannerType)">
                                @context.ScannerType
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Scan Date">
                            <MudText Typo="Typo.caption">@context.ScanDate.ToString("dd MMM yyyy HH:mm")</MudText>
                        </MudTd>
                        <MudTd DataLabel="ICUMS Date">
                            @if (context.ICUMSDataDate.HasValue)
                            {
                                <MudText Typo="Typo.caption">@context.ICUMSDataDate.Value.ToString("dd MMM yyyy HH:mm")</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">-</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Time to Complete">
                            @if (context.ICUMSDataDate.HasValue)
                            {
                                var timeSpan = context.ICUMSDataDate.Value - context.ScanDate;
                                <MudText Typo="Typo.caption">@FormatTimeSpan(timeSpan)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">-</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                          Size="Size.Small"
                                          Href="@($"/containers/{context.ContainerNumber}")" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            
            <!-- Analytics Tab -->
            <MudTabPanel Text="Analytics" Icon="@Icons.Material.Outlined.Analytics">
                <MudPaper Elevation="0" Class="pa-8">
                    <MudStack AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Outlined.Analytics" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h5" Color="Color.Secondary">Analytics -- Coming Soon</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            Completeness trends, scanner distribution charts, and time-to-completion analysis
                            will be available in a future update.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudTabPanel>
            
            <!-- Service Logs Tab -->
            <MudTabPanel Text="Service Logs" Icon="@Icons.Material.Outlined.History">
                @if (serviceLogs.Any())
                {
                    <MudTable Items="@serviceLogs" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Recent Service Runs</MudText>
                            <MudSpacer />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Last 50 checks</MudText>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Run Time</MudTh>
                            <MudTh>Processed</MudTh>
                            <MudTh>New</MudTh>
                            <MudTh>Updated</MudTh>
                            <MudTh>Skipped</MudTh>
                            <MudTh>Duration</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Run Time">
                                <MudText Typo="Typo.caption">@context.RunTime.ToString("dd MMM HH:mm:ss")</MudText>
                            </MudTd>
                            <MudTd DataLabel="Processed">@context.ProcessedCount</MudTd>
                            <MudTd DataLabel="New">@context.NewCount</MudTd>
                            <MudTd DataLabel="Updated">@context.UpdatedCount</MudTd>
                            <MudTd DataLabel="Skipped">@context.SkippedCount</MudTd>
                            <MudTd DataLabel="Duration">@context.Duration.TotalSeconds.ToString("F1")s</MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@(context.Success ? Color.Success : Color.Error)">
                                    @(context.Success ? "Success" : "Failed")
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                    </MudTable>
                }
                else
                {
                    <MudPaper Elevation="0" Class="pa-8">
                        <MudStack AlignItems="AlignItems.Center" Spacing="3">
                            <MudIcon Icon="@Icons.Material.Outlined.History" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.h5" Color="Color.Secondary">Service Logs -- Coming Soon</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                Service run history and detailed processing logs will be available once the logging integration is complete.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
            </MudTabPanel>
            
            <!-- Ready for Validation Tab -->
            <MudTabPanel Text="Ready for Validation" Icon="@Icons.Material.Outlined.FactCheck" BadgeData="@readyForValidationCount" BadgeColor="Color.Info">
                <MudStack Spacing="3">
                    <!-- Filters -->
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudGrid>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSelect T="string" 
                                          Label="Clearance Type" 
                                          Variant="Variant.Outlined"
                                          @bind-Value="filterClearanceType"
                                          Clearable="true">
                                    <MudSelectItem T="string">All Types</MudSelectItem>
                                    <MudSelectItem T="string">CMR</MudSelectItem>
                                    <MudSelectItem T="string">IMEX</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSelect T="string" 
                                          Label="Scanner Type" 
                                          Variant="Variant.Outlined"
                                          @bind-Value="filterScannerType"
                                          Clearable="true">
                                    <MudSelectItem T="string">All Scanners</MudSelectItem>
                                    <MudSelectItem T="string">ASE</MudSelectItem>
                                    <MudSelectItem T="string">FS6000</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudSelect T="string" 
                                          Label="Status" 
                                          Variant="Variant.Outlined"
                                          @bind-Value="filterStatus"
                                          Clearable="true">
                                    <MudSelectItem T="string">All Status</MudSelectItem>
                                    <MudSelectItem T="string">Pending</MudSelectItem>
                                    <MudSelectItem T="string">Validated</MudSelectItem>
                                    <MudSelectItem T="string">In Review</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudTextField T="string" 
                                             Label="Search" 
                                             Variant="Variant.Outlined"
                                             @bind-Value="searchTerm"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Outlined.Search"
                                             Placeholder="Container number..." />
                            </MudItem>
                        </MudGrid>
                        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                            <MudButton Variant="Variant.Filled" 
                                      Color="Color.Primary"
                                      StartIcon="@Icons.Material.Outlined.FilterList"
                                      OnClick="@ApplyValidationFilters">
                                Apply Filters
                            </MudButton>
                        </MudStack>
                    </MudPaper>

                    <!-- Validation Table -->
                    <MudPaper Elevation="1">
                        <MudTable T="ValidationContainerItem" 
                                 Items="@filteredValidationContainers" 
                                 Dense="true"
                                 Hover="true"
                                 Striped="true"
                                 Loading="@isLoadingValidationData"
                                 FixedHeader="true"
                          Height="600px"
                          MultiSelection="true"
                          @bind-SelectedItems="selectedValidationContainers">
                    <HeaderContent>
                        <MudTh>Container Number</MudTh>
                        <MudTh>Clearance Type</MudTh>
                        <MudTh>Scanner</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Data Completeness</MudTh>
                        <MudTh>Scanner Data</MudTh>
                        <MudTh>ICUMS Data</MudTh>
                        <MudTh>Image Data</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Container Number">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.body2">@context.ContainerNumber</MudText>
                                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" 
                                                      Size="Size.Small"
                                               OnClick="@(() => CopyToClipboard(context.ContainerNumber))" />
                                    </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Clearance Type">
                            <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(context.ClearanceType)" Variant="Variant.Filled">
                                @context.ClearanceType
                                    </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Scanner">
                            <MudChip T="string" Size="Size.Small" Color="@GetScannerTypeColor(context.ScannerType)" Variant="Variant.Filled">
                                @context.ScannerType
                                    </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@GetValidationStatusColor(context.Status)" Variant="Variant.Filled" Icon="@GetValidationStatusIcon(context.Status)">
                                @context.Status
                                    </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Data Completeness">
                                    <MudStack Spacing="1">
                                <MudProgressLinear Color="@GetCompletenessColor(context.DataCompletenessPercentage)"
                                                   Value="@context.DataCompletenessPercentage"
                                                   Min="0" Max="100" Size="Size.Small" Rounded="true" />
                                <MudText Typo="Typo.caption" Color="@GetCompletenessColor(context.DataCompletenessPercentage)">
                                    @context.DataCompletenessPercentage%
                                        </MudText>
                                    </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Scanner Data">
                                    <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="@(context.ScannerDataPercentage == 100 ? Color.Success : Color.Warning)">
                                    @(context.ScannerDataPercentage == 100 ? "Complete" : "Incomplete")
                                        </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ScannerDataPercentage%</MudText>
                                    </MudStack>
                        </MudTd>
                        <MudTd DataLabel="ICUMS Data">
                                    <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="@(context.ICUMSDataPercentage == 100 ? Color.Success : Color.Warning)">
                                    @(context.ICUMSDataPercentage == 100 ? "Complete" : "Incomplete")
                                        </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ICUMSDataPercentage%</MudText>
                                    </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Image Data">
                            <MudChip T="string" Size="Size.Small" Color="@(context.HasImageData ? Color.Success : Color.Error)" Variant="Variant.Filled">
                                @(context.HasImageData ? "Available" : "Missing")
                                    </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created">
                            <MudText Typo="Typo.caption">@context.CreatedAt.ToString("MMM dd, yyyy HH:mm")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                                    <MudStack Row="true" Spacing="1">
                                        <MudIconButton Icon="@Icons.Material.Outlined.Visibility" 
                                                      Size="Size.Small"
                                                      Color="Color.Info"
                                               OnClick="@(() => ViewContainer(context.ContainerNumber))" />
                                @if (context.Status == "Validated")
                                        {
                                            <MudIconButton Icon="@Icons.Material.Outlined.Check" 
                                                          Size="Size.Small"
                                                          Color="Color.Success"
                                                   OnClick="@(() => ApproveContainer(context.ContainerNumber))" />
                                            <MudIconButton Icon="@Icons.Material.Outlined.Close" 
                                                          Size="Size.Small"
                                                          Color="Color.Error"
                                                   OnClick="@(() => RejectContainer(context.ContainerNumber))" />
                                        }
                                    </MudStack>
                        </MudTd>
                    </RowTemplate>
                        </MudTable>
                        
                        <!-- Pagination -->
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3">
                            <MudText Typo="Typo.body2">
                                Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, totalValidationContainers)) of @totalValidationContainers containers
                            </MudText>
                            <MudPagination Count="@totalPages" 
                                          Selected="@currentPage" 
                                          SelectedChanged="@((int page) => OnPageChanged(page))" />
                        </MudStack>
                    </MudPaper>
                    
                    <!-- Queue Publishing Health Section -->
                    <MudDivider Class="my-4" />
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Outlined.HealthAndSafety" Class="mr-2" Color="Color.Primary" />
                                    Queue Publishing Health
                                    @if (queuePublishingHealth?.Alerts?.Count > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2">
                                            @queuePublishingHealth.Alerts.Count alerts
                                        </MudChip>
                                    }
                                </MudText>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudChip T="string" Size="Size.Small" Color="@GetQueueHealthStatusColor()" Icon="@GetQueueHealthStatusIcon()">
                                        @(queuePublishingHealth?.Status ?? "Loading...")
                                    </MudChip>
                                    <MudButton Variant="Variant.Text" 
                                              Color="Color.Primary"
                                              Size="Size.Small"
                                              StartIcon="@Icons.Material.Outlined.Refresh"
                                              OnClick="@LoadQueuePublishingHealth"
                                              Disabled="@isLoadingQueuePublishingHealth">
                                        Refresh
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                            
                            @if (queuePublishingHealth?.Metrics != null)
                            {
                                <!-- Overview Metrics Cards -->
                                <MudGrid>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudPaper Elevation="2" Class="pa-3 rounded-lg" Style="background: linear-gradient(135deg, #388e3c 0%, #2e7d32 100%); color: white;">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Style="opacity: 0.9;">Success Rate</MudText>
                                                <MudText Typo="Typo.h5">@queuePublishingHealth.Metrics.SuccessRate.ToString("F2")%</MudText>
                                                <MudProgressLinear Color="Color.Success" Value="@queuePublishingHealth.Metrics.SuccessRate" Min="0" Max="100" Size="Size.Small" Rounded="true" Style="background: rgba(255,255,255,0.2);" />
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudPaper Elevation="2" Class="pa-3 rounded-lg" Style="background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%); color: white;">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Style="opacity: 0.9;">Total Attempts</MudText>
                                                <MudText Typo="Typo.h5">@queuePublishingHealth.Metrics.TotalAttempts</MudText>
                                                <MudText Typo="Typo.caption">@queuePublishingHealth.Metrics.SuccessfulPublishes successful</MudText>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudPaper Elevation="2" Class="pa-3 rounded-lg" Style="background: linear-gradient(135deg, #d32f2f 0%, #c62828 100%); color: white;">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Style="opacity: 0.9;">Failed Publishes</MudText>
                                                <MudText Typo="Typo.h5">@queuePublishingHealth.Metrics.FailedPublishes</MudText>
                                                <MudText Typo="Typo.caption">@queuePublishingHealth.Metrics.SkippedPublishes skipped</MudText>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="3">
                                        <MudPaper Elevation="2" Class="pa-3 rounded-lg" Style="background: linear-gradient(135deg, #f57c00 0%, #ef6c00 100%); color: white;">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Style="opacity: 0.9;">Avg Retry Count</MudText>
                                                <MudText Typo="Typo.h5">@queuePublishingHealth.Metrics.AverageRetryCount.ToString("F2")</MudText>
                                                <MudText Typo="Typo.caption">@queuePublishingHealth.Metrics.TotalRetries total retries</MudText>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                <!-- Alerts -->
                                @if (queuePublishingHealth.Alerts != null && queuePublishingHealth.Alerts.Any())
                                {
                                    <MudPaper Elevation="1" Class="pa-3">
                                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                                            <MudIcon Icon="@Icons.Material.Outlined.Warning" Class="mr-2" Color="Color.Warning" />
                                            Active Alerts
                                        </MudText>
                                        <MudStack Spacing="1">
                                            @foreach (var alert in queuePublishingHealth.Alerts)
                                            {
                                                var severity = alert.Contains("[Critical]", StringComparison.OrdinalIgnoreCase) ? Severity.Error : Severity.Warning;
                                                <MudAlert Severity="@severity" Variant="Variant.Filled" Dense="true">@alert</MudAlert>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                }

                                <!-- Metrics Summary Table -->
                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudPaper Elevation="1" Class="pa-3">
                                            <MudText Typo="Typo.subtitle1" Class="mb-2">Performance Metrics</MudText>
                                            <MudSimpleTable Dense="true">
                                                <tbody>
                                                    <tr><td><MudText Typo="Typo.caption">Avg Publish Duration</MudText></td><td><MudText Typo="Typo.body2">@FormatDuration(queuePublishingHealth.Metrics.AveragePublishDuration)</MudText></td></tr>
                                                    <tr><td><MudText Typo="Typo.caption">Time Window</MudText></td><td><MudText Typo="Typo.body2">@FormatTimeSpan(queuePublishingHealth.Metrics.TimeWindow)</MudText></td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudPaper Elevation="1" Class="pa-3">
                                            <MudText Typo="Typo.subtitle1" Class="mb-2">Statistics</MudText>
                                            <MudSimpleTable Dense="true">
                                                <tbody>
                                                    <tr><td><MudText Typo="Typo.caption">Total Attempts</MudText></td><td><MudText Typo="Typo.body2">@queuePublishingHealth.Metrics.TotalAttempts</MudText></td></tr>
                                                    <tr><td><MudText Typo="Typo.caption">Total Retries</MudText></td><td><MudText Typo="Typo.body2">@queuePublishingHealth.Metrics.TotalRetries</MudText></td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                <!-- Recent Failures -->
                                @if (queuePublishingHealth.Metrics.RecentFailures != null && queuePublishingHealth.Metrics.RecentFailures.Any())
                                {
                                    <MudPaper Elevation="1" Class="pa-3">
                                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                                            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Class="mr-2" Color="Color.Error" />
                                            Recent Failures (Last 5)
                                        </MudText>
                                        <MudTable Items="@queuePublishingHealth.Metrics.RecentFailures.Take(5)" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                                            <HeaderContent>
                                                <MudTh>Timestamp</MudTh>
                                                <MudTh>Scanner</MudTh>
                                                <MudTh>Retries</MudTh>
                                                <MudTh>Error</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd DataLabel="Timestamp"><MudText Typo="Typo.caption">@context.Timestamp.ToString("HH:mm:ss")</MudText></MudTd>
                                                <MudTd DataLabel="Scanner"><MudChip T="string" Size="Size.Small" Color="@GetScannerColor(context.ScannerType)">@context.ScannerType</MudChip></MudTd>
                                                <MudTd DataLabel="Retries"><MudText Typo="Typo.body2">@context.RetryCount</MudText></MudTd>
                                                <MudTd DataLabel="Error"><MudText Typo="Typo.caption" Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">@context.ErrorMessage</MudText></MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </MudPaper>
                                }
                            }
                            else if (isLoadingQueuePublishingHealth)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Loading queue publishing health...</MudText>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">Queue publishing health data is not available.</MudAlert>
                            }
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudTabPanel>

            <!-- Settings Tab -->
            <MudTabPanel Text="Settings" Icon="@Icons.Material.Outlined.Settings">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" Class="mb-4">Service Configuration</MudText>
                        <MudStack Spacing="3">
                            <MudNumericField T="int" 
                                            @bind-Value="checkInterval" 
                                            Label="Check Interval (minutes)" 
                                            Variant="Variant.Outlined"
                                            Min="1"
                                            Max="60" />
                            <MudSwitch T="bool" 
                                      @bind-Value="autoRequestMissing" 
                                      Color="Color.Primary" 
                                      Label="Auto-request missing BOE data" />
                            <MudSwitch T="bool" 
                                      @bind-Value="enableNotifications" 
                                      Color="Color.Primary" 
                                      Label="Enable notifications for missing data" />
                            <MudDivider />
                            <MudButton Variant="Variant.Filled" 
                                      Color="Color.Primary" 
                                      StartIcon="@Icons.Material.Outlined.Save"
                                      OnClick="@(() => Snackbar.Add("Settings saved", Severity.Success))">
                                Save Settings
                            </MudButton>
                        </MudStack>
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" Class="mb-4">Service Control</MudText>
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Outlined" 
                                      Color="@(serviceRunning ? Color.Error : Color.Success)"
                                      StartIcon="@(serviceRunning ? Icons.Material.Outlined.Stop : Icons.Material.Outlined.PlayArrow)"
                                      FullWidth="true"
                                      OnClick="@ToggleService">
                                @(serviceRunning ? "Stop Service" : "Start Service")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" 
                                      Color="Color.Info"
                                      StartIcon="@Icons.Material.Outlined.Refresh"
                                      FullWidth="true"
                                      OnClick="@(() => Snackbar.Add("Restarting service...", Severity.Info))">
                                Restart Service
                            </MudButton>
                            <MudDivider Class="my-2" />
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Service will check @totalContainers containers every @checkInterval minutes
                            </MudAlert>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudContainer>

@code {
