    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
    
    /// <summary>
    /// Wait for authentication to be ready before making API calls
    /// </summary>
    private async Task WaitForAuthenticationAsync()
    {
        try
        {
            // Wait for authentication state to be available
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            // If using SimpleAuthStateProvider, wait for token to be available
            if (AuthStateProvider is NickScanWebApp.New.Services.SimpleAuthStateProvider simpleAuth)
            {
                var token = await simpleAuth.GetTokenAsync();
                if (string.IsNullOrEmpty(token))
                {
                    // Wait a bit and retry (token might still be loading from session storage)
                    await Task.Delay(100);
                    token = await simpleAuth.GetTokenAsync();
                }
                
                if (!string.IsNullOrEmpty(token))
                {
                    Logger.LogInformation("[ContainerCompleteness] ✅ Authentication token available");
                }
                else
                {
                    Logger.LogWarning("[ContainerCompleteness] ⚠️ No authentication token available yet");
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ContainerCompleteness] Error waiting for authentication: {Message}", ex.Message);
        }
    }
    
    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // ✅ CONNECTED TO REAL API
            // Load statistics
            var stats = await ApiService.GetAsync<CompletenessStatsApi>("/api/containercompleteness/stats");
            if (stats != null)
            {
                totalContainers = stats.TotalContainers;
                completeContainers = stats.CompleteContainers;
                missingContainers = stats.MissingContainers;
                failedRequests = stats.FailedRequests;
                completenessRate = stats.CompletenessRate;
                
                fs6000Total = stats.FS6000Total;
                fs6000Complete = stats.FS6000Complete;
                fs6000Missing = stats.FS6000Missing;
                fs6000Rate = fs6000Total > 0 ? (double)fs6000Complete / fs6000Total * 100 : 0;
                
                aseTotal = stats.ASETotal;
                aseComplete = stats.ASEComplete;
                aseMissing = stats.ASEMissing;
                aseRate = aseTotal > 0 ? (double)aseComplete / aseTotal * 100 : 0;
                
                lastCheckTime = stats.LastCheckTime;
                serviceRunning = stats.ServiceRunning;
            }
            
            // Load missing containers
            var missingResponse = await ApiService.GetAsync<List<ApiMissingContainer>>("/api/containercompleteness/missing");
            if (missingResponse != null)
            {
                allMissingData = missingResponse.Select(m => new MissingContainerData
                {
                    ContainerNumber = m.ContainerNumber ?? "",
                    ScannerType = m.ScannerType ?? "Unknown",
                    ScanDate = m.ScanDate,
                    DaysMissing = (int)(DateTime.Now - m.ScanDate).TotalDays,
                    Status = m.Status ?? "Missing",
                    RetryCount = m.RetryCount,
                    LastChecked = m.LastCheckedAt
                }).ToList();
                
                filteredMissingData = allMissingData;
                criticalMissing = allMissingData.Count(m => m.DaysMissing > 7);
            }
            
            // Load complete containers
            var completeResponse = await ApiService.GetAsync<List<ApiMissingContainer>>("/api/containercompleteness/complete");
            if (completeResponse != null)
            {
                completeData = completeResponse.Select(m => new CompleteContainerData
                {
                    ContainerNumber = m.ContainerNumber ?? "",
                    ScannerType = m.ScannerType ?? "Unknown",
                    ScanDate = m.ScanDate,
                    ICUMSDataDate = null
                }).ToList();
            }
            
            // Initialize service logs with empty list
            serviceLogs = new List<ServiceLogEntry>();
            
            Snackbar.Add("Completeness data loaded from API", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading completeness data: {Message}", ex.Message);
            
            // Reset to zero instead of showing fake data
            totalContainers = 0;
            completeContainers = 0;
            missingContainers = 0;
            failedRequests = 0;
            completenessRate = 0;
            
            fs6000Total = 0;
            fs6000Complete = 0;
            fs6000Missing = 0;
            fs6000Rate = 0;
            
            aseTotal = 0;
            aseComplete = 0;
            aseMissing = 0;
            aseRate = 0;
            
            allMissingData = new List<MissingContainerData>();
            filteredMissingData = new List<MissingContainerData>();
            criticalMissing = 0;
            completeData = new List<CompleteContainerData>();
            serviceLogs = new List<ServiceLogEntry>();
            
            Snackbar.Add($"Error loading completeness data: {ex.Message}. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
