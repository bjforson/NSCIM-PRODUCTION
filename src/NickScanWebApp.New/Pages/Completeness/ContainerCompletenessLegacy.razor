    private async Task TriggerManualCheck()
    {
        isChecking = true;
        Snackbar.Add("Triggering completeness check...", Severity.Info);
        
        try
        {
            // ✅ CONNECTED TO REAL API
            var response = await ApiService.PostAsync<object, object>("/api/containercompleteness/trigger-check", new { });
            
            lastCheckTime = DateTime.Now;
            Snackbar.Add("Completeness check completed successfully", Severity.Success);
            
            await LoadData(); // Refresh data
        }
        catch (Exception ex)
