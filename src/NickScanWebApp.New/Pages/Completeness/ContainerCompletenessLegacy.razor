    // Queue Publishing Health Methods
    private async Task LoadQueuePublishingHealth()
    {
        isLoadingQueuePublishingHealth = true;
        try
        {
            Logger.LogInformation("[ContainerCompleteness] Loading queue publishing health data...");
            
            var response = await ApiService.GetAsync<QueuePublishingHealthResponse>("/api/QueueHealth/publishing");
            
            if (response != null)
            {
                queuePublishingHealth = response;
                Logger.LogInformation("[ContainerCompleteness] Loaded queue publishing health: Status={Status}, SuccessRate={SuccessRate:F2}%", 
                    response.Status, response.Metrics?.SuccessRate ?? 0);
            }
            else
            {
                Logger.LogWarning("[ContainerCompleteness] Queue publishing health response was null");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ContainerCompleteness] Error loading queue publishing health: {Message}", ex.Message);
            Snackbar.Add($"Could not load queue publishing health: {ex.Message}", Severity.Warning);
        }
        finally
        {
            isLoadingQueuePublishingHealth = false;
            StateHasChanged();
        }
    }
    
    private Color GetQueueHealthStatusColor()
    {
        if (queuePublishingHealth == null) return Color.Default;
        
        return queuePublishingHealth.Status switch
        {
            "Healthy" => Color.Success,
            "Warning" => Color.Warning,
            "Critical" => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetQueueHealthStatusIcon()
    {
        if (queuePublishingHealth == null) return Icons.Material.Outlined.Circle;
        
        return queuePublishingHealth.Status switch
        {
            "Healthy" => Icons.Material.Outlined.CheckCircle,
            "Warning" => Icons.Material.Outlined.Warning,
            "Critical" => Icons.Material.Outlined.Error,
            _ => Icons.Material.Outlined.Circle
        };
    }
    
    private Color GetQueueHealthBadgeColor()
    {
        if (queuePublishingHealth?.Alerts == null || !queuePublishingHealth.Alerts.Any())
            return Color.Success;
        
        var hasCritical = queuePublishingHealth.Alerts.Any(a => a.Contains("[Critical]", StringComparison.OrdinalIgnoreCase));
        return hasCritical ? Color.Error : Color.Warning;
    }
    
    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalMilliseconds < 1000)
            return $"{duration.TotalMilliseconds:F0}ms";
        if (duration.TotalSeconds < 60)
            return $"{duration.TotalSeconds:F2}s";
        return $"{duration.TotalMinutes:F2}m";
    }
    
