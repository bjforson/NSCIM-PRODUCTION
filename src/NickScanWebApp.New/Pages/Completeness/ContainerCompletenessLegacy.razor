    private string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalDays >= 1)
            return $"{ts.TotalDays:F1} days";
        if (ts.TotalHours >= 1)
            return $"{ts.TotalHours:F1} hours";
        return $"{ts.TotalMinutes:F0} minutes";
