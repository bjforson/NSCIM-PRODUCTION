    private Color GetValidationStatusColor(string status)
    {
        return status switch
        {
            "Validated" => Color.Success,
            "Pending" => Color.Warning,
            "InReview" => Color.Info,
            "Approved" => Color.Success,
            "Rejected" => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetValidationStatusIcon(string status)
    {
        return status switch
        {
            "Validated" => Icons.Material.Outlined.CheckCircle,
            "Pending" => Icons.Material.Outlined.PendingActions,
            "InReview" => Icons.Material.Outlined.Visibility,
            "Approved" => Icons.Material.Outlined.Check,
            "Rejected" => Icons.Material.Outlined.Close,
            _ => Icons.Material.Outlined.Circle
        };
    }
    
    private Color GetCompletenessColor(int percentage)
    {
        return percentage switch
        {
            >= 90 => Color.Success,
            >= 70 => Color.Warning,
            _ => Color.Error
        };
    }
    
