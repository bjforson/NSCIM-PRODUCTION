    // Validation Methods
    private async Task LoadValidationData()
    {
        isLoadingValidationData = true;
        try
        {
            Logger.LogInformation("🔍 Loading validation data - Page: {Page}, PageSize: {PageSize}", currentPage, pageSize);
            
            // ✅ FIXED: Use currentPage variable and optimized pageSize (100 records per page to avoid timeout)
            // 100 records balances performance and data visibility - can be adjusted based on server performance
            var queryParams = $"page={currentPage}&pageSize=100&search={searchTerm}&scannerType={filterScannerType}&status={filterStatus}";
            var response = await ApiService.GetAsync<PagedValidationApiResponse>($"/api/containervalidation/pending?{queryParams}");
            
            if (response?.Data != null)
            {
                allValidationContainers = response.Data.Select(v => new ValidationContainerItem
                {
                    Id = v.Id,
                    ContainerNumber = v.ContainerNumber ?? "",
                    ClearanceType = ConvertClearanceTypeToString(v.ClearanceType),
                    ScannerType = v.ScannerType ?? "Unknown",
                    Status = ConvertValidationStatusToString(v.Status),
                    DataCompletenessPercentage = v.DataCompletenessPercentage,
                    ScannerDataPercentage = v.ScannerCompleteness?.CompletenessScore ?? 0,
                    ICUMSDataPercentage = v.ICUMSCompleteness?.CompletenessScore ?? 0,
                    HasImageData = v.ImageCompleteness?.HasImage ?? false,
                    CreatedAt = v.CreatedAt,
                    IsReadyForSubmission = v.IsReadyForSubmission
                }).ToList();
                
                filteredValidationContainers = allValidationContainers;
                
                // ✅ FIXED: Use API response total count instead of local count
                totalValidationContainers = response.TotalCount;
                totalPages = response.TotalPages > 0 ? response.TotalPages : (int)Math.Ceiling((double)totalValidationContainers / pageSize);
                readyForValidationCount = totalValidationContainers;
                
                Logger.LogInformation("✅ Loaded {Count} validation containers out of {Total} total (Page {Page}/{TotalPages})", 
                    allValidationContainers.Count, totalValidationContainers, currentPage, totalPages);
                Snackbar.Add($"Loaded {allValidationContainers.Count} validation containers (Total: {totalValidationContainers})", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading validation data: {Message}", ex.Message);
            
            allValidationContainers = new List<ValidationContainerItem>();
            filteredValidationContainers = allValidationContainers;
            totalValidationContainers = 0;
            totalPages = 0;
            readyForValidationCount = 0;
            
            Snackbar.Add($"No validation data available: {ex.Message}", Severity.Info);
        }
        finally
        {
            isLoadingValidationData = false;
        }
    }
    
