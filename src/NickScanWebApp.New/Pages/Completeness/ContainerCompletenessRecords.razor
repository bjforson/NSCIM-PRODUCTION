    // ✅ CONSOLIDATED CARGO MODEL - Load cargo groups
    private async Task LoadCargoGroups()
    {
        isLoadingCargoGroups = true;
        try
        {
            Console.WriteLine("[ContainerCompletenessRecords] Loading cargo groups from consolidated cargo API...");
            
            try
            {
                // ✅ PERFORMANCE FIX: Reduced pageSize from 100 to 25 for faster loading
                // Load non-consolidated cargo groups
                var nonConsolidatedResponse = await ConsolidatedCargoClient.GetNonConsolidatedAsync<NonConsolidatedCargoGroup>(25);
                if (nonConsolidatedResponse != null)
                {
                    nonConsolidatedGroups = nonConsolidatedResponse;
                    Console.WriteLine($"[ContainerCompletenessRecords] Loaded {nonConsolidatedGroups.Count} non-consolidated cargo groups");
                }
                else
                {
                    nonConsolidatedGroups = new List<NonConsolidatedCargoGroup>();
                    Console.WriteLine("[ContainerCompletenessRecords] No non-consolidated cargo groups returned from API");
                }
            }
            catch (Exception ex)
            {
                // ✅ FIX: Handle errors gracefully to prevent log spam
                Console.WriteLine($"[ContainerCompletenessRecords] Error loading cargo groups: {ex.Message}");
                nonConsolidatedGroups = new List<NonConsolidatedCargoGroup>();
                // Don't throw - allow page to continue without cargo groups
            }
            
            // ✅ PERFORMANCE FIX: Reduced pageSize from 100 to 25 for faster loading
            // Load consolidated cargo groups
            try
            {
                var consolidatedResponse = await ConsolidatedCargoClient.GetConsolidatedAsync<ConsolidatedCargoGroup>(25);
                if (consolidatedResponse != null)
                {
                    consolidatedGroups = consolidatedResponse;
                    Console.WriteLine($"[ContainerCompletenessRecords] Loaded {consolidatedGroups.Count} consolidated cargo groups");
                }
                else
                {
                    consolidatedGroups = new List<ConsolidatedCargoGroup>();
                    Console.WriteLine("[ContainerCompletenessRecords] No consolidated cargo groups returned from API");
                }
            }
            catch (Exception ex)
            {
                // ✅ FIX: Handle errors gracefully to prevent log spam
                Console.WriteLine($"[ContainerCompletenessRecords] Error loading consolidated cargo groups: {ex.Message}");
                consolidatedGroups = new List<ConsolidatedCargoGroup>();
                // Don't throw - allow page to continue without cargo groups
            }
            
            StateHasChanged(); // Force UI update
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ContainerCompletenessRecords] Error loading cargo groups: {ex.Message}");
            Console.WriteLine($"[ContainerCompletenessRecords] Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Could not load cargo groups from API: {ex.Message}", Severity.Error);
            nonConsolidatedGroups = new List<NonConsolidatedCargoGroup>();
            consolidatedGroups = new List<ConsolidatedCargoGroup>();
        }
        finally
        {
            isLoadingCargoGroups = false;
        }
    }
    
