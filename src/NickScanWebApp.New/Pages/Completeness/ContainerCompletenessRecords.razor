@code {
    // Top-level hub tab: 0=Records, 1=Queue, 2=Pending Export, 3=Cross-Record, 4=Cargo Groups, 5=Completed
    private int _activeHubTab = 0;

    private List<BreadcrumbItem> breadcrumbs = new();
    
    // Validation Data
    private List<ValidationContainerItem> allValidationContainers = new();
    private List<ValidationContainerItem> filteredValidationContainers = new();
    private HashSet<ValidationContainerItem> selectedValidationContainers = new();
    private bool isLoadingValidationData = false;
    private bool selectAll = false;
    private int readyForValidationCount = 0;
    
    // ✅ CONSOLIDATED CARGO MODEL - New data for cargo groups
    private List<NonConsolidatedCargoGroup> nonConsolidatedGroups = new();
    private List<ConsolidatedCargoGroup> consolidatedGroups = new();
    private bool isLoadingCargoGroups = false;
    private HashSet<NonConsolidatedCargoGroup> expandedNonConsolidated = new();
    private HashSet<ConsolidatedCargoGroup> expandedConsolidated = new();
    
    // Validation Filters
    private string filterClearanceType = "";
    private string filterScannerType = ""; // Empty = All Scanners
    private string filterStatus = ""; // Empty = All Status
    private string searchTerm = "";
    
    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalValidationContainers = 0;
    private int totalPages = 0;
    
    // Auto-refresh timer
    private System.Threading.Timer? _refreshTimer;
    private DateTime lastRefreshTime = DateTime.Now;
    
    protected override async Task OnInitializedAsync()
    {
        // Route-based initial hub tab
        var path = new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        _activeHubTab = path switch
        {
            "/validation/ccq" or "/completeness/queue"                                  => 1,
            "/operations/export-pending" or "/completeness/pending-export"              => 2,
            "/operations/cross-record-scans" or "/completeness/cross-record"            => 3,
            "/validation/new-completeness-model" or "/completeness/cargo-groups"        => 4,
            "/operations/completed-records" or "/completeness/completed"                => 5,
            _                                                                            => 0
        };

        breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home),
            new BreadcrumbItem("Completeness", href: null, disabled: true, icon: Icons.Material.Outlined.FactCheck)
        };

        await LoadValidationData();
        await LoadCargoGroups();
        
        var refreshSeconds = Configuration.GetValue<int>("UI:AutoRefreshSeconds", 30);
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadValidationData();
                await LoadCargoGroups();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(refreshSeconds), TimeSpan.FromSeconds(refreshSeconds));
    }
    
    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
    
    private async Task LoadValidationData()
    {
        isLoadingValidationData = true;
        try
        {
            Console.WriteLine($"🔍 Loading validation data - Page: {currentPage}, PageSize: {pageSize}");
            
            // ✅ FIXED: Use currentPage variable and optimized pageSize (100 records per page to avoid timeout)
            // 100 records balances performance and data visibility - can be adjusted based on server performance
            // ✅ FIX: Properly encode search term and only include non-empty parameters
            var queryParams = new List<string> { $"page={currentPage}", "pageSize=100" };
            if (!string.IsNullOrWhiteSpace(searchTerm))
                queryParams.Add($"search={Uri.EscapeDataString(searchTerm)}");
            
            // ✅ FIX: Map frontend filter values to backend expected values
            var scannerTypeParam = filterScannerType?.Trim();
            if (!string.IsNullOrWhiteSpace(scannerTypeParam) && 
                scannerTypeParam != "All Scanners" && 
                scannerTypeParam != "All")
                queryParams.Add($"scannerType={Uri.EscapeDataString(scannerTypeParam)}");
            
            var statusParam = filterStatus?.Trim();
            if (!string.IsNullOrWhiteSpace(statusParam) && 
                statusParam != "All Status" && 
                statusParam != "All")
                queryParams.Add($"status={Uri.EscapeDataString(statusParam)}");
            
            var queryString = string.Join("&", queryParams);
            Console.WriteLine($"🔍 API Call: /api/containervalidation/pending?{queryString}");
            var response = await ContainerValidationClient.GetPendingAsync<PagedValidationApiResponse>(queryString);
            
            if (response?.Data != null)
            {
                allValidationContainers = response.Data.Select(v => new ValidationContainerItem
                {
                    Id = v.Id,
                    ContainerNumber = v.ContainerNumber ?? "",
                    ClearanceType = ConvertClearanceTypeToString(v.ClearanceType),
                    ScannerType = v.ScannerType ?? "Unknown",
                    Status = ConvertValidationStatusToString(v.Status),
                    DataCompletenessPercentage = v.DataCompletenessPercentage,
                    ScannerDataPercentage = v.ScannerCompleteness?.CompletenessScore ?? 0,
                    ICUMSDataPercentage = v.ICUMSCompleteness?.CompletenessScore ?? 0,
                    HasImageData = v.ImageCompleteness?.HasImage ?? false,
                    CreatedAt = v.CreatedAt,
                    IsReadyForSubmission = v.IsReadyForSubmission
                }).ToList();
                
                filteredValidationContainers = allValidationContainers;
                
                // ✅ FIXED: Use API response total count instead of local count
                totalValidationContainers = response.TotalCount;
                totalPages = response.TotalPages > 0 ? response.TotalPages : (int)Math.Ceiling((double)totalValidationContainers / pageSize);
                readyForValidationCount = totalValidationContainers;
                
                Console.WriteLine($"✅ Loaded {allValidationContainers.Count} validation containers out of {totalValidationContainers} total (Page {currentPage}/{totalPages})");
                Snackbar.Add($"Loaded {allValidationContainers.Count} validation containers (Total: {totalValidationContainers})", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading validation data: {ex.Message}");
            
            allValidationContainers = new List<ValidationContainerItem>();
            filteredValidationContainers = allValidationContainers;
            totalValidationContainers = 0;
            totalPages = 0;
            readyForValidationCount = 0;
            
            Snackbar.Add($"No validation data available: {ex.Message}", Severity.Info);
        }
        finally
        {
            isLoadingValidationData = false;
            lastRefreshTime = DateTime.Now; // ✅ Update last refresh time
        }
    }
    
    private async Task ApplyValidationFilters()
    {
        await LoadValidationData();
    }

    private async Task OnSearchTermChanged(string value)
    {
        searchTerm = value;
        currentPage = 1;
        await LoadValidationData();
    }
    
    private async Task ClearFilters()
    {
        filterClearanceType = "";
        filterScannerType = ""; // Reset to empty (All Scanners)
        filterStatus = ""; // Reset to empty (All Status)
        searchTerm = "";
        currentPage = 1; // ✅ FIX: Reset to page 1 when clearing filters
        await LoadValidationData();
    }
    
    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        await LoadValidationData();
    }

    private Task OnSelectAllChanged(bool value)
    {
        selectAll = value;
        SelectAllContainers();
        return Task.CompletedTask;
    }

    private Task OnRowSelectionChanged(ValidationContainerItem item, bool isSelected)
    {
        if (isSelected)
        {
            selectedValidationContainers.Add(item);
        }
        else
        {
            selectedValidationContainers.Remove(item);
        }

        return Task.CompletedTask;
    }
    
    private void SelectAllContainers()
    {
        if (selectAll)
        {
            selectedValidationContainers = filteredValidationContainers.ToHashSet();
        }
        else
        {
            selectedValidationContainers.Clear();
        }
    }

    private string GetPagerSummary()
    {
        if (totalValidationContainers == 0)
        {
            return "No items to display";
        }

        var start = ((currentPage - 1) * pageSize) + 1;
        var end = Math.Min(currentPage * pageSize, totalValidationContainers);
        return $"Showing {start}-{end} of {totalValidationContainers} items";
    }
    
    private void CopyToClipboard(string text)
    {
        try
        {
            NavigationManager.NavigateTo($"javascript: navigator.clipboard.writeText('{text}')");
            Snackbar.Add($"Copied {text} to clipboard", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying to clipboard: {ex.Message}");
            Snackbar.Add("Could not copy to clipboard", Severity.Error);
        }
    }
    
    private async Task ViewContainer(string containerNumber)
    {
        try
        {
            var parameters = new DialogParameters<ContainerDetailsModal>
            {
                { x => x.ContainerNumber, containerNumber }
            };

            var options = new DialogOptions 
            { 
                MaxWidth = MaxWidth.ExtraExtraLarge, 
                FullWidth = true,
                CloseButton = true,
                BackdropClick = true
            };

            var dialog = await DialogService.ShowAsync<ContainerDetailsModal>(
                $"Container Details: {containerNumber}", 
                parameters, 
                options);
                
            // Wait for the dialog to close
            var result = await dialog.Result;
            
            Console.WriteLine("✅ [ContainerCompletenessRecords] Dialog closed successfully");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error opening container details: {ex.Message}");
            Snackbar.Add("Could not open container details", Severity.Error);
        }
    }
    
    private async Task ApproveContainer(string containerNumber)
    {
        try
        {
            var result = await ContainerValidationClient.ApproveAsync(containerNumber);
            
            if (result != null)
            {
                Snackbar.Add($"Container {containerNumber} approved successfully", Severity.Success);
                await LoadValidationData(); // Refresh data
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error approving container: {ex.Message}");
            Snackbar.Add($"Could not approve container {containerNumber}", Severity.Error);
        }
    }
    
    private async Task RejectContainer(string containerNumber)
    {
        try
        {
            var result = await ContainerValidationClient.RejectAsync(containerNumber);
            
            if (result != null)
            {
                Snackbar.Add($"Container {containerNumber} rejected", Severity.Info);
                await LoadValidationData(); // Refresh data
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error rejecting container: {ex.Message}");
            Snackbar.Add($"Could not reject container {containerNumber}", Severity.Error);
        }
    }
    
    // Helper Methods - API now returns enums as strings
    private string ConvertClearanceTypeToString(string? clearanceType)
    {
        return clearanceType ?? "Unknown";
    }
    
    private string ConvertValidationStatusToString(string? status)
    {
        return status ?? "Pending";
    }
    
    // Color Helper Methods
    private Color GetClearanceTypeColor(string clearanceType)
    {
        return clearanceType switch
        {
            "CMR" => Color.Info,
            "IMEX" => Color.Warning,
            _ => Color.Default
        };
    }
    
    private Color GetScannerTypeColor(string scannerType)
    {
        return scannerType switch
        {
            "ASE" => Color.Secondary,
            "FS6000" => Color.Primary,
            _ => Color.Default
        };
    }
    
    private Color GetValidationStatusColor(string status)
    {
        return status switch
        {
            "Validated" => Color.Success,
            "Pending" => Color.Warning,
            "InReview" => Color.Info,
            "Approved" => Color.Success,
            "PendingSubmission" => Color.Warning,
            "Submitted" => Color.Tertiary,
            "Rejected" => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetValidationStatusIcon(string status)
    {
        return status switch
        {
            "Validated" => Icons.Material.Outlined.CheckCircle,
            "Pending" => Icons.Material.Outlined.PendingActions,
            "InReview" => Icons.Material.Outlined.Visibility,
            "Approved" => Icons.Material.Outlined.Check,
            "PendingSubmission" => Icons.Material.Outlined.Schedule,
            "Submitted" => Icons.Material.Outlined.CloudDone,
            "Rejected" => Icons.Material.Outlined.Close,
            _ => Icons.Material.Outlined.Circle
        };
    }
    
    private Color GetCompletenessColor(int percentage)
    {
        return percentage switch
        {
            >= 90 => Color.Success,
            >= 70 => Color.Warning,
            _ => Color.Error
        };
    }
    
    // Validation Data Models
    public class ValidationContainerItem
    {
        public int Id { get; set; }
        public string ContainerNumber { get; set; } = "";
