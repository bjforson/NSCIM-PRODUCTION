        public bool IsReadyForSubmission { get; set; }
    }
    
    // API Response Models
    public class PagedValidationApiResponse
    {
        public List<ApiValidationContainer>? Data { get; set; }
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
    }
    
    public class ApiValidationContainer
    {
        public int Id { get; set; }
        public string? ContainerNumber { get; set; }
        public string? ClearanceType { get; set; } // ✅ Changed to string (API returns "CMR" or "IMEX")
        public string? ScannerType { get; set; }
