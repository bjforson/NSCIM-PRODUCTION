@page "/operations/completeness-records"
@page "/completeness/records"
@page "/completeness"
@page "/validation/ccq"
@page "/completeness/queue"
@page "/operations/export-pending"
@page "/completeness/pending-export"
@page "/operations/cross-record-scans"
@page "/completeness/cross-record"
@page "/validation/new-completeness-model"
@page "/completeness/cargo-groups"
@page "/operations/completed-records"
@page "/completeness/completed"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesContainerCompleteness)]
@using NickScanWebApp.Shared.Services
@using NickScanWebApp.New.Components.Containers
@using NickScanWebApp.New.Components.Completeness
@inject NickScanWebApp.Shared.Services.ContainerValidationClient ContainerValidationClient
@inject NickScanWebApp.Shared.Services.ConsolidatedCargoClient ConsolidatedCargoClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IConfiguration Configuration
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" @bind-ActivePanelIndex="_activeHubTab">
    <MudTabPanel Text="Records" Icon="@Icons.Material.Filled.FactCheck">
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Page Header -->
    <MudPaper Elevation="0" Class="mb-4 pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4" Color="Color.Primary">
                    <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Class="mr-2" />
                    Container Completeness Records
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Detailed validation records for all containers ready for submission
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Outlined.Update" Size="Size.Small" Class="mr-1" />
                    Last updated: @lastRefreshTime.ToString("HH:mm:ss")
                </MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          StartIcon="@Icons.Material.Outlined.Refresh"
                          OnClick="@LoadValidationData"
                          Disabled="@isLoadingValidationData">
                    @if (isLoadingValidationData)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Refresh
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Secondary" 
                          StartIcon="@Icons.Material.Outlined.Download">
                    Export
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Stats Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Records</MudText>
                            <MudText Typo="Typo.h5">@totalValidationContainers</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Primary" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Outlined.Inventory" />
                        </MudAvatar>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Ready for Validation</MudText>
                            <MudText Typo="Typo.h5">@readyForValidationCount</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Success" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                        </MudAvatar>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Selected</MudText>
                            <MudText Typo="Typo.h5">@selectedValidationContainers.Count</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Info" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Outlined.Checklist" />
                        </MudAvatar>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Current Page</MudText>
                            <MudText Typo="Typo.h5">@currentPage / @totalPages</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Secondary" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Outlined.Pages" />
                        </MudAvatar>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    
    <!-- Filters and Search -->
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect T="string" 
                          Label="Clearance Type" 
                          Variant="Variant.Outlined"
                          @bind-Value="filterClearanceType"
                          Clearable="true">
                    <MudSelectItem T="string" Value="@("All Types")">All Types</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CMR")">CMR</MudSelectItem>
                    <MudSelectItem T="string" Value="@("IMEX")">IMEX</MudSelectItem>
                </MudSelect>
            </MudItem>
            
            <MudItem xs="12" md="3">
                <MudSelect T="string" 
                          Label="Scanner Type" 
                          Variant="Variant.Outlined"
                          @bind-Value="filterScannerType"
                          Clearable="true">
                    <MudSelectItem T="string" Value="@("All Scanners")">All Scanners</MudSelectItem>
                    <MudSelectItem T="string" Value="@("ASE")">ASE</MudSelectItem>
                    <MudSelectItem T="string" Value="@("FS6000")">FS6000</MudSelectItem>
                </MudSelect>
            </MudItem>
            
            <MudItem xs="12" md="3">
                <MudSelect T="string" 
                          Label="Status" 
                          Variant="Variant.Outlined"
                          @bind-Value="filterStatus"
                          Clearable="true">
                    <MudSelectItem T="string" Value="@("All Status")">All Status</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Pending")">Pending</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Validated")">Validated</MudSelectItem>
                    <MudSelectItem T="string" Value="@("InReview")">In Review</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Approved")">Approved (In Audit)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PendingSubmission")">Pending Submission</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Submitted")">Submitted</MudSelectItem>
                </MudSelect>
            </MudItem>
            
            <MudItem xs="12" md="3">
                <MudTextField T="string" 
                             Label="Search Container" 
                             Value="@searchTerm"
                             ValueChanged="OnSearchTermChanged"
                             Variant="Variant.Outlined"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Outlined.Search"
                             Placeholder="Container number..." 
                             Immediate="true"
                             DebounceInterval="500" />
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary"
                      StartIcon="@Icons.Material.Outlined.FilterList"
                      OnClick="@ApplyValidationFilters">
                Apply Filters
            </MudButton>
            <MudButton Variant="Variant.Outlined" 
                      Color="Color.Secondary"
                      StartIcon="@Icons.Material.Outlined.Clear"
                      OnClick="@ClearFilters">
                Clear
            </MudButton>
        </MudStack>
    </MudPaper>
    
    <!-- Tabs for Different Views -->
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">
        <!-- Validation Records Tab (Current View) -->
        <MudTabPanel Text="Validation Records" Icon="@Icons.Material.Outlined.FactCheck" BadgeData="@totalValidationContainers" BadgeColor="Color.Info">
            <!-- Data Table -->
            <MudPaper Elevation="2" Class="pa-4">
                <MudTable T="ValidationContainerItem"
                 Items="@filteredValidationContainers"
                 Loading="@isLoadingValidationData"
                 Hover="true"
                 Striped="true"
                 Dense="true"
                 FixedHeader="true"
                 Height="600px">
            <HeaderContent>
                <MudTh>
                    <MudCheckBox T="bool"
                                 Value="@selectAll"
                                 ValueChanged="@OnSelectAllChanged" />
                </MudTh>
                
                <!-- Container Number Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.ContainerNumber">Container Number</MudTableSortLabel></MudTh>
                
                <!-- Clearance Type Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.ClearanceType">Clearance Type</MudTableSortLabel></MudTh>
                
                <!-- Scanner Type Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.ScannerType">Scanner</MudTableSortLabel></MudTh>
                
                <!-- Status Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.Status">Status</MudTableSortLabel></MudTh>
                
                <!-- Data Completeness Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.DataCompletenessPercentage">Data Completeness</MudTableSortLabel></MudTh>
                
                <!-- Scanner Data Column -->
                <MudTh>Scanner Data</MudTh>
                
                <!-- ICUMS Data Column -->
                <MudTh>ICUMS Data</MudTh>
                
                <!-- Image Data Column -->
                <MudTh>Image Data</MudTh>
                
                <!-- Created Column -->
                <MudTh><MudTableSortLabel T="ValidationContainerItem" SortBy="x => x.CreatedAt">Created</MudTableSortLabel></MudTh>
                
                <!-- Actions Column -->
                <MudTh>Actions</MudTh>
            </HeaderContent>
            
            <RowTemplate>
                <MudTd DataLabel="Select">
                    <MudCheckBox T="bool" 
                                 Value="@selectedValidationContainers.Contains(context)"
                                 ValueChanged="@((bool val) => OnRowSelectionChanged(context, val))" />
                </MudTd>
                
                <MudTd DataLabel="Container Number">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">@context.ContainerNumber</MudText>
                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" 
                                      Size="Size.Small"
                                      aria-label="Copy container number"
                                      OnClick="@(() => CopyToClipboard(context.ContainerNumber))" />
                    </MudStack>
                </MudTd>
                
                <MudTd DataLabel="Clearance Type">
                    <MudChip T="string" 
                            Size="Size.Small" 
                            Color="@GetClearanceTypeColor(context.ClearanceType)"
                            Variant="Variant.Filled">
                        @context.ClearanceType
                    </MudChip>
                </MudTd>
                
                <MudTd DataLabel="Scanner">
                    <MudChip T="string" 
                            Size="Size.Small" 
                            Color="@GetScannerTypeColor(context.ScannerType)"
                            Variant="Variant.Filled">
                        @context.ScannerType
                    </MudChip>
                </MudTd>
                
                <MudTd DataLabel="Status">
                    <MudChip T="string" 
                            Size="Size.Small" 
                            Color="@GetValidationStatusColor(context.Status)"
                            Variant="Variant.Filled"
                            Icon="@GetValidationStatusIcon(context.Status)">
                        @context.Status
                    </MudChip>
                </MudTd>
                
                <MudTd DataLabel="Data Completeness">
                    <MudStack Spacing="1">
                        <MudProgressLinear Color="@GetCompletenessColor(context.DataCompletenessPercentage)" 
                                          Value="@context.DataCompletenessPercentage" 
                                          Min="0" 
                                          Max="100" 
                                          Size="Size.Small" />
                        <MudText Typo="Typo.caption" Align="Align.Center">
                            @context.DataCompletenessPercentage%
                        </MudText>
                    </MudStack>
                </MudTd>
                
                <MudTd DataLabel="Scanner Data">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="@(context.ScannerDataPercentage == 100 ? Color.Success : Color.Warning)">
                            @(context.ScannerDataPercentage == 100 ? "Complete" : "Incomplete")
                        </MudText>
                        <MudText Typo="Typo.caption">@context.ScannerDataPercentage%</MudText>
                    </MudStack>
                </MudTd>
                
                <MudTd DataLabel="ICUMS Data">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="@(context.ICUMSDataPercentage == 100 ? Color.Success : Color.Warning)">
                            @(context.ICUMSDataPercentage == 100 ? "Complete" : "Incomplete")
                        </MudText>
                        <MudText Typo="Typo.caption">@context.ICUMSDataPercentage%</MudText>
                    </MudStack>
                </MudTd>
                
                <MudTd DataLabel="Image Data">
                    <MudChip T="string" 
                            Size="Size.Small" 
                            Color="@(context.HasImageData ? Color.Success : Color.Error)"
                            Variant="Variant.Filled">
                        @(context.HasImageData ? "Available" : "Missing")
                    </MudChip>
                </MudTd>
                
                <MudTd DataLabel="Created">
                    <MudText Typo="Typo.caption">@context.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.CreatedAt.ToString("HH:mm")</MudText>
                </MudTd>
                
                <MudTd DataLabel="Actions">
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Outlined.Visibility" 
                                      Size="Size.Small"
                                      Color="Color.Info"
                                      aria-label="View container details"
                                      OnClick="@(() => ViewContainer(context.ContainerNumber))" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Check" 
                                      Size="Size.Small"
                                      Color="Color.Success"
                                      aria-label="Approve container"
                                      OnClick="@(() => ApproveContainer(context.ContainerNumber))" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Close" 
                                      Size="Size.Small"
                                      Color="Color.Error"
                                      aria-label="Reject container"
                                      OnClick="@(() => RejectContainer(context.ContainerNumber))" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
            
            <PagerContent>
                <MudText Typo="Typo.caption" Class="px-4 py-2">
                    @GetPagerSummary()
                </MudText>
            </PagerContent>
        </MudTable>
        
        <!-- Pagination -->
        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudPagination Count="@totalPages" 
                          Selected="@currentPage"
                          SelectedChanged="@(async (int page) => await OnPageChanged(page))"
                          BoundaryCount="2"
                          MiddleCount="3"
                          Color="Color.Primary" />
        </MudStack>
            </MudPaper>
        </MudTabPanel>
        
        <!-- Cargo Groups Tab - Consolidated Model -->
        <MudTabPanel Text="Cargo Groups" Icon="@Icons.Material.Outlined.Inventory2" BadgeData="@(nonConsolidatedGroups.Count + consolidatedGroups.Count)" BadgeColor="Color.Info">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" Color="Color.Info">
                <!-- Non-Consolidated Sub-Tab -->
                <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Outlined.LocalShipping" BadgeData="@nonConsolidatedGroups.Count" BadgeColor="Color.Primary">
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        <MudText>Non-Consolidated Cargo: One Master BL covers multiple containers. Expand to see all containers under each Master BL.</MudText>
                    </MudAlert>
                    
                    <MudTable Items="@nonConsolidatedGroups" 
                             Dense="true" 
                             Hover="true" 
                             Breakpoint="Breakpoint.Sm"
                             Loading="@isLoadingCargoGroups"
                             ExpandableRows="true"
                             @bind-ExpandedItems="expandedNonConsolidated">
                        <HeaderContent>
                            <MudTh>Declaration Number</MudTh>
                            <MudTh>Master BL</MudTh>
                            <MudTh>Containers</MudTh>
                            <MudTh>Consignee</MudTh>
                            <MudTh>Clearance Type</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Declaration">
                                <MudText Typo="Typo.body2"><strong>@context.DeclarationNumber</strong></MudText>
                            </MudTd>
                            <MudTd DataLabel="Master BL">
                                <MudText Typo="Typo.body2">@context.MasterBL</MudText>
                            </MudTd>
                            <MudTd DataLabel="Containers">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                    @context.Containers.Count / @context.NoOfContainers
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Consignee">
                                <MudText Typo="Typo.caption">@context.ConsigneeName</MudText>
                            </MudTd>
                            <MudTd DataLabel="Clearance Type">
                                <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(context.ClearanceType)">
                                    @context.ClearanceType
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                              Size="Size.Small"
                                              Color="Color.Info"
                                              Href="@($"/containers/{context.Containers.FirstOrDefault()}")"
                                              Disabled="@(!context.Containers.Any())" />
                            </MudTd>
                        </RowTemplate>
                        <ChildRowContent>
                            <MudTd ColSpan="6">
                                <MudCard Elevation="1" Class="ma-2">
                                    <MudCardHeader>
                                        <CardHeaderContent>
                                            <MudText Typo="Typo.h6">Containers under Declaration @context.DeclarationNumber</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Master BL: @context.MasterBL</MudText>
                                        </CardHeaderContent>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudSimpleTable Dense="true">
                                            <thead>
                                                <tr>
                                                    <th>Container Number</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var container in context.Containers)
                                                {
                                                    <tr>
                                                        <td>
                                                            <MudLink Href="@($"/containers/{container}")">
                                                                <strong>@container</strong>
                                                            </MudLink>
                                                        </td>
                                                        <td>
                                                            <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                          Size="Size.Small"
                                                                          Color="Color.Info"
                                                                          Href="@($"/containers/{container}")" />
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    </MudCardContent>
                                </MudCard>
                            </MudTd>
                        </ChildRowContent>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info">No non-consolidated cargo groups found.</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
                </MudTabPanel>
                
                <!-- Consolidated Sub-Tab -->
                <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Outlined.Inventory" BadgeData="@consolidatedGroups.Count" BadgeColor="Color.Warning">
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        <MudText>Consolidated Cargo: One Master BL has multiple House BLs (different consignees). A Master BL can span one or multiple containers. Expand to see all House BLs and containers under each Master BL.</MudText>
                    </MudAlert>
                    
                    <MudTable Items="@consolidatedGroups" 
                             Dense="true" 
                             Hover="true" 
                             Breakpoint="Breakpoint.Sm"
                             Loading="@isLoadingCargoGroups"
                             ExpandableRows="true"
                             @bind-ExpandedItems="expandedConsolidated">
                        <HeaderContent>
                            <MudTh>Master BL</MudTh>
                            <MudTh>Containers</MudTh>
                            <MudTh>House BLs</MudTh>
                            <MudTh>Clearance Type</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Master BL">
                                <MudText Typo="Typo.body2"><strong>@context.MasterBL</strong></MudText>
                            </MudTd>
                            <MudTd DataLabel="Containers">
                                @if (context.ContainerNumbers.Any())
                                {
                                    <MudStack Spacing="1">
                                        @foreach (var container in context.ContainerNumbers.Take(3))
                                        {
                                            <MudLink Href="@($"/containers/{container}")" Typo="Typo.caption">
                                                @container
                                            </MudLink>
                                        }
                                        @if (context.ContainerNumbers.Count > 3)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                +@(context.ContainerNumbers.Count - 3) more
                                            </MudText>
                                        }
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">No containers</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="House BLs">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                    @context.HouseBLDetails.Count HBLs
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Clearance Type">
                                @if (context.HouseBLDetails.Any())
                                {
                                    var clearanceType = context.HouseBLDetails.First().ClearanceType;
                                    <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(clearanceType)">
                                        @clearanceType
                                    </MudChip>
                                }
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                @if (context.ContainerNumbers.Any())
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                  Size="Size.Small"
                                                  Color="Color.Info"
                                                  Href="@($"/containers/{context.ContainerNumbers.First()}")" />
                                }
                            </MudTd>
                        </RowTemplate>
                        <ChildRowContent>
                            <MudTd ColSpan="5">
                                <MudCard Elevation="1" Class="ma-2">
                                    <MudCardHeader>
                                        <CardHeaderContent>
                                            <MudText Typo="Typo.h6">House BLs under Master BL: @context.MasterBL</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @context.ContainerNumbers.Count container(s): @string.Join(", ", context.ContainerNumbers)
                                            </MudText>
                                        </CardHeaderContent>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudSimpleTable Dense="true" Striped="true">
                                            <thead>
                                                <tr>
                                                    <th>House BL</th>
                                                    <th>Declaration</th>
                                                    <th>Consignee</th>
                                                    <th>Clearance Type</th>
                                                    <th>Container</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var hbl in context.HouseBLDetails)
                                                {
                                                    <tr>
                                                        <td><strong>@hbl.HouseBL</strong></td>
                                                        <td>@hbl.DeclarationNumber</td>
                                                        <td>@hbl.ConsigneeName</td>
                                                        <td>
                                                            <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(hbl.ClearanceType)">
                                                                @hbl.ClearanceType
                                                            </MudChip>
                                                        </td>
                                                        <td>
                                                            <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                @hbl.ContainerNumber
                                                            </MudLink>
                                                        </td>
                                                        <td>
                                                            <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                                          Size="Size.Small"
                                                                          Color="Color.Info"
