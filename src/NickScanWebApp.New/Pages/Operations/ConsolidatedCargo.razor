@page "/services/consolidated-cargo"
@page "/operations/consolidated-cargo"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesServicesConsolidatedCargo)]
@using MudBlazor
@inject NickScanWebApp.Shared.Services.ConsolidatedCargoClient ConsolidatedCargoClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject ILogger<ConsolidatedCargo> Logger

<PageTitle>NICKSCAN ERP — NSCIS — Consolidated Cargo Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Class="mr-2" />
        Consolidated Cargo Management
    </MudText>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        <MudText>Consolidated cargo refers to containers with multiple House BLs (multiple consignees in one container).</MudText>
    </MudAlert>

    <!-- Search and Filters -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="@_searchContainerNumber" 
                         Label="Container Number" 
                         Variant="Variant.Outlined"
                         Placeholder="Search by container number..."
                         Adornment="Adornment.End"
                         AdornmentIcon="@Icons.Material.Outlined.Search"
                         OnAdornmentClick="SearchContainers" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchContainers" StartIcon="@Icons.Material.Outlined.Search">
                Search Consolidated Containers
            </MudButton>
        </MudStack>
    </MudPaper>

    <!-- Results Table -->
    @if (_consolidatedContainers != null && _consolidatedContainers.Any())
    {
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Consolidated Containers (@_consolidatedContainers.Count)</MudText>
            <MudTable Items="@_consolidatedContainers" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh>Container Number</MudTh>
                    <MudTh>Master BL</MudTh>
                    <MudTh>House BLs</MudTh>
                    <MudTh>Total Items</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var container = (dynamic)context;
                    }
                    <MudTd DataLabel="Container Number">@(container.ContainerNumber ?? "")</MudTd>
                    <MudTd DataLabel="Master BL">@(container.MasterBlNumber ?? "N/A")</MudTd>
                    <MudTd DataLabel="House BLs">
                        <MudChip T="string" Color="Color.Info" Size="Size.Small">
                            @(container.HouseBlCount ?? 0) BLs
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Total Items">@(container.TotalItems ?? 0)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" 
                                 OnClick="@(() => ViewContainerDetails(container.ContainerNumber))">
                            View Details
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
    else if (_consolidatedContainers != null && !_consolidatedContainers.Any())
    {
        <MudAlert Severity="Severity.Info">No consolidated containers found.</MudAlert>
    }
</MudContainer>

@code {
    private string _searchContainerNumber = "";
    private List<object>? _consolidatedContainers;

    private async Task SearchContainers()
    {
        try
        {
            _consolidatedContainers = await ConsolidatedCargoClient.GetContainersAsync<object>(_searchContainerNumber);
            Snackbar.Add($"Found {_consolidatedContainers?.Count ?? 0} consolidated containers", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching consolidated containers");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void ViewContainerDetails(string? containerNumber)
    {
        if (!string.IsNullOrWhiteSpace(containerNumber))
        {
            Navigation.NavigateTo($"/containers/{containerNumber}");
        }
    }
}

