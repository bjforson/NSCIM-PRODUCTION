@page "/scanners"
@page "/scanners/ase"
@page "/scanners/fs6000"
@page "/scanners/heimann-smith"
@page "/scanners/eagle-a25"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesScannersView)]
@using NickScanWebApp.New.Components.Scanners
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.FS6000Client FS6000Client
@inject NickScanWebApp.Shared.Services.AseClient AseClient
@inject NickScanWebApp.Shared.Services.EagleA25Client EagleA25Client
@inject NickScanWebApp.Shared.Services.HeimannSmithClient HeimannSmithClient

<PageTitle>NICKSCAN ERP — NSCIS — Scanner Overview</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4"></MudBreadcrumbs>
    
    <!-- Page Header -->
    <MudPaper Elevation="0" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">Scanner Overview</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Monitor all scanner systems and their status
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       OnClick="LoadScannerStatus">
                Refresh
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" @bind-ActivePanelIndex="_activeHubTab">
        <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">

    <!-- System Health Overview -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4" Style="border-left: 4px solid var(--mud-palette-success);">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Scanners</MudText>
                        <MudText Typo="Typo.h4">4</MudText>
                        <MudText Typo="Typo.caption" Color="@GetSystemStatusColor()">@GetSystemStatusText()</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.Scanner" Size="Size.Large" Color="Color.Success" />
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Today's Scans</MudText>
                        <MudText Typo="Typo.h4">@_todayScans</MudText>
                        @if (_yesterdayTotalScans > 0)
                        {
                            var percentChange = ((_todayScans - _yesterdayTotalScans) / (double)_yesterdayTotalScans) * 100;
                            var changeColor = percentChange >= 0 ? Color.Success : Color.Error;
                            var changeSymbol = percentChange >= 0 ? "+" : "";
                            <MudText Typo="Typo.caption" Color="@changeColor">
                                @changeSymbol@percentChange.ToString("F1")% from yesterday
                            </MudText>
                        }
                        else if (_yesterdayTotalScans == 0 && _todayScans > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Success">New today</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">No scans yesterday</MudText>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.TrendingUp" Size="Size.Large" Color="Color.Info" />
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Average Processing</MudText>
                        <MudText Typo="Typo.h4">@FormatProcessingTime(_avgProcessingTimeMinutes)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Success">Per container</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.Speed" Size="Size.Large" Color="Color.Primary" />
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Scanner Status Cards -->
    <MudGrid>
        <!-- FS6000 Scanner -->
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="4" Class="pa-6" Style="height: 100%;">
                <MudStack Spacing="4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">FS6000 X-Ray</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetFS6000StatusColor()" Icon="@GetFS6000StatusIcon()">
                            @GetFS6000StatusText()
                        </MudChip>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Status Information</MudText>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Today's Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_fs6000Scans</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Total Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_totalFS6000Scans.ToString("N0")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Last Scan:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@FormatLastScanTime(_fs6000LastScan)</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Health:</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetNullableHealthColor(_fs6000Healthy)">@FormatNullableHealth(_fs6000Healthy)</MudChip>
                        </MudStack>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Info"
                               FullWidth="true"
                               OnClick="@(() => _activeHubTab = 2)">
                        View Details
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- ASE Scanner -->
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="4" Class="pa-6" Style="height: 100%;">
                <MudStack Spacing="4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">ASE X-Ray</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetASEStatusColor()" Icon="@GetASEStatusIcon()">
                            @GetASEStatusText()
                        </MudChip>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Status Information</MudText>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Today's Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_aseScans</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Total Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_totalAseScans.ToString("N0")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Last Scan:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@FormatLastScanTime(_aseLastScan)</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Sync Config:</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetNullableHealthColor(_aseSyncConfigured)">@FormatSyncConfig(_aseSyncConfigured)</MudChip>
                        </MudStack>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               FullWidth="true"
                               OnClick="@(() => _activeHubTab = 1)">
                        View Details
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Heimann Smith Scanner -->
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="4" Class="pa-6" Style="height: 100%;">
                <MudStack Spacing="4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">Heimann Smith</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetHSStatusColor()" Icon="@GetHSStatusIcon()">
                            @GetHSStatusText()
                        </MudChip>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Status Information</MudText>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Today's Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_hsScans</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Total Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_totalHsScans.ToString("N0")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Last Scan:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@FormatLastScanTime(_hsLastScan)</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Data Source:</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetNullableHealthColor(_hsDataAvailable)">@FormatDataSource(_hsDataAvailable)</MudChip>
                        </MudStack>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               FullWidth="true"
                               OnClick="@(() => _activeHubTab = 3)">
                        View Details
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Eagle A25 Scanner -->
        <MudItem xs="12" md="6" lg="3">
            <MudPaper Elevation="4" Class="pa-6" Style="height: 100%;">
                <MudStack Spacing="4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">Eagle A25</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetEagleA25StatusColor()" Icon="@GetEagleA25StatusIcon()">
                            @GetEagleA25StatusText()
                        </MudChip>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Status Information</MudText>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Today's Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_eagleA25Scans</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Total Scans:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@_totalEagleA25Scans.ToString("N0")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Last Scan:</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">@FormatLastScanTime(_eagleA25LastScan)</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2">Assignment:</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Disabled</MudChip>
                        </MudStack>
                    </MudStack>
                    
                    <MudDivider />
                    
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               FullWidth="true"
                               OnClick="@(() => _activeHubTab = 4)">
                        View Details
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Unified Scanner Records Search -->
    <MudPaper Elevation="2" Class="mt-4 pa-4">
        <MudStack Spacing="3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Search All Scanner Records</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Search across all scanner types</MudText>
            </MudStack>
            
            <!-- Scanner Type Selection -->
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" Color="Color.Primary" @bind-ActivePanelIndex="_activeScannerTab">
                <MudTabPanel Text="FS6000" Icon="@Icons.Material.Outlined.Scanner">
                    <MudStack Spacing="2" Class="mt-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Search FS6000 scanner records</MudText>
                        <MudButton Variant="Variant.Filled"
                                 Color="Color.Info"
                                 StartIcon="@Icons.Material.Outlined.Search"
                                 OnClick="@(() => _activeHubTab = 2)">
                            View All FS6000 Records
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
                
                <MudTabPanel Text="ASE" Icon="@Icons.Material.Outlined.Scanner">
                    <MudStack Spacing="2" Class="mt-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Search ASE scanner records</MudText>
                        <MudButton Variant="Variant.Filled"
                                 Color="Color.Success"
                                 StartIcon="@Icons.Material.Outlined.Search"
                                 OnClick="@(() => _activeHubTab = 1)">
                            View All ASE Records
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
                
                <MudTabPanel Text="Heimann Smith" Icon="@Icons.Material.Outlined.Scanner">
                    <MudStack Spacing="2" Class="mt-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Search Heimann Smith scanner records</MudText>
                        <MudButton Variant="Variant.Filled"
                                 Color="Color.Warning"
                                 StartIcon="@Icons.Material.Outlined.Search"
                                 OnClick="@(() => _activeHubTab = 3)">
                            View All Heimann Smith Records
                        </MudButton>
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="Eagle A25" Icon="@Icons.Material.Outlined.Scanner">
                    <MudStack Spacing="2" Class="mt-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Search Eagle A25 air cargo records</MudText>
                        <MudButton Variant="Variant.Filled"
                                 Color="Color.Secondary"
                                 StartIcon="@Icons.Material.Outlined.Search"
                                 OnClick="@(() => _activeHubTab = 4)">
                            View All Eagle A25 Records
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
            </MudTabs>
        </MudStack>
    </MudPaper>

    <!-- Recent Activity -->
    <MudPaper Elevation="2" Class="mt-4 pa-4">
        <MudText Typo="Typo.h6" Class="mb-4">Recent Scanner Activity</MudText>
        @if (_recentActivity.Any())
        {
            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical">
                @foreach (var activity in _recentActivity)
                {
                    <MudTimelineItem Color="@activity.Color" Size="Size.Small">
                        <MudText Typo="Typo.body1">@activity.ScannerName completed scan for @activity.ContainerNumber</MudText>
                        <MudText Typo="Typo.caption">@FormatRelativeTime(activity.ScanTime)</MudText>
                    </MudTimelineItem>
                }
            </MudTimeline>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No recent activity</MudText>
        }
    </MudPaper>

        </MudTabPanel>

        <MudTabPanel Text="ASE X-Ray" Icon="@Icons.Material.Filled.Radar">
            <AsePanel />
        </MudTabPanel>

        <MudTabPanel Text="FS6000" Icon="@Icons.Material.Filled.CameraRear">
            <Fs6000Panel />
        </MudTabPanel>

        <MudTabPanel Text="Heimann Smith" Icon="@Icons.Material.Filled.Sensors">
            <HeimannSmithPanel />
        </MudTabPanel>

        <MudTabPanel Text="Eagle A25" Icon="@Icons.Material.Filled.FlightTakeoff">
            <EagleA25Panel />
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();
    private int _todayScans = 0;
    private int _yesterdayTotalScans = 0;
    private int _fs6000Scans = 0;
    private int _aseScans = 0;
    private int _hsScans = 0;
    private int _eagleA25Scans = 0;
    private int _totalFS6000Scans = 0;
    private int _totalAseScans = 0;
    private int _totalHsScans = 0;
    private int _totalEagleA25Scans = 0;
    private string? _lastError = null;
    
    // Last scan times
    private DateTime? _fs6000LastScan = null;
    private DateTime? _aseLastScan = null;
    private DateTime? _hsLastScan = null;
    private DateTime? _eagleA25LastScan = null;
    
    // Live telemetry health flags
    private bool? _fs6000Healthy;
    private bool? _aseSyncConfigured;
    private bool? _hsDataAvailable;
    
    // Average processing time (in minutes)
    private double _avgProcessingTimeMinutes = 0;
    
    // Recent activity
    private List<RecentActivityItem> _recentActivity = new();
    
    // Unified search
    private int _activeScannerTab = 0;

    // Top-level hub tab: 0 = Overview, 1 = ASE, 2 = FS6000, 3 = Heimann Smith, 4 = Eagle A25
    private int _activeHubTab = 0;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Outlined.Home),
            new BreadcrumbItem("Scanners", href: null, disabled: true, icon: Icons.Material.Outlined.Scanner)
        };

        // Route-based initial tab selection so legacy /scanners/ase etc. open on the right panel
        var path = new Uri(NavManager.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        _activeHubTab = path switch
        {
            "/scanners/ase"           => 1,
            "/scanners/fs6000"        => 2,
            "/scanners/heimann-smith" => 3,
            "/scanners/eagle-a25"     => 4,
            _                         => 0
        };

        await LoadScannerStatus();
    }

    private async Task LoadScannerStatus()
    {
        _lastError = null;
        
        try
        {
            Console.WriteLine("🔍 Loading scanner statistics from API...");
            
            // Load FS6000 statistics directly
            try
            {
                var fs6000Telemetry = await FS6000Client.GetTelemetryAsync<FS6000Telemetry>();
                if (fs6000Telemetry != null)
                {
                    _totalFS6000Scans = fs6000Telemetry.TotalScans;
                    _fs6000Scans = fs6000Telemetry.TodayScans;
                    _fs6000LastScan = fs6000Telemetry.LastScanTime;
                    _fs6000Healthy = fs6000Telemetry.SyncHealthy && fs6000Telemetry.IngestionHealthy;
                    Console.WriteLine($"✅ Loaded FS6000 telemetry: Total={_totalFS6000Scans}, Today={_fs6000Scans}, Healthy={_fs6000Healthy}");
                }

                var fs6000Stats = await FS6000Client.GetStatisticsAsync<FS6000Statistics>();
                if (fs6000Stats != null && fs6000Telemetry == null)
                {
                    _totalFS6000Scans = fs6000Stats.Scans?.Total ?? 0;
                    _fs6000Scans = fs6000Stats.Scans?.Today ?? 0; // Use actual today's scans
                    Console.WriteLine($"✅ Loaded FS6000 stats: Total={_totalFS6000Scans}, Today={_fs6000Scans}");
                }
                
                // Get last scan time - ensure we get the most recent scan
                var fs6000ScansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
                {
                    PageSize = 1
                });
                if (!_fs6000LastScan.HasValue && fs6000ScansResponse?.Data != null && fs6000ScansResponse.Data.Any())
                {
                    // API returns scans ordered by ScanTime descending, so First() is most recent
                    _fs6000LastScan = fs6000ScansResponse.Data.OrderByDescending(s => s.ScanTime).First().ScanTime;
                    Console.WriteLine($"✅ FS6000 last scan time: {_fs6000LastScan:yyyy-MM-dd HH:mm:ss}");
                }
                else
                {
                    _fs6000LastScan = null;
                    Console.WriteLine("⚠️ No FS6000 scans found");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not load FS6000 stats: {ex.Message}");
            }
            
            // Load ASE statistics directly
            try
            {
                var aseTelemetry = await AseClient.GetTelemetryAsync<AseTelemetry>();
                if (aseTelemetry != null)
                {
                    _totalAseScans = aseTelemetry.TotalScans;
                    _aseScans = aseTelemetry.TodayScans;
                    _aseLastScan = aseTelemetry.LastScanTime;
                    _aseSyncConfigured = aseTelemetry.SyncConfigured;
                    Console.WriteLine($"✅ Loaded ASE telemetry: Total={_totalAseScans}, Today={_aseScans}, SyncConfigured={_aseSyncConfigured}");
                }

                var aseStats = await AseClient.GetSyncStatusAsync<AseSyncStatus>();
                if (aseStats != null && aseTelemetry == null)
                {
                    _totalAseScans = aseStats.TotalScans;
                    _aseScans = aseStats.TodayScans ?? aseStats.RecentScans24h; // Use TodayScans if available
                    _aseLastScan = aseStats.LastSyncTime; // Use last sync time as proxy for last scan
                    _aseSyncConfigured = aseStats.Configuration?.CanSync;
                    Console.WriteLine($"✅ Loaded ASE stats: Total={_totalAseScans}, Today={_aseScans}");
                }
                
                // Get actual last scan time from recent scans - ensure we get the most recent scan
                // ✅ FIX: API returns AseScan entities directly, not wrapped in Data property
                // The response structure is: { Data: AseScan[], TotalCount, Page, PageSize, TotalPages }
                try
                {
                    var aseScansResponse = await AseClient.GetScansAsync<AseScanResponse>(new NickScanWebApp.Shared.Services.AseScanQuery
                    {
                        PageSize = 1
                    });
                    if (!_aseLastScan.HasValue && aseScansResponse?.Data != null && aseScansResponse.Data.Any())
                    {
                        // API returns scans ordered by ScanTime descending, so First() is most recent
                        // Ensure we get the most recent scan (in case API doesn't sort)
                        var mostRecentScan = aseScansResponse.Data.OrderByDescending(s => s.ScanTime).First();
                        _aseLastScan = mostRecentScan.ScanTime;
                        Console.WriteLine($"✅ ASE last scan time: {_aseLastScan:yyyy-MM-dd HH:mm:ss} UTC, Container: {mostRecentScan.ContainerNumber ?? "Unknown"}");
                    }
                    else
                    {
                        // Keep LastSyncTime if no scans found, but log it
                        if (!_aseLastScan.HasValue)
                        {
                            Console.WriteLine("⚠️ No ASE scans found in database");
                        }
                        else
                        {
                            Console.WriteLine($"⚠️ No ASE scans in response, using LastSyncTime: {_aseLastScan:yyyy-MM-dd HH:mm:ss}");
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Error loading ASE scans: {ex.Message}");
                    // Keep LastSyncTime as fallback
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not load ASE stats: {ex.Message}");
            }

            // Load Heimann Smith statistics from the live table when configured.
            try
            {
                var hsStats = await HeimannSmithClient.GetStatisticsAsync();
                if (hsStats != null)
                {
                    _totalHsScans = hsStats.TotalScans;
                    _hsScans = hsStats.TodayScans;
                    _hsLastScan = hsStats.LastScan?.ScanDateTime;
                    _hsDataAvailable = hsStats.TotalScans > 0;
                    Console.WriteLine($"✅ Loaded Heimann Smith stats: Total={_totalHsScans}, Today={_hsScans}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not load Heimann Smith stats: {ex.Message}");
            }

            // Load Eagle A25 statistics directly. This scanner is captured but assignment intake stays disabled by config.
            try
            {
                var eagleStatus = await EagleA25Client.GetSyncStatusAsync();
                if (eagleStatus != null)
                {
                    _totalEagleA25Scans = eagleStatus.TotalScans;
                    _eagleA25LastScan = eagleStatus.LastScan?.ScanDateUtc;

                    var todayUtc = DateTime.UtcNow.Date;
                    var tomorrowUtc = todayUtc.AddDays(1);
                    var todayResponse = await EagleA25Client.GetScansAsync(new NickScanWebApp.Shared.Services.EagleA25ScanQuery
                    {
                        PageSize = 1,
                        StartDate = todayUtc,
                        EndDate = tomorrowUtc
                    });
                    _eagleA25Scans = todayResponse?.TotalCount ?? 0;

                    Console.WriteLine($"✅ Loaded Eagle A25 stats: Total={_totalEagleA25Scans}, Today={_eagleA25Scans}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not load Eagle A25 stats: {ex.Message}");
            }
            
            // Calculate totals
            _todayScans = _fs6000Scans + _aseScans + _hsScans + _eagleA25Scans;
            
            // Load recent activity (last 10 scans across all scanners)
            await LoadRecentActivity();
            
            // Calculate average processing time from recent scans
            await CalculateAverageProcessingTime();
            
            _fs6000Healthy ??= _fs6000LastScan.HasValue;
            _aseSyncConfigured ??= _aseLastScan.HasValue;
            _hsDataAvailable ??= _hsLastScan.HasValue;
            
            // Calculate yesterday's total scans
            var yesterday = DateTime.Today.AddDays(-1);
            var yesterdayStart = yesterday;
            var yesterdayEnd = yesterday.AddDays(1);
            
            try
            {
                var fs6000Yesterday = await FS6000Client.GetStatsAsync<List<FS6000DailyStats>>(new NickScanWebApp.Shared.Services.ScannerDailyStatsQuery
                {
                    StartDate = yesterdayStart,
                    EndDate = yesterdayEnd
                });
                int fs6000YesterdayCount = 0;
                if (fs6000Yesterday != null && fs6000Yesterday.Any())
                {
                    fs6000YesterdayCount = fs6000Yesterday.Sum(s => s.Count);
                }
                
                // Get yesterday's ASE scans from stats
                var aseStats = await AseClient.GetStatsAsync<List<AseDailyStats>>();
                int aseYesterdayCount = 0;
                if (aseStats != null)
                {
                    var yesterdayStat = aseStats.FirstOrDefault(s => s.Date.Date == yesterday.Date);
                    aseYesterdayCount = yesterdayStat?.Count ?? 0;
                }

                var hsYesterday = await HeimannSmithClient.GetScansAsync(new NickScanWebApp.Shared.Services.HeimannSmithScanQuery
                {
                    PageSize = 1,
                    StartDate = yesterdayStart,
                    EndDate = yesterdayEnd
                });
                var hsYesterdayCount = hsYesterday?.TotalCount ?? 0;
                
                _yesterdayTotalScans = fs6000YesterdayCount + aseYesterdayCount + hsYesterdayCount;
                Console.WriteLine($"✅ Calculated yesterday's total scans: {_yesterdayTotalScans}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Could not calculate yesterday's scans: {ex.Message}");
                _yesterdayTotalScans = 0;
            }
            
            Console.WriteLine($"✅ Total scans today: {_todayScans}");
            Snackbar.Add("Scanner status refreshed", Severity.Success);
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            Console.WriteLine($"❌ Error loading scanner status: {ex.Message}");
            Snackbar.Add($"Failed to load scanner status: {ex.Message}", Severity.Error);
        }
    }
    
