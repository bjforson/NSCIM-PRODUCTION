    private async Task LoadRecentActivity()
    {
        try
        {
            _recentActivity.Clear();
            
            // Get recent FS6000 scans
            var fs6000ScansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
            {
                PageSize = 5
            });
            if (fs6000ScansResponse?.Data != null)
            {
                foreach (var scan in fs6000ScansResponse.Data.OrderByDescending(s => s.ScanTime).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "FS6000 Scanner",
                        ContainerNumber = scan.ContainerNumber ?? "Unknown",
                        ScanTime = scan.ScanTime,
                        Color = Color.Info
                    });
                }
            }
            
            // Get recent ASE scans
            var aseScansResponse = await AseClient.GetScansAsync<AseScanResponse>(new NickScanWebApp.Shared.Services.AseScanQuery
            {
                PageSize = 5
            });
            if (aseScansResponse?.Data != null)
            {
                foreach (var scan in aseScansResponse.Data.OrderByDescending(s => s.ScanTime).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "ASE Scanner",
                        ContainerNumber = scan.ContainerNumber ?? "Unknown",
                        ScanTime = scan.ScanTime,
                        Color = Color.Success
                    });
                }
            }

            var heimannScansResponse = await HeimannSmithClient.GetScansAsync(new NickScanWebApp.Shared.Services.HeimannSmithScanQuery
            {
                PageSize = 5
            });
            if (heimannScansResponse?.Data != null)
            {
                foreach (var scan in heimannScansResponse.Data.OrderByDescending(s => s.ScanDateTime).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "Heimann Smith Scanner",
                        ContainerNumber = string.IsNullOrWhiteSpace(scan.ContainerId) ? "Unknown" : scan.ContainerId,
                        ScanTime = scan.ScanDateTime,
                        Color = Color.Warning
                    });
                }
            }

            var eagleScansResponse = await EagleA25Client.GetScansAsync(new NickScanWebApp.Shared.Services.EagleA25ScanQuery
            {
                PageSize = 5
            });
            if (eagleScansResponse?.Data != null)
            {
                foreach (var scan in eagleScansResponse.Data.OrderByDescending(s => s.ScanDateUtc).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "Eagle A25 Scanner",
                        ContainerNumber = scan.CargoIdentifier ?? scan.AirWaybill ?? scan.Accession.ToString(),
                        ScanTime = scan.ScanDateUtc,
                        Color = Color.Secondary
                    });
                }
            }
            
            // Sort by time and take most recent 10
            _recentActivity = _recentActivity
                .OrderByDescending(a => a.ScanTime)
                .Take(10)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not load recent activity: {ex.Message}");
        }
    }
    
    private async Task CalculateAverageProcessingTime()
    {
        try
        {
            // Get recent scans and calculate average time between scans
            // This is a simplified calculation - ideally would use actual processing start/end times
            var fs6000ScansResponse = await FS6000Client.GetScansAsync<FS6000ScanResponse>(new NickScanWebApp.Shared.Services.FS6000ScanQuery
            {
                PageSize = 100
            });
            if (fs6000ScansResponse?.Data != null && fs6000ScansResponse.Data.Count > 1)
            {
                var sortedScans = fs6000ScansResponse.Data.OrderBy(s => s.ScanTime).ToList();
                var timeDiffs = new List<double>();
                
                for (int i = 1; i < sortedScans.Count; i++)
                {
                    var diff = (sortedScans[i].ScanTime - sortedScans[i-1].ScanTime).TotalMinutes;
                    if (diff > 0 && diff < 60) // Only count reasonable intervals (less than 1 hour)
                    {
                        timeDiffs.Add(diff);
                    }
                }
                
                if (timeDiffs.Any())
                {
                    _avgProcessingTimeMinutes = timeDiffs.Average();
                }
                else
                {
                    _avgProcessingTimeMinutes = 0;
                }
            }
            else
            {
                _avgProcessingTimeMinutes = 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not calculate average processing time: {ex.Message}");
            _avgProcessingTimeMinutes = 0;
        }
    }
    
    private string FormatRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;
        
        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} minutes ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} days ago";
        
        return dateTime.ToString("MMM dd, yyyy");
    }
    
    private string FormatLastScanTime(DateTime? lastScan)
    {
        if (!lastScan.HasValue)
            return "No scans";
        
        return FormatRelativeTime(lastScan.Value);
    }
    
