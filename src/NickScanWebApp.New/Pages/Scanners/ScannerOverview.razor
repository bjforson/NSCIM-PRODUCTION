    private string GetASEStatusText()
    {
        // Scanner is "Online" if:
        // 1. There are scans today, OR
        // 2. Last scan was within the last 24 hours (handle UTC vs local time)
        var now = DateTime.UtcNow; // Use UTC for consistent comparison
        var hasRecentActivity = _aseScans > 0;
        
        if (!hasRecentActivity && _aseLastScan.HasValue)
        {
            // Handle both UTC and local time scan times
            var lastScanUtc = _aseLastScan.Value;
            // If scan time appears to be local (no timezone info), assume it's UTC
            // Compare in UTC to avoid timezone issues
            var hoursSinceLastScan = (now - lastScanUtc).TotalHours;
            hasRecentActivity = hoursSinceLastScan < 24;
            
            if (!hasRecentActivity)
            {
                Console.WriteLine($"⚠️ ASE offline: Last scan {hoursSinceLastScan:F1} hours ago (UTC), Today's scans: {_aseScans}, Last scan time: {_aseLastScan:yyyy-MM-dd HH:mm:ss}");
            }
        }
        
        return hasRecentActivity ? "Online" : "Offline";
    }
    
    private Color GetASEStatusColor()
    {
        // Use same logic as GetASEStatusText for consistency
        var now = DateTime.UtcNow;
        var hasRecentActivity = _aseScans > 0;
        
        if (!hasRecentActivity && _aseLastScan.HasValue)
        {
            var hoursSinceLastScan = (now - _aseLastScan.Value).TotalHours;
            hasRecentActivity = hoursSinceLastScan < 24;
        }
        
        return hasRecentActivity ? Color.Success : Color.Error;
    }
    
