    private async Task LoadRecentActivity()
    {
        try
        {
            _recentActivity.Clear();
            
            // Get recent FS6000 scans
            var fs6000ScansResponse = await ApiService.GetAsync<FS6000ScanResponse>("/api/FS6000/scans?pageSize=5");
            if (fs6000ScansResponse?.Data != null)
            {
                foreach (var scan in fs6000ScansResponse.Data.OrderByDescending(s => s.ScanTime).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "FS6000 Scanner",
                        ContainerNumber = scan.ContainerNumber ?? "Unknown",
                        ScanTime = scan.ScanTime,
                        Color = Color.Info
                    });
                }
            }
            
            // Get recent ASE scans
            var aseScansResponse = await ApiService.GetAsync<AseScanResponse>("/api/Ase/scans?pageSize=5");
            if (aseScansResponse?.Data != null)
            {
                foreach (var scan in aseScansResponse.Data.OrderByDescending(s => s.ScanTime).Take(5))
                {
                    _recentActivity.Add(new RecentActivityItem
                    {
                        ScannerName = "ASE Scanner",
                        ContainerNumber = scan.ContainerNumber ?? "Unknown",
                        ScanTime = scan.ScanTime,
                        Color = Color.Success
                    });
                }
            }
            
            // Sort by time and take most recent 10
            _recentActivity = _recentActivity
                .OrderByDescending(a => a.ScanTime)
                .Take(10)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not load recent activity: {ex.Message}");
        }
    }
    
    private async Task CalculateAverageProcessingTime()
    {
        try
        {
            // Get recent scans and calculate average time between scans
            // This is a simplified calculation - ideally would use actual processing start/end times
            var fs6000ScansResponse = await ApiService.GetAsync<FS6000ScanResponse>("/api/FS6000/scans?pageSize=100");
            if (fs6000ScansResponse?.Data != null && fs6000ScansResponse.Data.Count > 1)
            {
                var sortedScans = fs6000ScansResponse.Data.OrderBy(s => s.ScanTime).ToList();
                var timeDiffs = new List<double>();
                
                for (int i = 1; i < sortedScans.Count; i++)
                {
                    var diff = (sortedScans[i].ScanTime - sortedScans[i-1].ScanTime).TotalMinutes;
                    if (diff > 0 && diff < 60) // Only count reasonable intervals (less than 1 hour)
                    {
                        timeDiffs.Add(diff);
                    }
                }
                
                if (timeDiffs.Any())
                {
                    _avgProcessingTimeMinutes = timeDiffs.Average();
                }
                else
                {
                    _avgProcessingTimeMinutes = 2.3; // Default fallback
                }
            }
            else
            {
                _avgProcessingTimeMinutes = 2.3; // Default fallback
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not calculate average processing time: {ex.Message}");
            _avgProcessingTimeMinutes = 2.3; // Default fallback
        }
    }
    
    private string FormatRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;
        
        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} minutes ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} days ago";
        
        return dateTime.ToString("MMM dd, yyyy");
    }
    
    private string FormatLastScanTime(DateTime? lastScan)
    {
        if (!lastScan.HasValue)
            return "No scans";
        
        return FormatRelativeTime(lastScan.Value);
    }
    
    private string FormatUptime(double uptime)
    {
        if (uptime <= 0)
            return "N/A";
        
        return $"{uptime:F1}%";
    }
    
    private string FormatProcessingTime(double minutes)
    {
        if (minutes < 1)
            return $"{(int)(minutes * 60)}s";
        if (minutes < 60)
            return $"{minutes:F1} min";
        
        var hours = minutes / 60;
        return $"{hours:F1} hr";
    }
    
    private string GetUptimeColor(double uptime)
    {
        if (uptime >= 99.0) return "var(--mud-palette-success)";
        if (uptime >= 95.0) return "var(--mud-palette-warning)";
        return "var(--mud-palette-error)";
    }
    
    private string GetUptimeColorString(double uptime)
    {
        return GetUptimeColor(uptime);
    }
    
    private string GetSystemStatusText()
    {
        var onlineCount = 0;
        if (_fs6000Scans > 0 || _fs6000LastScan.HasValue) onlineCount++;
        if (_aseScans > 0 || _aseLastScan.HasValue) onlineCount++;
        if (_hsScans > 0 || _hsLastScan.HasValue) onlineCount++;
        
        if (onlineCount == 3) return "All Systems Operational";
        if (onlineCount == 2) return "2 of 3 Systems Online";
        if (onlineCount == 1) return "1 of 3 Systems Online";
        return "Systems Offline";
    }
    
    private Color GetSystemStatusColor()
    {
        var onlineCount = 0;
        if (_fs6000Scans > 0 || _fs6000LastScan.HasValue) onlineCount++;
        if (_aseScans > 0 || _aseLastScan.HasValue) onlineCount++;
        if (_hsScans > 0 || _hsLastScan.HasValue) onlineCount++;
        
        if (onlineCount == 3) return Color.Success;
        if (onlineCount >= 1) return Color.Warning;
        return Color.Error;
    }
    
    private string GetFS6000StatusText()
    {
        // Scanner is "Online" if:
        // 1. There are scans today, OR
        // 2. Last scan was within the last 24 hours
        var hasRecentActivity = _fs6000Scans > 0 || 
                                (_fs6000LastScan.HasValue && (DateTime.Now - _fs6000LastScan.Value).TotalHours < 24);
        
        if (!hasRecentActivity && _fs6000LastScan.HasValue)
        {
            var hoursSinceLastScan = (DateTime.Now - _fs6000LastScan.Value).TotalHours;
            Console.WriteLine($"⚠️ FS6000 offline: Last scan {hoursSinceLastScan:F1} hours ago, Today's scans: {_fs6000Scans}");
        }
        
        return hasRecentActivity ? "Online" : "Offline";
    }
    
    private Color GetFS6000StatusColor()
    {
        if (_fs6000Scans > 0 || (_fs6000LastScan.HasValue && (DateTime.Now - _fs6000LastScan.Value).TotalHours < 24))
            return Color.Success;
        return Color.Error;
    }
    
    private string GetFS6000StatusIcon()
    {
        if (_fs6000Scans > 0 || (_fs6000LastScan.HasValue && (DateTime.Now - _fs6000LastScan.Value).TotalHours < 24))
            return Icons.Material.Outlined.CheckCircle;
        return Icons.Material.Outlined.Error;
    }
    
    private string GetASEStatusText()
    {
        // Scanner is "Online" if:
        // 1. There are scans today, OR
        // 2. Last scan was within the last 24 hours (handle UTC vs local time)
        var now = DateTime.UtcNow; // Use UTC for consistent comparison
        var hasRecentActivity = _aseScans > 0;
        
        if (!hasRecentActivity && _aseLastScan.HasValue)
        {
            // Handle both UTC and local time scan times
            var lastScanUtc = _aseLastScan.Value;
            // If scan time appears to be local (no timezone info), assume it's UTC
            // Compare in UTC to avoid timezone issues
            var hoursSinceLastScan = (now - lastScanUtc).TotalHours;
            hasRecentActivity = hoursSinceLastScan < 24;
            
            if (!hasRecentActivity)
            {
                Console.WriteLine($"⚠️ ASE offline: Last scan {hoursSinceLastScan:F1} hours ago (UTC), Today's scans: {_aseScans}, Last scan time: {_aseLastScan:yyyy-MM-dd HH:mm:ss}");
            }
        }
        
        return hasRecentActivity ? "Online" : "Offline";
    }
    
    private Color GetASEStatusColor()
    {
        // Use same logic as GetASEStatusText for consistency
        var now = DateTime.UtcNow;
        var hasRecentActivity = _aseScans > 0;
        
        if (!hasRecentActivity && _aseLastScan.HasValue)
        {
            var hoursSinceLastScan = (now - _aseLastScan.Value).TotalHours;
            hasRecentActivity = hoursSinceLastScan < 24;
        }
        
        return hasRecentActivity ? Color.Success : Color.Error;
    }
    
