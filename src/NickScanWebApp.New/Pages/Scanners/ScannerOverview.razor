    private string FormatProcessingTime(double minutes)
    {
        if (minutes <= 0)
            return "N/A";
        if (minutes < 1)
            return $"{(int)(minutes * 60)}s";
        if (minutes < 60)
            return $"{minutes:F1} min";
        
        var hours = minutes / 60;
        return $"{hours:F1} hr";
    }
    
    private string GetSystemStatusText()
    {
        var onlineCount = 0;
        if (_fs6000Scans > 0 || _fs6000LastScan.HasValue) onlineCount++;
        if (_aseScans > 0 || _aseLastScan.HasValue) onlineCount++;
        if (_hsScans > 0 || _hsLastScan.HasValue) onlineCount++;
        if (_eagleA25Scans > 0 || _eagleA25LastScan.HasValue) onlineCount++;
        
        if (onlineCount == 4) return "All Systems Operational";
        if (onlineCount > 0) return $"{onlineCount} of 4 Systems Online";
        return "Systems Offline";
    }
    
