@page "/containers/{ContainerNumber}"
@page "/containers/details"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesContainersDetails)]
@using MudBlazor
@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using NickScanWebApp.Mobile.Services
@using NickScanWebApp.Mobile.Components.CargoGroup
@using NickScanWebApp.Mobile.Components.Containers
@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject IConfiguration Configuration
@inject CargoGroupService CargoGroupService
@inject ILogger<ContainerDetails> Logger

<PageTitle>@ContainerNumber - Container Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    
    <!-- Breadcrumbs -->
    <MudBreadcrumbs Items="@_breadcrumbs" Class="mb-2 pa-0" Style="font-size:12px;">
        <ItemTemplate Context="item">
            <MudLink Href="@item.Href" Typo="Typo.caption">@item.Text</MudLink>
        </ItemTemplate>
    </MudBreadcrumbs>
    
    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        <MudText Align="Align.Center">Loading container data...</MudText>
    }
    else if (containerData == null)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Class="mt-4">Container not found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No data found for container: @ContainerNumber</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/containers" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mt-4">
                Back to Container List
            </MudButton>
        </MudPaper>
    }
    else
    {
        <!-- Header Card with promoted actions -->
        <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h5" Style="font-family: monospace;">@ContainerNumber</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @containerData.ScannerType on @containerData.ScanDate.ToString("dd MMM yyyy HH:mm")
                        </MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" OnClick="@RefreshData" />
                </MudStack>
                
                <!-- Status Chips -->
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    <MudChip T="string" Size="Size.Small" Color="@GetValidationColor(containerData.ValidationStatus)">
                        @containerData.ValidationStatus
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@GetCompletenessColor((int)containerData.CompletenessScore)">
                        @((int)containerData.CompletenessScore)% Complete
                    </MudChip>
                    @if (containerData.HasICUMSData)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">ICUMS</MudChip>
                    }
                    @if (containerData.ImageCount > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@containerData.ImageCount Image(s)</MudChip>
                    }
                </MudStack>

                <!-- Promoted Action Bar -->
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    @if (containerData.ValidationStatus != "Validated")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="@ApproveContainer">
                            Approve
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Cancel" OnClick="@RejectContainer">
                            Reject
                        </MudButton>
                    }
                    @if (canSubmit)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CloudUpload" OnClick="@SubmitToICUMS">
                            ICUMS
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportReport">
                        Export
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
        
        <!-- Status Overview Cards - Mobile Optimized (4 cards like desktop) -->
        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Validation Status</MudText>
                        <ValidationStatusBadge Status="@containerData.ValidationStatus" Size="Size.Small" />
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Data Completeness</MudText>
                        <CompletenessIndicator Score="@containerData.CompletenessScore" ShowAsProgressBar="false" ChipSize="Size.Small" />
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Images Available</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Image" 
                                    Color="@(containerData.ImageCount > 0 ? Color.Success : Color.Default)" 
                                    Size="Size.Medium" />
                            <MudText Typo="Typo.h6">@containerData.ImageCount</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Clearance Type</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                            @(containerData.ClearanceType ?? "N/A")
                        </MudChip>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
        
        <!-- Actions already promoted to header card above -->
        
        <!-- Image Preview - Mobile Collapsible -->
        @if (containerData.ImageCount > 0 && imageMetadataList != null && imageMetadataList.Any() && !string.IsNullOrEmpty(imageMetadataList.First().ThumbnailUrl))
        {
            <MudExpansionPanels Class="mb-3">
                <MudExpansionPanel Text="Image Preview" Icon="@Icons.Material.Filled.Image">
                    <MudPaper Elevation="0" Class="pa-2">
                        <MudImage Src="@imageMetadataList.First().ThumbnailUrl"
                                 Alt="Container scan"
                                 Elevation="1"
                                 Class="rounded-lg mb-2"
                                 ObjectFit="ObjectFit.Contain"
                                 MaxHeight="300" />
                        <MudButton Variant="Variant.Outlined"
                                  Color="Color.Primary"
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.ZoomIn"
                                  FullWidth="true"
                                  OnClick="@(() => OpenFullscreenViewer(imageMetadataList.First().FullImageUrl))">
                            View Full Image
                        </MudButton>
                    </MudPaper>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
        
        <!-- Main Content - CargoGroupView or Legacy Tabs -->
        @if (_loadingGroupIdentifier)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2">Determining cargo group...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrEmpty(_groupIdentifier))
        {
            <!-- Use standardized CargoGroupView -->
            <CargoGroupView GroupIdentifier="@_groupIdentifier" Type="@_cargoType" />
        }
        else
        {
            <!-- Fallback to legacy tabs if group identifier not found -->
            <!-- Tabs -->
            <MudTabs Elevation="2" Rounded="true" PanelClass="pa-3" Color="Color.Primary">
            
                <!-- Scanner Data Tab -->
                <MudTabPanel Text="Scanner" Icon="@Icons.Material.Filled.Scanner">
                <MudStack Spacing="3">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.h6" Class="mb-3">Scanner Information</MudText>
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr>
                                    <td><strong>Scanner Type</strong></td>
                                    <td>@containerData.ScannerType</td>
                                </tr>
                                <tr>
                                    <td><strong>Scan Date</strong></td>
                                    <td>@containerData.ScanDate.ToString("dd MMM yyyy HH:mm:ss")</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(containerData.ScanLocation))
                                {
                                    <tr>
                                        <td><strong>Location</strong></td>
                                        <td>@containerData.ScanLocation</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudStack>
            </MudTabPanel>
            
            <!-- ICUMS Data Tab -->
            <MudTabPanel Text="ICUMS" Icon="@Icons.Material.Filled.Description" Disabled="@(!containerData.HasICUMSData)">
                @if (containerData.HasICUMSData && icumsDataRecords != null && icumsDataRecords.Data.Any())
                {
                    <MudStack Spacing="3">
                        @foreach (var categoryGroup in GetGroupedICUMSData())
                        {
                            <MudPaper Elevation="2" Class="pa-3">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@GetCategoryIcon(categoryGroup.Key)" Color="@GetCategoryColor(categoryGroup.Key)" />
                                        <MudText Typo="Typo.h6" Color="@GetCategoryColor(categoryGroup.Key)">@categoryGroup.Key</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@categoryGroup.Value.Count fields</MudChip>
                                    </MudStack>
                                    
                                    <MudGrid Spacing="2">
                                        @foreach (var record in categoryGroup.Value)
                                        {
                                            <MudItem xs="12" sm="6">
                                                <MudStack Spacing="1">
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;">
                                                            @record.Field
                                                        </MudText>
                                                        @if (record.IsRequired)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Style="height: 18px; font-size: 0.7rem;">Required</MudChip>
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.body2" Color="@(record.Value == "Not available" || record.Value == "N/A" ? Color.Warning : Color.Default)">
                                                        @record.Value
                                                    </MudText>
                                                </MudStack>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudStack>
                            </MudPaper>
                        }
                        
                        <!-- Summary -->
                        <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true">
                            <MudText Typo="Typo.caption">
                                Total ICUMS Fields: @icumsDataRecords.TotalCount | Categories: @GetGroupedICUMSData().Count
                            </MudText>
                        </MudAlert>
                    </MudStack>
                }
                else if (containerData.HasICUMSData)
                {
                    <MudAlert Severity="Severity.Warning">
                        ICUMS data is marked as available but records could not be loaded. Try refreshing.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">
                        No ICUMS data available. Use the action button to fetch from ICUMS.
                    </MudAlert>
                }
            </MudTabPanel>
            
            <!-- Images Tab -->
            <MudTabPanel Text="Images" Icon="@Icons.Material.Filled.Image" BadgeData="@containerData.ImageCount" BadgeColor="Color.Success">
                @if (containerData.ImageCount > 0 && imageMetadataList != null && imageMetadataList.Any())
                {
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body1">@containerData.ImageCount image(s) available</MudText>
                        
                        @foreach (var image in imageMetadataList)
                        {
                            <MudPaper Elevation="2" Class="pa-2 mb-3">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@image.ImageType - @image.FileName</MudText>
                                    @if (!string.IsNullOrEmpty(image.ThumbnailUrl))
                                    {
                                        <MudImage Src="@image.ThumbnailUrl"
                                                 Alt="@($"Container scan - {image.ImageType}")"
                                                 Elevation="1"
                                                 Class="rounded-lg"
                                                 ObjectFit="ObjectFit.Contain"
                                                 MaxHeight="400"
                                                 @onerror="@(() => Snackbar.Add($"Failed to load image: {image.ImageType}", Severity.Warning))" />
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Warning">Image URL not available</MudAlert>
                                    }
                                    
                                    <MudStack Row="true" Spacing="2">
                                        @if (!string.IsNullOrEmpty(image.FullImageUrl))
                                        {
                                            <MudButton Variant="Variant.Outlined" 
                                                      Size="Size.Small"
                                                      StartIcon="@Icons.Material.Filled.ZoomIn"
                                                      OnClick="@(() => OpenFullscreenViewer(image.FullImageUrl))">
                                                View Full Screen
                                            </MudButton>
                                        }
                                        <MudButton Variant="Variant.Outlined" 
                                                  Size="Size.Small"
                                                  StartIcon="@Icons.Material.Filled.Download"
                                                  OnClick="@(() => DownloadImage(image))">
                                            Download
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
                else if (containerData.ImageCount > 0)
                {
                    <MudAlert Severity="Severity.Warning">
                        Images are marked as available but metadata could not be loaded. Try refreshing.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">
                        No images available for this container.
                    </MudAlert>
                }
            </MudTabPanel>
            
            <!-- Validation Tab -->
            <MudTabPanel Text="Validation" Icon="@Icons.Material.Filled.FactCheck">
                <MudStack Spacing="3">
                    <MudAlert Severity="@GetValidationSeverity()">
                        <MudText Typo="Typo.body1"><strong>Status:</strong> @containerData.ValidationStatus</MudText>
                        <MudText Typo="Typo.body2">Completeness Score: @((int)containerData.CompletenessScore)%</MudText>
                    </MudAlert>
                    
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.h6" Class="mb-3">Data Checks</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="@(containerData.HasScannerData ? Color.Success : Color.Error)">
                                Scanner Data: @(containerData.HasScannerData ? "Available" : "Missing")
                            </MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="@(containerData.HasICUMSData ? Color.Success : Color.Error)">
                                ICUMS Data: @(containerData.HasICUMSData ? "Available" : "Missing")
                            </MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="@(containerData.ImageCount > 0 ? Color.Success : Color.Error)">
                                Images: @(containerData.ImageCount > 0 ? $"{containerData.ImageCount} found" : "None")
                            </MudListItem>
                        </MudList>
                    </MudPaper>
                </MudStack>
            </MudTabPanel>
            
            <!-- History/Audit Tab -->
            <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
                <MudStack Spacing="3">
                    <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                        <MudTimelineItem Color="Color.Success" Size="Size.Small">
                            <ItemContent>
                                <MudText Typo="Typo.body1"><strong>Container Scanned</strong></MudText>
                                <MudText Typo="Typo.caption">@containerData.ScanDate.ToString("dd MMM yyyy HH:mm")</MudText>
                                <MudText Typo="Typo.body2">Scanned by @containerData.ScannerType</MudText>
                            </ItemContent>
                        </MudTimelineItem>
                        
                        @if (containerData.HasICUMSData)
                        {
                            <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                <ItemContent>
                                    <MudText Typo="Typo.body1"><strong>ICUMS Data Fetched</strong></MudText>
                                    <MudText Typo="Typo.caption">@DateTime.Now.AddHours(-2).ToString("dd MMM yyyy HH:mm")</MudText>
                                    <MudText Typo="Typo.body2">BOE data synchronized</MudText>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                        
                        @if (containerData.ValidationStatus == "Validated")
                        {
                            <MudTimelineItem Color="Color.Success" Size="Size.Small">
                                <ItemContent>
                                    <MudText Typo="Typo.body1"><strong>Validated</strong></MudText>
                                    <MudText Typo="Typo.caption">@DateTime.Now.AddMinutes(-30).ToString("dd MMM yyyy HH:mm")</MudText>
                                    <MudText Typo="Typo.body2">Approved for customs clearance</MudText>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                </MudStack>
            </MudTabPanel>
            
        </MudTabs>
        }
    }
</MudContainer>

@code {
    [Parameter] public string ContainerNumber { get; set; } = "";
    
    private bool isLoading = true;
    private bool isFetchingICUMS = false;
    private bool canSubmit = false;
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Home", href: "/dashboard", icon: Icons.Material.Filled.Home),
        new BreadcrumbItem("Containers", href: "/containers", icon: Icons.Material.Filled.Inventory),
        new BreadcrumbItem("Details", href: null, disabled: true)
    };
    private bool _loadingGroupIdentifier = false;
    private string? _groupIdentifier;
    private CargoType _cargoType;
    private ContainerDetailsViewModel? containerData;
    private PagedResult<ICUMSDataRecord>? icumsDataRecords;
    private List<NickScanWebApp.Shared.Models.ImageMetadata>? imageMetadataList;
    
    protected override async Task OnParametersSetAsync()
    {
        await LoadContainerData();
        await DetermineCargoGroupAsync();
    }
    
    private async Task LoadContainerData()
    {
        isLoading = true;
        try
        {
            var basicInfo = await ContainerDetailsService.GetBasicInfoAsync(ContainerNumber);
            
            if (basicInfo != null)
            {
                var scannerData = await ContainerDetailsService.GetFullScannerDataAsync(ContainerNumber);
                var icumsData = await ContainerDetailsService.GetFullBOEDataAsync(ContainerNumber);
                imageMetadataList = await ContainerDetailsService.GetImageMetadataAsync(ContainerNumber);
                
                // Load full ICUMS data records if available
                if (basicInfo.ICUMSRecordCount > 0)
                {
                    icumsDataRecords = await ContainerDetailsService.GetICUMSDataAsync(ContainerNumber, page: 1, pageSize: 100);
                }
                
                containerData = new ContainerDetailsViewModel
                {
                    ContainerNumber = ContainerNumber,
                    ScannerType = basicInfo.ScannerType ?? "Unknown",
                    ScanDate = basicInfo.LastUpdated,
                    ValidationStatus = basicInfo.ValidationStatus ?? "Pending",
                    CompletenessScore = basicInfo.DataCompletenessScore,
                    ClearanceType = icumsData?.ClearanceType,
                    ImageCount = basicInfo.ImageCount,
                    HasScannerData = basicInfo.ScannerRecordCount > 0,
                    HasICUMSData = basicInfo.ICUMSRecordCount > 0,
                    BOENumber = icumsData?.DeclarationNumber,
                    Consignee = icumsData?.ConsigneeName,
                    OriginPort = null,
                    Destination = null,
                    VesselName = null,
                    VehicleCount = 0,
                    ScanLocation = null,
                    Operator = null,
                    ContainerSize = null
                };
                
                canSubmit = containerData.CompletenessScore >= 70 && containerData.HasICUMSData;
            }
            else
            {
                Snackbar.Add("No data found for container", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            containerData = null;
            Snackbar.Add($"Error loading container: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task RefreshData()
    {
        await LoadContainerData();
        await DetermineCargoGroupAsync();
        Snackbar.Add("Data refreshed", Severity.Success);
    }

    private async Task DetermineCargoGroupAsync()
    {
        if (string.IsNullOrEmpty(ContainerNumber))
        {
            _loadingGroupIdentifier = false;
            return;
        }

        _loadingGroupIdentifier = true;
        try
        {
            var groupIdentifierResponse = await CargoGroupService.GetGroupIdentifierByContainerAsync(ContainerNumber);

            if (groupIdentifierResponse != null)
            {
                _groupIdentifier = groupIdentifierResponse.GroupIdentifier;
                _cargoType = groupIdentifierResponse.Type;
                Logger.LogInformation("Determined cargo group: {GroupIdentifier}, Type: {Type}", _groupIdentifier, _cargoType);
            }
            else
            {
                Logger.LogInformation("No cargo group found for container: {ContainerNumber}", ContainerNumber);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error determining cargo group for container {ContainerNumber}", ContainerNumber);
            _groupIdentifier = null;
        }
        finally
        {
            _loadingGroupIdentifier = false;
        }
    }
    
    private async Task FetchICUMSData()
    {
        isFetchingICUMS = true;
        Snackbar.Add("Fetching ICUMS data...", Severity.Info);
        await Task.Delay(2000);
        isFetchingICUMS = false;
        Snackbar.Add("ICUMS data fetched successfully", Severity.Success);
    }
    
    private void ApproveContainer()
    {
        Snackbar.Add($"Container {ContainerNumber} approved", Severity.Success);
        if (containerData != null) containerData.ValidationStatus = "Validated";
    }
    
    private void RejectContainer()
    {
        Snackbar.Add($"Container {ContainerNumber} rejected", Severity.Warning);
    }
    
    private void SubmitToICUMS()
    {
        Snackbar.Add($"Submitting {ContainerNumber} to ICUMS...", Severity.Info);
    }
    
    private void ExportReport()
    {
        Snackbar.Add($"Exporting report for {ContainerNumber}", Severity.Info);
        // TODO: Generate PDF/Excel report
        // Could use JS interop to trigger download
    }
    
    private void OpenFullscreenViewer(string? imageUrl = null)
    {
        if (!string.IsNullOrEmpty(imageUrl))
        {
            // Open in new tab/window with the full image URL
            NavigationManager.NavigateTo(imageUrl, forceLoad: true);
        }
        else
        {
            NavigationManager.NavigateTo($"/images/viewer/{ContainerNumber}");
        }
    }
    
    private void DownloadImage(NickScanWebApp.Shared.Models.ImageMetadata? image = null)
    {
        if (image != null && !string.IsNullOrEmpty(image.FullImageUrl))
        {
            // Open download link
            NavigationManager.NavigateTo(image.FullImageUrl, forceLoad: true);
            Snackbar.Add($"Downloading {image.ImageType} image...", Severity.Info);
        }
        else
        {
            Snackbar.Add("Downloading image...", Severity.Info);
            // TODO: Implement actual download
        }
    }
    
    private Severity GetValidationSeverity()
    {
        return containerData?.ValidationStatus switch
        {
            "Validated" => Severity.Success,
            "Pending" => Severity.Warning,
            "Error" => Severity.Error,
            _ => Severity.Info
        };
    }
    
    private Color GetValidationColor(string status)
    {
        return status switch
        {
            "Validated" => Color.Success,
            "Pending" => Color.Warning,
            "Error" => Color.Error,
            _ => Color.Default
        };
    }
    
    private Color GetCompletenessColor(int score)
    {
        if (score >= 90) return Color.Success;
        if (score >= 70) return Color.Warning;
        return Color.Error;
    }
    
    private Dictionary<string, List<ICUMSDataRecord>> GetGroupedICUMSData()
    {
        if (icumsDataRecords?.Data == null)
            return new Dictionary<string, List<ICUMSDataRecord>>();
        
        return icumsDataRecords.Data
            .GroupBy(r => r.Category ?? "Other")
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }
    
    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Container Info" => Icons.Material.Filled.Inventory2,
            "Declaration Info" => Icons.Material.Filled.Description,
            "Manifest Info" => Icons.Material.Filled.List,
            "Party Info" => Icons.Material.Filled.People,
            "Location Info" => Icons.Material.Filled.Place,
            "Cargo Info" => Icons.Material.Filled.LocalShipping,
            "Financial Info" => Icons.Material.Filled.AttachMoney,
            "Risk Assessment" => Icons.Material.Filled.Security,
            "Status" => Icons.Material.Filled.Info,
            "Data Info" => Icons.Material.Filled.DataUsage,
            "Additional Fields" => Icons.Material.Filled.AddCircle,
            _ => Icons.Material.Filled.Category
        };
    }
    
    private Color GetCategoryColor(string category)
    {
        return category switch
        {
            "Container Info" => Color.Primary,
            "Declaration Info" => Color.Info,
            "Manifest Info" => Color.Secondary,
            "Party Info" => Color.Success,
            "Location Info" => Color.Warning,
            "Cargo Info" => Color.Default,
            "Financial Info" => Color.Success,
            "Risk Assessment" => Color.Error,
            "Status" => Color.Info,
            "Data Info" => Color.Secondary,
            "Additional Fields" => Color.Warning,
            _ => Color.Default
        };
    }
    
