@page "/operations/completeness-records"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesContainerCompleteness)]
@using NickScanWebApp.Mobile.Services
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Container Completeness Records - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    
    <!-- Header -->
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5" Color="Color.Primary">
                <MudIcon Icon="@Icons.Material.Filled.FactCheck" Class="mr-2" />
                Container Completeness Records
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Detailed validation records for all containers ready for submission
            </MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          Size="Size.Small"
                          StartIcon="@Icons.Material.Filled.Refresh"
                          OnClick="@LoadValidationData"
                          Disabled="@isLoadingValidationData">
                    @if (isLoadingValidationData)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Refresh
                </MudButton>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Total: @totalValidationContainers
                </MudText>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Stats Cards -->
    <MudGrid Class="mb-3">
        <MudItem xs="6">
            <MudPaper Elevation="2" Class="pa-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Total Records</MudText>
                <MudText Typo="Typo.h5">@totalValidationContainers</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="2" Class="pa-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Ready</MudText>
                <MudText Typo="Typo.h5">@readyForValidationCount</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
    
    <!-- Validation Records List -->
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (filteredValidationContainers.Any())
    {
        <MudStack Spacing="2">
            @foreach (var container in filteredValidationContainers)
            {
                <MudCard Elevation="2" Class="pa-3" OnClick="@(() => ViewContainer(container.ContainerNumber))">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                            <MudText Typo="Typo.body1" Style="font-family: monospace;"><strong>@container.ContainerNumber</strong></MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetValidationStatusColor(container.Status)">
                                @container.Status
                            </MudChip>
                        </MudStack>
                        
                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                            <MudChip T="string" Size="Size.Small" Color="@GetClearanceTypeColor(container.ClearanceType)">
                                @container.ClearanceType
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="@GetScannerTypeColor(container.ScannerType)">
                                @container.ScannerType
                            </MudChip>
                        </MudStack>
                        
                        <MudProgressLinear Color="@GetCompletenessColor(container.DataCompletenessPercentage)"
                                         Value="@container.DataCompletenessPercentage"
                                         Size="Size.Small" Rounded="true" />
                        <MudText Typo="Typo.caption" Color="@GetCompletenessColor(container.DataCompletenessPercentage)">
                            Completeness: @container.DataCompletenessPercentage%
                        </MudText>
                        
                        <MudStack Row="true" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Scanner" 
                                   Color="@(container.ScannerDataPercentage == 100 ? Color.Success : Color.Warning)" 
                                   Size="Size.Small" />
                            <MudText Typo="Typo.caption">Scanner: @container.ScannerDataPercentage%</MudText>
                            
                            <MudIcon Icon="@Icons.Material.Filled.Description" 
                                   Color="@(container.ICUMSDataPercentage == 100 ? Color.Success : Color.Warning)" 
                                   Size="Size.Small" Class="ml-3" />
                            <MudText Typo="Typo.caption">ICUMS: @container.ICUMSDataPercentage%</MudText>
                            
                            <MudIcon Icon="@Icons.Material.Filled.Image" 
                                   Color="@(container.HasImageData ? Color.Success : Color.Error)" 
                                   Size="Size.Small" Class="ml-3" />
                        </MudStack>
                        
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Created: @container.CreatedAt.ToString("dd MMM yyyy HH:mm")
                        </MudText>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
        
        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <MudPaper Elevation="0" Class="pa-3 mt-3">
                <MudPagination Count="@totalPages" 
                             Selected="@currentPage" 
                             SelectedChanged="@OnPageChanged" 
                             Color="Color.Primary" />
            </MudPaper>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Info">
            No validation records found.
        </MudAlert>
    }
</MudContainer>

@code {
    private bool _isLoading = false;
    private bool isLoadingValidationData = false;
    private List<ValidationContainerItem> allValidationContainers = new();
    private List<ValidationContainerItem> filteredValidationContainers = new();
    private int readyForValidationCount = 0;
    private int totalValidationContainers = 0;
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 0;
    
    private System.Threading.Timer? _refreshTimer;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadValidationData();
        
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadValidationData();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }
    
    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
    
    private async Task LoadValidationData()
    {
        isLoadingValidationData = true;
        try
        {
            var queryParams = $"page={currentPage}&pageSize={pageSize}";
            var response = await ApiService.GetAsync<PagedValidationApiResponse>($"/api/containervalidation/pending?{queryParams}");
            
            if (response?.Data != null)
            {
                allValidationContainers = response.Data.Select(v => new ValidationContainerItem
                {
                    Id = v.Id,
                    ContainerNumber = v.ContainerNumber ?? "",
                    ClearanceType = v.ClearanceType ?? "Unknown",
                    ScannerType = v.ScannerType ?? "Unknown",
                    Status = v.Status ?? "Pending",
                    DataCompletenessPercentage = v.DataCompletenessPercentage,
                    ScannerDataPercentage = v.ScannerCompleteness?.CompletenessScore ?? 0,
                    ICUMSDataPercentage = v.ICUMSCompleteness?.CompletenessScore ?? 0,
                    HasImageData = v.ImageCompleteness?.HasImage ?? false,
                    CreatedAt = v.CreatedAt,
                    IsReadyForSubmission = v.IsReadyForSubmission
                }).ToList();
                
                filteredValidationContainers = allValidationContainers;
                totalValidationContainers = response.TotalCount;
                totalPages = response.TotalPages > 0 ? response.TotalPages : (int)Math.Ceiling((double)totalValidationContainers / pageSize);
                readyForValidationCount = totalValidationContainers;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading validation data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoadingValidationData = false;
            _isLoading = false;
        }
    }
    
    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        await LoadValidationData();
    }
    
    private void ViewContainer(string containerNumber)
    {
        NavigationManager.NavigateTo($"/containers/{containerNumber}");
    }
    
    private Color GetClearanceTypeColor(string clearanceType)
    {
        return clearanceType switch
        {
            "CMR" => Color.Info,
            "IMEX" => Color.Warning,
            _ => Color.Default
        };
    }
    
    private Color GetScannerTypeColor(string scannerType)
    {
        return scannerType switch
        {
            "ASE" => Color.Secondary,
            "FS6000" => Color.Primary,
            _ => Color.Default
        };
    }
    
    private Color GetValidationStatusColor(string status)
    {
        return status switch
        {
            "Validated" => Color.Success,
            "Pending" => Color.Warning,
            "InReview" => Color.Info,
            _ => Color.Default
        };
    }
    
    private Color GetCompletenessColor(int percentage)
    {
        return percentage switch
        {
            >= 90 => Color.Success,
            >= 70 => Color.Warning,
            _ => Color.Error
        };
    }
    
    public class ValidationContainerItem
    {
        public int Id { get; set; }
        public string ContainerNumber { get; set; } = "";
        public string ClearanceType { get; set; } = "";
        public string ScannerType { get; set; } = "";
        public string Status { get; set; } = "";
        public int DataCompletenessPercentage { get; set; }
        public int ScannerDataPercentage { get; set; }
        public int ICUMSDataPercentage { get; set; }
        public bool HasImageData { get; set; }
        public DateTime CreatedAt { get; set; }
        public bool IsReadyForSubmission { get; set; }
    }
    
    public class PagedValidationApiResponse
    {
        public List<ApiValidationContainer>? Data { get; set; }
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
    }
    
    public class ApiValidationContainer
    {
        public int Id { get; set; }
        public string? ContainerNumber { get; set; }
        public string? ClearanceType { get; set; }
        public string? ScannerType { get; set; }
        public string? Status { get; set; }
        public int DataCompletenessPercentage { get; set; }
        public bool IsReadyForSubmission { get; set; }
        public DateTime CreatedAt { get; set; }
        public ApiScannerCompleteness? ScannerCompleteness { get; set; }
        public ApiICUMSCompleteness? ICUMSCompleteness { get; set; }
        public ApiImageCompleteness? ImageCompleteness { get; set; }
    }
    
    public class ApiScannerCompleteness
    {
        public int CompletenessScore { get; set; }
    }
    
    public class ApiICUMSCompleteness
    {
        public int CompletenessScore { get; set; }
    }
    
    public class ApiImageCompleteness
    {
        public bool HasImage { get; set; }
    }
}

