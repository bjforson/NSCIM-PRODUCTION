@page "/operations/bl-review"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesImageAnalysisView)]
@using NickScanWebApp.Mobile.Components.BLReview
@using MudBlazor
@inject NickScanWebApp.Shared.Services.BLReviewService BLReviewService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<BLReview> Logger
@implements IDisposable

<PageTitle>BL Review - NickScan Mobile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 pb-8 px-2">
    <!-- Header -->
    <MudStack Spacing="1" Class="mb-4">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
            Bill of Lading (BL) Review
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Review and validate containers grouped by Bill of Lading
        </MudText>
    </MudStack>

    <!-- Statistics Cards -->
    <MudGrid Spacing="2" Class="mb-4">
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total BL Groups</MudText>
                    <MudText Typo="Typo.h5">@_totalBLGroups</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Pending</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Warning">@_pendingCount</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">In Progress</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Info">@_inProgressCount</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Completed</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success">@_completedCount</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- BL Review List Component -->
    <BLReviewList />

</MudContainer>

@code {
    private bool _isLoading = false;
    private int _totalBLGroups = 0;
    private int _pendingCount = 0;
    private int _inProgressCount = 0;
    private int _completedCount = 0;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
        
        // Auto-refresh every 30 seconds
        _refreshTimer = new System.Threading.Timer(async _ => await InvokeAsync(async () =>
        {
            await LoadStatistics();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadStatistics()
    {
        try
        {
            _isLoading = true;
            
            // Load all groups to calculate statistics
            var allGroups = await BLReviewService.GetBLGroupsAsync(null, 1, 1000);
            
            _totalBLGroups = allGroups.Count;
            _pendingCount = allGroups.Count(g => g.ReviewStatus == "Pending");
            _inProgressCount = allGroups.Count(g => g.ReviewStatus == "InProgress");
            _completedCount = allGroups.Count(g => g.ReviewStatus == "Completed");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading BL review statistics");
            Snackbar.Add($"❌ Error loading statistics: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadBLGroups()
    {
        await LoadStatistics();
        Snackbar.Add("✅ BL groups refreshed", Severity.Success);
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}

