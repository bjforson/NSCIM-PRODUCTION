@page "/operations/containers/{ContainerNumber}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesContainersDetails)]
@using NickScanWebApp.Mobile.Services
@inject NavigationManager NavigationManager

<PageTitle>Container Details - Operations</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <!-- Redirect to container details -->
    @code {
        [Parameter] public string ContainerNumber { get; set; } = "";
        
        protected override void OnInitialized()
        {
            NavigationManager.NavigateTo($"/containers/{ContainerNumber}");
        }
    }
</MudContainer>

