@page "/operations/errors"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesOperationsErrors)]
@using NickScanWebApp.Mobile.Services
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Error Monitor - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <!-- Header -->
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" />
                <MudText Typo="Typo.h6">Error Monitor</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="1">
                <MudChip T="string" Color="@(_autoRefresh ? Color.Success : Color.Default)" Size="Size.Small"
                         OnClick="ToggleAutoRefresh" Icon="@Icons.Material.Filled.Refresh">
                    @(_autoRefresh ? $"Live ({_refreshCountdown}s)" : "Paused")
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadData" Disabled="_loading" Size="Size.Small" />
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Stats -->
    @if (_statistics != null && _statistics.ServiceStats.Any())
    {
        <MudGrid Class="mb-3" Spacing="2">
            <MudItem xs="4">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="border-left: 3px solid var(--mud-palette-error); text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">ERRORS 24h</MudText>
                    <MudText Typo="Typo.h6">@_errorCount24h</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="border-left: 3px solid var(--mud-palette-warning); text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">WARNINGS</MudText>
                    <MudText Typo="Typo.h6">@_warningCount24h</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="border-left: 3px solid var(--mud-palette-info); text-align:center;">
                    <MudText Typo="Typo.caption" Style="font-size:10px;">SERVICES</MudText>
                    <MudText Typo="Typo.h6">@_affectedServices</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <!-- Filters -->
    <MudPaper Elevation="1" Class="pa-3 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudStack Row="true" Spacing="2">
                <MudSelect T="string" Label="Level" @bind-Value="_filterLevel" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Fatal")">Fatal</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Error")">Error</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Warning")">Warning</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadLogs"
                           Disabled="_loading" StartIcon="@Icons.Material.Filled.FilterList" Size="Size.Small">
                    Filter
                </MudButton>
            </MudStack>
            <MudTextField T="string" Label="Search" Placeholder="Search messages..."
                          @bind-Value="_searchTerm" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Error" Indeterminate="true" />
    }

    <!-- Log entries as cards for mobile -->
    @if (_logs.Any())
    {
        @foreach (var log in _logs)
        {
            <MudPaper Elevation="1" Class="pa-3 mb-2 rounded-lg"
                      Style="@(log.Level == "Error" ? "border-left: 3px solid var(--mud-palette-error);" : log.Level == "Warning" ? "border-left: 3px solid var(--mud-palette-warning);" : "")">
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="@GetLevelColor(log.Level)" Variant="Variant.Filled">@log.Level</MudChip>
                        <MudText Typo="Typo.caption" Style="font-family:monospace">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ShortenSource(log.ServiceId)</MudText>
                    <MudText Typo="Typo.body2" Style="word-break:break-word;">@TruncateMessage(log.Message, 200)</MudText>
                    @if (!string.IsNullOrEmpty(log.Exception))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.BugReport"
                                   OnClick="@(() => ShowExceptionDetail(log))">
                            View Exception
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>
        }

        <!-- Pagination -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-2">
            <MudText Typo="Typo.caption">@_totalCount entries</MudText>
            <MudStack Row="true" Spacing="1">
                <MudButton Size="Size.Small" Disabled="@(_currentPage <= 1)" OnClick="PrevPage">Prev</MudButton>
                <MudText Typo="Typo.caption" Class="align-self-center">@_currentPage / @_totalPages</MudText>
                <MudButton Size="Size.Small" Disabled="@(_currentPage >= _totalPages)" OnClick="NextPage">Next</MudButton>
            </MudStack>
        </MudStack>
    }
    else if (!_loading)
    {
        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">No errors found. System operating normally.</MudAlert>
    }
</MudContainer>

@code {
    private List<LogEntryDto> _logs = new();
    private LogStatisticsDto? _statistics;
    private bool _loading;
    private string _filterLevel = "All";
    private string _searchTerm = "";
    private int _currentPage = 1;
    private int _pageSize = 30;
    private int _totalCount;
    private int _totalPages;
    private bool _autoRefresh = true;
    private int _refreshCountdown = 30;
    private DateTime _lastChecked = DateTime.Now;
    private System.Threading.Timer? _refreshTimer;

    private int _errorCount24h => _statistics?.ServiceStats.Where(s => s.Level == "Error" || s.Level == "Fatal").Sum(s => s.LogCount) ?? 0;
    private int _warningCount24h => _statistics?.ServiceStats.Where(s => s.Level == "Warning").Sum(s => s.LogCount) ?? 0;
    private int _affectedServices => _statistics?.ServiceStats.Select(s => s.ServiceId).Distinct().Count() ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        StartAutoRefresh();
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (!_autoRefresh) return;
            _refreshCountdown--;
            if (_refreshCountdown <= 0)
            {
                _refreshCountdown = 30;
                await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }, null, 1000, 1000);
    }

    private void ToggleAutoRefresh() { _autoRefresh = !_autoRefresh; _refreshCountdown = 30; }

    private async Task LoadData()
    {
        await Task.WhenAll(LoadLogs(), LoadStatistics());
        _lastChecked = DateTime.Now;
    }

    private async Task LoadLogs()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var queryParams = new List<string> { $"page={_currentPage}", $"pageSize={_pageSize}" };
            if (_filterLevel != "All") queryParams.Add($"level={_filterLevel}");
            if (!string.IsNullOrEmpty(_searchTerm)) queryParams.Add($"search={Uri.EscapeDataString(_searchTerm)}");

            var url = $"/api/LogManagement/logs?{string.Join("&", queryParams)}";
            var result = await ApiService.GetAsync<PagedResultDto>(url);
            if (result != null)
            {
                _logs = result.Data ?? new();
                _totalCount = result.TotalCount;
                _totalPages = result.TotalPages;
            }
            else
            {
                _logs = new(); _totalCount = 0; _totalPages = 0;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading logs: {ex.Message}", Severity.Error);
            _logs = new();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStatistics()
    {
        try { _statistics = await ApiService.GetAsync<LogStatisticsDto>("/api/LogManagement/statistics?hoursBack=24"); }
        catch { }
    }

    private async Task PrevPage() { if (_currentPage > 1) { _currentPage--; await LoadLogs(); } }
    private async Task NextPage() { if (_currentPage < _totalPages) { _currentPage++; await LoadLogs(); } }

    private void ShowExceptionDetail(LogEntryDto log)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = $"Source: {log.ServiceId}\n\nMessage: {log.Message}\n\nException:\n{log.Exception}",
            ["ButtonText"] = "Close",
            ["Color"] = Color.Error
        };
        DialogService.Show<MudMessageBox>("Exception Detail", parameters, new DialogOptions { FullScreen = true, CloseButton = true });
    }

    private Color GetLevelColor(string? level) => level switch
    {
        "Fatal" => Color.Dark, "Error" => Color.Error, "Warning" => Color.Warning, _ => Color.Default
    };

    private string ShortenSource(string? source)
    {
        if (string.IsNullOrEmpty(source)) return "System";
        var parts = source.Split('.');
        return parts.Length > 2 ? parts[^1] : source;
    }

    private string TruncateMessage(string? msg, int max)
    {
        if (string.IsNullOrEmpty(msg)) return "";
        return msg.Length > max ? msg[..max] + "..." : msg;
    }

    public void Dispose() => _refreshTimer?.Dispose();

    public class LogEntryDto
    {
        public long Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string? Level { get; set; }
        public string? ServiceId { get; set; }
        public string? Message { get; set; }
        public string? Exception { get; set; }
    }

    public class PagedResultDto
    {
        public List<LogEntryDto>? Data { get; set; }
        public int TotalCount { get; set; }
        public int TotalPages { get; set; }
    }

    public class LogStatisticsDto
    {
        public List<ServiceLogStatsDto> ServiceStats { get; set; } = new();
    }

    public class ServiceLogStatsDto
    {
        public string ServiceId { get; set; } = "";
        public string Level { get; set; } = "";
        public int LogCount { get; set; }
    }
}
