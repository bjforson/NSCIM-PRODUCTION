@page "/operations/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesImageAnalysisAudit)]
@using NickScanWebApp.Mobile.Services
@inject NavigationManager NavigationManager

<PageTitle>Operations Audit - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <!-- Redirect to audit logs -->
    @code {
        protected override void OnInitialized()
        {
            NavigationManager.NavigateTo("/administration/audit");
        }
    }
</MudContainer>

