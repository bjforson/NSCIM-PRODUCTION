@page "/operations/image-analysis"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesImageAnalysisView)]
@using NickScanWebApp.Mobile.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ImageAnalysis> Logger
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>Image Analysis - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <!-- Header -->
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.ImageSearch" />
                <MudText Typo="Typo.h6">Image Analysis (Analyst)</MudText>
                @if (_assignmentMode == "UserClaim")
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">UserClaim</MudChip>
                }
                else if (_assignmentMode == "Auto")
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Auto</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Manual</MudChip>
                }
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudSwitch T="bool" Value="_isReadyForAssignment"
                           Color="@(_isReadyForAssignment ? Color.Success : Color.Default)"
                           Label="Ready"
                           LabelPosition="LabelPosition.End"
                           Disabled="@_isLoading"
                           ValueChanged="@OnReadyChanged" />
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Dashboard"
                                   Color="Color.Primary" Size="Size.Small"
                                   Href="/operations/image-analysis-dashboard" />
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Default" Size="Size.Small"
                                   OnClick="LoadData" Disabled="@_isLoading" />
                </MudStack>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Statistics Cards -->
    <MudGrid Class="mb-3" Spacing="2">
        <MudItem xs="4">
            <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned</MudText>
                <MudText Typo="Typo.h5">@_myAssignments.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="4">
            <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Queue</MudText>
                <MudText Typo="Typo.h5" Color="Color.Warning">@_availableGroups.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="4">
            <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Containers</MudText>
                <MudText Typo="Typo.h5" Color="Color.Info">@_myAssignments.Sum(a => a.ContainerCount)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Available Queue (UserClaim mode only) -->
    @if (_assignmentMode == "UserClaim" && _availableGroups.Any())
    {
        <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Queue" Size="Size.Small" Class="mr-1" />
                Available Queue
            </MudText>
            @foreach (var group in _availableGroups)
            {
                <MudPaper Elevation="0" Class="pa-2 mb-2 rounded-lg" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-family: monospace; font-weight: 600;">@group.GroupIdentifier</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@group.ScannerType</MudChip>
                                <MudText Typo="Typo.caption">@group.ContainerCount containers</MudText>
                            </MudStack>
                        </MudStack>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.AddTask"
                                   OnClick="@(() => ClaimGroup(group))" Disabled="@_isLoading">
                            Claim
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }
        </MudPaper>
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
            @_errorMessage
        </MudAlert>
    }

    <!-- Filter bar -->
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.subtitle1">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Class="mr-1" />
                My Assignments (@_myAssignments.Count)
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudSelect T="string" @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                <MudSelectItem Value="@("Ready")">Ready</MudSelectItem>
                <MudSelectItem Value="@("AnalystAssigned")">Assigned</MudSelectItem>
                <MudSelectItem Value="@("AnalystCompleted")">Completed</MudSelectItem>
                <MudSelectItem Value="@("PartiallyCompleted")">Partial</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_scannerFilter" Label="Scanner" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                <MudSelectItem Value="@("FS6000")">FS6000</MudSelectItem>
                <MudSelectItem Value="@("ASE")">ASE</MudSelectItem>
                <MudSelectItem Value="@("Nuctech")">Nuctech</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudPaper>

    <!-- Assignments List (card layout for mobile) -->
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-4">
                <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2">Loading assignments...</MudText>
            </MudStack>
        }
        else if (!_myAssignments.Any())
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-4">
                <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">No assignments</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    @if (_assignmentMode == "UserClaim")
                    {
                        <text>Claim groups from the queue above, or wait for assignment.</text>
                    }
                    else
                    {
                        <text>Wait for Admin/Lead to assign groups, or groups will be auto-assigned if enabled.</text>
                    }
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Mode: <strong>@_assignmentMode</strong>
                </MudText>
            </MudStack>
        }
        else
        {
            var filteredAssignments = _myAssignments
                .Where(a => _statusFilter == null || a.Status == _statusFilter)
                .Where(a => _scannerFilter == null || a.ScannerType == _scannerFilter)
                .ToList();

            @foreach (var assignment in filteredAssignments)
            {
                var progressPercent = assignment.ContainerCount > 0 ? (assignment.DecidedCount * 100.0 / assignment.ContainerCount) : 0;
                <MudPaper Elevation="0" Class="pa-3 mb-2 rounded-lg" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Spacing="2">
                        <!-- Row 1: Status + Group ID -->
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2" Style="font-family: monospace; font-weight: 600;">@assignment.GroupIdentifier</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(assignment.Status)" Variant="Variant.Filled">
                                @assignment.Status
                            </MudChip>
                        </MudStack>

                        <!-- Row 2: Scanner, Type, Containers -->
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@assignment.ScannerType</MudChip>
                            @if (assignment.IsConsolidated)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Consolidated</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Non-Consolidated</MudChip>
                            }
                            <MudText Typo="Typo.caption">@assignment.ContainerCount containers</MudText>
                        </MudStack>

                        <!-- Row 3: Progress -->
                        <MudStack Spacing="0">
                            <MudProgressLinear Value="@progressPercent" Color="@GetProgressColor(progressPercent)" />
                            <MudText Typo="Typo.caption">@assignment.DecidedCount / @assignment.ContainerCount decided</MudText>
                        </MudStack>

                        <!-- Row 4: Image info + lease -->
                        @if (assignment.ContainersWithImages.HasValue || assignment.ContainersWithoutImages.HasValue)
                        {
                            <MudStack Row="true" Spacing="1">
                                @if (assignment.ContainersWithImages.HasValue && assignment.ContainersWithImages > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@assignment.ContainersWithImages with images</MudChip>
                                }
                                @if (assignment.ContainersWithoutImages.HasValue && assignment.ContainersWithoutImages > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@assignment.ContainersWithoutImages pending</MudChip>
                                }
                            </MudStack>
                        }

                        <!-- Row 5: Actions -->
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            @if (assignment.LeaseUntilUtc.HasValue)
                            {
                                var timeRemaining = assignment.LeaseUntilUtc.Value.ToLocalTime() - DateTime.Now;
                                if (timeRemaining.TotalMinutes < 10)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Refresh"
                                               OnClick="@(() => RenewLease(assignment))" Disabled="@_isLoading">
                                        Renew (@timeRemaining.ToString(@"mm\:ss"))
                                    </MudButton>
                                }
                            }
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Visibility"
                                       OnClick="@(() => ViewDetails(assignment))">
                                View
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudPaper>
</MudContainer>

@code {
    private bool _isLoading = false;
    private List<MyAssignmentDto> _myAssignments = new();
    private List<MyAssignmentDto> _availableGroups = new();
    private string _assignmentMode = "Manual";
    private System.Threading.Timer? _refreshTimer;
    private System.Threading.Timer? _heartbeatTimer;
    private string? _errorMessage = null;
    private bool _isReadyForAssignment = false;
    private HubConnection? _readinessHub;
    private string _userRole = "Analyst";
    private string? _statusFilter;
    private string? _scannerFilter;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("[ImageAnalysis] OnInitializedAsync START");

        try
        {
            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ImageAnalysis] Error in OnInitializedAsync");
            _errorMessage = $"Initialization error: {ex.Message}";
        }

        await DetectUserRole();
        await InitializeReadinessHub();
        await SetReadyForAssignment(true);

        var refreshSeconds = Configuration.GetValue<int>("UI:AutoRefreshSeconds", 30);
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadData();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(refreshSeconds), TimeSpan.FromSeconds(refreshSeconds));

        Logger.LogInformation("[ImageAnalysis] OnInitializedAsync COMPLETE");
    }

    private async Task DetectUserRole()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var roleClaim = user.Claims.FirstOrDefault(c => c.Type == "role" || c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role");
            if (roleClaim != null)
            {
                var role = roleClaim.Value;
                if (role.Contains("Analyst", StringComparison.OrdinalIgnoreCase))
                    _userRole = "Analyst";
                else if (role.Contains("Audit", StringComparison.OrdinalIgnoreCase))
                    _userRole = "Audit";
            }
            Logger.LogInformation("Detected user role: {Role}", _userRole);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error detecting user role, defaulting to Analyst");
            _userRole = "Analyst";
        }
    }

    private async Task InitializeReadinessHub()
    {
        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            var hubUrl = $"{apiBaseUrl}/hubs/userReadiness";

            string? token = null;
            try
            {
                if (AuthStateProvider is SimpleAuthStateProvider simpleAuth)
                {
                    token = await simpleAuth.GetTokenAsync();
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error retrieving token for SignalR connection");
            }

            _readinessHub = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    if (!string.IsNullOrEmpty(token))
                        options.AccessTokenProvider = () => Task.FromResult<string?>(token);
                })
                .WithAutomaticReconnect()
                .Build();

            _readinessHub.Reconnected += async _ =>
            {
                Logger.LogInformation("UserReadinessHub reconnected");
                await SetReadyForAssignment(_isReadyForAssignment);
            };

            await _readinessHub.StartAsync();
            Logger.LogInformation("UserReadinessHub connected successfully");

            _heartbeatTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                    if (authState?.User?.Identity?.IsAuthenticated != true)
                    {
                        Logger.LogDebug("Skipping heartbeat - user not authenticated");
                        return;
                    }

                    await ApiService.PostAsync<object, object>("/api/image-analysis/user/heartbeat", new { Role = _userRole });

                    if (_readinessHub?.State == HubConnectionState.Connected && _isReadyForAssignment)
                    {
                        await _readinessHub.SendAsync("SendHeartbeat", _userRole);
                    }
                }
                catch (ApiException apiEx) when (apiEx.Message.Contains("401") || apiEx.Message.Contains("Unauthorized"))
                {
                    Logger.LogDebug("Heartbeat failed - user not authenticated (401)");
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Error sending heartbeat: {Message}", ex.Message);
                }
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

            Logger.LogInformation("Heartbeat timer started (30 second interval)");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing UserReadinessHub");
            Snackbar.Add("Warning: Could not connect to readiness service", Severity.Warning);
        }
    }

    private async Task OnReadyChanged(bool isReady)
    {
        _isReadyForAssignment = isReady;
        await SetReadyForAssignment(isReady);
    }

    private async Task SetReadyForAssignment(bool ready)
    {
        try
        {
            Logger.LogInformation("Setting readiness to {Ready} for role {Role}", ready, _userRole);

            if (_readinessHub?.State == HubConnectionState.Connected)
            {
                try
                {
                    await _readinessHub.SendAsync("SetReadyForAssignment", _userRole, ready, null);
                }
                catch (Exception hubEx)
                {
                    Logger.LogWarning(hubEx, "SignalR readiness send failed, continuing with API call");
                }
            }

            await ApiService.PostAsync<object, object>("/api/image-analysis/user/ready", new
            {
                Role = _userRole,
                IsReady = ready,
                SessionId = (string?)null
            });

            if (ready)
                Snackbar.Add($"Ready to receive {_userRole} assignments", Severity.Success);
            else
                Snackbar.Add($"No longer ready for {_userRole} assignments", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error setting readiness status");
            Snackbar.Add($"Error updating readiness: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose()
    {
        if (_isReadyForAssignment)
        {
            try { _ = SetReadyForAssignment(false); } catch { }
        }
        _heartbeatTimer?.Dispose();
        _refreshTimer?.Dispose();
        if (_readinessHub != null)
        {
            _ = _readinessHub.DisposeAsync();
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            Logger.LogInformation("[ImageAnalysis] Loading data...");

            var settings = await ApiService.GetAsync<AnalysisSettingsDto>("/api/image-analysis-management/service-state");
            if (settings != null)
            {
                _assignmentMode = settings.AssignmentMode ?? "Manual";
            }

            var assignments = await ApiService.GetAsync<List<MyAssignmentDto>>("/api/image-analysis/my-assignments?role=Analyst");
            _myAssignments = assignments ?? new();
            Logger.LogInformation("Loaded {Count} assignments", _myAssignments.Count);

            if (_assignmentMode == "UserClaim")
            {
                try
                {
                    var available = await ApiService.GetAsync<List<MyAssignmentDto>>("/api/image-analysis/available?role=Analyst");
                    _availableGroups = available ?? new();
                }
                catch (Exception ex2)
                {
                    Logger.LogError(ex2, "Error loading available groups");
                    _availableGroups = new();
                }
            }
            else
            {
                _availableGroups = new();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ImageAnalysis] Error loading data");
            _errorMessage = $"Error loading data: {ex.Message}";
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ClaimGroup(MyAssignmentDto group)
    {
        try
        {
            _isLoading = true;
            await ApiService.PostAsync<object, object>($"/api/image-analysis/groups/{group.GroupId}/claim", new { });
            Snackbar.Add($"Claimed group {group.GroupIdentifier}", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error claiming group: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RenewLease(MyAssignmentDto assignment)
    {
        try
        {
            _isLoading = true;
            await ApiService.PostAsync<object, object>($"/api/image-analysis/groups/{assignment.GroupIdentifier}/lease/renew", new { });
            Snackbar.Add("Lease renewed", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error renewing lease: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ViewDetails(MyAssignmentDto assignment)
    {
        IDialogReference? dialogRef = null;
        var parameters = new DialogParameters
        {
            ["GroupIdentifier"] = assignment.GroupIdentifier,
            ["IsConsolidated"] = assignment.IsConsolidated,
            ["Containers"] = assignment.Containers,
            ["OnDecisionSaved"] = EventCallback.Factory.Create(this, async () =>
            {
                if (dialogRef != null)
                {
                    dialogRef.Close(DialogResult.Ok(true));
                    await Task.Delay(500);
                    await LoadData();
                }
            }),
            ["OnAllContainersDecided"] = EventCallback.Factory.Create(this, async () =>
            {
                await Task.Delay(1000);
                await LoadData();
            })
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            FullScreen = true,
            CloseButton = true
        };

        dialogRef = await DialogService.ShowAsync<Components.Operations.ImageAnalysisViewDialog>(
            $"{(assignment.IsConsolidated ? "Container" : "BOE")}: {assignment.GroupIdentifier}",
            parameters,
            options);

        await dialogRef.Result;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Ready" => Color.Info,
        "AnalystAssigned" => Color.Warning,
        "AnalystCompleted" => Color.Success,
        "AuditAssigned" => Color.Secondary,
        "AuditCompleted" => Color.Tertiary,
        "PartiallyCompleted" => Color.Warning,
        "Submitted" => Color.Dark,
        "Completed" => Color.Success,
        _ => Color.Default
    };

    private Color GetProgressColor(double percent)
    {
        if (percent >= 100) return Color.Success;
        if (percent >= 75) return Color.Info;
        if (percent >= 50) return Color.Warning;
        return Color.Error;
    }

    public class MyAssignmentDto
    {
        public Guid GroupId { get; set; }
        public string GroupIdentifier { get; set; } = string.Empty;
        public string ScannerType { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public int ContainerCount { get; set; }
        public List<string> Containers { get; set; } = new();
        public DateTime? LeaseUntilUtc { get; set; }
        public DateTime CreatedAtUtc { get; set; }
        public bool IsConsolidated { get; set; }
        public int? ContainersWithImages { get; set; }
        public int? ContainersWithoutImages { get; set; }
        public int DecidedCount { get; set; }
        public int? TotalContainerCount { get; set; }
        public int? SubmittedContainerCount { get; set; }
        public int? PendingContainerCount { get; set; }
        public DateTime? PartiallyCompletedDate { get; set; }
        public DateTime? UpdatedAtUtc { get; set; }
    }

    public class AnalysisSettingsDto
    {
        public bool Enabled { get; set; }
        public string? AssignmentMode { get; set; }
        public string? AutoAssignStrategy { get; set; }
        public bool AutoAssign { get; set; }
        public int LeaseMinutes { get; set; }
        public int MaxConcurrentPerUser { get; set; }
    }
}
