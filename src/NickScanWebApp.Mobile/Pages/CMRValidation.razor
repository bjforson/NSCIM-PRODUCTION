@page "/cmr-validation"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesCmrValidation)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService
@implements IDisposable

<PageTitle>CMR Validation & Re-download Queue</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    
    <!-- Header -->
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2" />
                CMR Data Quality Management
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Validate and manage CMR records quality
            </MudText>
            <MudButton Variant="Variant.Outlined" 
                      Color="Color.Primary"
                      Size="Size.Small"
                      StartIcon="@Icons.Material.Filled.Refresh"
                      OnClick="@LoadStatistics">
                Refresh
            </MudButton>
        </MudStack>
    </MudPaper>
    
    <!-- Stats -->
    @if (_statistics != null)
    {
        <MudGrid Class="mb-3">
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3" Style="background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%); color: white;">
                    <MudText Typo="Typo.caption" Style="opacity: 0.9;">Total CMR</MudText>
                    <MudText Typo="Typo.h4">@_statistics.TotalCMRRecords</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3" Style="background: linear-gradient(135deg, #388e3c 0%, #2e7d32 100%); color: white;">
                    <MudText Typo="Typo.caption" Style="opacity: 0.9;">Valid</MudText>
                    <MudText Typo="Typo.h4">@_statistics.ValidCMRRecords</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3" Style="background: linear-gradient(135deg, #d32f2f 0%, #c62828 100%); color: white;">
                    <MudText Typo="Typo.caption" Style="opacity: 0.9;">Invalid</MudText>
                    <MudText Typo="Typo.h4">@_statistics.InvalidCMRRecords</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="2" Class="pa-3" Style="background: linear-gradient(135deg, #f57c00 0%, #ef6c00 100%); color: white;">
                    <MudText Typo="Typo.caption" Style="opacity: 0.9;">Success Rate</MudText>
                    <MudText Typo="Typo.h4">@_statistics.ValidationSuccessRate.ToString("F1")%</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    
    @if (_loadingStatistics)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    
    <!-- Invalid Records -->
    @if (_invalidRecords.Any())
    {
        <MudPaper Elevation="2" Class="rounded-lg">
            <MudPaper Elevation="0" Class="pa-3">
                <MudText Typo="Typo.h6">Invalid Records (@_invalidRecords.Count)</MudText>
            </MudPaper>
            <MudTabs Elevation="0" Rounded="true" PanelClass="pa-3" Color="Color.Primary">
                
                <MudTabPanel Text="Missing BL" Icon="@Icons.Material.Filled.Warning">
                    <MudStack Spacing="2">
                        @foreach (var record in _invalidRecords.Where(r => r.Issue == "Missing BL Number").Take(20))
                        {
                            <MudCard Elevation="1" Class="pa-3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@record.ContainerNumber</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Error">@record.Issue</MudText>
                                    <MudButton Size="Size.Small" 
                                              Variant="Variant.Outlined" 
                                              Color="Color.Primary"
                                              StartIcon="@Icons.Material.Filled.CloudDownload"
                                              OnClick="@(() => RequestReDownload(record.ContainerNumber))">
                                        Re-download
                                    </MudButton>
                                </MudStack>
                            </MudCard>
                        }
                    </MudStack>
                </MudTabPanel>
                
            </MudTabs>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _loadingStatistics = false;
    private CMRStatisticsDto? _statistics;
    private List<InvalidRecordDto> _invalidRecords = new();
    private System.Threading.Timer? _refreshTimer;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
        await LoadInvalidRecords();
        
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadStatistics();
                await LoadInvalidRecords();
                StateHasChanged();
            });
        }, null, TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));
    }
    
    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
    
    private async Task LoadStatistics()
    {
        _loadingStatistics = true;
        try
        {
            // TODO: Replace with actual API call
            // _statistics = await ApiService.GetAsync<CMRStatisticsDto>("/api/cmrvalidation/statistics");
            
            // Mock data for now
            _statistics = new CMRStatisticsDto
            {
                TotalCMRRecords = 1250,
                ValidCMRRecords = 1180,
                InvalidCMRRecords = 70,
                ValidationSuccessRate = 94.4,
                MissingBlNumber = 45,
                MissingRotationNumber = 20,
                MissingBothFields = 5
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading statistics: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingStatistics = false;
        }
    }
    
    private async Task LoadInvalidRecords()
    {
        try
        {
            // TODO: Replace with actual API call
            // var response = await ApiService.GetAsync<List<InvalidRecordDto>>("/api/cmrvalidation/invalid");
            // _invalidRecords = response ?? new();
            
            // Mock data for now
            _invalidRecords = new List<InvalidRecordDto>
            {
                new() { ContainerNumber = "MSDU1234567", Issue = "Missing BL Number" },
                new() { ContainerNumber = "MSDU2345678", Issue = "Missing Rotation Number" },
                new() { ContainerNumber = "MSDU3456789", Issue = "Missing Both Fields" }
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading invalid records: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task RequestReDownload(string containerNumber)
    {
        try
        {
            // TODO: Replace with actual API call
            // await ApiService.PostAsync<object, object>($"/api/cmrvalidation/redownload/{containerNumber}", new { });
            Snackbar.Add($"Re-download requested for {containerNumber}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error requesting re-download: {ex.Message}", Severity.Error);
        }
    }
    
    public class CMRStatisticsDto
    {
        public int TotalCMRRecords { get; set; }
        public int ValidCMRRecords { get; set; }
        public int InvalidCMRRecords { get; set; }
        public double ValidationSuccessRate { get; set; }
        public int MissingBlNumber { get; set; }
        public int MissingRotationNumber { get; set; }
        public int MissingBothFields { get; set; }
    }
    
    public class InvalidRecordDto
    {
        public string ContainerNumber { get; set; } = "";
        public string Issue { get; set; } = "";
    }
}

