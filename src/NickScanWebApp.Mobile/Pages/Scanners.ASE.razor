@page "/scanners/ase"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using NickScanWebApp.Mobile.Services
@attribute [Authorize(Policy = Permissions.PagesScannersAse)]
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>ASE Scanner - NickScan Mobile</PageTitle>

@if (!_initialized)
{
    <MudContainer Class="d-flex flex-column align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
        <MudText Typo="Typo.h6" Align="Align.Center">
            Loading ASE scanner data&hellip;
        </MudText>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pt-2 pb-8 px-2">
        <MudStack Spacing="1">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">ASE X-Ray Scanner</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Today: @_todayScans • Total: @_totalScans
                </MudText>
            </MudStack>

            <MudPaper Class="pa-2" Elevation="1">
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Last sync</MudText>
                        <MudText Typo="Typo.caption">@_lastSync.ToString("dd MMM HH:mm")</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudDivider Class="my-2" />

            <MudText Typo="Typo.subtitle2" Class="mb-1">Recent scans</MudText>

            @if (_recentScans.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    No recent scans found.
                </MudText>
            }
            else
            {
                <MudStack Spacing="1">
                    @foreach (var scan in _recentScans)
                    {
                        <MudPaper Class="pa-2" Elevation="1">
                            <MudStack Spacing="1">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.subtitle2">@scan.ContainerNumber</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @scan.ScanDate.ToString("dd MMM HH:mm")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @scan.Origin → @scan.Destination
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Truck: @scan.TruckId
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudStack>
    </MudContainer>
}

@code {
    private bool _initialized;
    private bool _isLoading;

    private int _todayScans;
    private int _totalScans;
    private DateTime _lastSync = DateTime.Now;

    private readonly List<AseScanRecord> _recentScans = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        await LoadData();
        _initialized = true;
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var syncStatus = await ApiService.GetAsync<AseSyncStatus>("/api/Ase/sync-status");
            if (syncStatus != null)
            {
                _totalScans = syncStatus.TotalScans;
                _todayScans = syncStatus.TodayScans ?? syncStatus.RecentScans24h;
                _lastSync = syncStatus.LastSyncTime ?? DateTime.Now;
            }

            var scansResponse = await ApiService.GetAsync<AseScanResponse>("/api/Ase/scans?pageSize=20");
            _recentScans.Clear();
            if (scansResponse?.Data != null)
            {
                _recentScans.AddRange(scansResponse.Data.Select(s => new AseScanRecord
                {
                    ContainerNumber = s.ContainerNumber ?? "Unknown",
                    ScanDate = s.ScanTime,
                    Origin = s.Origin ?? "N/A",
                    Destination = s.Destination ?? "N/A",
                    TruckId = s.TruckID ?? "N/A"
                }));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading ASE data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class AseScanRecord
    {
        public string ContainerNumber { get; set; } = string.Empty;
        public DateTime ScanDate { get; set; }
        public string Origin { get; set; } = string.Empty;
        public string Destination { get; set; } = string.Empty;
        public string TruckId { get; set; } = string.Empty;
    }

    public class AseSyncStatus
    {
        public DateTime? LastSyncTime { get; set; }
        public int TotalScans { get; set; }
        public int RecentScans24h { get; set; }
        public int? TodayScans { get; set; }
    }

    public class AseScanResponse
    {
        public List<AseScanDto>? Data { get; set; }
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
    }

    public class AseScanDto
    {
        public int InspectionId { get; set; }
        public DateTime ScanTime { get; set; }
        public string? ContainerNumber { get; set; }
        public string? TruckID { get; set; }
        public string? Origin { get; set; }
        public string? Destination { get; set; }
    }
}


