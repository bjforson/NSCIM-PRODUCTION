@page "/"
@inject NavigationManager Navigation

<PageTitle>NickScan Mobile</PageTitle>

@* Redirect root to the mobile dashboard for a consistent entry point *@

<MudContainer Class="d-flex flex-column align-center justify-center" Style="height: 100vh;">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
    <MudText Typo="Typo.h6" Align="Align.Center">
        Loading NickScan Mobile&hellip;
    </MudText>
</MudContainer>

@code {
    protected override void OnInitialized()
    {
        // Always land on the dashboard route for the main experience
        Navigation.NavigateTo("/dashboard", forceLoad: true);
    }
}
