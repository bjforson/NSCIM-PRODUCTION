@page "/services/debug"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesServicesDebug)]
@using NickScanWebApp.Mobile.Services

<PageTitle>Debug Services - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
            Debug Services
        </MudText>
    </MudPaper>
    
    <MudAlert Severity="Severity.Warning">
        Debug service tools. Use desktop version for debugging and troubleshooting.
    </MudAlert>
</MudContainer>

