@page "/services/consolidated-cargo"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesServicesConsolidatedCargo)]
@using NickScanWebApp.Mobile.Services

<PageTitle>Consolidated Cargo Services - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.Merge" Class="mr-2" />
            Consolidated Cargo Services
        </MudText>
    </MudPaper>
    
    <MudAlert Severity="Severity.Info">
        Consolidated cargo service monitoring. Use desktop version for detailed management.
    </MudAlert>
</MudContainer>

