@page "/services/monitoring"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesServicesMonitoring)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService

<PageTitle>System Monitoring - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Class="mr-2" />
            System Monitoring
        </MudText>
    </MudPaper>
    
    <MudAlert Severity="Severity.Info">
        System monitoring dashboard. Use desktop version for detailed metrics and charts.
    </MudAlert>
</MudContainer>

