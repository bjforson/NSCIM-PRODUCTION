@page "/images/viewer/{ContainerNumber}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using NickScanWebApp.Mobile.Services
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration

<PageTitle>Image Viewer - @ContainerNumber</PageTitle>

<div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.95); z-index: 2000; display: flex; flex-direction: column;">
    
    <!-- Toolbar -->
    <MudPaper Elevation="4" Class="pa-2" Style="background: #1a237e; color: white;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" 
                              Color="Color.Inherit" 
                              OnClick="@GoBack" />
                <MudText Typo="Typo.h6">@ContainerNumber</MudText>
            </MudStack>
            
            <MudStack Row="true" Spacing="1">
                <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" 
                              Color="Color.Inherit" 
                              OnClick="@ZoomIn"
                              title="Zoom In" />
                <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" 
                              Color="Color.Inherit" 
                              OnClick="@ZoomOut"
                              title="Zoom Out" />
                <MudIconButton Icon="@Icons.Material.Filled.Download" 
                              Color="Color.Inherit" 
                              OnClick="@DownloadImage"
                              title="Download" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                              Color="Color.Inherit" 
                              OnClick="@GoBack"
                              title="Close" />
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Image Container -->
    <div style="flex: 1; display: flex; align-items: center; justify-content: center; overflow: auto; padding: 20px;">
        <img src="@GetImageUrl()" 
             alt="Container scan"
             style="max-width: 100%; max-height: 100%; object-fit: contain; transform: scale(@_zoomLevel); transition: transform 0.2s;" />
    </div>
</div>

@code {
    [Parameter] public string ContainerNumber { get; set; } = "";
    
    private double _zoomLevel = 1.0;
    
    private void GoBack()
    {
        NavigationManager.NavigateTo($"/containers/{ContainerNumber}");
    }
    
    private void ZoomIn()
    {
        if (_zoomLevel < 3.0)
            _zoomLevel += 0.25;
    }
    
    private void ZoomOut()
    {
        if (_zoomLevel > 0.5)
            _zoomLevel -= 0.25;
    }
    
    private void DownloadImage()
    {
        var imageUrl = GetImageUrl();
        // TODO: Implement actual download
    }
    
    private string GetImageUrl()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://10.0.1.254:5205";
        return $"{apiBaseUrl}/api/image/serve/{Uri.EscapeDataString(ContainerNumber)}";
    }
}

