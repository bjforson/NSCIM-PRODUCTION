@page "/admin/users/management"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesAdminUsers)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService

<PageTitle>User Management - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
                User Management
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manage system users and their permissions
            </MudText>
        </MudStack>
    </MudPaper>
    
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_users.Any())
    {
        <MudStack Spacing="2">
            @foreach (var user in _users.Take(50))
            {
                <MudCard Elevation="1" Class="pa-3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1"><strong>@user.UserName</strong></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@user.Role</MudChip>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    }
    else
    {
        <MudAlert Severity="Severity.Info">No users found</MudAlert>
    }
</MudContainer>

@code {
    private bool _isLoading = false;
    private List<UserDto> _users = new();
    
    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }
    
    private async Task LoadUsers()
    {
        _isLoading = true;
        try
        {
            // TODO: Replace with actual API call
            // var response = await ApiService.GetAsync<List<UserDto>>("/api/users");
            // _users = response ?? new();
            
            _users = new List<UserDto>
            {
                new() { UserName = "admin", Email = "admin@nickscan.com", Role = "Administrator" },
                new() { UserName = "operator", Email = "operator@nickscan.com", Role = "Operator" }
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    public class UserDto
    {
        public string UserName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
    }
}

