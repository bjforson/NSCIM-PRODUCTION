@page "/admin/icums-payloads"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesIcumsPayloads)]
@using NickScanWebApp.Mobile.Services
@using System.Text.Json
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IConfiguration Configuration

<PageTitle>ICUMS Payload Viewer</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.FactCheck" />
            <MudText Typo="Typo.h6">ICUMS Payloads</MudText>
        </MudStack>
    </MudPaper>

    <!-- Summary -->
    @if (_hasSummary)
    {
        <MudGrid Class="mb-3" Spacing="2">
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@GetProp(_summary, "internalPayloads.count", "0")</MudText>
                    <MudText Typo="Typo.caption">Internal</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Color="Color.Info" />
                    <MudText Typo="Typo.h6">@GetProp(_summary, "icumsPayloads.count", "0")</MudText>
                    <MudText Typo="Typo.caption">ICUMS</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                    <MudIcon Icon="@(GetProp(_summary, "liveSubmitEnabled", "false") == "True" ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudOff)"
                             Color="@(GetProp(_summary, "liveSubmitEnabled", "false") == "True" ? Color.Success : Color.Warning)" />
                    <MudText Typo="Typo.h6">@(GetProp(_summary, "liveSubmitEnabled", "false") == "True" ? "LIVE" : "OFF")</MudText>
                    <MudText Typo="Typo.caption">Live Submit</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success" />
                    <MudText Typo="Typo.h6">@GetProp(_summary, "acknowledgedPayloads.count", "0")</MudText>
                    <MudText Typo="Typo.caption">Acknowledged</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <!-- Tabs -->
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTab" Class="mb-3">
        <MudTabPanel Text="ICUMS" Icon="@Icons.Material.Filled.Send" BadgeData="@_icumsFiles.Count" BadgeColor="Color.Info">
            @RenderFileCards(_icumsFiles, "ICUMS")
        </MudTabPanel>
        <MudTabPanel Text="Acknowledged" Icon="@Icons.Material.Filled.VerifiedUser" BadgeData="@_acknowledgedFiles.Count" BadgeColor="Color.Success">
            @RenderFileCards(_acknowledgedFiles, "ICUMS/Acknowledged")
        </MudTabPanel>
        <MudTabPanel Text="Internal" Icon="@Icons.Material.Filled.Folder" BadgeData="@_internalFiles.Count" BadgeColor="Color.Primary">
            @RenderFileCards(_internalFiles, null)
        </MudTabPanel>
        <MudTabPanel Text="Verify" Icon="@Icons.Material.Filled.Verified">
            <MudPaper Elevation="0" Class="pa-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Verify ICUMS Receipt</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_verifyContainer" Label="Container Number" Variant="Variant.Outlined"
                                  Dense="true" Margin="Margin.Dense" Placeholder="e.g. MSKU1234567" />
                    <MudTextField @bind-Value="_verifyRotation" Label="Rotation Number" Variant="Variant.Outlined"
                                  Dense="true" Margin="Margin.Dense" Placeholder="e.g. 2024/12345" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerifyStatus"
                               Disabled="@(string.IsNullOrWhiteSpace(_verifyContainer) || _verifying)"
                               StartIcon="@Icons.Material.Filled.Search" FullWidth="true">
                        @(_verifying ? "Checking..." : "Verify Status")
                    </MudButton>
                </MudStack>
                @if (_verifyResult != null)
                {
                    <MudAlert Severity="@(_verifySuccess ? Severity.Success : Severity.Error)" Class="mt-2">
                        @_verifyMessage
                    </MudAlert>
                }
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private JsonElement _summary;
    private bool _hasSummary;
    private List<PayloadFileInfo> _internalFiles = new();
    private List<PayloadFileInfo> _icumsFiles = new();
    private List<PayloadFileInfo> _acknowledgedFiles = new();
    private int _activeTab;
    private bool _loading = true;

    private string _verifyContainer = "";
    private string _verifyRotation = "";
    private bool _verifying;
    private JsonElement? _verifyResult;
    private bool _verifySuccess;
    private string _verifyMessage = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var s = await ApiService.GetAsync<JsonElement>("/api/IcumsPayload/summary");
            _summary = s; _hasSummary = s.ValueKind != JsonValueKind.Undefined;

            var internalResult = await ApiService.GetAsync<JsonElement>("/api/IcumsPayload/list?limit=100");
            _internalFiles = ParseFileList(internalResult);

            var icumsResult = await ApiService.GetAsync<JsonElement>("/api/IcumsPayload/list?subfolder=ICUMS&limit=100");
            _icumsFiles = ParseFileList(icumsResult);

            var ackResult = await ApiService.GetAsync<JsonElement>("/api/IcumsPayload/list?subfolder=ICUMS%2FAcknowledged&limit=100");
            _acknowledgedFiles = ParseFileList(ackResult);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private List<PayloadFileInfo> ParseFileList(JsonElement result)
    {
        var list = new List<PayloadFileInfo>();
        if (result.ValueKind == JsonValueKind.Undefined) return list;
        try
        {
            if (result.TryGetProperty("files", out var filesArr) && filesArr.ValueKind == JsonValueKind.Array)
            {
                foreach (var f in filesArr.EnumerateArray())
                {
                    list.Add(new PayloadFileInfo
                    {
                        Name = f.GetProperty("name").GetString() ?? "",
                        SizeBytes = f.GetProperty("sizeBytes").GetInt64(),
                        LastModified = f.GetProperty("lastModified").GetDateTime()
                    });
                }
            }
        }
        catch { }
        return list;
    }

    private RenderFragment RenderFileCards(List<PayloadFileInfo> files, string? subfolder) => __builder =>
    {
        if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />;
            return;
        }

        <MudPaper Elevation="0" Class="pa-2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadData">Refresh</MudButton>
                <MudText Typo="Typo.caption">@files.Count file(s)</MudText>
            </MudStack>

            @if (!files.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No payload files found.</MudAlert>
            }
            else
            {
                @foreach (var file in files)
                {
                    <MudPaper Elevation="0" Class="pa-2 mb-1 rounded-lg" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Style="font-family:monospace;font-size:11px;">@file.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatSize(file.SizeBytes) | @file.LastModified.ToLocalTime().ToString("MM-dd HH:mm")</MudText>
                            </MudStack>
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => ViewPayload(file.Name, subfolder))" />
                        </MudStack>
                    </MudPaper>
                }
            }
        </MudPaper>;
    };

    private async Task ViewPayload(string fileName, string? subfolder)
    {
        try
        {
            var url = $"/api/IcumsPayload/read?fileName={Uri.EscapeDataString(fileName)}";
            if (!string.IsNullOrEmpty(subfolder)) url += $"&subfolder={Uri.EscapeDataString(subfolder)}";

            var result = await ApiService.GetAsync<JsonElement>(url);
            if (result.ValueKind != JsonValueKind.Undefined && result.TryGetProperty("content", out var content))
            {
                var raw = JsonSerializer.Serialize(content, new JsonSerializerOptions { WriteIndented = true });
                if (raw.Length > 5000) raw = raw[..5000] + "\n... (truncated)";

                var parameters = new DialogParameters
                {
                    ["ContentText"] = raw,
                    ["ButtonText"] = "Close",
                    ["Color"] = Color.Primary
                };
                await DialogService.ShowAsync<MudMessageBox>(fileName, parameters, new DialogOptions { FullScreen = true, CloseButton = true });
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error reading payload: {ex.Message}", Severity.Error); }
    }

    private async Task VerifyStatus()
    {
        if (string.IsNullOrWhiteSpace(_verifyContainer)) return;
        _verifying = true; _verifyResult = null; StateHasChanged();
        try
        {
            var payload = new { containerNumbers = new[] { new { rotationNumber = _verifyRotation ?? "", blNumber = (string?)null, containerNumber = _verifyContainer.Trim() } } };
            var result = await ApiService.PostAsync<object, JsonElement?>("/api/IcumsPayload/verify-status", payload);
            if (result.HasValue)
            {
                _verifyResult = result;
                _verifySuccess = result.Value.TryGetProperty("success", out var s) && s.GetBoolean();
                _verifyMessage = _verifySuccess ? "ICUMS receipt confirmed" : (result.Value.TryGetProperty("error", out var e) ? e.GetString() ?? "Unknown error" : "Unknown error");
            }
        }
        catch (Exception ex) { _verifyMessage = ex.Message; }
        finally { _verifying = false; StateHasChanged(); }
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private string GetProp(JsonElement el, string path, string fallback)
    {
        if (!_hasSummary) return fallback;
        try
        {
            var current = el;
            foreach (var part in path.Split('.'))
            {
                if (!current.TryGetProperty(part, out current)) return fallback;
            }
            return current.ValueKind switch { JsonValueKind.String => current.GetString() ?? fallback, JsonValueKind.Number => current.GetRawText(), JsonValueKind.True => "True", JsonValueKind.False => "False", _ => current.GetRawText() };
        }
        catch { return fallback; }
    }

    private class PayloadFileInfo
    {
        public string Name { get; set; } = "";
        public long SizeBytes { get; set; }
        public DateTime LastModified { get; set; }
    }
}
