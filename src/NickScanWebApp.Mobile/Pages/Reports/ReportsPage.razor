@page "/reports/templates"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesReportsTemplates)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService

<PageTitle>Reports Templates - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
            Report Templates
        </MudText>
    </MudPaper>
    
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_reportTemplates.Any())
    {
        <MudStack Spacing="2">
            @foreach (var template in _reportTemplates)
            {
                <MudCard Elevation="2" Class="pa-3">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                            <MudIcon Icon="@template.Icon" Size="Size.Large" Color="Color.Primary" />
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@template.Category</MudChip>
                        </MudStack>
                        <MudText Typo="Typo.h6">@template.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@template.Description</MudText>
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary"
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.PlayArrow"
                                  OnClick="@(() => GenerateReport(template))"
                                  FullWidth="true">
                            Generate Report
                        </MudButton>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    }
    else
    {
        <MudAlert Severity="Severity.Info">No report templates available</MudAlert>
    }
</MudContainer>

@code {
    private bool _isLoading = false;
    private List<ReportTemplateDto> _reportTemplates = new();
    
    protected override async Task OnInitializedAsync()
    {
        await LoadTemplates();
    }
    
    private async Task LoadTemplates()
    {
        _isLoading = true;
        try
        {
            // TODO: Replace with actual API call
            // var response = await ApiService.GetAsync<List<ReportTemplateDto>>("/api/reports/templates");
            // _reportTemplates = response ?? new();
            
            _reportTemplates = new List<ReportTemplateDto>
            {
                new() { Name = "Container Summary", Description = "Overview of all container scans", Icon = Icons.Material.Filled.Inventory, Category = "Container" },
                new() { Name = "Scanner Performance", Description = "Scanner statistics and uptime", Icon = Icons.Material.Filled.Scanner, Category = "Scanner" },
                new() { Name = "ICUMS Activity", Description = "Download and submission metrics", Icon = Icons.Material.Filled.Cloud, Category = "ICUMS" }
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading templates: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task GenerateReport(ReportTemplateDto template)
    {
        try
        {
            Snackbar.Add($"Generating {template.Name}...", Severity.Info);
            // TODO: Replace with actual API call
            // await ApiService.PostAsync<object, object>($"/api/reports/generate/{template.Id}", new { });
            Snackbar.Add($"Report {template.Name} generated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
    }
    
    public class ReportTemplateDto
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Category { get; set; } = "";
    }
}

