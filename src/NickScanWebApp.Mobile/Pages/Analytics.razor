@page "/analytics"
@page "/dashboard/analytics"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Hosting
@using NickScanWebApp.Shared.Services
@attribute [Authorize(Policy = Permissions.PagesDashboardAnalytics)]
@inject ApiService ApiService
@inject NavigationManager Navigation
@inject ILogger<Analytics> Logger
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject IWebHostEnvironment Environment
@implements IAsyncDisposable

<PageTitle>System Analytics Dashboard - NickScan Mobile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 pb-8 px-2">
    <!-- Header Section -->
    <MudStack Spacing="2" Class="mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
                    System Analytics Dashboard
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Real-time monitoring and comprehensive system insights
                </MudText>
            </MudStack>
            <MudChip T="string" 
                     Size="Size.Small" 
                     Color="@(_isConnected ? Color.Success : Color.Error)" 
                     Icon="@(_isConnected ? Icons.Material.Filled.Cloud : Icons.Material.Filled.CloudOff)">
                @(_isConnected ? "Live" : "Offline")
            </MudChip>
        </MudStack>
    </MudStack>

    @if (_isLoading)
    {
        <MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 200px;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1">Loading analytics data...</MudText>
        </MudStack>
    }
    else
    {
        <!-- System Overview Cards -->
        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">System Status</MudText>
                        <MudText Typo="Typo.h6" Color="@GetStatusColor(_systemStatus)">
                            @_systemStatus
                        </MudText>
                        <MudText Typo="Typo.caption">Health: @_healthScore%</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Uptime</MudText>
                        <MudText Typo="Typo.h6">@_uptime</MudText>
                        <MudText Typo="Typo.caption">Since: @_startTime?.ToString("g")</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Containers</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">@_totalContainers.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Today: @_todayContainers</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="6">
                <MudPaper Elevation="1" Class="pa-2">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Errors (24h)</MudText>
                        <MudText Typo="Typo.h6" Color="@(_totalErrors > 10 ? Color.Error : Color.Success)">
                            @_totalErrors
                        </MudText>
                        <MudText Typo="Typo.caption">Warnings: @_totalWarnings</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Performance Metrics -->
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Memory" Class="mr-2" />
                Memory Usage
            </MudText>
            <MudProgressLinear Color="@GetMemoryColor(_memoryUsagePercent)" Size="Size.Medium" 
                               Value="@_memoryUsagePercent" Class="mb-2" />
            <MudText Typo="Typo.body2">
                @_memoryUsedMB MB / @_totalMemoryMB MB (@_memoryUsagePercent.ToString("F1")%)
            </MudText>
        </MudPaper>

        <!-- Database Statistics -->
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
                Database Statistics
            </MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Containers</MudText>
                        <MudText Typo="Typo.h6">@_totalContainers.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Success">Today: +@_todayContainers</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">FS6000 Scans</MudText>
                        <MudText Typo="Typo.h6">@_totalFS6000Scans.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Success">Today: +@_todayFS6000Scans</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ASE Scans</MudText>
                        <MudText Typo="Typo.h6">@_totalAseScans.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Success">Today: +@_todayAseScans</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Images</MudText>
                        <MudText Typo="Typo.h6">@_totalImages.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Info">FS6000: @_totalFS6000Images.ToString("N0")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- API Performance -->
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
                API Performance
            </MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Requests (24h)</MudText>
                    <MudText Typo="Typo.h6">@_apiRequests24h.ToString("N0")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Avg Response</MudText>
                    <MudText Typo="Typo.h6">@_avgResponseTime</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Error Rate</MudText>
                    <MudText Typo="Typo.h6" Color="@(_errorRate > 5 ? Color.Error : Color.Success)">
                        @_errorRate.ToString("F2")%
                    </MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active Connections</MudText>
                    <MudText Typo="Typo.h6">@_activeConnections</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- System Information -->
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                System Information
            </MudText>
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Environment</MudText>
                    <MudText Typo="Typo.body2">@_environment</MudText>
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Version</MudText>
                    <MudText Typo="Typo.body2">@_version</MudText>
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Machine</MudText>
                    <MudText Typo="Typo.body2">@_machineName</MudText>
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Processors</MudText>
                    <MudText Typo="Typo.body2">@_processorCount cores</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Disk Usage - Mobile Optimized -->
        @if (_diskDrives.Any())
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
                    Disk Usage
                </MudText>
                @foreach (var drive in _diskDrives.Take(2))
                {
                    <MudStack Spacing="1" Class="mb-2">
                        <MudText Typo="Typo.body2">@drive.Name</MudText>
                        <MudProgressLinear Color="@GetDiskColor(drive.UsagePercent)" 
                                         Value="@drive.UsagePercent" Class="mb-1" />
                        <MudText Typo="Typo.caption">
                            @drive.UsedGB GB / @drive.TotalGB GB (@drive.UsagePercent.ToString("F1")%)
                        </MudText>
                    </MudStack>
                }
            </MudPaper>
        }

        <!-- Background Services Status - Mobile Optimized -->
        @if (_backgroundServices.Any())
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                    Background Services
                </MudText>
                <MudGrid Spacing="2">
                    @foreach (var service in _backgroundServices.Take(6))
                    {
                        <MudItem xs="6">
                            <MudPaper Elevation="0" Class="pa-2">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <MudText Typo="Typo.caption" Style="flex: 1;">@service.Name</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@GetServiceStatusColor(service.Status)">
                                        @service.Status
                                    </MudChip>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        <!-- Recent Events - Mobile Optimized -->
        @if (_recentEvents.Any())
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3" Style="max-height: 300px; overflow-y: auto;">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" />
                    Recent Events
                </MudText>
                <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                    @foreach (var evt in _recentEvents.Take(5))
                    {
                        <MudTimelineItem Color="@GetEventColor(evt.Severity)" Size="Size.Small">
                            <ItemContent>
                                <MudText Typo="Typo.body2">@evt.Message</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @evt.Service - @evt.Timestamp.ToString("HH:mm:ss")
                                </MudText>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            </MudPaper>
        }

        <!-- Last Update Info -->
        @if (_lastUpdate.HasValue)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mb-2">
                Last update: @_lastUpdate.Value.ToString("HH:mm:ss")
            </MudText>
        }

        <!-- Refresh Button -->
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  FullWidth="true"
                  StartIcon="@Icons.Material.Filled.Refresh"
                  OnClick="LoadAnalyticsData"
                  Disabled="_isLoading">
            Refresh Data
        </MudButton>
    }
</MudContainer>

@code {
    // SignalR connection
    private HubConnection? _hubConnection;
    private bool _isConnected = false;
    private bool _isLoading = true;
    private string _systemStatus = "Unknown";
    private int _healthScore = 0;
    private string _uptime = "0 days";
    private DateTime? _startTime;
    private int _totalContainers = 0;
    private int _todayContainers = 0;
    private int _totalErrors = 0;
    private int _totalWarnings = 0;
    private long _memoryUsedMB = 0;
    private long _totalMemoryMB = 0;
    private double _memoryUsagePercent = 0;
    private int _totalFS6000Scans = 0;
    private int _todayFS6000Scans = 0;
    private int _totalAseScans = 0;
    private int _todayAseScans = 0;
    private int _totalImages = 0;
    private int _totalFS6000Images = 0;
    private int _apiRequests24h = 0;
    private string _avgResponseTime = "0ms";
    private double _errorRate = 0;
    private int _activeConnections = 0;
    private string _environment = "Unknown";
    private string _version = "Unknown";
    private string _machineName = "Unknown";
    private int _processorCount = 0;
    private DateTime? _lastUpdate;
    
    // Disk Drives
    private List<DiskDriveInfo> _diskDrives = new();
    
    // Background Services
    private List<ServiceStatus> _backgroundServices = new();
    
    // Events
    private List<SystemEvent> _recentEvents = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAnalyticsData();
            await InitializeSignalR();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing analytics dashboard");
            Snackbar.Add($"Error loading dashboard: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task InitializeSignalR()
    {
        try
        {
            // Use API base URL (where the hub is hosted), not WebApp URL
            var apiBaseUrl = Configuration?["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            var hubUrl = $"{apiBaseUrl}/hubs/comprehensive-dashboard";
            
            // Check if URL is HTTPS (needs SSL certificate validation)
            var isHttps = hubUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase);
            
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    // SSL Certificate Validation - Allow self-signed certificates in development
                    if (isHttps && Environment.IsDevelopment())
                    {
                        options.HttpMessageHandlerFactory = handler =>
                        {
                            if (handler is HttpClientHandler httpHandler)
                            {
                                httpHandler.ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true;
                            }
                            return handler;
                        };
                    }
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<object>("ReceiveDashboardUpdate", async (data) =>
            {
                Logger.LogInformation("Received dashboard update from SignalR");
                _lastUpdate = DateTime.Now;
                // Refresh data when update received
                await LoadAnalyticsData();
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.Closed += async (error) =>
            {
                _isConnected = false;
                await InvokeAsync(StateHasChanged);
                Logger.LogWarning("SignalR connection closed: {Error}", error?.Message);
                
                // Attempt to reconnect after delay
                await Task.Delay(5000);
                await InitializeSignalR();
            };

            _hubConnection.Reconnecting += (error) =>
            {
                _isConnected = false;
                Logger.LogInformation("SignalR reconnecting: {Error}", error?.Message);
                return Task.CompletedTask;
            };

            _hubConnection.Reconnected += (connectionId) =>
            {
                _isConnected = true;
                Logger.LogInformation("SignalR reconnected: {ConnectionId}", connectionId);
                return Task.CompletedTask;
            };

            await _hubConnection.StartAsync();
            _isConnected = true;
            Logger.LogInformation("Connected to dashboard SignalR hub at {Url}", apiBaseUrl);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to connect to SignalR hub");
            _isConnected = false;
            // Don't show error to user - SignalR is optional enhancement
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private async Task LoadAnalyticsData()
    {
        _isLoading = true;
        try
        {
            // Load system health
            var health = await ApiService.GetAsync<SystemHealthSummary>("/api/analytics/system-health");
            if (health != null)
            {
                _systemStatus = health.OverallStatus;
                _healthScore = _systemStatus == "Healthy" ? 100 : (_systemStatus == "Degraded" ? 75 : 50);
            }

            // Load system information
            var sysInfo = await ApiService.GetAsync<SystemInformation>("/api/analytics/system-info");
            if (sysInfo != null)
            {
                _environment = sysInfo.Environment;
                _version = sysInfo.Version;
                _machineName = sysInfo.MachineName;
                _processorCount = sysInfo.ProcessorCount;
                _startTime = sysInfo.StartTime;
                
                if (_startTime.HasValue)
                {
                    var uptime = DateTime.UtcNow - _startTime.Value;
                    _uptime = $"{uptime.Days}d {uptime.Hours}h {uptime.Minutes}m";
                }
            }

            // Load database statistics
            var dbStats = await ApiService.GetAsync<DatabaseStatsResponse>("/api/analytics/database-stats");
            if (dbStats != null)
            {
                _totalContainers = dbStats.TotalContainers;
                _totalFS6000Scans = dbStats.TotalFS6000Scans;
                _totalFS6000Images = dbStats.TotalFS6000Images;
                _totalAseScans = dbStats.TotalAseScans;
                _totalImages = dbStats.TotalContainerImages;
                
                if (dbStats.TodayActivity != null)
                {
                    _todayContainers = dbStats.TodayActivity.Containers;
                    _todayFS6000Scans = dbStats.TodayActivity.FS6000Scans;
                    _todayAseScans = dbStats.TodayActivity.AseScans;
                }
            }

            // Load performance metrics
            var perfMetrics = await ApiService.GetAsync<PerformanceMetricsResponse>("/api/analytics/performance-metrics");
            if (perfMetrics != null)
            {
                if (perfMetrics.ProcessMetrics != null)
                {
                    _memoryUsedMB = perfMetrics.ProcessMetrics.MemoryUsageMB;
                }
                if (perfMetrics.SystemMetrics != null)
                {
                    _totalMemoryMB = perfMetrics.SystemMetrics.TotalMemoryMB;
                    if (_totalMemoryMB > 0)
                    {
                        _memoryUsagePercent = (double)_memoryUsedMB / _totalMemoryMB * 100;
                    }
                }
            }

            // Load API performance
            var apiPerf = await ApiService.GetAsync<ApiPerformanceResponse>("/api/analytics/api-performance");
            if (apiPerf != null)
            {
                _apiRequests24h = apiPerf.Requests24h;
                _avgResponseTime = $"{apiPerf.AvgResponseTimeMs}ms";
                _errorRate = apiPerf.ErrorRate;
                _activeConnections = apiPerf.ActiveConnections;
            }

            // Load error counts
            var errorCounts = await ApiService.GetAsync<ErrorCountsResponse>("/api/analytics/error-counts");
            if (errorCounts != null)
            {
                _totalErrors = errorCounts.Errors24h;
                _totalWarnings = errorCounts.Warnings24h;
            }
            
            // Load services health
            var servicesHealth = await ApiService.GetAsync<Dictionary<string, ServiceHealthResponse>>("/api/Monitoring/health/services");
            if (servicesHealth != null)
            {
                _backgroundServices = servicesHealth.Select(kvp => new ServiceStatus
                {
                    Name = kvp.Key,
                    Status = kvp.Value.Status,
                    LastHeartbeat = kvp.Value.LastChecked
                }).ToList();
            }
            
            // Load recent events
            var recentEvents = await ApiService.GetAsync<RecentEventsResponse>("/api/Monitoring/events/recent");
            if (recentEvents?.Events != null)
            {
                _recentEvents = recentEvents.Events.Select(e => new SystemEvent
                {
                    Timestamp = e.Timestamp,
                    Service = e.Service,
                    Message = e.Message,
                    Severity = e.Severity
                }).ToList();
            }
            
            // Load filesystem status
            var filesystemStatus = await ApiService.GetAsync<FileSystemStatusResponse>("/api/Monitoring/filesystem/status");
            if (filesystemStatus?.DiskSpace != null)
            {
                _diskDrives = filesystemStatus.DiskSpace.Select(d => new DiskDriveInfo
                {
                    Name = d.Name,
                    TotalGB = d.TotalSizeGB,
                    UsedGB = d.UsedSpaceGB,
                    FreeGB = d.AvailableFreeSpaceGB,
                    UsagePercent = d.UsagePercentage
                }).ToList();
            }
            
            _lastUpdate = DateTime.Now;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading analytics data");
            Snackbar.Add("Failed to load analytics data", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Healthy" => Color.Success,
        "Degraded" => Color.Warning,
        "Unhealthy" => Color.Error,
        _ => Color.Default
    };

    private Color GetMemoryColor(double percent) => percent switch
    {
        >= 90 => Color.Error,
        >= 75 => Color.Warning,
        _ => Color.Success
    };
    
    private Color GetDiskColor(double percent) => percent switch
    {
        > 90 => Color.Error,
        > 75 => Color.Warning,
        _ => Color.Info
    };
    
    private Color GetServiceStatusColor(string status) => status.ToLower() switch
    {
        "healthy" => Color.Success,
        "running" => Color.Success,
        "degraded" => Color.Warning,
        "stopped" => Color.Warning,
        "error" => Color.Error,
        "unhealthy" => Color.Error,
        _ => Color.Default
    };
    
    private Color GetEventColor(string severity) => severity.ToLower() switch
    {
        "high" => Color.Error,
        "error" => Color.Error,
        "medium" => Color.Warning,
        "warning" => Color.Warning,
        "low" => Color.Info,
        "info" => Color.Info,
        _ => Color.Default
    };

    // DTOs
    private class SystemHealthSummary
    {
        public string OverallStatus { get; set; } = "";
    }

    private class SystemInformation
    {
        public string Environment { get; set; } = "";
        public string Version { get; set; } = "";
        public string MachineName { get; set; } = "";
        public int ProcessorCount { get; set; }
        public DateTime StartTime { get; set; }
    }

    private class DatabaseStatsResponse
    {
        public int TotalContainers { get; set; }
        public int TotalFS6000Scans { get; set; }
        public int TotalFS6000Images { get; set; }
        public int TotalAseScans { get; set; }
        public int TotalContainerImages { get; set; }
        public TodayActivityData? TodayActivity { get; set; }
    }

    private class TodayActivityData
    {
        public int Containers { get; set; }
        public int FS6000Scans { get; set; }
        public int AseScans { get; set; }
    }

    private class PerformanceMetricsResponse
    {
        public ProcessMetricsData? ProcessMetrics { get; set; }
        public SystemMetricsData? SystemMetrics { get; set; }
    }

    private class ProcessMetricsData
    {
        public long MemoryUsageMB { get; set; }
        public int ThreadCount { get; set; }
    }

    private class SystemMetricsData
    {
        public long TotalMemoryMB { get; set; }
    }

    private class ApiPerformanceResponse
    {
        public int Requests24h { get; set; }
        public int AvgResponseTimeMs { get; set; }
        public double ErrorRate { get; set; }
        public int ActiveConnections { get; set; }
    }

    private class ErrorCountsResponse
    {
        public int Errors24h { get; set; }
        public int Warnings24h { get; set; }
    }
    
    private class ServiceHealthResponse
    {
        public string Status { get; set; } = "";
        public DateTime LastChecked { get; set; }
    }
    
    private class RecentEventsResponse
    {
        public List<EventData> Events { get; set; } = new();
    }
    
    private class EventData
    {
        public DateTime Timestamp { get; set; }
        public string Service { get; set; } = "";
        public string Message { get; set; } = "";
        public string Severity { get; set; } = "";
    }
    
    private class FileSystemStatusResponse
    {
        public List<DiskSpaceData> DiskSpace { get; set; } = new();
    }
    
    private class DiskSpaceData
    {
        public string Name { get; set; } = "";
        public long TotalSizeGB { get; set; }
        public long UsedSpaceGB { get; set; }
        public long AvailableFreeSpaceGB { get; set; }
        public double UsagePercentage { get; set; }
    }
    
    private class ServiceStatus
    {
        public string Name { get; set; } = "";
