@page "/validation/image-analysis-management"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesImageAnalysisManagement)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar

<PageTitle>Image Analysis Management - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.ImageSearch" Class="mr-2" />
            Image Analysis Management
        </MudText>
    </MudPaper>
    
    <MudAlert Severity="Severity.Info">
        Image analysis management. Use desktop version for configuration and monitoring.
    </MudAlert>
</MudContainer>

