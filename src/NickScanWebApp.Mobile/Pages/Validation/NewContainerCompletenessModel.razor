@page "/validation/new-completeness-model"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesValidationCompleteness)]
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject NickScanWebApp.Mobile.Services.ApiService ApiService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>New Container Completeness Model - NickScan Mobile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    
    <!-- Header -->
    <MudPaper Elevation="0" Class="mb-3">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-2" />
                New Container Completeness Model
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Consolidated cargo model with completeness tracking by Master BL and House BL
            </MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Size="Size.Small" 
                         Color="Color.Info"
                         Icon="@Icons.Material.Filled.Info">
                    @(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count) Cargo Groups
                </MudChip>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Primary" 
                          Size="Size.Small"
                          StartIcon="@Icons.Material.Filled.Refresh"
                          OnClick="@RefreshData"
                          Disabled="@isLoadingCargoGroups">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    <!-- Statistics Cards - Mobile Optimized -->
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Groups</MudText>
                    <MudText Typo="Typo.h6">@(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count)</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Complete</MudText>
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-success);">@completeGroupsCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@completeGroupsPercentage.ToString("F1")%</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Partial</MudText>
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-warning);">@partialGroupsCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@partialGroupsPercentage.ToString("F1")%</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="1" Class="pa-2">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Incomplete</MudText>
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-error);">@incompleteGroupsCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@incompleteGroupsPercentage.ToString("F1")%</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
    
    <!-- Main Content - Mobile Optimized Tabs -->
    <MudPaper Elevation="2" Class="rounded-lg">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" Color="Color.Primary" Variant="Variant.Scrollable">
            
            <!-- Cargo Groups Tab -->
            <MudTabPanel Text="Cargo Groups" Icon="@Icons.Material.Filled.Inventory2" BadgeData="@(nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count)" BadgeColor="Color.Info">
                
                <!-- Filters - Mobile Stacked -->
                <MudPaper Elevation="1" Class="pa-2 mb-3">
                    <MudStack Spacing="2">
                        <MudSelect T="string" 
                                  Label="Status" 
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  @bind-Value="filterCompletenessStatus"
                                  Clearable="true">
                            <MudSelectItem T="string" Value="@("All")">All Status</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Complete")">Complete</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Partial")">Partial</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Incomplete")">Incomplete</MudSelectItem>
                        </MudSelect>
                        <MudTextField T="string" 
                                     Label="Search" 
                                     Variant="Variant.Outlined"
                                     Dense="true"
                                     @bind-Value="searchTerm"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     Placeholder="Master BL, Declaration, Container..." />
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary" 
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.FilterList"
                                  OnClick="@ApplyCargoGroupFilters"
                                  FullWidth="true">
                            Filter
                        </MudButton>
                    </MudStack>
                </MudPaper>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-1" Color="Color.Info" Variant="Variant.Scrollable">
                    <!-- Non-Consolidated Sub-Tab -->
                    <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Filled.LocalShipping" BadgeData="@filteredNonConsolidatedGroups.Count" BadgeColor="Color.Primary">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!filteredNonConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No non-consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in filteredNonConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                @group.DeclarationNumber
                                            </MudText>
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudChip T="string" 
                                                        Size="Size.Small" 
                                                        Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                        Icon="@GetCompletenessStatusIcon(group.CompletenessStatus)">
                                                    @group.CompletenessStatus
                                                </MudChip>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @group.ContainersWithData / @group.TotalContainers
                                                </MudText>
                                                <MudProgressLinear Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                                   Value="@group.CompletionPercentage"
                                                                   Min="0" Max="100" 
                                                                   Size="Size.Small" 
                                                                   Rounded="true"
                                                                   Style="width: 60px;" />
                                            </MudStack>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-background-grey);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Master BL: @group.MasterBL</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Consignee: @group.ConsigneeName</MudText>
                                                
                                                <MudDivider />
                                                
                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">Containers (@group.Containers.Count)</MudText>
                                                @foreach (var container in group.Containers)
                                                {
                                                    var isComplete = group.CompleteContainers.Contains(container);
                                                    var isMissing = group.MissingContainers.Contains(container);
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudLink Href="@($"/containers/{container}")" Typo="Typo.body2">
                                                                <strong>@container</strong>
                                                            </MudLink>
                                                            <MudStack Row="true" Spacing="1">
                                                                @if (isComplete)
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                                        Complete
                                                                    </MudChip>
                                                                }
                                                                else if (isMissing)
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">
                                                                        Missing
                                                                    </MudChip>
                                                                    <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                                                                                  Size="Size.Small"
                                                                                  Color="Color.Primary"
                                                                                  OnClick="@(() => RequestBOE(container))"
                                                                                  title="Request BOE" />
                                                                }
                                                                else
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Info">
                                                                        Unknown
                                                                    </MudChip>
                                                                }
                                                            </MudStack>
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                    
                    <!-- Consolidated Sub-Tab -->
                    <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Filled.Inventory" BadgeData="@filteredConsolidatedGroups.Count" BadgeColor="Color.Warning">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!filteredConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in filteredConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                @group.MasterBL
                                            </MudText>
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudChip T="string" 
                                                        Size="Size.Small" 
                                                        Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                        Icon="@GetCompletenessStatusIcon(group.CompletenessStatus)">
                                                    @group.CompletenessStatus
                                                </MudChip>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @group.CompleteHouseBLs / @group.TotalHouseBLs House BLs
                                                </MudText>
                                                <MudProgressLinear Color="@GetCompletenessStatusColor(group.CompletenessStatus)"
                                                                   Value="@group.CompletionPercentage"
                                                                   Min="0" Max="100" 
                                                                   Size="Size.Small" 
                                                                   Rounded="true"
                                                                   Style="width: 60px;" />
                                            </MudStack>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-background-grey);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@group.ContainerNumbers.Count container(s)</MudText>
                                                
                                                <MudDivider />
                                                
                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">House BLs (@group.HouseBLDetails.Count)</MudText>
                                                @foreach (var hbl in group.HouseBLDetails)
                                                {
                                                    var isComplete = group.CompleteHouseBLsList.Contains(hbl.HouseBL);
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Spacing="1">
                                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">@hbl.HouseBL</MudText>
                                                                @if (isComplete)
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                                        Complete
                                                                    </MudChip>
                                                                }
                                                                else
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">
                                                                        Incomplete
                                                                    </MudChip>
                                                                }
                                                            </MudStack>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Declaration: @hbl.DeclarationNumber</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Container: 
                                                                <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                    @hbl.ContainerNumber
                                                                </MudLink>
                                                            </MudText>
                                                            @if (!isComplete)
                                                            {
                                                                <MudButton Variant="Variant.Text" 
                                                                          Size="Size.Small"
                                                                          StartIcon="@Icons.Material.Filled.CloudDownload"
                                                                          OnClick="@(() => RequestBOE(hbl.ContainerNumber))">
                                                                    Request BOE
                                                                </MudButton>
                                                            }
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
            
            <!-- Missing Data Tab -->
            <MudTabPanel Text="Missing Data" Icon="@Icons.Material.Filled.Warning" BadgeData="@incompleteGroupsCount" BadgeColor="Color.Error">
                <MudAlert Severity="Severity.Warning" Class="mb-3" Dense="true">
                    Showing cargo groups with incomplete data
                </MudAlert>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-1" Color="Color.Error" Variant="Variant.Scrollable">
                    <!-- Non-Consolidated Missing -->
                    <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Filled.LocalShipping" BadgeData="@incompleteNonConsolidatedGroups.Count" BadgeColor="Color.Error">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Error" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!incompleteNonConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No incomplete non-consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in incompleteNonConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: var(--mud-palette-error);">
                                                @group.DeclarationNumber
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">
                                                @group.MissingContainers.Count missing
                                            </MudChip>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-error-lighten);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.body2" Color="Color.Error">Missing Containers (@group.MissingContainers.Count)</MudText>
                                                @foreach (var container in group.MissingContainers)
                                                {
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudLink Href="@($"/containers/{container}")" Typo="Typo.body2">
                                                                <strong>@container</strong>
                                                            </MudLink>
                                                            <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                                                                          Size="Size.Small"
                                                                          Color="Color.Primary"
                                                                          OnClick="@(() => RequestBOE(container))"
                                                                          title="Request BOE" />
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                    
                    <!-- Consolidated Missing -->
                    <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Filled.Inventory" BadgeData="@incompleteConsolidatedGroups.Count" BadgeColor="Color.Error">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Error" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!incompleteConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No incomplete consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in incompleteConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: var(--mud-palette-error);">
                                                @group.MasterBL
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">
                                                @(group.TotalHouseBLs - group.CompleteHouseBLs) missing
                                            </MudChip>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-error-lighten);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.body2" Color="Color.Error">Incomplete House BLs (@(group.TotalHouseBLs - group.CompleteHouseBLs))</MudText>
                                                @foreach (var hbl in group.HouseBLDetails.Where(h => !group.CompleteHouseBLsList.Contains(h.HouseBL)))
                                                {
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Spacing="1">
                                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@hbl.HouseBL</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Container: 
                                                                <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                    @hbl.ContainerNumber
                                                                </MudLink>
                                                            </MudText>
                                                            <MudButton Variant="Variant.Text" 
                                                                      Size="Size.Small"
                                                                      StartIcon="@Icons.Material.Filled.CloudDownload"
                                                                      OnClick="@(() => RequestBOE(hbl.ContainerNumber))">
                                                                Request BOE
                                                            </MudButton>
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
            
            <!-- Complete Data Tab -->
            <MudTabPanel Text="Complete Data" Icon="@Icons.Material.Filled.CheckCircle" BadgeData="@completeGroupsCount" BadgeColor="Color.Success">
                <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">
                    Showing cargo groups with complete data
                </MudAlert>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-1" Color="Color.Success" Variant="Variant.Scrollable">
                    <!-- Non-Consolidated Complete -->
                    <MudTabPanel Text="Non-Consolidated" Icon="@Icons.Material.Filled.LocalShipping" BadgeData="@completeNonConsolidatedGroups.Count" BadgeColor="Color.Success">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Success" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!completeNonConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No complete non-consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in completeNonConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: var(--mud-palette-success);">
                                                @group.DeclarationNumber
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                @group.TotalContainers / @group.TotalContainers complete
                                            </MudChip>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-success-lighten);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.body2" Color="Color.Success">All Containers Complete (@group.Containers.Count)</MudText>
                                                @foreach (var container in group.Containers)
                                                {
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudLink Href="@($"/containers/{container}")" Typo="Typo.body2">
                                                                <strong>@container</strong>
                                                            </MudLink>
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                                Complete
                                                            </MudChip>
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                    
                    <!-- Consolidated Complete -->
                    <MudTabPanel Text="Consolidated" Icon="@Icons.Material.Filled.Inventory" BadgeData="@completeConsolidatedGroups.Count" BadgeColor="Color.Success">
                        @if (isLoadingCargoGroups)
                        {
                            <MudProgressLinear Color="Color.Success" Indeterminate="true" Class="mb-3" />
                        }
                        
                        @if (!completeConsolidatedGroups.Any() && !isLoadingCargoGroups)
                        {
                            <MudAlert Severity="Severity.Info">No complete consolidated cargo groups found.</MudAlert>
                        }
                        
                        <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                            @foreach (var group in completeConsolidatedGroups)
                            {
                                <MudExpansionPanel>
                                    <TitleContent>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: var(--mud-palette-success);">
                                                @group.MasterBL
                                            </MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                @group.TotalHouseBLs / @group.TotalHouseBLs House BLs
                                            </MudChip>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: var(--mud-palette-success-lighten);">
                                            <MudStack Spacing="2">
                                                <MudText Typo="Typo.body2" Color="Color.Success">All House BLs Complete (@group.HouseBLDetails.Count)</MudText>
                                                @foreach (var hbl in group.HouseBLDetails)
                                                {
                                                    <MudPaper Elevation="1" Class="pa-2 mb-1">
                                                        <MudStack Spacing="1">
                                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">@hbl.HouseBL</MudText>
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                                                    Complete
                                                                </MudChip>
                                                            </MudStack>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Container: 
                                                                <MudLink Href="@($"/containers/{hbl.ContainerNumber}")" Typo="Typo.caption">
                                                                    @hbl.ContainerNumber
                                                                </MudLink>
                                                            </MudText>
                                                        </MudStack>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudTabPanel>
                </MudTabs>
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudContainer>

@code {
    // ✅ CONSOLIDATED CARGO MODEL - Data with Completeness
    private List<NonConsolidatedCargoGroupWithCompleteness> nonConsolidatedGroupsWithCompleteness = new();
    private List<ConsolidatedCargoGroupWithCompleteness> consolidatedGroupsWithCompleteness = new();
    
    // Filtered lists
    private List<NonConsolidatedCargoGroupWithCompleteness> filteredNonConsolidatedGroups = new();
    private List<ConsolidatedCargoGroupWithCompleteness> filteredConsolidatedGroups = new();
    
    // Missing/Complete filtered lists
    private List<NonConsolidatedCargoGroupWithCompleteness> incompleteNonConsolidatedGroups = new();
    private List<ConsolidatedCargoGroupWithCompleteness> incompleteConsolidatedGroups = new();
    private List<NonConsolidatedCargoGroupWithCompleteness> completeNonConsolidatedGroups = new();
    private List<ConsolidatedCargoGroupWithCompleteness> completeConsolidatedGroups = new();
    
    // Completeness data
    private List<MissingContainerData> allMissingData = new();
    private List<CompleteContainerData> completeData = new();
    
    // Statistics
    private int completeGroupsCount = 0;
    private int partialGroupsCount = 0;
    private int incompleteGroupsCount = 0;
    private double completeGroupsPercentage = 0;
    private double partialGroupsPercentage = 0;
    private double incompleteGroupsPercentage = 0;
    
    // Loading state
    private bool isLoadingCargoGroups = false;
    
    // Filters
    private string filterCompletenessStatus = "All";
    private string searchTerm = "";
    
    // Auto-refresh timer
    private System.Threading.Timer? _refreshTimer;
    
    protected override async Task OnInitializedAsync()
    {
        // Wait for authentication
        await WaitForAuthenticationAsync();
        
        // Load completeness data first
        await LoadCompletenessData();
        
        // Load cargo groups and calculate completeness
        await LoadCargoGroupsWithCompleteness();
        
        // Apply initial filters
        ApplyCargoGroupFilters();
        UpdateMissingCompleteLists();
        
        // Auto-refresh every 30 seconds
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadCompletenessData();
                await LoadCargoGroupsWithCompleteness();
                ApplyCargoGroupFilters();
                UpdateMissingCompleteLists();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }
    
    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
    
    private async Task WaitForAuthenticationAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (AuthStateProvider is NickScanWebApp.Mobile.Services.SimpleAuthStateProvider simpleAuth)
            {
                var token = await simpleAuth.GetTokenAsync();
                if (string.IsNullOrEmpty(token))
                {
                    await Task.Delay(100);
                    token = await simpleAuth.GetTokenAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NewCompletenessModel] Error waiting for authentication: {ex.Message}");
        }
    }
    
    private async Task LoadCompletenessData()
    {
        try
        {
            var missingResponse = await ApiService.GetAsync<List<ApiMissingContainer>>("/api/containercompleteness/missing");
            if (missingResponse != null)
            {
                allMissingData = missingResponse.Select(m => new MissingContainerData
                {
                    ContainerNumber = m.ContainerNumber ?? "",
                    ScannerType = m.ScannerType ?? "Unknown",
                    ScanDate = m.ScanDate,
                    DaysMissing = (int)(DateTime.Now - m.ScanDate).TotalDays,
                    Status = m.Status ?? "Missing",
                    RetryCount = m.RetryCount,
                    LastChecked = m.LastCheckedAt
                }).ToList();
            }
            
            var completeResponse = await ApiService.GetAsync<List<ApiMissingContainer>>("/api/containercompleteness/complete");
            if (completeResponse != null)
            {
                completeData = completeResponse.Select(m => new CompleteContainerData
                {
                    ContainerNumber = m.ContainerNumber ?? "",
                    ScannerType = m.ScannerType ?? "Unknown",
                    ScanDate = m.ScanDate,
                    ICUMSDataDate = DateTime.Now.AddDays(-1)
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NewCompletenessModel] Error loading completeness data: {ex.Message}");
            allMissingData = new List<MissingContainerData>();
            completeData = new List<CompleteContainerData>();
        }
    }
    
    private async Task LoadCargoGroupsWithCompleteness()
    {
        isLoadingCargoGroups = true;
        try
        {
            var nonConsolidatedResponse = await ApiService.GetAsync<List<NonConsolidatedCargoGroup>>("/api/consolidatedcargo/non-consolidated?pageSize=50");
            if (nonConsolidatedResponse != null)
            {
                nonConsolidatedGroupsWithCompleteness = nonConsolidatedResponse.Select(g => CalculateNonConsolidatedCompleteness(g)).ToList();
            }
            
            var consolidatedResponse = await ApiService.GetAsync<List<ConsolidatedCargoGroup>>("/api/consolidatedcargo/consolidated?pageSize=50");
            if (consolidatedResponse != null)
            {
                consolidatedGroupsWithCompleteness = consolidatedResponse.Select(g => CalculateConsolidatedCompleteness(g)).ToList();
            }
            
            UpdateStatistics();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NewCompletenessModel] Error loading cargo groups: {ex.Message}");
            Snackbar.Add($"Could not load cargo groups: {ex.Message}", Severity.Error);
            nonConsolidatedGroupsWithCompleteness = new List<NonConsolidatedCargoGroupWithCompleteness>();
            consolidatedGroupsWithCompleteness = new List<ConsolidatedCargoGroupWithCompleteness>();
        }
        finally
        {
            isLoadingCargoGroups = false;
        }
    }
    
    private NonConsolidatedCargoGroupWithCompleteness CalculateNonConsolidatedCompleteness(NonConsolidatedCargoGroup group)
    {
        var totalContainers = group.Containers.Count;
        var completeContainers = group.Containers.Where(c => 
            completeData.Any(cd => cd.ContainerNumber == c) || 
            !allMissingData.Any(md => md.ContainerNumber == c)
        ).ToList();
        var missingContainers = group.Containers.Where(c => 
            allMissingData.Any(md => md.ContainerNumber == c)
        ).ToList();
        
        var containersWithData = completeContainers.Count;
        var completionPercentage = totalContainers > 0 ? (containersWithData * 100) / totalContainers : 0;
        
        string status;
        if (completionPercentage == 100)
            status = "Complete";
        else if (completionPercentage > 0)
            status = "Partial";
        else
            status = "Incomplete";
        
        return new NonConsolidatedCargoGroupWithCompleteness
        {
            DeclarationNumber = group.DeclarationNumber,
            MasterBL = group.MasterBL,
            Containers = group.Containers,
            NoOfContainers = group.NoOfContainers,
            ClearanceType = group.ClearanceType,
            ConsigneeName = group.ConsigneeName,
            RotationNumber = group.RotationNumber,
            GoodsDescription = group.GoodsDescription,
            TotalDutyPaid = group.TotalDutyPaid,
            DeclarationDate = group.DeclarationDate,
            SampleBOEId = group.SampleBOEId,
            TotalContainers = totalContainers,
            ContainersWithData = containersWithData,
            CompletionPercentage = completionPercentage,
            CompletenessStatus = status,
            CompleteContainers = completeContainers,
            MissingContainers = missingContainers
        };
    }
    
    private ConsolidatedCargoGroupWithCompleteness CalculateConsolidatedCompleteness(ConsolidatedCargoGroup group)
    {
        var totalHouseBLs = group.HouseBLDetails.Count;
        var completeHouseBLs = group.HouseBLDetails.Where(hbl =>
            completeData.Any(cd => cd.ContainerNumber == hbl.ContainerNumber) ||
            !allMissingData.Any(md => md.ContainerNumber == hbl.ContainerNumber)
        ).Select(hbl => hbl.HouseBL).ToList();
        
        var completeHouseBLsCount = completeHouseBLs.Count;
        var completionPercentage = totalHouseBLs > 0 ? (completeHouseBLsCount * 100) / totalHouseBLs : 0;
        
        string status;
        if (completionPercentage == 100)
            status = "Complete";
        else if (completionPercentage > 0)
            status = "Partial";
        else
            status = "Incomplete";
        
        return new ConsolidatedCargoGroupWithCompleteness
        {
            MasterBL = group.MasterBL,
            ContainerNumbers = group.ContainerNumbers,
            HouseBLDetails = group.HouseBLDetails,
            TotalHouseBLs = totalHouseBLs,
            CompleteHouseBLs = completeHouseBLsCount,
            CompletionPercentage = completionPercentage,
            CompletenessStatus = status,
            CompleteHouseBLsList = completeHouseBLs
        };
    }
    
    private void UpdateStatistics()
    {
        var allGroups = nonConsolidatedGroupsWithCompleteness.Count + consolidatedGroupsWithCompleteness.Count;
        
        completeGroupsCount = nonConsolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Complete") +
                             consolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Complete");
        
        partialGroupsCount = nonConsolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Partial") +
                           consolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Partial");
        
        incompleteGroupsCount = nonConsolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Incomplete") +
                               consolidatedGroupsWithCompleteness.Count(g => g.CompletenessStatus == "Incomplete");
        
        if (allGroups > 0)
        {
            completeGroupsPercentage = (completeGroupsCount * 100.0) / allGroups;
            partialGroupsPercentage = (partialGroupsCount * 100.0) / allGroups;
            incompleteGroupsPercentage = (incompleteGroupsCount * 100.0) / allGroups;
        }
    }
    
    private void ApplyCargoGroupFilters()
    {
        filteredNonConsolidatedGroups = nonConsolidatedGroupsWithCompleteness.Where(g =>
        {
            if (filterCompletenessStatus != "All" && g.CompletenessStatus != filterCompletenessStatus)
                return false;
            
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var searchLower = searchTerm.ToLower();
                if (!g.DeclarationNumber.ToLower().Contains(searchLower) &&
                    !g.MasterBL.ToLower().Contains(searchLower) &&
                    !g.Containers.Any(c => c.ToLower().Contains(searchLower)))
                    return false;
            }
            
            return true;
        }).ToList();
        
        filteredConsolidatedGroups = consolidatedGroupsWithCompleteness.Where(g =>
        {
            if (filterCompletenessStatus != "All" && g.CompletenessStatus != filterCompletenessStatus)
                return false;
            
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var searchLower = searchTerm.ToLower();
                if (!g.MasterBL.ToLower().Contains(searchLower) &&
                    !g.ContainerNumbers.Any(c => c.ToLower().Contains(searchLower)) &&
                    !g.HouseBLDetails.Any(h => h.HouseBL.ToLower().Contains(searchLower)))
                    return false;
            }
            
            return true;
        }).ToList();
    }
    
    private void UpdateMissingCompleteLists()
    {
        incompleteNonConsolidatedGroups = nonConsolidatedGroupsWithCompleteness
            .Where(g => g.CompletenessStatus != "Complete")
            .ToList();
        
        incompleteConsolidatedGroups = consolidatedGroupsWithCompleteness
            .Where(g => g.CompletenessStatus != "Complete")
            .ToList();
        
        completeNonConsolidatedGroups = nonConsolidatedGroupsWithCompleteness
            .Where(g => g.CompletenessStatus == "Complete")
            .ToList();
        
        completeConsolidatedGroups = consolidatedGroupsWithCompleteness
            .Where(g => g.CompletenessStatus == "Complete")
            .ToList();
    }
    
    private async Task RefreshData()
    {
        await LoadCompletenessData();
        await LoadCargoGroupsWithCompleteness();
        ApplyCargoGroupFilters();
        UpdateMissingCompleteLists();
        Snackbar.Add("Data refreshed", Severity.Success);
    }
    
    private async Task RequestBOE(string containerNumber)
    {
        try
        {
            await ApiService.PostAsync<object, object>($"/api/containercompleteness/request-boe/{containerNumber}", new { });
            Snackbar.Add($"BOE request queued for {containerNumber}", Severity.Success);
            await RefreshData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error requesting BOE: {ex.Message}");
            Snackbar.Add("Could not request BOE", Severity.Error);
        }
    }
    
    private Color GetCompletenessStatusColor(string status)
    {
        return status switch
        {
            "Complete" => Color.Success,
            "Partial" => Color.Warning,
            "Incomplete" => Color.Error,
            _ => Color.Default
        };
    }
    
    private string GetCompletenessStatusIcon(string status)
    {
        return status switch
        {
            "Complete" => Icons.Material.Filled.CheckCircle,
            "Partial" => Icons.Material.Filled.Warning,
            "Incomplete" => Icons.Material.Filled.Error,
            _ => Icons.Material.Filled.Circle
        };
    }
    
