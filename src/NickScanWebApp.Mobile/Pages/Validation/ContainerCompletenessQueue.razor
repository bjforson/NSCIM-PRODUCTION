@page "/validation/ccq"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesValidationCompleteness)]
@using NickScanWebApp.Mobile.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<ContainerCompletenessQueue> Logger
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>CCQ - Container Completeness Queue</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <!-- Header -->
    <MudPaper Elevation="2" Class="pa-3 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Queue" />
                <MudText Typo="Typo.h6">CCQ - Completeness Queue</MudText>
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small"
                         Color="@(_autoRefreshEnabled ? Color.Success : Color.Default)"
                         Icon="@(_autoRefreshEnabled ? Icons.Material.Filled.Autorenew : Icons.Material.Filled.PauseCircle)"
                         OnClick="ToggleAutoRefresh">
                    @(_autoRefreshEnabled ? "Live (30s)" : "Paused")
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="@(() => LoadQueueItems())"
                               Disabled="_isLoading" Size="Size.Small" />
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Stats -->
    @if (_queueStats != null)
    {
        <MudGrid Class="mb-3" Spacing="2">
            <MudItem xs="3">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="background:#e3f2fd;text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Info" Style="font-size:10px;">Pending</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Info">@_queueStats.TotalPending</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="3">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="background:#fff3e0;text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">Working</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Warning">@_queueStats.TotalProcessing</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="3">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Done</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Success">@_queueStats.TotalCompleted</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="3">
                <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                    <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">Failed</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Error">@_queueStats.TotalFailed</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <!-- Filters -->
    <MudPaper Elevation="1" Class="pa-3 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudStack Row="true" Spacing="2">
                <MudSelect T="string" Label="Scanner" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                           Value="_filterScannerType"
                           ValueChanged="@((string val) => { _filterScannerType = val; _ = LoadQueueItems(); })">
                    <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("FS6000")">FS6000</MudSelectItem>
                    <MudSelectItem T="string" Value="@("ASE")">ASE</MudSelectItem>
                    <MudSelectItem T="string" Value="@("HeimannSmith")">Heimann</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" Label="Status" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                           Value="_filterStatus"
                           ValueChanged="@((string val) => { _filterStatus = val; _ = LoadQueueItems(); })">
                    <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Pending")">Pending</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Processing")">Processing</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Failed")">Failed</MudSelectItem>
                </MudSelect>
            </MudStack>
            <MudTextField T="string" Label="Search" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                          @bind-Value="_searchText" Placeholder="Container number..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    <!-- Queue items as cards -->
    @if (_queueItems.Any())
    {
        @foreach (var item in _queueItems)
        {
            <MudPaper Elevation="1" Class="pa-3 mb-2 rounded-lg" Style="@($"border-left: 3px solid {GetStatusBorderColor(item.Status)};")">
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Style="font-family:monospace;font-weight:600;">@item.ContainerNumber</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(item.Status)" Variant="Variant.Filled">@item.Status</MudChip>
                    </MudStack>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="@GetScannerColor(item.ScannerType)">@item.ScannerType</MudChip>
                        <MudText Typo="Typo.caption">Queued: @item.QueuedAt.ToString("MMM dd HH:mm")</MudText>
                        <MudText Typo="Typo.caption">Retries: @item.RetryCount/@item.MaxRetries</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @if (_pagedResponse != null && _pagedResponse.TotalPages > 1)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-2">
                <MudText Typo="Typo.caption">@_pagedResponse.TotalCount items</MudText>
                <MudPagination Count="@_pagedResponse.TotalPages"
                               Selected="@_currentPage"
                               SelectedChanged="@OnPageChanged"
                               ShowFirstButton="true" ShowLastButton="true" />
            </MudStack>
        }
    }
    else if (!_isLoading)
    {
        <MudAlert Severity="Severity.Info">No queue items found</MudAlert>
    }
</MudContainer>

@code {
    private bool _isLoading = false;
    private List<QueueItemDto> _queueItems = new();
    private QueueStatistics? _queueStats;
    private PagedQueueResponse? _pagedResponse;
    private string _filterScannerType = "All";
    private string _filterStatus = "All";
    private string _searchText = "";
    private int _currentPage = 1;
    private int _pageSize = 30;
    private string _sortBy = "QueuedAt";
    private bool _sortDescending = true;
    private System.Threading.Timer? _refreshTimer;
    private bool _autoRefreshEnabled = true;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadQueueStatistics();
        await LoadQueueItems();
        await InitializeSignalR();
        StartAutoRefresh();
    }

    private void StartAutoRefresh()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (!_autoRefreshEnabled) return;
            await InvokeAsync(async () => { await LoadQueueStatistics(); await LoadQueueItems(); StateHasChanged(); });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private void ToggleAutoRefresh() { _autoRefreshEnabled = !_autoRefreshEnabled; StateHasChanged(); }

    private async Task InitializeSignalR()
    {
        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5205";
            var hubUrl = $"{apiBaseUrl}/hubs/containerScanQueue";
            string? token = null;
            try
            {
                if (AuthStateProvider is SimpleAuthStateProvider simpleAuth)
                    token = await simpleAuth.GetTokenAsync();
            }
            catch { }

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    if (!string.IsNullOrEmpty(token))
                        options.AccessTokenProvider = () => Task.FromResult<string?>(token);
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<object>("QueueItemAdded", _ => InvokeAsync(async () => { await LoadQueueItems(); await LoadQueueStatistics(); StateHasChanged(); }));
            _hubConnection.On<object>("QueueItemUpdated", _ => InvokeAsync(async () => { await LoadQueueItems(); await LoadQueueStatistics(); StateHasChanged(); }));
            _hubConnection.On<object>("QueueStatisticsUpdated", _ => InvokeAsync(async () => { await LoadQueueStatistics(); StateHasChanged(); }));

            await _hubConnection.StartAsync();
            Logger.LogInformation("SignalR connected to ContainerScanQueueHub");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing SignalR");
            Snackbar.Add("Could not connect to real-time updates", Severity.Warning);
        }
    }

    private async Task LoadQueueItems()
    {
        _isLoading = true;
        try
        {
            var q = $"page={_currentPage}&pageSize={_pageSize}&sortBy={_sortBy}&sortDescending={_sortDescending}";
            if (_filterScannerType != "All") q += $"&scannerType={Uri.EscapeDataString(_filterScannerType)}";
            if (_filterStatus != "All") q += $"&status={Uri.EscapeDataString(_filterStatus)}";
            if (!string.IsNullOrEmpty(_searchText)) q += $"&search={Uri.EscapeDataString(_searchText)}";

            _pagedResponse = await ApiService.GetAsync<PagedQueueResponse>($"/api/QueueHealth/items?{q}");
            _queueItems = _pagedResponse?.Items ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading queue items");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _isLoading = false; StateHasChanged(); }
    }

    private async Task LoadQueueStatistics()
    {
        try
        {
            var response = await ApiService.GetAsync<QueueStatsResponse>("/api/QueueHealth/statistics");
            _queueStats = response?.Statistics;
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading queue statistics"); }
    }

    private async Task OnPageChanged(int page) { _currentPage = page; await LoadQueueItems(); }

    private string GetStatusBorderColor(string status) => status switch
    {
        "Pending" => "var(--mud-palette-info)", "Processing" => "var(--mud-palette-warning)",
        "Completed" => "var(--mud-palette-success)", "Failed" => "var(--mud-palette-error)", _ => "var(--mud-palette-lines-default)"
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Info, "Processing" => Color.Warning, "Completed" => Color.Success, "Failed" => Color.Error, _ => Color.Default
    };

    private Color GetScannerColor(string scanner) => scanner switch
    {
        "FS6000" => Color.Primary, "ASE" => Color.Secondary, "HeimannSmith" => Color.Tertiary, _ => Color.Default
    };

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _hubConnection?.DisposeAsync().AsTask().Wait(1000);
    }

    private class QueueItemDto
    {
        public string ContainerNumber { get; set; } = "";
        public string ScannerType { get; set; } = "";
        public string Status { get; set; } = "";
        public string? InspectionId { get; set; }
        public DateTime QueuedAt { get; set; }
        public DateTime ScanDate { get; set; }
        public int RetryCount { get; set; }
        public int MaxRetries { get; set; }
        public DateTime? ProcessedAt { get; set; }
    }

    private class PagedQueueResponse
    {
        public List<QueueItemDto> Items { get; set; } = new();
        public int TotalCount { get; set; }
        public int TotalPages { get; set; }
    }

    private class QueueStatsResponse { public QueueStatistics? Statistics { get; set; } }

    private class QueueStatistics
    {
        public int TotalPending { get; set; }
        public int TotalProcessing { get; set; }
        public int TotalCompleted { get; set; }
        public int TotalFailed { get; set; }
    }
}
