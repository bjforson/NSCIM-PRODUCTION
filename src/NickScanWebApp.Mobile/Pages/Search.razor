@page "/search"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesSearch)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService
@inject NavigationManager NavigationManager

<PageTitle>Search - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                Search
            </MudText>
            <MudTextField @bind-Value="_searchQuery"
                         Placeholder="Search containers, BOE, VIN..."
                         Adornment="Adornment.End"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         OnAdornmentClick="PerformSearch"
                         Variant="Variant.Outlined"
                         FullWidth="true" />
        </MudStack>
    </MudPaper>
    
    @if (_isSearching)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_searchResults.Any())
    {
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Found @_searchResults.Count result(s) for "@_searchQuery"
            </MudText>
            @foreach (var result in _searchResults)
            {
                <MudCard Elevation="1" Class="pa-3" OnClick="@(() => NavigateToResult(result))">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1"><strong>@result.Title</strong></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@result.Description</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@result.Type</MudChip>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(_searchQuery) && !_isSearching)
    {
        <MudAlert Severity="Severity.Info">No results found</MudAlert>
    }
</MudContainer>

@code {
    private bool _isSearching = false;
    private string _searchQuery = "";
    private List<SearchResultDto> _searchResults = new();
    
    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return;
            
        _isSearching = true;
        try
        {
            // TODO: Replace with actual API call
            // var response = await ApiService.GetAsync<SearchResponseDto>($"/api/search?q={Uri.EscapeDataString(_searchQuery)}");
            // _searchResults = response?.Results ?? new();
            
            _searchResults = new List<SearchResultDto>
            {
                new() { Type = "Container", Title = "MSDU1234567", Description = "Container record", Url = "/containers/MSDU1234567" },
                new() { Type = "BOE", Title = "BOE123456", Description = "Bill of Entry record", Url = "/icums/boe-request" }
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error searching: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSearching = false;
        }
    }
    
    private void NavigateToResult(SearchResultDto result)
    {
        NavigationManager.NavigateTo(result.Url);
    }
    
    public class SearchResultDto
    {
        public string Type { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Url { get; set; } = "";
    }
}

