@page "/icums/boe-request"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesIcumsBoeRequest)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService
@inject NavigationManager NavigationManager

<PageTitle>BOE Manual Request - ICUMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                Manual BOE Request
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manually request Bill of Entry data from ICUMS
            </MudText>
        </MudStack>
    </MudPaper>
    
    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_containerNumber"
                         Label="Container Number"
                         Variant="Variant.Outlined"
                         Placeholder="MSDU1234567"
                         FullWidth="true" />
            <MudSelect T="int" @bind-Value="_priority" Label="Priority" Variant="Variant.Outlined">
                <MudSelectItem Value="1">Low</MudSelectItem>
                <MudSelectItem Value="2">Normal</MudSelectItem>
                <MudSelectItem Value="3">High</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary"
                      StartIcon="@Icons.Material.Filled.CloudDownload"
                      OnClick="@RequestBOE"
                      Disabled="@_isRequesting"
                      FullWidth="true">
                @if (_isRequesting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Requesting...</span>
                }
                else
                {
                    <span>Request BOE</span>
                }
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private bool _isRequesting = false;
    private string _containerNumber = "";
    private int _priority = 2;
    
    private async Task RequestBOE()
    {
        if (string.IsNullOrWhiteSpace(_containerNumber))
        {
            Snackbar.Add("Please enter a container number", Severity.Warning);
            return;
        }
        
        _isRequesting = true;
        try
        {
            await ApiService.PostAsync<object, object>("/api/ICUMSDownloadQueue/request", new 
            { 
                ContainerNumber = _containerNumber,
                Priority = _priority
            });
            Snackbar.Add($"BOE request queued for {_containerNumber}", Severity.Success);
            NavigationManager.NavigateTo("/icums/download-queue");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error requesting BOE: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRequesting = false;
        }
    }
}

