@page "/icums/analytics"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesIcumsAnalytics)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService

<PageTitle>ICUMS Analytics</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
            ICUMS Analytics
        </MudText>
    </MudPaper>
    
    <MudAlert Severity="Severity.Info">
        ICUMS analytics and reporting. Use desktop version for detailed charts and analysis.
    </MudAlert>
</MudContainer>

