@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using NickScanWebApp.Mobile.Services
@attribute [Authorize(Policy = Permissions.PagesDashboardView)]
@inject ILogger<Dashboard> Logger
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ApiService ApiService
@implements IDisposable

<PageTitle>NickScan Mobile - Dashboard</PageTitle>

@if (!_authenticated)
{
    <MudContainer Class="d-flex flex-column align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
        <MudText Typo="Typo.h6" Align="Align.Center">Checking your session&hellip;</MudText>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pt-3 pb-8 px-2">
        <MudStack Spacing="2">
            <!-- Header -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Welcome back</MudText>
                    <MudText Typo="Typo.h6">@_username</MudText>
                </MudStack>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_apiConnected ? Color.Success : Color.Error)"
                             Icon="@(_apiConnected ? Icons.Material.Filled.Cloud : Icons.Material.Filled.CloudOff)">
                        @(_apiConnected ? "Online" : "Offline")
                    </MudChip>
                    <MudIconButton Icon="@(_autoRefreshEnabled ? Icons.Material.Filled.Autorenew : Icons.Material.Filled.PauseCircle)"
                                   Color="@(_autoRefreshEnabled ? Color.Success : Color.Default)"
                                   Size="Size.Small" OnClick="ToggleAutoRefresh" />
                </MudStack>
            </MudStack>

            <!-- System Health -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Size="Size.Small" Class="mr-1" />
                    System Health
                </MudText>
                @if (_healthData != null)
                {
                    <MudGrid Spacing="1">
                        <MudItem xs="3">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="@($"{HealthCardStyle(_healthData.SystemHealth?.OverallStatus)}; text-align:center;")">
                                <MudText Typo="Typo.caption" Style="color:inherit;opacity:0.8;font-size:10px;">Overall</MudText>
                                <MudText Typo="Typo.body1" Style="color:inherit;font-weight:600;">@HealthLabel(_healthData.SystemHealth?.OverallStatus)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="3">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Healthy</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Success"><b>@(_healthData.SystemHealth?.HealthyServices ?? 0)</b></MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="3">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#fff3e0;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">Degraded</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Warning"><b>@(_healthData.SystemHealth?.DegradedServices ?? 0)</b></MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="3">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">Unhealthy</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Error"><b>@(_healthData.SystemHealth?.UnhealthyServices ?? 0)</b></MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                    @if (!string.IsNullOrEmpty(_healthData.Uptime))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Uptime: @_healthData.Uptime</MudText>
                    }
                }
                else
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
            </MudPaper>

            <!-- Operational KPIs -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Size="Size.Small" Class="mr-1" />
                    Operational KPIs
                </MudText>
                <MudGrid Spacing="1">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e3f2fd;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-size:10px;">Total Containers</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary">@_totalContainers</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Today's Scans</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@_todayScans</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#f3e5f5;text-align:center;">
                            <MudText Typo="Typo.caption" Style="color:#7b1fa2;font-size:10px;">Completeness</MudText>
                            <MudText Typo="Typo.h6" Style="color:#7b1fa2">@_completenessRate</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#fce4ec;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">API Error Rate</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Error">@_apiErrorRate</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Processing Pipeline -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mr-1" />
                    Processing Pipeline
                </MudText>
                @if (_queueStats != null)
                {
                    <MudGrid Spacing="1">
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e3f2fd;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Info" Style="font-size:10px;">Pending</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Info">@_queueStats.TotalPending</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#fff3e0;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">Processing</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Warning">@_queueStats.TotalProcessing</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Completed</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">@_queueStats.TotalCompleted</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">Failed</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Error">@_queueStats.TotalFailed</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#f3e5f5;text-align:center;">
                                <MudText Typo="Typo.caption" Style="color:#7b1fa2;font-size:10px;">Per Hour</MudText>
                                <MudText Typo="Typo.h6" Style="color:#7b1fa2">@_queueStats.ItemsProcessedLastHour</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e0f2f1;text-align:center;">
                                <MudText Typo="Typo.caption" Style="color:#00695c;font-size:10px;">Success</MudText>
                                <MudText Typo="Typo.h6" Style="color:#00695c">@($"{_queueStats.SuccessRate:F0}%")</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
            </MudPaper>

            <!-- Container Completeness -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">
                        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" Class="mr-1" />
                        Completeness
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Href="/validation"
                               EndIcon="@Icons.Material.Filled.ArrowForward">Details</MudButton>
                </MudStack>
                @if (_completenessStats != null)
                {
                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="4">
                            <div style="text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Success">Complete</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">@_completenessStats.CompleteContainers.ToString("N0")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="4">
                            <div style="text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Warning">Missing</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Warning">@_completenessStats.MissingContainers.ToString("N0")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="4">
                            <div style="text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Error">Failed</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Error">@_completenessStats.FailedRequests.ToString("N0")</MudText>
                            </div>
                        </MudItem>
                    </MudGrid>
                    <MudProgressLinear Value="@_completenessStats.CompletenessRate"
                                       Color="@(_completenessStats.CompletenessRate >= 80 ? Color.Success : _completenessStats.CompletenessRate >= 50 ? Color.Warning : Color.Error)"
                                       Rounded="true" Size="Size.Large">
                        <MudText Typo="Typo.caption"><b>@($"{_completenessStats.CompletenessRate:F1}%")</b></MudText>
                    </MudProgressLinear>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">FS6000: @_completenessStats.FS6000Complete/@_completenessStats.FS6000Total</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ASE: @_completenessStats.ASEComplete/@_completenessStats.ASETotal</MudText>
                    </MudStack>
                }
                else
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
            </MudPaper>

            <!-- Safeguard Summary -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">
                        <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Class="mr-1" />
                        Safeguard
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Href="/operations/image-analysis"
                               EndIcon="@Icons.Material.Filled.ArrowForward">Details</MudButton>
                </MudStack>
                @if (_safeguardData != null)
                {
                    <MudGrid Spacing="1">
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#fff3e0;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">Export Pending</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Warning"><b>@_safeguardData.ExportPendingCount</b></MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">Mismatch</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Error"><b>@_safeguardData.LocationMismatchCount</b></MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Complete</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Success"><b>@_safeguardData.CompleteCount</b></MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
            </MudPaper>

            <!-- Quick Actions -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Quick Actions</MudText>
                <MudStack Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search" Href="/containers">
                        Search Containers
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.PlaylistAddCheck" Href="/validation">
                        Check Completeness
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Analytics" Href="/operations/image-analysis">
                        Image Analysis
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Assessment" Href="/reports">
                        Reports
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    </MudContainer>
}

@code {
    private string _username = "";
    private bool _authenticated = false;
    private bool _apiConnected = false;
    private bool _autoRefreshEnabled = true;
    private System.Threading.Timer? _refreshTimer;

    private string _totalContainers = "...";
    private string _todayScans = "...";
    private string _completenessRate = "...";
    private string _apiErrorRate = "...";

    private HealthOverviewResponse? _healthData;
    private QueueStatsInner? _queueStats;
    private CompletenessStatsResponse? _completenessStats;
    private SafeguardSummaryResponse? _safeguardData;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        _authenticated = true;
        _username = authState.User.Identity?.Name ?? "User";
        Logger.LogInformation("Dashboard loaded for user: {User}", _username);

        await LoadAllSections();
        StartAutoRefresh();
    }

    private async Task LoadAllSections()
    {
        var tasks = new List<Task>
        {
            LoadHealthOverview(),
            LoadKPIs(),
            LoadQueueStats(),
            LoadCompletenessStats(),
            LoadSafeguardSummary()
        };
        await Task.WhenAll(tasks);
        StateHasChanged();
    }

    private async Task LoadHealthOverview()
    {
        try
        {
            _healthData = await ApiService.GetAsync<HealthOverviewResponse>("/api/Monitoring/health/overview");
            _apiConnected = _healthData != null;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load health overview");
            _apiConnected = false;
        }
    }

    private async Task LoadKPIs()
    {
        try
        {
            var stats = await ApiService.GetAsync<CompletenessStatsResponse>("/api/containercompleteness/stats");
            if (stats != null)
            {
                _totalContainers = stats.TotalContainers.ToString("N0");
                _completenessRate = $"{stats.CompletenessRate:F1}%";
                _apiConnected = true;
            }
        }
        catch { _totalContainers = "N/A"; _completenessRate = "N/A"; }

        try
        {
            var dbStats = await ApiService.GetAsync<DbStatsResponse>("/api/Monitoring/database/statistics");
            _todayScans = dbStats?.TodayActivity?.TotalScans.ToString("N0") ?? "N/A";
        }
        catch { _todayScans = "N/A"; }

        try
        {
            var apiMetrics = await ApiService.GetAsync<ApiMetricsResponse>("/api/Monitoring/api-metrics");
            _apiErrorRate = apiMetrics != null ? $"{apiMetrics.ErrorRate:F1}%" : "N/A";
        }
        catch { _apiErrorRate = "N/A"; }
    }

    private async Task LoadQueueStats()
    {
        try
        {
            var resp = await ApiService.GetAsync<QueueStatsResponse>("/api/QueueHealth/statistics");
            _queueStats = resp?.Statistics;
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to load queue stats"); }
    }

    private async Task LoadCompletenessStats()
    {
        try
        {
            _completenessStats = await ApiService.GetAsync<CompletenessStatsResponse>("/api/containercompleteness/stats");
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to load completeness stats"); }
    }

    private async Task LoadSafeguardSummary()
    {
        try
        {
            _safeguardData = await ApiService.GetAsync<SafeguardSummaryResponse>("/api/image-analysis/dashboard/safeguard-summary");
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to load safeguard summary"); }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (!_autoRefreshEnabled) return;
            await InvokeAsync(async () => { await LoadAllSections(); });
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private void ToggleAutoRefresh()
    {
        _autoRefreshEnabled = !_autoRefreshEnabled;
        StateHasChanged();
    }

    private string HealthLabel(string? status) => (status ?? "").ToLower() switch
    {
        "healthy" => "OK",
        "degraded" => "Warn",
        "unhealthy" => "Down",
        _ => status ?? "?"
    };

    private string HealthCardStyle(string? status) => (status ?? "").ToLower() switch
    {
        "healthy" => "background:#e8f5e9",
        "degraded" => "background:#fff3e0",
        "unhealthy" => "background:#ffebee",
        _ => "background:#f5f5f5"
    };

    public void Dispose() => _refreshTimer?.Dispose();

    // DTOs
    private class HealthOverviewResponse
    {
        public SystemHealthSummary? SystemHealth { get; set; }
        public string Uptime { get; set; } = "";
    }

    private class SystemHealthSummary
    {
        public string OverallStatus { get; set; } = "Unknown";
        public int TotalServices { get; set; }
        public int HealthyServices { get; set; }
        public int DegradedServices { get; set; }
        public int UnhealthyServices { get; set; }
    }

    private class DbStatsResponse
    {
        public TodayActivityDto? TodayActivity { get; set; }
    }

    private class TodayActivityDto
    {
        public int TotalScans { get; set; }
    }

    private class ApiMetricsResponse
    {
        public double ErrorRate { get; set; }
    }

    private class QueueStatsResponse
    {
        public QueueStatsInner? Statistics { get; set; }
    }

    private class QueueStatsInner
    {
        public int TotalPending { get; set; }
        public int TotalProcessing { get; set; }
        public int TotalCompleted { get; set; }
        public int TotalFailed { get; set; }
        public int ItemsProcessedLastHour { get; set; }
        public double SuccessRate { get; set; }
    }

    private class CompletenessStatsResponse
    {
        public int TotalContainers { get; set; }
        public int CompleteContainers { get; set; }
        public int MissingContainers { get; set; }
        public int FailedRequests { get; set; }
        public double CompletenessRate { get; set; }
        public int FS6000Total { get; set; }
        public int FS6000Complete { get; set; }
        public int ASETotal { get; set; }
        public int ASEComplete { get; set; }
    }

    private class SafeguardSummaryResponse
    {
        public int ExportPendingCount { get; set; }
        public int LocationMismatchCount { get; set; }
        public int CompleteCount { get; set; }
    }
}
