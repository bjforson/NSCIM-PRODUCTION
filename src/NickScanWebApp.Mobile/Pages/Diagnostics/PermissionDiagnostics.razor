@page "/diagnostics/permissions"
@using Microsoft.AspNetCore.Components.Authorization
@using NickScanWebApp.Mobile.Services
@using NickScanWebApp.Mobile.Services.Permissions
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionGuard PermissionGuard
@inject ILogger<PermissionDiagnostics> Logger

<PageTitle>Permission Diagnostics - Mobile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pt-2 pb-8 px-2">
    <MudStack Spacing="2" Class="mb-3">
        <MudText Typo="Typo.h6">🔍 Permission Diagnostics</MudText>
    </MudStack>
    
    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudText Typo="Typo.h6" Class="mb-2">Authentication Status</MudText>
        <MudStack Spacing="2">
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2">Authenticated:</MudText>
                <MudChip T="string" Color="@(_isAuthenticated ? Color.Success : Color.Error)" Size="Size.Small">
                    @(_isAuthenticated ? "Yes" : "No")
                </MudChip>
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2">Username:</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(_username ?? "N/A")</MudText>
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2">Role:</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(_role ?? "N/A")</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudText Typo="Typo.h6" Class="mb-2">Permission Claims</MudText>
        @if (_permissionClaims.Any())
        {
            <MudChipSet T="string">
                @foreach (var claim in _permissionClaims)
                {
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@claim</MudChip>
                }
            </MudChipSet>
            <MudText Typo="Typo.caption" Class="mt-2">Total: <strong>@_permissionClaims.Count</strong> permission claims</MudText>
        }
        else
        {
            <MudAlert Severity="Severity.Warning">No permission claims found</MudAlert>
        }
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudText Typo="Typo.h6" Class="mb-2">Permission Test</MudText>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="_testPermission" 
                          Label="Test Permission" 
                          Variant="Variant.Outlined"
                          FullWidth="true" />
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary" 
                      OnClick="TestPermission"
                      FullWidth="true">
                Test Permission
            </MudButton>
            @if (!string.IsNullOrEmpty(_testResult))
            {
                <MudChip T="string" 
                        Color="@(_testResult == "Granted" ? Color.Success : Color.Error)" 
                        Size="Size.Medium"
                        FullWidth="true">
                    @_testResult
                </MudChip>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.h6">Common Permissions</MudText>
            <MudButton Size="Size.Small" 
                      Variant="Variant.Outlined" 
                      Color="Color.Primary" 
                      OnClick="TestAllPermissions">
                Test All
            </MudButton>
        </MudStack>
        <MudSimpleTable Dense="true">
            <thead>
                <tr>
                    <th>Permission</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var perm in _commonPermissions)
                {
                    <tr>
                        <td>@perm</td>
                        <td>
                            @if (_permissionStatus.ContainsKey(perm))
                            {
                                <MudChip T="string" 
                                        Color="@(_permissionStatus[perm] ? Color.Success : Color.Error)" 
                                        Size="Size.Small">
                                    @(_permissionStatus[perm] ? "Granted" : "Denied")
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Not Tested</MudChip>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-3 mb-3">
        <MudText Typo="Typo.h6" Class="mb-2">Actions</MudText>
        <MudStack Spacing="2">
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary" 
                      OnClick="RefreshDiagnostics"
                      FullWidth="true">
                🔄 Refresh Diagnostics
            </MudButton>
            <MudButton Variant="Variant.Outlined" 
                      Color="Color.Info" 
                      OnClick="ExportDiagnostics"
                      FullWidth="true">
                📋 Export Diagnostics
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrEmpty(_diagnosticsJson))
    {
        <MudPaper Elevation="1" Class="pa-3">
            <MudText Typo="Typo.h6" Class="mb-2">Diagnostics JSON</MudText>
            <MudTextField Value="@_diagnosticsJson" 
                         Variant="Variant.Outlined" 
                         ReadOnly="true" 
                         Lines="10"
                         FullWidth="true" />
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isAuthenticated;
    private string? _username;
    private string? _role;
    private List<string> _permissionClaims = new();
    private string _testPermission = "";
    private string _testResult = "";
    private Dictionary<string, bool> _permissionStatus = new();
    private string _diagnosticsJson = "";

    private readonly List<string> _commonPermissions = new()
    {
        "pages.dashboard",
        "pages.admin",
        "pages.admin.logs",
        "pages.admin.audit",
        "pages.operations",
        "pages.operations.containercompleteness",
        "pages.images",
        "pages.images.analysis",
        "pages.images.edit",
        "pages.images.annotate"
    };

    protected override async Task OnInitializedAsync()
    {
        await RefreshDiagnostics();
    }

    private async Task RefreshDiagnostics()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
            _username = user.Identity?.Name;
            _role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

            _permissionClaims = user.Claims
                .Where(c => c.Type == "Permission")
                .Select(c => c.Value)
                .OrderBy(p => p)
                .ToList();

            Logger.LogInformation("Permission Diagnostics: User={User}, Authenticated={Auth}, PermissionCount={Count}",
                _username, _isAuthenticated, _permissionClaims.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing permission diagnostics");
        }
    }

    private void TestPermission()
    {
        if (string.IsNullOrWhiteSpace(_testPermission))
        {
            _testResult = "Please enter a permission";
            return;
        }

        try
        {
            var hasPermission = PermissionGuard.Can(PermissionId.From(_testPermission), "Diagnostics");
            _testResult = hasPermission ? "Granted" : "Denied";
            
            Logger.LogInformation("Permission test: {Permission} = {Result}", _testPermission, _testResult);
        }
        catch (Exception ex)
        {
            _testResult = $"Error: {ex.Message}";
            Logger.LogError(ex, "Error testing permission: {Permission}", _testPermission);
        }
    }

    private void TestAllPermissions()
    {
        _permissionStatus.Clear();
        
        foreach (var perm in _commonPermissions)
        {
            try
            {
                var hasPermission = PermissionGuard.Can(PermissionId.From(perm), "Diagnostics");
                _permissionStatus[perm] = hasPermission;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error testing permission: {Permission}", perm);
                _permissionStatus[perm] = false;
            }
        }
        
        Logger.LogInformation("Tested {Count} permissions", _permissionStatus.Count);
    }

    private void ExportDiagnostics()
    {
        var diagnostics = new
        {
            timestamp = DateTime.UtcNow,
            user = new
            {
                username = _username,
                role = _role,
                isAuthenticated = _isAuthenticated
            },
            permissions = new
            {
                claimCount = _permissionClaims.Count,
                claims = _permissionClaims,
                testResults = _permissionStatus
            }
        };

        _diagnosticsJson = System.Text.Json.JsonSerializer.Serialize(diagnostics, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true
        });
    }
}
