@page "/icums"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using NickScanWebApp.Mobile.Services
@attribute [Authorize(Policy = Permissions.PagesIcumsView)]
@inject ApiService ApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>ICUMS - NickScan Mobile</PageTitle>

@if (!_initialized)
{
    <MudContainer Class="d-flex flex-column align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
        <MudText Typo="Typo.h6" Align="Align.Center">Loading ICUMS dashboard&hellip;</MudText>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pt-2 pb-8 px-2">
        <MudStack Spacing="2">
            <!-- Header with connection status -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">ICUMS Dashboard</MudText>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="@_connectionColor" Icon="@_connectionIcon">
                        @_connectionStatus
                    </MudChip>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" OnClick="RefreshData" />
                </MudStack>
            </MudStack>

            <!-- Connection Stats -->
            <MudGrid Spacing="1">
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                        <MudIcon Icon="@Icons.Material.Filled.Link" Color="@(_connectionUptimeDisplay == "Online" ? Color.Success : Color.Error)" Size="Size.Small" />
                        <MudText Typo="Typo.h6" Color="@(_connectionUptimeDisplay == "Online" ? Color.Success : Color.Error)">@_connectionUptimeDisplay</MudText>
                        <MudText Typo="Typo.caption">@(_apiResponseTime)ms response</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.h6" Color="Color.Success">@(_queueHealth)%</MudText>
                        <MudText Typo="Typo.caption">Queue Health</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Today's Stats -->
            <MudGrid Spacing="1">
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Color="Color.Info" Size="Size.Small" />
                        <MudText Typo="Typo.h6">@_downloadsToday</MudText>
                        <MudText Typo="Typo.caption">Downloads Today</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2 rounded-lg" Style="text-align:center;">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.h6">@_submissionsToday</MudText>
                        <MudText Typo="Typo.caption">Submissions Today</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Download Queue Priority Breakdown -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small" Class="mr-1" />
                        Download Queue
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="/icums/download-queue">View All</MudButton>
                </MudStack>
                <MudGrid Spacing="1" Class="mb-2">
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">High</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Error">@_highPriorityDownloads</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#fff3e0;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">Normal</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Warning">@_normalPriorityDownloads</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Low</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@_lowPriorityDownloads</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                @foreach (var d in _recentDownloads.Take(3))
                {
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="py-1">
                        <MudText Typo="Typo.body2">@d.ContainerNumber</MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Color="@GetDownloadStatusColor(d.Status)">@d.Status</MudChip>
                            <MudText Typo="Typo.caption">@d.Time.ToString("HH:mm")</MudText>
                        </MudStack>
                    </MudStack>
                }
            </MudPaper>

            <!-- Submission Queue -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Class="mr-1" />
                        Submission Queue
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="/icums/submission-queue">View All</MudButton>
                </MudStack>
                <MudGrid Spacing="1" Class="mb-2">
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e3f2fd;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Info" Style="font-size:10px;">Pending</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Info">@_pendingSubmissions</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#e8f5e9;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Success" Style="font-size:10px;">Success</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@_successfulSubmissions</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="background:#ffebee;text-align:center;">
                            <MudText Typo="Typo.caption" Color="Color.Error" Style="font-size:10px;">Failed</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Error">@_failedSubmissions</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                @foreach (var s in _recentSubmissions.Take(3))
                {
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="py-1">
                        <MudText Typo="Typo.body2">@s.ContainerNumber</MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Color="@GetSubmissionStatusColor(s.Status)">@s.Status</MudChip>
                            <MudText Typo="Typo.caption">@s.Time.ToString("HH:mm")</MudText>
                        </MudStack>
                    </MudStack>
                }
            </MudPaper>

            <!-- Quick Actions -->
            <MudPaper Elevation="2" Class="pa-3 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Quick Actions</MudText>
                <MudStack Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search" Href="/icums/boe-request">
                        BOE Request
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.CloudDownload" Href="/icums/download-queue">
                        Download Queue
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.CloudUpload" Href="/icums/submission-queue">
                        Submission Queue
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    </MudContainer>
}

@code {
    private bool _initialized;
    private int _downloadsToday;
    private int _submissionsToday;
    private int _pendingDownloads;
    private int _pendingSubmissions;
    private int _highPriorityDownloads;
    private int _normalPriorityDownloads;
    private int _lowPriorityDownloads;
    private int _successfulSubmissions;
    private int _failedSubmissions;
    private int _queueHealth;
    private int _apiResponseTime;
    private string _connectionUptimeDisplay = "N/A";
    private Color _connectionColor = Color.Default;
    private string _connectionIcon = Icons.Material.Filled.CloudOff;
    private string _connectionStatus = "Checking...";
    private System.Threading.Timer? _refreshTimer;

    private readonly List<QueueItem> _recentDownloads = new();
    private readonly List<QueueItem> _recentSubmissions = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        await LoadData();
        _initialized = true;

        var refreshSeconds = Configuration.GetValue<int>("UI:AutoRefreshSeconds", 30);
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
        }, null, TimeSpan.FromSeconds(refreshSeconds), TimeSpan.FromSeconds(refreshSeconds));
    }

    private async Task LoadData()
    {
        _recentDownloads.Clear();
        _recentSubmissions.Clear();

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var downloadStats = await ApiService.GetAsync<DownloadQueueStats>("/api/ICUMSDownloadQueue/stats");
            sw.Stop();
            _apiResponseTime = (int)sw.ElapsedMilliseconds;

            if (downloadStats != null)
            {
                _downloadsToday = downloadStats.CompletedToday;
                _pendingDownloads = downloadStats.pending;
                _highPriorityDownloads = downloadStats.HighPriority;
                _normalPriorityDownloads = downloadStats.NormalPriority;
                _lowPriorityDownloads = downloadStats.LowPriority;
                _connectionUptimeDisplay = "Online";
            }
            else
            {
                _connectionUptimeDisplay = "Offline";
            }

            var downloads = await ApiService.GetAsync<List<DownloadQueueItemDto>>("/api/ICUMSDownloadQueue?limit=5&status=Completed");
            if (downloads != null)
            {
                _recentDownloads.AddRange(downloads.Select(d => new QueueItem
                {
                    ContainerNumber = d.ContainerNumber,
                    Time = d.CompletedAt ?? d.QueuedAt,
                    Status = d.Status
                }));
            }
        }
        catch { _connectionUptimeDisplay = "Offline"; _apiResponseTime = 0; }

        try
        {
            var submissionStats = await ApiService.GetAsync<SubmissionQueueStats>("/api/ICUMSSubmissionQueue/stats");
            if (submissionStats != null)
            {
                _submissionsToday = submissionStats.SuccessfulToday;
                _pendingSubmissions = submissionStats.Pending;
                _successfulSubmissions = submissionStats.SuccessfulToday;
                _failedSubmissions = submissionStats.FailedToday;
            }

            var submissions = await ApiService.GetAsync<List<SubmissionQueueItemDto>>("/api/ICUMSSubmissionQueue?limit=5");
            if (submissions != null)
            {
                _recentSubmissions.AddRange(submissions.Select(s => new QueueItem
                {
                    ContainerNumber = s.ContainerNumber,
                    Time = s.SubmittedAt ?? s.QueuedAt,
                    Status = s.Status
                }));
            }
        }
        catch { }

        _queueHealth = (_successfulSubmissions + _failedSubmissions) > 0
            ? (int)((double)_successfulSubmissions / (_successfulSubmissions + _failedSubmissions) * 100)
            : 100;

        UpdateConnectionStatus();
    }

    private async Task RefreshData()
    {
        await LoadData();
        Snackbar.Add("Dashboard refreshed", Severity.Success);
    }

    private void UpdateConnectionStatus()
    {
        if (_apiResponseTime > 0 && _apiResponseTime < 500)
        {
            _connectionStatus = "Connected"; _connectionColor = Color.Success; _connectionIcon = Icons.Material.Filled.CloudDone;
        }
        else if (_apiResponseTime >= 500 && _apiResponseTime < 2000)
        {
            _connectionStatus = "Degraded"; _connectionColor = Color.Warning; _connectionIcon = Icons.Material.Filled.CloudSync;
        }
        else
        {
            _connectionStatus = "Disconnected"; _connectionColor = Color.Error; _connectionIcon = Icons.Material.Filled.CloudOff;
        }
    }

    private Color GetDownloadStatusColor(string status) => status switch
    {
        "Completed" => Color.Success, "Processing" => Color.Info, "Failed" => Color.Error, _ => Color.Default
    };

    private Color GetSubmissionStatusColor(string status) => status switch
    {
        "Completed" => Color.Success, "Processing" => Color.Warning, "Failed" => Color.Error, _ => Color.Default
    };

    public void Dispose() => _refreshTimer?.Dispose();

    public class QueueItem { public string ContainerNumber { get; set; } = ""; public DateTime Time { get; set; } public string Status { get; set; } = ""; }

    public class DownloadQueueStats
    {
        public int pending { get; set; } public int completed { get; set; } public int failed { get; set; }
        public int highPriority { get; set; } public int normalPriority { get; set; } public int lowPriority { get; set; }
        public double successRate { get; set; }
        [System.Text.Json.Serialization.JsonIgnore] public int CompletedToday => completed;
        [System.Text.Json.Serialization.JsonIgnore] public int HighPriority => highPriority;
        [System.Text.Json.Serialization.JsonIgnore] public int NormalPriority => normalPriority;
        [System.Text.Json.Serialization.JsonIgnore] public int LowPriority => lowPriority;
    }

    public class DownloadQueueItemDto { public string ContainerNumber { get; set; } = ""; public string Status { get; set; } = ""; public DateTime QueuedAt { get; set; } public DateTime? CompletedAt { get; set; } }

    public class SubmissionQueueStats
    {
        public int pending { get; set; } public int successful { get; set; } public int failed { get; set; }
        public int successfulToday { get; set; } public int failedToday { get; set; }
        [System.Text.Json.Serialization.JsonIgnore] public int Pending => pending;
        [System.Text.Json.Serialization.JsonIgnore] public int SuccessfulToday => successfulToday;
        [System.Text.Json.Serialization.JsonIgnore] public int FailedToday => failedToday;
    }

    public class SubmissionQueueItemDto { public string ContainerNumber { get; set; } = ""; public string Status { get; set; } = ""; public DateTime QueuedAt { get; set; } public DateTime? SubmittedAt { get; set; } }
}
