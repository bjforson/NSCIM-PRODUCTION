@page "/notifications"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Permissions.PagesNotifications)]
@using NickScanWebApp.Mobile.Services
@inject ISnackbar Snackbar
@inject ApiService ApiService

<PageTitle>Notifications - NickScan Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    <MudPaper Elevation="2" Class="pa-4 mb-3 rounded-lg">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="mr-2" />
                Notifications
            </MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          Size="Size.Small"
                          StartIcon="@Icons.Material.Filled.DoneAll"
                          OnClick="@MarkAllAsRead">
                    Mark All Read
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          Size="Size.Small"
                          StartIcon="@Icons.Material.Filled.Refresh"
                          OnClick="@LoadNotifications">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
    
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_notifications.Any())
    {
        <MudStack Spacing="2">
            @foreach (var notification in _notifications.Take(50))
            {
                <MudCard Elevation="1" Class="pa-3" Style="@(!notification.IsRead ? "border-left: 4px solid #1976d2;" : "")">
                    <MudStack Spacing="1">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                            <MudText Typo="Typo.body1"><strong>@notification.Title</strong></MudText>
                            @if (!notification.IsRead)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary">New</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2">@notification.Message</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @notification.CreatedAt.ToString("dd MMM yyyy HH:mm")
                        </MudText>
                    </MudStack>
                </MudCard>
            }
        </MudStack>
    }
    else
    {
        <MudAlert Severity="Severity.Info">No notifications</MudAlert>
    }
</MudContainer>

@code {
    private bool _isLoading = false;
    private List<NotificationDto> _notifications = new();
    
    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }
    
    private async Task LoadNotifications()
    {
        _isLoading = true;
        try
        {
            // TODO: Replace with actual API call
            // var response = await ApiService.GetAsync<List<NotificationDto>>("/api/notifications");
            // _notifications = response ?? new();
            
            _notifications = new List<NotificationDto>
            {
                new() { Title = "System Alert", Message = "New container scanned", IsRead = false, CreatedAt = DateTime.Now.AddMinutes(-10) },
                new() { Title = "Validation Complete", Message = "Container MSDU1234567 validated", IsRead = true, CreatedAt = DateTime.Now.AddHours(-1) }
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading notifications: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task MarkAllAsRead()
    {
        try
        {
            // TODO: Replace with actual API call
            // await ApiService.PostAsync<object, object>("/api/notifications/mark-all-read", new { });
            foreach (var n in _notifications) n.IsRead = true;
            Snackbar.Add("All notifications marked as read", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error marking as read: {ex.Message}", Severity.Error);
        }
    }
    
    public class NotificationDto
    {
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}

