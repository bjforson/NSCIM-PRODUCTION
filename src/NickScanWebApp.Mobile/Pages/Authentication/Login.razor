@page "/login"
@page "/authentication/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authentication
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@using System.Net.Http.Headers
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject NickScanWebApp.Mobile.Services.SimpleAuthStateProvider AuthProvider
@inject NickScanWebApp.Mobile.Services.CustomAuthStateProvider CustomAuthProvider
@inject AuthBootstrapper AuthBootstrapper
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Login> Logger

<PageTitle>Login - NickScan Portal</PageTitle>

<div class="professional-login-container">
    <!-- Hero Background with Overlay -->
    <div class="hero-background">
        <div class="hero-overlay"></div>
        <div class="hero-pattern"></div>
    </div>

    <!-- Main Login Card -->
    <div class="login-card">
        <!-- Header Section -->
        <div class="login-header">
            <div class="logo-container">
                <div class="logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" />
                </div>
                <div class="security-badge">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                    <span>Secured</span>
                </div>
            </div>
            
            <div class="brand-section">
                <h1 class="brand-title">NickScan Portal</h1>
                <p class="brand-subtitle">Advanced Container Scanning & Customs Management</p>
                <div class="organization-info">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                    <span>Ghana Revenue Authority - Customs Division</span>
                </div>
            </div>
        </div>

        <!-- Login Form -->
        <div class="login-form-container">
            <EditForm Model="@loginModel" OnSubmit="HandleLogin">
                <div class="form-group">
                    <MudTextField @bind-Value="loginModel.Username"
                                  Label="User ID"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.None"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  AdornmentColor="Color.Primary"
                                  FullWidth="true"
                                  Disabled="@isLoading"
                                  Class="modern-input"
                                  Style="height: 56px;" />
                </div>

                <div class="form-group">
                    <MudTextField @bind-Value="loginModel.Password"
                                  Label="Password"
                                  InputType="@passwordInputType"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.None"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(passwordInputType == InputType.Password ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="TogglePasswordVisibility"
                                  AdornmentColor="Color.Primary"
                                  FullWidth="true"
                                  Disabled="@isLoading"
                                  Class="modern-input"
                                  Style="height: 56px;" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" 
                              Class="error-alert" 
                              Dense="true" 
                              CloseIcon="true" 
                              CloseIconClicked="@(() => errorMessage = string.Empty)">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                        @errorMessage
                    </MudAlert>
                }

                <div class="form-options">
                    <MudCheckBox @bind-Value="loginModel.RememberMe" 
                                Label="Remember me" 
                                Color="Color.Primary" 
                                Disabled="@isLoading" />
                    
                    <div class="security-indicators">
                        <div class="security-item">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                            <span>SSL Secured</span>
                        </div>
                    </div>
                </div>

                <MudButton Variant="Variant.Filled"
                          Color="Color.Primary"
                          FullWidth="true"
                          Size="Size.Large"
                          ButtonType="ButtonType.Submit"
                          Class="login-button"
                          Disabled="@isLoading">
                    @if (isLoading)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        <span>Authenticating...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                        <span>LOGIN TO PORTAL</span>
                    }
                </MudButton>
            </EditForm>
        </div>

        <!-- Footer Links -->
        <div class="login-footer-custom">
            <div class="quick-links">
                <MudLink Href="/forgot-password" Class="footer-link">
                    <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Small" />
                    <span>Forgot Password?</span>
                </MudLink>
                <MudLink Href="/request-account" Class="footer-link">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" />
                    <span>Request Account</span>
                </MudLink>
            </div>
            
            <div class="system-info">
                <div class="info-item">
                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                    <span>Support: +233 302 123456</span>
                </div>
                <div class="info-item">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                    <span>Version 2.1.3</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Badge - Moved to bottom of page -->
    <div class="security-badge-bottom-page">
        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
        <span>ISO 27001 Certified</span>
    </div>
</div>

