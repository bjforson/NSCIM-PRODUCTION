@code {
    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private InputType passwordInputType = InputType.Password;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Reason { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // If user is already authenticated, redirect to dashboard
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/dashboard", true);
            return;
        }
        
        // Show message if logged out due to inactivity
        if (Reason == "inactivity")
        {
            errorMessage = "You have been logged out due to 15 minutes of inactivity. Please log in again.";
        }
        else if (Reason == "server_restart")
        {
            errorMessage = "Server restarted. Please log in again.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = false;
    }

    public class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
        public string RefreshToken { get; set; } = string.Empty;
        public int ExpiresIn { get; set; }
        public string TokenType { get; set; } = string.Empty;
    }

    private void TogglePasswordVisibility()
    {
        passwordInputType = passwordInputType == InputType.Password 
            ? InputType.Text 
            : InputType.Password;
    }

    private async Task HandleLogin()
    {
        Logger.LogInformation("Login button clicked for user: {Username}", loginModel.Username ?? "unknown");
        errorMessage = string.Empty;
        isLoading = true;
        StateHasChanged(); // Force UI update

        try
        {
            // Validate input
            if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
            {
                errorMessage = "Please enter username and password";
                Snackbar.Add(errorMessage, Severity.Warning);
                isLoading = false;
                return;
            }
            
            using var httpClient = HttpClientFactory.CreateClient("NickScanAPI");
            
            var loginRequest = new 
            { 
                Username = loginModel.Username, 
                Password = loginModel.Password
            };
            
            var response = await httpClient.PostAsJsonAsync("/api/Authentication/login", loginRequest);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                
                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    try
                    {
                        Logger.LogInformation("Login successful for user: {Username}. Token received (length: {TokenLength})", 
                            loginModel.Username, result.Token.Length);
                        
                        // ✅ Store token and update auth state
                        await AuthProvider.LoginAsync(result.Token);
                        Logger.LogDebug("AuthProvider.LoginAsync completed for user: {Username}", loginModel.Username);

                        await PopulatePermissionClaimsAsync(httpClient, result.Token);
                        
                        Snackbar.Add($"Welcome, {loginModel.Username}!", Severity.Success);
                        Logger.LogDebug("Welcome snackbar shown for user: {Username}", loginModel.Username);
                        
                        // Force update UI
                        StateHasChanged();
                        await Task.Delay(100);
                        
                        Logger.LogInformation("Navigating to dashboard for user: {Username}", loginModel.Username);
                        
                        NavigationManager.NavigateTo("/dashboard");
                        Logger.LogDebug("Navigation to dashboard completed for user: {Username}", loginModel.Username);
                    }
                    catch (Exception navEx)
                    {
                        Logger.LogError(navEx, "Navigation error after successful login for user: {Username}", loginModel.Username);
                        Snackbar.Add($"Navigation failed: {navEx.Message}", Severity.Error);
                    }
                }
                else
                {
                    Logger.LogWarning("Login failed - no token in response for user: {Username}", loginModel.Username);
                    errorMessage = "Login failed. Invalid response from server.";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                Logger.LogWarning("Login API call failed with status {StatusCode} for user: {Username}", 
                    response.StatusCode, loginModel.Username);
                errorMessage = "Invalid username or password";
                Snackbar.Add(errorMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Login error for user: {Username}. Error: {ErrorMessage}", 
                loginModel.Username ?? "unknown", ex.Message);
            errorMessage = "Login failed. Please check your connection and try again.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        finally
        {
            isLoading = false;
            Logger.LogDebug("Login handler finished for user: {Username}. isLoading = false", loginModel.Username ?? "unknown");
        }
    }

    private async Task PopulatePermissionClaimsAsync(HttpClient httpClient, string token)
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(token);

            var username = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value ?? loginModel.Username;
            var email = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value ?? string.Empty;
            var role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? string.Empty;

            var permissionClaims = jwt.Claims
                .Where(c => string.Equals(c.Type, "Permission", StringComparison.OrdinalIgnoreCase))
                .Select(c => c.Value)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            Logger.LogDebug("JWT parsed - Username: {Username}, Role: {Role}, Permission claims: {Count}", 
                username, role, permissionClaims.Count);
            Logger.LogTrace("Permission claims for {Username}: {Permissions}", 
                username, string.Join(", ", permissionClaims));

            if (permissionClaims.Count == 0)
            {
                try
                {
                    httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
                    var apiPermissions = await httpClient.GetFromJsonAsync<List<string>>("/api/permissions/my-permissions");
                    if (apiPermissions != null)
                    {
                        permissionClaims = apiPermissions
                            .Where(p => !string.IsNullOrWhiteSpace(p))
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();
                    }
                }
                catch (Exception permEx)
                {
                    Logger.LogWarning(permEx, "Unable to fetch permissions from API for user: {Username}", username);
                }
            }

            CustomAuthProvider.SetAuthenticatedUserWithPermissions(
                username,
                string.IsNullOrWhiteSpace(role) ? "Viewer" : role,
                email,
                permissionClaims);

            await AuthBootstrapper.RefreshAsync();
        }
        catch (Exception claimEx)
        {
            Logger.LogWarning(claimEx, "Permission claim processing failed for user: {Username}", loginModel.Username ?? "unknown");
            CustomAuthProvider.SetAuthenticatedUserWithPermissions(
                loginModel.Username,
                "Viewer",
                string.Empty,
                new List<string>());

            await AuthBootstrapper.RefreshAsync();
        }
    }
    
    public class ServerLoginResponse
    {
        public bool Success { get; set; }
        public string Token { get; set; } = string.Empty;
        public object? User { get; set; }
    }
}