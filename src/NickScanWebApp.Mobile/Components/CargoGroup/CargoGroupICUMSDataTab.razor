@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using NickScanWebApp.Mobile.Services
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    @if (CargoGroup?.Data?.ICUMSData?.Any() == true)
    {
        <MudText Typo="Typo.h6" Class="mb-3">ICUMS Details (BOE/CMR)</MudText>
        
        @* Cargo Content Summary *@
        @if (_cargoSummary != null && !string.IsNullOrWhiteSpace(_cargoSummary.SummaryText))
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3" Style="background: linear-gradient(135deg, var(--mud-palette-primary-lighten) 0%, var(--mud-palette-primary) 100%); border-left: 3px solid var(--mud-palette-primary-darken);">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Summarize" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight: 600;">Cargo Content Summary</MudText>
                    </MudStack>
                    <MudDivider />
                    <MudText Typo="Typo.body2" Style="white-space: pre-line; line-height: 1.5;">@_cargoSummary.SummaryText</MudText>
                </MudStack>
            </MudPaper>
        }
        
        @if (CargoGroup.Type == CargoType.Consolidated)
        {
            var houseBLCount = CargoGroup.Data.ICUMSData.Count;
            
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" Class="mr-2" />
                <strong>Consolidated:</strong> @houseBLCount House BL(s)
            </MudAlert>
            
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var houseBLGroup in CargoGroup.Data.ICUMSData)
                {
                    var categoryGroups = houseBLGroup.Records.GroupBy(r => r.Category).OrderBy(g => GetCategoryOrder(g.Key)).ToList();
                    var totalFields = houseBLGroup.Records.Count;
                    
                    <MudExpansionPanel Text="@($"House BL: {houseBLGroup.HouseBL}")" 
                                       Icon="@Icons.Material.Filled.Article"
                                       IsExpanded="false">
                        <MudStack Spacing="2" Class="pa-2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                @totalFields field(s)
                            </MudChip>
                            
                            @if (houseBLGroup.BOEDetails.Any())
                            {
                                <MudPaper Elevation="1" Class="pa-2 mb-2">
                                    <MudText Typo="Typo.body2" Color="Color.Info" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> BOE Details
                                    </MudText>
                                    @foreach (var boe in houseBLGroup.BOEDetails)
                                    {
                                        <MudStack Spacing="1" Class="mb-2">
                                            <MudText Typo="Typo.caption">
                                                <strong>Declaration:</strong> @boe.DeclarationNumber
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                <strong>Consignee:</strong> @boe.ConsigneeName
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                <strong>Container:</strong> @boe.ContainerNumber
                                            </MudText>
                                        </MudStack>
                                    }
                                </MudPaper>
                            }
                            
                            <MudExpansionPanels MultiExpansion="true">
                                @foreach (var categoryGroup in categoryGroups)
                                {
                                    <MudExpansionPanel Text="@categoryGroup.Key" 
                                                       Icon="@GetCategoryIcon(categoryGroup.Key)"
                                                       IsExpanded="false">
                                        <MudStack Spacing="2" Class="pa-2">
                                            <MudGrid Spacing="2">
                                                @foreach (var record in categoryGroup)
                                                {
                                                    <MudItem xs="12">
                                                        <MudStack Spacing="0">
                                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    <strong>@record.Field</strong>
                                                                </MudText>
                                                                @if (record.IsRequired)
                                                                {
                                                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">Required</MudChip>
                                                                }
                                                            </MudStack>
                                                            <MudText Typo="Typo.body2">@(record.Value ?? "N/A")</MudText>
                                                        </MudStack>
                                                    </MudItem>
                                                }
                                            </MudGrid>
                                        </MudStack>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        </MudStack>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
        else
        {
            var containerCount = CargoGroup.Data.ICUMSData.Count;
            
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" />
                <strong>Declaration:</strong> @CargoGroup.GroupIdentifier | <strong>Containers:</strong> @containerCount
            </MudAlert>
            
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var containerGroup in CargoGroup.Data.ICUMSData)
                {
                    var categoryGroups = containerGroup.Records.GroupBy(r => r.Category).OrderBy(g => GetCategoryOrder(g.Key)).ToList();
                    var totalFields = containerGroup.Records.Count;
                    
                    <MudExpansionPanel Text="@($"Container: {containerGroup.ContainerNumber}")" 
                                       Icon="@Icons.Material.Filled.Inventory2"
                                       IsExpanded="false">
                        <MudStack Spacing="2" Class="pa-2">
                            @if (totalFields > 0 && categoryGroups.Any())
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                    @totalFields field(s)
                                </MudChip>
                                
                                <MudExpansionPanels MultiExpansion="true">
                                    @foreach (var categoryGroup in categoryGroups)
                                    {
                                        <MudExpansionPanel Text="@categoryGroup.Key" 
                                                           Icon="@GetCategoryIcon(categoryGroup.Key)"
                                                           IsExpanded="false">
                                            <MudStack Spacing="2" Class="pa-2">
                                                <MudGrid Spacing="2">
                                                    @foreach (var record in categoryGroup)
                                                    {
                                                        <MudItem xs="12">
                                                            <MudStack Spacing="0">
                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                        <strong>@record.Field</strong>
                                                                    </MudText>
                                                                    @if (record.IsRequired)
                                                                    {
                                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">Required</MudChip>
                                                                    }
                                                                </MudStack>
                                                                <MudText Typo="Typo.body2">@(record.Value ?? "N/A")</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                    }
                                                </MudGrid>
                                            </MudStack>
                                        </MudExpansionPanel>
                                    }
                                </MudExpansionPanels>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true">
                                    No ICUMS records available for this container.
                                </MudAlert>
                            }
                        </MudStack>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Warning">
            No ICUMS data available for this cargo group.
        </MudAlert>
    }
</MudContainer>

@code {
    [Parameter] public CargoGroupDto? CargoGroup { get; set; }
    
    [Inject] private CargoSummaryService CargoSummaryService { get; set; } = null!;
    
    private CargoSummaryDto? _cargoSummary;
    private bool _isLoadingSummary = false;
    
    protected override async Task OnParametersSetAsync()
    {
        await LoadCargoSummary();
    }
    
    private async Task LoadCargoSummary()
    {
        if (CargoGroup == null || CargoGroup.Data?.ICUMSData?.Any() != true)
        {
            _cargoSummary = null;
            return;
        }
        
        try
        {
            _isLoadingSummary = true;
            _cargoSummary = await CargoSummaryService.GenerateSummaryAsync(CargoGroup);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading cargo summary: {ex.Message}");
            _cargoSummary = null;
        }
        finally
        {
            _isLoadingSummary = false;
        }
    }
    
    private int GetCategoryOrder(string category)
    {
        return category switch
        {
            "Container Info" => 1,
            "Declaration Info" => 2,
            "CMR Info" => 3,
            "Manifest Info" => 4,
            "Party Info" => 5,
            "Location Info" => 6,
            "Cargo Info" => 7,
            "Financial Info" => 8,
            "Risk Assessment" => 9,
            "Status" => 10,
            "Data Info" => 11,
            "Additional Fields" => 12,
            _ => 99
        };
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Container Info" => Icons.Material.Filled.Inventory2,
            "Declaration Info" => Icons.Material.Filled.Description,
            "CMR Info" => Icons.Material.Filled.Sailing,
            "Manifest Info" => Icons.Material.Filled.ListAlt,
            "Party Info" => Icons.Material.Filled.Business,
            "Location Info" => Icons.Material.Filled.LocationOn,
            "Financial Info" => Icons.Material.Filled.AttachMoney,
            "Cargo Info" => Icons.Material.Filled.Inventory,
            "Risk Assessment" => Icons.Material.Filled.Security,
            "Status" => Icons.Material.Filled.Info,
            "Data Info" => Icons.Material.Filled.Schedule,
            "Additional Fields" => Icons.Material.Filled.Info,
            _ => Icons.Material.Filled.Description
        };
    }
}
