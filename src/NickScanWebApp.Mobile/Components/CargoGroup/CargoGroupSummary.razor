@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using MudBlazor
@inject NavigationManager Navigation

<MudCard Elevation="1" Class="mb-2" Style="cursor: pointer;" OnClick="@(() => NavigateToDetails())">
    <MudCardContent>
        <MudStack Spacing="2">
            <!-- Header Row -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" 
                            Color="@(Summary.Type == CargoType.Consolidated ? Color.Info : Color.Success)" 
                            Variant="Variant.Filled" 
                            Size="Size.Small">
                        @(Summary.Type == CargoType.Consolidated ? "CONS" : "NON-CONS")
                    </MudChip>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                        @Summary.DisplayName
                    </MudText>
                </MudStack>
                <MudChip T="string" Color="@GetStatusColor()" Size="Size.Small">
                    @Summary.Status
                </MudChip>
            </MudStack>

            <!-- Stats Grid - Mobile 2x2 -->
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Containers</MudText>
                        <MudText Typo="Typo.h6">@Summary.TotalContainers</MudText>
                    </MudStack>
                </MudItem>
                @if (Summary.Type == CargoType.Consolidated)
                {
                    <MudItem xs="6">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">House BLs</MudText>
                            <MudText Typo="Typo.h6">@Summary.TotalHouseBLs</MudText>
                        </MudStack>
                    </MudItem>
                }
                <MudItem xs="6">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Completeness</MudText>
                        <MudProgressLinear Color="@GetCompletenessColor()" 
                                          Value="@Summary.CompletenessScore" 
                                          Variant="Variant.Filled" 
                                          Class="mt-1" />
                        <MudText Typo="Typo.caption">@Summary.CompletenessScore%</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Clearance</MudText>
                        <MudText Typo="Typo.body2">@Summary.ClearanceType</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>

            <!-- Data Availability - Mobile Compact -->
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                @if (Summary.ICUMSRecordCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                        ICUMS: @Summary.ICUMSRecordCount
                    </MudChip>
                }
                @if (Summary.ScannerRecordCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                        Scanner: @Summary.ScannerRecordCount
                    </MudChip>
                }
                @if (Summary.ImageCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">
                        Images: @Summary.ImageCount
                    </MudChip>
                }
            </MudStack>

            @if (Summary.LatestUpdateDate.HasValue)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Updated: @Summary.LatestUpdateDate.Value.ToString("g")
                </MudText>
            }
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public CargoGroupSummaryDto Summary { get; set; } = null!;
    [Parameter] public string? DetailsPageRoute { get; set; } = "/containers/details";
    [Parameter] public EventCallback OnViewDetails { get; set; }

    private void NavigateToDetails()
    {
        if (OnViewDetails.HasDelegate)
        {
            OnViewDetails.InvokeAsync();
        }
        else
        {
            var route = $"{DetailsPageRoute}?groupIdentifier={Uri.EscapeDataString(Summary.GroupIdentifier)}&type={Summary.Type}";
            Navigation.NavigateTo(route);
        }
    }

    private Color GetStatusColor()
    {
        return Summary.Status.ToUpper() switch
        {
            "COMPLETE" => Color.Success,
            "INCOMPLETE" => Color.Warning,
            "PENDING" => Color.Info,
            _ => Color.Default
        };
    }

    private Color GetCompletenessColor()
    {
        return Summary.CompletenessScore switch
        {
            >= 90 => Color.Success,
            >= 50 => Color.Warning,
            _ => Color.Error
        };
    }
}
