@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using NickScanCentralImagingPortal.Core.Utilities
@using NickScanWebApp.Mobile.Services
@using MudBlazor
@inject CargoGroupService CargoGroupService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body2">Loading cargo group data...</MudText>
        </MudStack>
    }
    else if (_cargoGroup == null)
    {
        <MudAlert Severity="Severity.Warning">
            Cargo group not found for identifier: @GroupIdentifier
        </MudAlert>
    }
    else
    {
        <!-- Header - Mobile Optimized -->
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                    <MudChip T="string" 
                            Color="@(_cargoGroup.Type == CargoType.Consolidated ? Color.Info : Color.Success)" 
                            Variant="Variant.Filled" 
                            Size="Size.Small">
                        @(_cargoGroup.Type == CargoType.Consolidated ? "CONSOLIDATED" : "NON-CONSOLIDATED")
                    </MudChip>
                    <MudText Typo="Typo.h6">
                        @(_cargoGroup.Type == CargoType.Consolidated ? "Master BL: " : "Declaration: ") 
                        <strong>@_cargoGroup.GroupIdentifier</strong>
                    </MudText>
                </MudStack>
                
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Containers</MudText>
                        <MudText Typo="Typo.h6">@_cargoGroup.TotalContainers</MudText>
                    </MudItem>
                    @if (_cargoGroup.Type == CargoType.Consolidated)
                    {
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">House BLs</MudText>
                            <MudText Typo="Typo.h6">@_cargoGroup.TotalHouseBLs</MudText>
                        </MudItem>
                    }
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">BOEs</MudText>
                        <MudText Typo="Typo.h6">@_cargoGroup.TotalBOEs</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Clearance Type</MudText>
                        <MudText Typo="Typo.body2">@_cargoGroup.ClearanceType</MudText>
                    </MudItem>
                </MudGrid>

                @if (_cargoGroup.ContainerNumbers.Any())
                {
                    <MudExpansionPanels>
                        <MudExpansionPanel Text="@($"Containers ({_cargoGroup.ContainerNumbers.Count})")">
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    @foreach (var container in _cargoGroup.ContainerNumbers)
                                    {
                                        var containerType = ContainerNumberValidator.ClassifyContainerNumber(container);
                                        <tr>
                                            <td>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    @if (containerType == ContainerNumberType.ValidISO)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">ISO</MudChip>
                                                    }
                                                    else if (containerType == ContainerNumberType.LooseCargo)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Loose</MudChip>
                                                    }
                                                    <MudText Typo="Typo.body2">@container</MudText>
                                                </MudStack>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            </MudStack>
        </MudPaper>

        <!-- Tabs - Mobile Optimized -->
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">
            <MudTabPanel Text="Summary" Icon="@Icons.Material.Filled.Summarize">
                <CargoGroupSummaryTab CargoGroup="@_cargoGroup" />
            </MudTabPanel>
            
            <MudTabPanel Text="ICUMS" Icon="@Icons.Material.Filled.Description">
                <CargoGroupICUMSDataTab CargoGroup="@_cargoGroup" />
            </MudTabPanel>
            
            <MudTabPanel Text="Scanner" Icon="@Icons.Material.Filled.Scanner">
                <CargoGroupScannerDataTab CargoGroup="@_cargoGroup" />
            </MudTabPanel>
            
            <MudTabPanel Text="Images" Icon="@Icons.Material.Filled.Image">
                <CargoGroupImagesTab CargoGroup="@_cargoGroup" />
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    [Parameter] public string GroupIdentifier { get; set; } = string.Empty;
    [Parameter] public CargoType? Type { get; set; }

    private CargoGroupDto? _cargoGroup;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCargoGroupAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(GroupIdentifier))
        {
            await LoadCargoGroupAsync();
        }
    }

    private async Task LoadCargoGroupAsync()
    {
        if (string.IsNullOrEmpty(GroupIdentifier))
        {
            _loading = false;
            return;
        }

        _loading = true;
        try
        {
            _cargoGroup = await CargoGroupService.GetCargoGroupAsync(GroupIdentifier, Type);
            
            if (_cargoGroup == null)
            {
                Snackbar.Add($"Cargo group not found: {GroupIdentifier}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading cargo group: {ex.Message}", Severity.Error);
            _cargoGroup = null;
        }
        finally
        {
            _loading = false;
        }
    }
}
