<MudCard Elevation="@Elevation" Class="@Class" Style="overflow: hidden;">
    <MudCardHeader Style="@($"background: {GetHeaderColor()}; color: white; padding: 8px 12px;")">
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle1" Style="color: white;">@ScannerName</MudText>
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.85);">@ScannerType</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudChip T="string" Size="Size.Small" Style="color: white; border-color: rgba(255,255,255,0.5);">@Status</MudChip>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-2">
        <MudGrid Spacing="1">
            <MudItem xs="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Scans today</MudText>
                <MudText Typo="Typo.body1"><strong>@ScansToday</strong></MudText>
            </MudItem>
            <MudItem xs="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">This month</MudText>
                <MudText Typo="Typo.body1"><strong>@ScansThisMonth</strong></MudText>
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Last scan</MudText>
                <MudText Typo="Typo.body2">@FormatLastScan()</MudText>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string ScannerName { get; set; } = "";
    [Parameter] public string ScannerType { get; set; } = "";
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public int ScansToday { get; set; }
    [Parameter] public int ScansThisMonth { get; set; }
    [Parameter] public DateTime? LastScanTime { get; set; }
    [Parameter] public int Elevation { get; set; } = 2;
    [Parameter] public string Class { get; set; } = "";

    private string FormatLastScan() =>
        LastScanTime.HasValue ? LastScanTime.Value.ToString("yyyy-MM-dd HH:mm:ss") : "—";

    private string GetHeaderColor()
    {
        var s = Status?.Trim() ?? "";
        if (s.Equals("Online", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("OK", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Healthy", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Running", StringComparison.OrdinalIgnoreCase))
        {
            return "#2e7d32";
        }

        if (s.Equals("Degraded", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Warning", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Busy", StringComparison.OrdinalIgnoreCase))
        {
            return "#f9a825";
        }

        if (s.Equals("Offline", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Error", StringComparison.OrdinalIgnoreCase) ||
            s.Equals("Down", StringComparison.OrdinalIgnoreCase))
        {
            return "#c62828";
        }

        return "#455a64";
    }
}
