<MudDialog FullWidth="true" MaxWidth="MaxWidth.Small" ContentClass="overflow-y-auto" Style="max-height: 85vh;">
    <TitleContent>
        <MudText Typo="Typo.h6">Caller details</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@Endpoint</MudText>
    </TitleContent>
    <DialogContent>
        @if (Callers == null || !Callers.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No callers recorded for this endpoint.</MudText>
        }
        else
        {
            <MudStack Spacing="2">
                @foreach (var caller in Callers)
                {
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Spacing="1">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.subtitle2" Style="word-break: break-all;">@caller.IpAddress</MudText>
                                @if (caller.IsInternal)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">Internal</MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="word-break: break-word;">
                                @caller.UserAgent
                            </MudText>
                            <MudDivider Class="my-1" />
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Calls</MudText>
                                <MudText Typo="Typo.body2"><strong>@caller.CallCount</strong></MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">First</MudText>
                                <MudText Typo="Typo.caption">@FormatDateTime(caller.FirstCall)</MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Last</MudText>
                                <MudText Typo="Typo.caption">@FormatDateTime(caller.LastCall)</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close" FullWidth="true">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Endpoint { get; set; } = "";
    [Parameter] public List<CallerDto> Callers { get; set; } = new();

    private void Close()
    {
        MudDialog.Close();
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("MMM dd, yyyy HH:mm:ss") : "—";
    }

    public class CallerDto
    {
        public string IpAddress { get; set; } = "";
        public string UserAgent { get; set; } = "";
        public int CallCount { get; set; }
        public DateTime? FirstCall { get; set; }
        public DateTime? LastCall { get; set; }
        public bool IsInternal { get; set; }
    }
}
