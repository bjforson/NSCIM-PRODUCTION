@using System.Text.Json
@using MudBlazor

@if (HasUnmappedFields)
{
    <MudExpansionPanels MultiExpansion="false" Class="mb-2">
        <MudExpansionPanel Text="@GetUnmappedFieldsTitle()" 
                      Icon="@Icons.Material.Filled.Info"
                      IsExpanded="false"
                      Class="mt-2"
                      Dense="true">
            <ChildContent>
                <!-- Structured Fields (from columns) -->
                @if (StructuredUnmappedFields.Any())
                {
                    <MudGrid Spacing="2" Class="mb-2">
                        @foreach (var field in StructuredUnmappedFields)
                        {
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-2">
                                    <MudStack Spacing="1">
                                        <MudChip T="string" Size="Size.Small" 
                                                Color="Color.Warning" 
                                                Variant="Variant.Outlined"
                                                Class="mb-1">
                                            @field.Section
                                        </MudChip>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            @field.FieldName
                                        </MudText>
                                        <MudText Typo="Typo.body2">@field.Value</MudText>
                                        @if (field.IsTruncated)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                                                Value truncated - see Raw JSON for complete value
                                            </MudText>
                                        }
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }

                <!-- Overflow Indicator -->
                @if (UnmappedFieldsOverflow)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Class="mr-2" />
                        <strong>@UnmappedFieldsCount unmapped fields detected</strong>
                        <p class="mb-2">Showing first 20 fields. Click below to view complete list from Raw JSON.</p>
                        <MudButton Variant="Variant.Text" 
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.Code"
                                  OnClick="ShowRawJsonDialog"
                                  Color="Color.Primary">
                            View All Unmapped Fields (Raw JSON)
                        </MudButton>
                    </MudAlert>
                }
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

<!-- Raw JSON Dialog -->
<MudDialog @bind-IsVisible="_showRawJsonDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Code" Class="mr-2" />
            Complete Unmapped Fields (Raw JSON)
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 500px; overflow-y: auto;">
            @if (string.IsNullOrEmpty(RawJsonData))
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No raw JSON data available for this record.
                </MudAlert>
            }
            else
            {
                <MudTextField Value="@GetFormattedRawJson()" 
                             ReadOnly="true"
                             Variant="Variant.Outlined"
                             MultiLine="true"
                             Rows="15"
                             Size="Size.Small"
                             Class="mt-2" />
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showRawJsonDialog = false" Size="Size.Small">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public List<object>? UnmappedFields { get; set; }
    [Parameter] public int? UnmappedFieldsCount { get; set; }
    [Parameter] public bool UnmappedFieldsOverflow { get; set; }
    [Parameter] public string? RawJsonData { get; set; }

    private bool _showRawJsonDialog = false;

    private bool HasUnmappedFields => UnmappedFieldsCount > 0 || (UnmappedFields?.Any() == true);

    private List<UnmappedFieldDto> StructuredUnmappedFields => 
        (UnmappedFields?.Take(20).Select(f => ConvertToDto(f)).Where(x => x != null).Cast<UnmappedFieldDto>().ToList()) ?? new List<UnmappedFieldDto>();

    private UnmappedFieldDto? ConvertToDto(object? field)
    {
        if (field == null) return null;
        
        try
        {
            var type = field.GetType();
            return new UnmappedFieldDto
            {
                Label = type.GetProperty("Label")?.GetValue(field)?.ToString() ?? string.Empty,
                Value = type.GetProperty("Value")?.GetValue(field)?.ToString(),
                Section = type.GetProperty("Section")?.GetValue(field)?.ToString() ?? string.Empty,
                FieldName = type.GetProperty("FieldName")?.GetValue(field)?.ToString() ?? string.Empty,
                IsTruncated = type.GetProperty("IsTruncated")?.GetValue(field) as bool? ?? false
            };
        }
        catch
        {
            return null;
        }
    }

    public class UnmappedFieldDto
    {
        public string Label { get; set; } = string.Empty;
        public string? Value { get; set; }
        public string Section { get; set; } = string.Empty;
        public string FieldName { get; set; } = string.Empty;
        public bool IsTruncated { get; set; }
    }

    private string GetUnmappedFieldsTitle()
    {
        var count = UnmappedFieldsCount ?? (UnmappedFields?.Count ?? 0);
        if (count == 0) return "Additional Fields";
        return $"Additional Fields ({count})";
    }

    private void ShowRawJsonDialog()
    {
        _showRawJsonDialog = true;
    }

    private string GetFormattedRawJson()
    {
        if (string.IsNullOrEmpty(RawJsonData)) return "{}";

        try
        {
            var jsonDoc = JsonDocument.Parse(RawJsonData);
            var options = new JsonSerializerOptions { WriteIndented = true };
            return JsonSerializer.Serialize(jsonDoc, options);
        }
        catch
        {
            return RawJsonData;
        }
    }
}

