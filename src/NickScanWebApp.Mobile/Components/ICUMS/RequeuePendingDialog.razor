@using MudBlazor
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" Size="Size.Medium" />
                <div>
                    <MudText Typo="Typo.h6">Pending Queue Summary</MudText>
                    <MudText Typo="Typo.body2">
                        Total pending: @PendingCount containers
                    </MudText>
                </div>
            </MudStack>
        </MudPaper>
        
        <MudText Typo="Typo.h6" Class="mb-3">Requeue Options</MudText>
        
        <MudRadioGroup T="string" @bind-Value="_requeueOption">
            <MudRadio T="string" Value="@("all")" Color="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Requeue All Pending (@PendingCount items)</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Reset retry counts and reprocess all pending containers
                    </MudText>
                </MudText>
            </MudRadio>
            
            <MudRadio T="string" Value="@("high-priority")" Color="Color.Warning" Class="mt-2">
                <MudText Typo="Typo.body2">
                    <strong>Requeue High Priority Only</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Only requeue containers with priority ≥ 2
                    </MudText>
                </MudText>
            </MudRadio>
            
            <MudRadio T="string" Value="@("custom")" Color="Color.Info" Class="mt-2">
                <MudText Typo="Typo.body2">
                    <strong>Custom Container Numbers</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Enter specific container numbers to requeue
                    </MudText>
                </MudText>
            </MudRadio>
        </MudRadioGroup>
        
        @if (_requeueOption == "custom")
        {
            <MudTextField @bind-Value="_customContainers" 
                          Label="Container Numbers" 
                          Variant="Variant.Outlined"
                          Lines="5"
                          Placeholder="Enter container numbers (one per line or comma-separated)"
                          HelperText="Example: MSDU123456, TCKU789012"
                          Size="Size.Small"
                          Class="mt-3" />
        }
        
        <MudDivider Class="my-3" />
        
        <MudText Typo="Typo.subtitle2" Class="mb-2">Advanced Options</MudText>
        
        <MudCheckBox T="bool" 
                     @bind-Value="_resetRetryCount" 
                     Label="Reset retry count to 0" 
                     Color="Color.Primary"
                     Dense="true" />
        
        <MudCheckBox T="bool" 
                     @bind-Value="_resetTimestamps" 
                     Label="Reset queue timestamp (push to front)" 
                     Color="Color.Primary"
                     Dense="true" />
        
        <MudSwitch T="bool" 
                   @bind-Value="_changePriority" 
                   Label="Change priority" 
                   Color="Color.Primary"
                   Class="mt-2" />
        
        @if (_changePriority)
        {
            <MudSelect @bind-Value="_priority" 
                       Label="New Priority" 
                       Variant="Variant.Outlined"
                       Size="Size.Small"
                       Class="mt-2">
                <MudSelectItem Value="0">Low Priority (0)</MudSelectItem>
                <MudSelectItem Value="1">Normal Priority (1)</MudSelectItem>
                <MudSelectItem Value="2">High Priority (2)</MudSelectItem>
                <MudSelectItem Value="3">Urgent Priority (3)</MudSelectItem>
            </MudSelect>
        }
        
        <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
            <strong>Note:</strong> Requeuing will modify the existing pending items. 
            The background service will reprocess them based on priority and queue time.
        </MudAlert>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" Size="Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Replay"
                   OnClick="Submit"
                   Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Requeuing...</span>
            }
            else
            {
                <span>Requeue Items</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int PendingCount { get; set; }
    [Parameter] public EventCallback<RequeuePendingDialogResult> OnRequeue { get; set; }
    
    private string _requeueOption = "all";
    private string _customContainers = "";
    private bool _resetRetryCount = true;
    private bool _resetTimestamps = false;
    private bool _changePriority = false;
    private int _priority = 1;
    private bool _isSubmitting = false;

    private async Task Submit()
    {
        _isSubmitting = true;
        
        try
        {
            var result = new RequeuePendingDialogResult
            {
                RequeueAll = _requeueOption == "all",
                RequeueHighPriority = _requeueOption == "high-priority",
                ResetRetryCount = _resetRetryCount,
                ResetTimestamps = _resetTimestamps,
                NewPriority = _changePriority ? _priority : null
            };
            
            if (_requeueOption == "custom")
            {
                var input = _customContainers.Replace("\n", ",").Replace("\r", "");
                result.ContainerNumbers = input.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Select(c => c.Trim().ToUpper())
                    .Where(c => !string.IsNullOrWhiteSpace(c))
                    .Distinct()
                    .ToList();
                
                if (!result.ContainerNumbers.Any())
                {
                    return;
                }
            }
            
            await OnRequeue.InvokeAsync(result);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task Cancel() => Task.CompletedTask;
    
    public class RequeuePendingDialogResult
    {
        public bool RequeueAll { get; set; } = true;
        public bool RequeueHighPriority { get; set; } = false;
        public List<string>? ContainerNumbers { get; set; }
        public bool ResetRetryCount { get; set; } = true;
        public int? NewPriority { get; set; }
        public bool ResetTimestamps { get; set; } = false;
    }
}

