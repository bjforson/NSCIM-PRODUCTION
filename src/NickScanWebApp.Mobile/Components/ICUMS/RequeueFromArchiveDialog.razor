@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Archive" Color="Color.Warning" Size="Size.Medium" />
                <div>
                    <MudText Typo="Typo.h6">Archive Summary</MudText>
                    <MudText Typo="Typo.body2">
                        Total: @ArchiveCount items | Failed: @ArchivedFailed | Completed: @(ArchiveCount - ArchivedFailed)
                    </MudText>
                </div>
            </MudStack>
        </MudPaper>
        
        <MudText Typo="Typo.h6" Class="mb-3">Requeue Options</MudText>
        
        <MudRadioGroup T="string" @bind-Value="_requeueOption">
            <MudRadio T="string" Value="@("failed")" Color="Color.Error">
                <MudText Typo="Typo.body2">
                    <strong>Requeue All Failed (@ArchivedFailed items)</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Retry all containers that failed to download from ICUMS
                    </MudText>
                </MudText>
            </MudRadio>
            
            <MudRadio T="string" Value="@("sample")" Color="Color.Warning" Class="mt-2">
                <MudText Typo="Typo.body2">
                    <strong>Requeue Failed Sample (100 items)</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Test with first 100 failed containers to verify ICUMS connectivity
                    </MudText>
                </MudText>
            </MudRadio>
            
            <MudRadio T="string" Value="@("custom")" Color="Color.Info" Class="mt-2">
                <MudText Typo="Typo.body2">
                    <strong>Custom Container Numbers</strong><br/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Enter specific container numbers to requeue
                    </MudText>
                </MudText>
            </MudRadio>
        </MudRadioGroup>
        
        @if (_requeueOption == "custom")
        {
            <MudTextField @bind-Value="_customContainers" 
                          Label="Container Numbers" 
                          Variant="Variant.Outlined"
                          Lines="5"
                          Placeholder="Enter container numbers (one per line or comma-separated)"
                          HelperText="Example: MSDU123456, TCKU789012"
                          Size="Size.Small"
                          Class="mt-3" />
        }
        
        <MudSelect @bind-Value="_priority" 
                   Label="Priority" 
                   Variant="Variant.Outlined"
                   Size="Size.Small"
                   Class="mt-3">
            <MudSelectItem Value="0">Normal Priority</MudSelectItem>
            <MudSelectItem Value="1">High Priority</MudSelectItem>
            <MudSelectItem Value="2">Urgent Priority</MudSelectItem>
        </MudSelect>
        
        <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
            <strong>Warning:</strong> Requeuing will add items back to the active download queue. 
            Only requeue if you've confirmed ICUMS API is accessible.
        </MudAlert>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" Size="Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Replay"
                   OnClick="Submit"
                   Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Requeuing...</span>
            }
            else
            {
                <span>Requeue Items</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int ArchiveCount { get; set; }
    [Parameter] public int ArchivedFailed { get; set; }
    [Parameter] public EventCallback<RequeueDialogResult> OnRequeue { get; set; }
    
    private string _requeueOption = "sample";
    private string _customContainers = "";
    private int _priority = 1;
    private bool _isSubmitting = false;

    private async Task Submit()
    {
        _isSubmitting = true;
        
        try
        {
            var containerNumbers = new List<string>();
            
            if (_requeueOption == "custom")
            {
                var input = _customContainers.Replace("\n", ",").Replace("\r", "");
                containerNumbers = input.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Select(c => c.Trim().ToUpper())
                    .Where(c => !string.IsNullOrWhiteSpace(c))
                    .Distinct()
                    .ToList();
                
                if (!containerNumbers.Any())
                {
                    return;
                }
            }
            else
            {
                containerNumbers.Add($"ARCHIVE_OPTION:{_requeueOption}");
            }
            
            var result = new RequeueDialogResult
            {
                ContainerNumbers = containerNumbers,
                Priority = _priority
            };
            
            await OnRequeue.InvokeAsync(result);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task Cancel() => Task.CompletedTask;
    
    public class RequeueDialogResult
    {
        public List<string> ContainerNumbers { get; set; } = new();
        public int Priority { get; set; } = 1;
    }
}

