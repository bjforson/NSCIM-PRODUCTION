@* Submission table component for displaying ICUMS submission queue items - Mobile Optimized *@
@using NickScanWebApp.Mobile.Models.ICUMS

<!-- Mobile: Card view instead of table -->
@if (Items.Any())
{
    <MudStack Spacing="2">
        @foreach (var item in Items)
        {
            <MudCard Elevation="2" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Style="font-weight: 600; font-family: monospace;">@item.ContainerNumber</MudText>
                    
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudChip T="string" 
                                 Size="Size.Small" 
                                 Color="@GetStatusColor(item.Status)"
                                 Variant="Variant.Filled">
                            @item.Status
                        </MudChip>
                        <MudChip T="string" 
                                 Size="Size.Small" 
                                 Color="@GetPriorityColor(item.Priority)"
                                 Variant="Variant.Outlined">
                            @GetPriorityLabel(item.Priority)
                        </MudChip>
                    </MudStack>
                    
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        <strong>Type:</strong> @(item.SubmissionType ?? "Standard")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        <strong>Queued:</strong> @item.QueuedAt.ToString("MM/dd HH:mm")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        <strong>Attempts:</strong> @item.RetryCount / @item.MaxRetries
                    </MudText>
                    
                    @if (ShowError && !string.IsNullOrEmpty(item.LastErrorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-1">
                            <MudText Typo="Typo.caption">@item.LastErrorMessage</MudText>
                        </MudAlert>
                    }
                    
                    <MudStack Row="true" Spacing="1" Class="mt-2">
                        @if (OnRetry != null && item.Status == "Failed")
                        {
                            <MudButton Size="Size.Small" 
                                      Variant="Variant.Text" 
                                      Color="Color.Primary"
                                      StartIcon="@Icons.Material.Filled.Replay"
                                      OnClick="@(() => OnRetry(item.Id))">
                                Retry
                            </MudButton>
                        }
                        @if (OnCancel != null && (item.Status == "Pending" || item.Status == "Processing"))
                        {
                            <MudButton Size="Size.Small" 
                                      Variant="Variant.Text" 
                                      Color="Color.Warning"
                                      StartIcon="@Icons.Material.Filled.Cancel"
                                      OnClick="@(() => OnCancel(item.Id))">
                                Cancel
                            </MudButton>
                        }
                    </MudStack>
                </MudStack>
            </MudCard>
        }
    </MudStack>
}
else if (!Loading)
{
    <MudText Typo="Typo.body2" Align="Align.Center" Class="pa-4">
        No submission items found
    </MudText>
}

@if (Loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
}

@code {
    [Parameter] public IEnumerable<SubmissionQueueItem> Items { get; set; } = Array.Empty<SubmissionQueueItem>();
    [Parameter] public Func<int, Task>? OnRetry { get; set; }
    [Parameter] public Func<int, Task>? OnCancel { get; set; }
    [Parameter] public bool ShowError { get; set; } = false;
    [Parameter] public bool Dense { get; set; } = false;
    [Parameter] public bool Loading { get; set; } = false;

    private static Color GetStatusColor(string? status) => status?.ToLower() switch
    {
        "pending" => Color.Warning,
        "processing" => Color.Info,
        "completed" => Color.Success,
        "failed" => Color.Error,
        "submitted" => Color.Success,
        "cancelled" => Color.Default,
        _ => Color.Default
    };

    private static Color GetPriorityColor(int priority) => priority switch
    {
        0 => Color.Default,
        1 => Color.Primary,
        2 => Color.Warning,
        3 => Color.Error,
        _ => Color.Default
    };

    private static string GetPriorityLabel(int priority) => priority switch
    {
        0 => "Normal",
        1 => "High",
        2 => "Urgent",
        3 => "Critical",
        _ => "Unknown"
    };
}

