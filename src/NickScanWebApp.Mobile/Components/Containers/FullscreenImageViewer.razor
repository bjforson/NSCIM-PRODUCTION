@using MudBlazor
@inject IJSRuntime JS

@if (IsOpen)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" @onclick="Close">
        <MudPaper Class="fullscreen-viewer" 
                  @onclick:stopPropagation="true" 
                  Elevation="24" 
                  Style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 10000; background: #1e1e1e; display: flex; flex-direction: column;">
            
            <!-- Toolbar - Mobile Optimized -->
            <MudToolBar Dense="true" Style="background: #424242; color: white;">
                <MudText Typo="Typo.body2" Style="color: white; flex: 1; overflow: hidden; text-overflow: ellipsis;">@ImageFileName</MudText>
                <MudSpacer />
                
                <!-- Mobile: Simplified controls -->
                <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" 
                              Style="color: #90caf9;"
                              OnClick="ZoomIn" />
                <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" 
                              Style="color: #90caf9;"
                              OnClick="ZoomOut" />
                <MudIconButton Icon="@Icons.Material.Filled.RotateRight" 
                              Style="color: #ce93d8;"
                              OnClick="RotateRight" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                              Style="color: #ef5350;"
                              OnClick="Close" />
            </MudToolBar>

            <!-- Image Display Area -->
            <div style="flex: 1; display: flex; align-items: center; justify-content: center; overflow: auto; padding: 20px;">
                <img src="@ImageUrl" 
                     alt="@ImageFileName"
                     style="@GetImageStyle()"
                     @onclick:stopPropagation="true" />
            </div>
        </MudPaper>
    </MudOverlay>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string ImageUrl { get; set; } = string.Empty;
    [Parameter] public string ImageFileName { get; set; } = "Image";
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private double zoomLevel = 1.0;
    private double rotation = 0;

    private string GetImageStyle()
    {
        return $"transform: scale({zoomLevel}) rotate({rotation}deg); max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.3s ease;";
    }

    private void ZoomIn()
    {
        zoomLevel = Math.Min(zoomLevel + 0.25, 3.0);
    }

    private void ZoomOut()
    {
        zoomLevel = Math.Max(zoomLevel - 0.25, 0.5);
    }

    private void RotateRight()
    {
        rotation = (rotation + 90) % 360;
    }

    private async Task Close()
    {
        IsOpen = false;
        zoomLevel = 1.0;
        rotation = 0;
        await IsOpenChanged.InvokeAsync(false);
    }
}
