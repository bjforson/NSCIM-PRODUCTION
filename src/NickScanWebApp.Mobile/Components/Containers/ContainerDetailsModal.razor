@using NickScanWebApp.Mobile.Services
@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using NickScanWebApp.Mobile.Components.ICUMS
@using MudBlazor
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog ContentClass="overflow-y-auto" Style="max-height: 90vh;" FullWidth="true" MaxWidth="MaxWidth.False">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ViewInAr" Class="mr-2" />
            Container: @ContainerNumber
        </MudText>
    </TitleContent>
    
    <DialogContent>
        @if (isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2">Loading container data...</MudText>
            </MudStack>
        }
        else if (basicInfo != null)
        {
            <!-- Summary Cards - Mobile 2x2 -->
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Scanner" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h6">@basicInfo.ScannerRecordCount</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Scanner</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Success" Size="Size.Medium" />
                            <MudText Typo="Typo.h6">@basicInfo.ICUMSRecordCount</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">ICUMS</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Warning" Size="Size.Medium" />
                            <MudText Typo="Typo.h6">@basicInfo.ImageCount</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Images</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                
                <MudItem xs="6">
                    <MudPaper Elevation="1" Class="pa-2">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Update" Color="Color.Info" Size="Size.Medium" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Updated</MudText>
                            <MudText Typo="Typo.body2">@basicInfo.LastUpdated.ToString("MMM dd")</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Tabbed Interface - Mobile Optimized -->
            <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">
                <MudTabPanel Text="Scanner" Icon="@Icons.Material.Filled.Scanner">
                    <ScannerDataTab ContainerNumber="@ContainerNumber" TotalRecords="@basicInfo.ScannerRecordCount" />
                </MudTabPanel>
                
                <MudTabPanel Text="ICUMS" Icon="@Icons.Material.Filled.Description">
                    <ICUMSDataTab ContainerNumber="@ContainerNumber" TotalRecords="@basicInfo.ICUMSRecordCount" />
                </MudTabPanel>
                
                <MudTabPanel Text="Images" Icon="@Icons.Material.Filled.Image">
                    <ImagesTab ContainerNumber="@ContainerNumber" ImageCount="@basicInfo.ImageCount" />
                </MudTabPanel>
                
                <MudTabPanel Text="Search" Icon="@Icons.Material.Filled.Search">
                    <SearchTab ContainerNumber="@ContainerNumber" />
                </MudTabPanel>
            </MudTabs>
        }
        else if (errorMessage != null)
        {
            <MudAlert Severity="Severity.Error">
                @errorMessage
            </MudAlert>
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string ContainerNumber { get; set; } = string.Empty;
    [CascadingParameter] IDialogReference? MudDialog { get; set; }

    private ContainerBasicInfo? basicInfo;
    private bool isLoading = true;
    private string? errorMessage;
    private int loadingProgress = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadContainerData();
    }

    private async Task LoadContainerData()
    {
        isLoading = true;
        loadingProgress = 0;
        errorMessage = null;

        try
        {
            loadingProgress = 25;
            basicInfo = await ContainerDetailsService.GetBasicInfoAsync(ContainerNumber);
            loadingProgress = 100;

            if (basicInfo == null)
            {
                errorMessage = $"Container {ContainerNumber} not found";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading container data: {ex.Message}";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Close()
    {
        MudDialog?.Close();
    }
}
