@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using UnifiedSearchResults = NickScanWebApp.Shared.Models.UnifiedSearchResults
@inject NickScanWebApp.Shared.Services.IContainerDetailsService ContainerDetailsService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack Spacing="2">
        <!-- Search Input - Mobile Optimized -->
        <MudPaper Class="pa-3" Elevation="1">
            <MudStack Spacing="2">
                <MudTextField @bind-Value="searchQuery" 
                             Label="Search in container data" 
                             Variant="Variant.Outlined"
                             Adornment="Adornment.End"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             OnKeyUp="@OnSearchKeyUp"
                             FullWidth="true" />
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary"
                          OnClick="PerformSearch"
                          Disabled="@isSearching"
                          FullWidth="true"
                          StartIcon="@Icons.Material.Filled.Search">
                    @if (isSearching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Search
                </MudButton>
            </MudStack>
        </MudPaper>

        <!-- Search Results -->
        @if (searchResults != null)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">
                        Results (@searchResults.TotalResults found)
                    </MudText>
                    
                    @if (searchResults.ScannerResults?.Any() == true)
                    {
                        <MudExpansionPanels>
                            <MudExpansionPanel Text="Scanner Data" Icon="@Icons.Material.Filled.Scanner">
                                @foreach (var result in searchResults.ScannerResults)
                                {
                                    <MudPaper Elevation="0" Class="pa-2 mb-2" Style="background: #f5f5f5;">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@result.Field</MudText>
                                            <MudText Typo="Typo.body2">@result.Value</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@result.Source</MudChip>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }

                    @if (searchResults.ICUMSResults?.Any() == true)
                    {
                        <MudExpansionPanels>
                            <MudExpansionPanel Text="ICUMS Data" Icon="@Icons.Material.Filled.Description">
                                @foreach (var result in searchResults.ICUMSResults)
                                {
                                    <MudPaper Elevation="0" Class="pa-2 mb-2" Style="background: #f5f5f5;">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@result.Field</MudText>
                                            <MudText Typo="Typo.body2">@result.Value</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">@result.Source</MudChip>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }

                    @if (searchResults.TotalResults == 0)
                    {
                        <MudAlert Severity="Severity.Info">
                            No results found for "@searchQuery"
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        }
        else if (hasSearched)
        {
            <MudAlert Severity="Severity.Info">
                Enter a search term to find data in this container
            </MudAlert>
        }
    </MudStack>
</MudContainer>

@code {
    [Parameter] public string ContainerNumber { get; set; } = string.Empty;

    private string searchQuery = string.Empty;
    private UnifiedSearchResults? searchResults;
    private bool isSearching = false;
    private bool hasSearched = false;

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            Snackbar.Add("Please enter a search term", Severity.Warning);
            return;
        }

        isSearching = true;
        hasSearched = true;
        try
        {
            searchResults = await ContainerDetailsService.SearchContainerDataAsync(ContainerNumber, searchQuery);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error searching: {ex.Message}", Severity.Error);
            searchResults = null;
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await PerformSearch();
        }
    }
}
