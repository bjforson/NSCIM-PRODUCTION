@inherits LayoutComponentBase
@using NickScanWebApp.Mobile.Components.Authentication
@inject NavigationManager NavigationManager
@inject NickScanWebApp.Mobile.Services.ThemeService ThemeService
@using NickScanWebApp.Mobile.Theme
@implements IDisposable

<MudThemeProvider Theme="@_theme" IsDarkMode="@ThemeService.IsDarkMode" />

@* Inactivity monitor for auto-logout *@
<InactivityMonitor />

<MudLayout Class="mobile-layout">
    <!-- Mobile Top App Bar (Simplified) -->
    <MudAppBar Elevation="1" Dense="true" Class="mobile-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                       Color="Color.Inherit" 
                       Edge="Edge.Start" 
                       OnClick="@ToggleDrawer" />
        
        <MudText Typo="Typo.h6" Class="ml-2">NickScan</MudText>
        
        <MudSpacer />
        
        <!-- Mobile Top Bar Actions (Simplified) -->
        <TopBar />
    </MudAppBar>
    
    <!-- Navigation Drawer (Hamburger Menu) - Only for secondary navigation -->
    <MudDrawer @bind-Open="_drawerOpen" 
               Elevation="2" 
               ClipMode="DrawerClipMode.Always"
               Variant="@DrawerVariant.Temporary"
               Anchor="Anchor.Left">
        <NavMenu />
    </MudDrawer>
    
    <!-- Main Content Area - Padding for bottom nav -->
    <MudMainContent Class="mobile-main-content pa-2">
        @Body
    </MudMainContent>
    
    <!-- Mobile Bottom Navigation Bar -->
    <BottomNavigation />
</MudLayout>

<style>
    .mobile-layout {
        height: 100vh;
        overflow: hidden;
    }
    
    .mobile-appbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1100;
    }
    
    .mobile-main-content {
        padding-top: 56px !important; /* AppBar height */
        padding-bottom: 64px !important; /* Bottom nav height */
        min-height: calc(100vh - 120px);
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }
</style>

@code {
    private ICUMSTheme _theme = new ICUMSTheme();
    private bool _drawerOpen = false;
    
    protected override async Task OnInitializedAsync()
    {
        // Initialize theme from localStorage
        await ThemeService.InitializeAsync();
        
        // Subscribe to theme changes
        ThemeService.OnThemeChanged += OnThemeChanged;
    }
    
    private void OnThemeChanged()
    {
        StateHasChanged();
    }
    
    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
    
    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }
}


