@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager NavigationManager
@inject NickScanWebApp.Mobile.Services.ThemeService ThemeService
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<!-- Search Bar (Hidden on mobile) -->
<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudTextField Value="@_searchText"
                  ValueChanged="@((string val) => _searchText = val)"
                  Placeholder="Search..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  AdornmentColor="Color.Default"
                  IconSize="Size.Small"
                  Class="search-field-topbar"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Immediate="true"
                  OnKeyUp="@OnSearchKeyUp"
                  InputMode="InputMode.search" />
</MudHidden>

<style>
    /* Clean Integrated Search Bar */
    .search-field-topbar {
        width: 320px;
        max-width: 320px;
    }
    
    .search-field-topbar .mud-input-root {
        background-color: rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        transition: all 0.2s ease;
        height: 40px;
    }
    
    .search-field-topbar .mud-input {
        color: white !important;
        font-size: 13px;
        padding: 0 12px;
    }
    
    .search-field-topbar input {
        color: white !important;
        caret-color: white;
    }
    
    .search-field-topbar input::placeholder {
        color: rgba(255, 255, 255, 0.6) !important;
        font-size: 13px;
    }
    
    .search-field-topbar .mud-input-adornment {
        color: rgba(255, 255, 255, 0.7) !important;
    }
    
    .search-field-topbar .mud-input-adornment svg {
        width: 18px;
        height: 18px;
    }
    
    /* Outlined border */
    .search-field-topbar fieldset {
        border-color: rgba(255, 255, 255, 0.3) !important;
        border-width: 1px !important;
    }
    
    /* Hover */
    .search-field-topbar:hover .mud-input-root {
        background-color: rgba(255, 255, 255, 0.2);
    }
    
    .search-field-topbar:hover fieldset {
        border-color: rgba(255, 255, 255, 0.5) !important;
    }
    
    /* Focus */
    .search-field-topbar .mud-input-root:focus-within {
        background-color: white !important;
    }
    
    .search-field-topbar .mud-input-root:focus-within input,
    .search-field-topbar .mud-input-root:focus-within .mud-input {
        color: #333 !important;
    }
    
    .search-field-topbar .mud-input-root:focus-within input::placeholder {
        color: rgba(0, 0, 0, 0.5) !important;
    }
    
    .search-field-topbar .mud-input-root:focus-within .mud-input-adornment {
        color: #1976d2 !important;
    }
    
    .search-field-topbar .mud-input-root:focus-within fieldset {
        border-color: #1976d2 !important;
        border-width: 2px !important;
    }
</style>

<!-- Notification Bell -->
<MudBadge Content="@_notificationCount" 
          Color="Color.Error" 
          Overlap="true" 
          Visible="@(_notificationCount > 0)"
          Class="mx-2">
    <MudIconButton Icon="@Icons.Material.Filled.Notifications" 
                   Color="Color.Inherit" 
                   OnClick="@ToggleNotifications" />
</MudBadge>

<!-- Theme Toggle (Dark/Light) -->
<MudIconButton Icon="@Icons.Material.Filled.Brightness4" 
               Color="Color.Inherit" 
               OnClick="@ToggleTheme"
               title="Toggle dark mode" />

<!-- Help Icon -->
<MudIconButton Icon="@Icons.Material.Filled.Help" 
               Color="Color.Inherit" 
               Href="/help"
               title="Help & Documentation" />

<!-- User Profile Menu -->
<MudMenu Icon="@Icons.Material.Filled.AccountCircle" 
                 Color="Color.Inherit" 
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopRight">
            <ChildContent>
                <!-- User Info Header -->
                <MudPaper Elevation="0" Class="pa-4" Style="background: linear-gradient(135deg, #1a237e 0%, #283593 100%); color: white;">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1">@_username</MudText>
                        <MudText Typo="Typo.caption">@_userRole</MudText>
                    </MudStack>
                </MudPaper>
                
                <MudDivider />
                
                <!-- Menu Items -->
                <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">
                    My Profile
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings">
                    Settings
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Notifications" OnClick="@OpenNotifications">
                    Notifications
                    @if (_notificationCount > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2">@_notificationCount</MudChip>
                    }
                </MudMenuItem>
                
                <MudDivider />
                
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" 
                             OnClick="@HandleLogout"
                             IconColor="Color.Error">
                    Logout
                </MudMenuItem>
            </ChildContent>
        </MudMenu>

<!-- Notifications Popover -->
<MudPopover Open="@_notificationsOpen" 
            AnchorOrigin="Origin.BottomRight" 
            TransformOrigin="Origin.TopRight">
    <MudPaper Elevation="4" Class="pa-4" Style="width: 400px; max-height: 500px; overflow-y: auto;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
            <MudText Typo="Typo.h6">Notifications</MudText>
            <MudButton Size="Size.Small" 
                       Color="Color.Primary" 
                       Variant="Variant.Text"
                       OnClick="@ClearAllNotifications">
                Clear All
            </MudButton>
        </MudStack>
        
        @if (_notifications.Any())
        {
            @foreach (var notification in _notifications)
            {
                <MudAlert Severity="@notification.Severity" 
                          Class="mb-2" 
                          Dense="true"
                          CloseIconClicked="@(() => RemoveNotification(notification))">
                    <MudText Typo="Typo.body2">@notification.Message</MudText>
                    <MudText Typo="Typo.caption">@notification.Timestamp.ToString("HH:mm:ss")</MudText>
                </MudAlert>
            }
        }
        else
        {
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="py-8">
                No new notifications
            </MudText>
        }
    </MudPaper>
</MudPopover>

@code {
    private string _searchText = string.Empty;
    private int _notificationCount = 0;
    private bool _notificationsOpen = false;
    private List<NotificationItem> _notifications = new();
    private string _username = "Guest User";
    private string _userRole = "Visitor";
    private System.Threading.Timer? _notificationTimer;
    
    protected override async Task OnInitializedAsync()
    {
        // Get authenticated user information
        await LoadUserInfoAsync();
        
        // Load real notifications from API
        await LoadNotifications();
        
        // Subscribe to authentication state changes
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        
        // Start auto-refresh timer only if authenticated (every 30 seconds)
        if (_username != "Guest User" && !string.IsNullOrEmpty(_username))
        {
            StartNotificationTimer();
        }
    }
    
    private void StartNotificationTimer()
    {
        // Dispose existing timer if any
        _notificationTimer?.Dispose();
        
        // Start new timer
        _notificationTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                // Only load if still authenticated
                if (_username != "Guest User" && !string.IsNullOrEmpty(_username))
                {
                    await LoadNotifications();
                    StateHasChanged();
                }
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }
    
    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await LoadUserInfoAsync();
        await LoadNotifications();
        
        // Start timer if user just logged in
        if (_username != "Guest User" && !string.IsNullOrEmpty(_username))
        {
            StartNotificationTimer();
        }
        else
        {
            // Stop timer if user logged out
            _notificationTimer?.Dispose();
            _notificationTimer = null;
        }
        
        await InvokeAsync(StateHasChanged);
    }
    
    public void Dispose()
    {
        _notificationTimer?.Dispose();
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
    
    private async Task LoadUserInfoAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                // Get username from claims
                _username = user.Identity.Name ?? user.FindFirst("name")?.Value ?? user.FindFirst("sub")?.Value ?? "User";
                
                // Get role from claims
                var roleClaim = user.FindFirst(ClaimTypes.Role) ?? user.FindFirst("role");
                _userRole = roleClaim?.Value ?? "User";
                
                // Format role for display (SuperAdmin → Super Admin)
                _userRole = FormatRole(_userRole);
            }
            else
            {
                _username = "Guest User";
                _userRole = "Visitor";
            }
        }
        catch (Exception ex)
        {
            // Log error but don't fail
            Console.WriteLine($"Error loading user info: {ex.Message}");
            _username = "Guest User";
            _userRole = "Visitor";
        }
    }
    
    private string FormatRole(string role)
    {
        if (string.IsNullOrEmpty(role)) return "User";
        
        // Convert SuperAdmin → Super Admin, PortOfficer → Port Officer, etc.
        return System.Text.RegularExpressions.Regex.Replace(role, "([a-z])([A-Z])", "$1 $2");
    }
    
    private async Task LoadNotifications()
    {
        try
        {
            if (string.IsNullOrEmpty(_username) || _username == "Guest User")
            {
                return;
            }
            
            try
            {
                // Get unread notification count
                _notificationCount = await ApiService.GetAsync<int>($"/api/Notifications/user/{_username}/count");
            }
            catch (HttpRequestException ex) when (ex.Message.Contains("404"))
            {
                // API endpoint not available - silently skip
                _notificationCount = 0;
                return;
            }
            
            try
            {
                // Get recent notifications (limit to 10 for the dropdown)
                var notifications = await ApiService.GetAsync<List<NotificationDto>>($"/api/Notifications/user/{_username}?includeRead=false&limit=10");
                
                _notifications = notifications?.Select(n => new NotificationItem
                {
                    Id = n.Id,
                    Message = n.Message,
                    Severity = GetSeverityFromType(n.NotificationType),
                    Timestamp = n.CreatedAt
                }).ToList() ?? new List<NotificationItem>();
            }
            catch (HttpRequestException ex) when (ex.Message.Contains("404"))
            {
                // API endpoint not available - silently skip
                _notifications = new List<NotificationItem>();
                return;
            }
        }
        catch (Exception ex)
        {
            // Only log if it's not a 404
            if (!ex.Message.Contains("404"))
            {
                Console.WriteLine($"❌ Error loading notifications: {ex.Message}");
            }
            _notificationCount = 0;
            _notifications = new List<NotificationItem>();
        }
    }
    
    private Severity GetSeverityFromType(string type)
    {
        return type switch
        {
            "Alert" => Severity.Warning,
            "System" => Severity.Info,
            "User" => Severity.Normal,
            "Maintenance" => Severity.Info,
            _ => Severity.Normal
        };
    }
    
    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchText))
        {
            // Limit search text to prevent HTTP 414 errors
            var searchQuery = _searchText.Trim();
            if (searchQuery.Length > 100)
            {
                searchQuery = searchQuery.Substring(0, 100);
                Snackbar.Add("Search query truncated to prevent URL length issues", Severity.Warning);
            }
            
            NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(searchQuery)}");
        }
    }
    
    private void ToggleNotifications()
    {
        _notificationsOpen = !_notificationsOpen;
    }
    
    private void OpenNotifications()
    {
        NavigationManager.NavigateTo("/notifications");
    }
    
    private async Task ClearAllNotifications()
    {
        try
        {
            if (string.IsNullOrEmpty(_username) || _username == "Guest User")
            {
                return;
            }

            await ApiService.DeleteAsync<object>($"/api/Notifications/user/{_username}/clear-all");
        _notifications.Clear();
        _notificationCount = 0;
        _notificationsOpen = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error clearing notifications: {ex.Message}");
        }
    }
    
    private async Task RemoveNotification(NotificationItem notification)
    {
        try
        {
            await ApiService.DeleteAsync<object>($"/api/Notifications/{notification.Id}");
        _notifications.Remove(notification);
        _notificationCount = _notifications.Count;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error deleting notification: {ex.Message}");
        }
    }
    
    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }
    
    private async void HandleLogout()
    {
        try
        {
            if (AuthStateProvider is NickScanWebApp.Mobile.Services.SimpleAuthStateProvider simpleAuth)
            {
                await simpleAuth.LogoutAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error during logout: {ex.Message}");
        }
        finally
        {
            NavigationManager.NavigateTo("/login", true);
        }
    }
    
    public class NotificationItem
    {
        public int Id { get; set; }
        public string Message { get; set; } = string.Empty;
        public Severity Severity { get; set; }
        public DateTime Timestamp { get; set; }
    }
    
    public class NotificationDto
    {
        public int Id { get; set; }
        public string NotificationType { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public string? TargetUser { get; set; }
        public string? TargetRole { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime? ExpiresAt { get; set; }
        public bool IsRead { get; set; }
        public DateTime? ReadAt { get; set; }
    }
}

