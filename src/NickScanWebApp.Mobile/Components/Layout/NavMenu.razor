@code {
    private ClaimsPrincipal? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthStateProvider.GetAuthenticationStateAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[NavMenu] Failed to sync CustomAuthStateProvider — permissions may be delayed");
        }

        var authState = await BaseAuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState?.User;

        if (_currentUser != null && _currentUser.Identity?.IsAuthenticated == true)
        {
            var roleClaim = _currentUser.FindFirst(ClaimTypes.Role)?.Value ?? _currentUser.FindFirst("role")?.Value;
            Logger.LogInformation("[NavMenu] User: {User}, Role: {Role}", _currentUser.Identity?.Name, roleClaim);
            var permissionClaims = _currentUser.FindAll("Permission").Select(c => c.Value).ToList();
            Logger.LogDebug("[NavMenu] Permission claims count: {Count}", permissionClaims.Count);
        }

        BaseAuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        AuthStateProvider.PermissionsChanged += OnPermissionsChanged;
        StateHasChanged();
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            var authState = await task;
            _currentUser = authState?.User;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore failures
        }
    }

    private void OnPermissionsChanged()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                // Small delay to ensure permissions are fully updated
                await Task.Delay(50);
                var authState = await BaseAuthStateProvider.GetAuthenticationStateAsync();
                _currentUser = authState?.User;
            }
            catch
            {
                // ignore failures - keep current state
            }

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        BaseAuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        AuthStateProvider.PermissionsChanged -= OnPermissionsChanged;
    }

    private bool Can(PermissionId permission) => Guard.Can(permission, "NavMenu");
    private bool CanAny(params PermissionId[] permissions) => Guard.CanAny("NavMenu", permissions);

    private bool HasClaimPermission(string permissionValue)
    {
        if (_currentUser?.Identity?.IsAuthenticated != true) return false;
        var hasClaim = _currentUser.Claims.Any(c =>
            string.Equals(c.Type, "Permission", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(c.Value, permissionValue, StringComparison.OrdinalIgnoreCase));
        if (!hasClaim && permissionValue.StartsWith("pages.", StringComparison.OrdinalIgnoreCase))
        {
            var trimmed = permissionValue.Substring(6);
            hasClaim = _currentUser.Claims.Any(c =>
                string.Equals(c.Type, "Permission", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(c.Value, trimmed, StringComparison.OrdinalIgnoreCase));
        }
        return hasClaim;
    }
}

