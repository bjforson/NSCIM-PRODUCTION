@using NickScanWebApp.Mobile.Services
@using NickScanCentralImagingPortal.Core.Models
@inject NickScanWebApp.Mobile.Services.ApiService ApiService
@inject RoleLookupService RoleLookup
@inject ISnackbar Snackbar
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_formValid">
            <MudStack Spacing="2">
                <MudAlert Severity="Severity.Info" Dense="true">
                    Create a custom role with specific permissions for your organization's needs.
                </MudAlert>

                <MudTextField @bind-Value="_roleName" 
                              Label="Role Name" 
                              Required="true" 
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              HelperText="Internal name (e.g., 'CustomsInspector')"
                              Validation="@(new Func<string, string?>(ValidateRoleName))" />

                <MudTextField @bind-Value="_displayName" 
                              Label="Display Name" 
                              Required="true" 
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              HelperText="User-friendly name (e.g., 'Customs Inspector')" />

                <MudTextField @bind-Value="_description" 
                              Label="Description" 
                              Required="true" 
                              Variant="Variant.Outlined" 
                              Lines="3"
                              Size="Size.Small"
                              HelperText="Explain what this role is for" />

                <MudSelect @bind-Value="_baseRoleSelection" 
                           Label="Base Role Template" 
                           Variant="Variant.Outlined"
                           Size="Size.Small"
                           HelperText="Start with permissions from an existing role"
                           Disabled="_isLoadingRoles">
                    <MudSelectItem Value="@((string?)null)">None (Empty Role)</MudSelectItem>
                    @foreach (var role in _baseRoleOptions)
                    {
                        <MudSelectItem Value="@role.SelectionKey">@role.DisplayName</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Size="Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   Size="Size.Small"
                   OnClick="Submit" 
                   Disabled="@(!_formValid || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Creating...</span>
            }
            else
            {
                <span>Create Role</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string CurrentUsername { get; set; } = "admin";
    [Parameter] public EventCallback OnRoleCreated { get; set; }

    private MudForm? _form;
    private bool _formValid = false;
    private bool _isSubmitting = false;
    private bool _isLoadingRoles = false;

    private string _roleName = "";
    private string _displayName = "";
    private string _description = "";
    private string? _baseRoleSelection = null;
    private List<BaseRoleOption> _baseRoleOptions = new();
    private HashSet<string> _reservedRoleNames = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadRoleOptions();
    }

    private async Task LoadRoleOptions()
    {
        _isLoadingRoles = true;
        try
        {
            var roles = await RoleLookup.GetRolesAsync();
            _reservedRoleNames = roles.Select(r => r.Name).Where(name => !string.IsNullOrWhiteSpace(name)).ToHashSet(StringComparer.OrdinalIgnoreCase);

            _baseRoleOptions = roles
                .Where(r => r.IsSystemRole)
                .Select(r =>
                {
                    UserRole? baseRoleEnum = null;
                    if (!string.IsNullOrWhiteSpace(r.BaseRole) &&
                        Enum.TryParse<UserRole>(r.BaseRole, ignoreCase: true, out var parsed))
                    {
                        baseRoleEnum = parsed;
                    }

                    var selectionKey = r.Name;
                    if (string.IsNullOrWhiteSpace(selectionKey) && baseRoleEnum.HasValue)
                    {
                        selectionKey = baseRoleEnum.Value.ToString();
                    }

                    return new BaseRoleOption
                    {
                        Name = r.Name ?? string.Empty,
                        DisplayName = string.IsNullOrWhiteSpace(r.DisplayName) ? (r.Name ?? string.Empty) : r.DisplayName!,
                        BaseRole = baseRoleEnum,
                        SelectionKey = selectionKey ?? string.Empty
                    };
                })
                .OrderBy(r => r.DisplayName)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"⚠️ Could not load system roles: {ex.Message}", Severity.Warning);
            _baseRoleOptions = new List<BaseRoleOption>();
        }
        finally
        {
            _isLoadingRoles = false;
        }
    }

    private string? ValidateRoleName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "Role name is required";
        
        if (name.Length < 3)
            return "Role name must be at least 3 characters";
        
        if (!System.Text.RegularExpressions.Regex.IsMatch(name, "^[a-zA-Z][a-zA-Z0-9]*$"))
            return "Role name must start with a letter and contain only letters and numbers";
        
        if (_reservedRoleNames.Contains(name))
            return "Cannot use an existing role name";
        
        return null;
    }

    private void Cancel()
    {
        // Dialog will close via the Cancel button in DialogActions
    }

    private async Task Submit()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                Snackbar.Add("⚠️ Please fill in all required fields correctly", Severity.Warning);
                return;
            }
        }

        _isSubmitting = true;
        try
        {
            UserRole? parsedBaseRole = null;
            if (!string.IsNullOrWhiteSpace(_baseRoleSelection))
            {
                if (Enum.TryParse<UserRole>(_baseRoleSelection, ignoreCase: true, out var parsed))
                {
                    parsedBaseRole = parsed;
                }
                else
                {
                    var option = _baseRoleOptions.FirstOrDefault(o =>
                        string.Equals(o.SelectionKey, _baseRoleSelection, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(o.Name, _baseRoleSelection, StringComparison.OrdinalIgnoreCase));
                    if (option?.BaseRole != null)
                    {
                        parsedBaseRole = option.BaseRole;
                    }
                }
            }

            var request = new
            {
                Name = _roleName,
                DisplayName = _displayName,
                Description = _description,
                BaseRole = parsedBaseRole,
                CreatedBy = CurrentUsername
            };

            await ApiService.PostAsync<object, object>("/api/Roles", request);
            RoleLookup.ClearCache();
            await RoleLookup.GetRolesAsync(forceRefresh: true);
            
            Snackbar.Add($"✅ Role '{_displayName}' created successfully! Close this dialog to see the new role.", Severity.Success);
            
            await OnRoleCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Error creating role: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class BaseRoleOption
    {
        public string Name { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public UserRole? BaseRole { get; set; }
        public string SelectionKey { get; set; } = string.Empty;
    }
}

