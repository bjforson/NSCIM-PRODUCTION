@using MudBlazor
@using NickScanWebApp.Mobile.Services
@using NickScanWebApp.Mobile.Components.Containers
@using NickScanWebApp.Mobile.Components.CargoGroup
@using NickScanCentralImagingPortal.Core.DTOs.CargoGroup
@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject CargoGroupService CargoGroupService
@inject ILogger<ImageAnalysisViewDialog> Logger

<MudDialog FullWidth="true" MaxWidth="MaxWidth.False">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ImageSearch" Size="Size.Small" Class="mr-2" />
            Image Analysis - @GroupIdentifier
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 85vh; overflow-y: auto;">
            
            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body2">Loading cargo group data...</MudText>
                </MudStack>
            }
            else if (_cargoGroup != null)
            {
                <!-- Overall Decision Banner -->
                <MudAlert Severity="@GetOverallSeverity()" Variant="Variant.Filled" Class="mb-3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">Overall Decision: @_overallDecision</MudText>
                        <MudText Typo="Typo.caption">
                            @_normalCount Normal | @_abnormalCount Abnormal | @_totalImages Total Images
                        </MudText>
                    </MudStack>
                </MudAlert>

                <!-- Use CargoGroupView for standardized display -->
                <CargoGroupView GroupIdentifier="@GroupIdentifier" Type="@_cargoType" />
            }
            else
            {
                <MudAlert Severity="Severity.Warning">
                    Cargo group not found: @GroupIdentifier
                </MudAlert>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" FullWidth="true">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string GroupIdentifier { get; set; } = string.Empty;
    [Parameter] public bool IsConsolidated { get; set; }
    [CascadingParameter] IDialogReference? MudDialog { get; set; }

    private CargoGroupDto? _cargoGroup;
    private bool _loading = true;
    private CargoType _cargoType;
    private string _overallDecision = "Pending";
    private int _normalCount = 0;
    private int _abnormalCount = 0;
    private int _totalImages = 0;

    protected override async Task OnInitializedAsync()
    {
        _cargoType = IsConsolidated ? CargoType.Consolidated : CargoType.NonConsolidated;
        await LoadCargoGroup();
        await LoadDecisions();
    }

    private async Task LoadCargoGroup()
    {
        _loading = true;
        try
        {
            _cargoGroup = await CargoGroupService.GetCargoGroupAsync(GroupIdentifier, _cargoType);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading cargo group: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDecisions()
    {
        try
        {
            var decisions = await ApiService.GetAsync<List<ImageAnalysisDecision>>(
                $"/api/image-analysis/decisions?groupIdentifier={Uri.EscapeDataString(GroupIdentifier)}");
            
            if (decisions != null)
            {
                _normalCount = decisions.Count(d => d.Decision == "Normal");
                _abnormalCount = decisions.Count(d => d.Decision == "Abnormal");
                _totalImages = decisions.Count;
                _overallDecision = _abnormalCount > 0 ? "Abnormal" : (_normalCount > 0 ? "Normal" : "Pending");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading decisions");
        }
    }

    private Severity GetOverallSeverity()
    {
        return _overallDecision switch
        {
            "Normal" => Severity.Success,
            "Abnormal" => Severity.Error,
            _ => Severity.Info
        };
    }

    private void Close()
    {
        MudDialog?.Close();
    }
}
