@using MudBlazor
@using NickScanWebApp.Mobile.Services
@using NickScanWebApp.Shared.Services
@using NickScanCentralImagingPortal.Core.Models
@using NickScanWebApp.Mobile.Models
@inject NickScanWebApp.Shared.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudDialog FullWidth="true" MaxWidth="MaxWidth.Medium">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Class="mr-2" />
            Audit Review: @Record?.GroupIdentifier
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 70vh; overflow-y: auto;">
            
            <!-- Header Info -->
            <MudPaper Class="pa-3 mb-3" Elevation="1" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <MudText Typo="Typo.h6" Style="color: white;">
                    @Record?.GroupIdentifier
                </MudText>
                <MudText Typo="Typo.caption" Style="color: white;">
                    @Record?.TotalContainers container(s) | @Record?.ScannerType Scanner
                </MudText>
            </MudPaper>

            <!-- Original Decisions -->
            <MudPaper Class="pa-3 mb-3" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Original Image Analysis Decisions
                </MudText>
                
                @if (Record?.ImageAnalysisDecisions != null)
                {
                    @foreach (var decision in Record.ImageAnalysisDecisions)
                    {
                        <MudPaper Elevation="0" Class="pa-2 mb-2" Style="background: #f5f5f5;">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@decision.ContainerNumber</MudText>
                                <MudChip T="string" Size="Size.Small" 
                                        Color="@(decision.Decision == "Abnormal" ? Color.Error : Color.Success)">
                                    @decision.Decision
                                </MudChip>
                                @if (!string.IsNullOrEmpty(decision.Comments))
                                {
                                    <MudText Typo="Typo.caption">@decision.Comments</MudText>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>

            <!-- Audit Decisions Form -->
            <MudPaper Class="pa-3 mb-3" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-2">
                    Your Audit Decision
                </MudText>

                @if (_auditDecisions != null)
                {
                    @foreach (var auditDecision in _auditDecisions)
                    {
                        <MudPaper Elevation="0" Class="pa-3 mb-3" Outlined="true">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@auditDecision.ContainerNumber</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Original: @auditDecision.OriginalDecision
                                </MudText>
                                
                                <MudRadioGroup T="string" @bind-Value="auditDecision.Decision" Required="true">
                                    <MudRadio T="string" Value="@ApprovedValue" Color="Color.Success">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                                        Approve
                                    </MudRadio>
                                    <MudRadio T="string" Value="@RejectedValue" Color="Color.Error">
                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Class="mr-1" />
                                        Reject
                                    </MudRadio>
                                </MudRadioGroup>
                                
                                <MudTextField @bind-Value="auditDecision.Notes"
                                             Label="Audit Notes"
                                             Variant="Variant.Outlined"
                                             Lines="2"
                                             FullWidth="true" />
                            </MudStack>
                        </MudPaper>
                    }
                }

                <!-- Overall Decision Preview -->
                <MudAlert Severity="@GetOverallSeverity()" Dense="true" Class="mt-3">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                        Overall Decision: @GetOverallDecision()
                    </MudText>
                    <MudText Typo="Typo.caption">
                        @GetOverallMessage()
                    </MudText>
                </MudAlert>
            </MudPaper>

            @if (_submitting)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_submitting" FullWidth="true">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                  Variant="Variant.Filled" 
                  OnClick="SubmitAudit" 
                  Disabled="@(!AllDecisionsMade() || _submitting)"
                  StartIcon="@Icons.Material.Filled.Send"
                  FullWidth="true"
                  Class="mt-2">
            @(_submitting ? "Submitting..." : "Submit Audit Decisions")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public AuditGroupDto? Record { get; set; }
    [Parameter] public EventCallback<bool> OnAuditComplete { get; set; }
    [CascadingParameter] IDialogReference? MudDialog { get; set; }
    
    private const string ApprovedValue = "Approved";
    private const string RejectedValue = "Rejected";

    private List<ContainerAuditDecision>? _auditDecisions;
    private bool _submitting = false;
    private string _currentUser = "Unknown";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User?.Identity?.Name ?? "Unknown";

        if (Record?.ImageAnalysisDecisions != null)
        {
            _auditDecisions = Record.ImageAnalysisDecisions.Select(d => new ContainerAuditDecision
            {
                ContainerNumber = d.ContainerNumber,
                OriginalDecision = d.Decision,
                Decision = "",
                Notes = ""
            }).ToList();
        }
    }

    private bool AllDecisionsMade()
    {
        return _auditDecisions?.All(d => !string.IsNullOrEmpty(d.Decision)) ?? false;
    }

    private string GetOverallDecision()
    {
        if (!AllDecisionsMade()) return "Pending";
        
        var anyRejected = _auditDecisions?.Any(d => d.Decision == RejectedValue) ?? false;
        return anyRejected ? "REJECTED" : "APPROVED";
    }

    private Severity GetOverallSeverity()
    {
        if (!AllDecisionsMade()) return Severity.Normal;
        
        var decision = GetOverallDecision();
        return decision == "APPROVED" ? Severity.Success : Severity.Error;
    }

    private string GetOverallMessage()
    {
        if (!AllDecisionsMade())
            return "Please make decisions for all containers";
        
        var approved = _auditDecisions?.Count(d => d.Decision == ApprovedValue) ?? 0;
        var rejected = _auditDecisions?.Count(d => d.Decision == RejectedValue) ?? 0;
        return $"Approved: {approved} | Rejected: {rejected}";
    }

    private async Task SubmitAudit()
    {
        if (!AllDecisionsMade())
        {
            Snackbar.Add("Please make decisions for all containers", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            var request = new
            {
                GroupIdentifier = Record?.GroupIdentifier,
                Decisions = _auditDecisions?.Select(d => new
                {
                    ContainerNumber = d.ContainerNumber,
                    Decision = d.Decision,
                    Notes = d.Notes,
                    ReviewedBy = _currentUser
                }).ToList()
            };

            await ApiService.PostAsync<object, object>("/api/image-analysis/audit/submit", request);
            Snackbar.Add("Audit decisions submitted successfully", Severity.Success);
            
            if (OnAuditComplete.HasDelegate)
            {
                await OnAuditComplete.InvokeAsync(true);
            }
            
            MudDialog?.Close();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting audit: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Close();
    }

    // Helper class
    private class ContainerAuditDecision
    {
        public string ContainerNumber { get; set; } = "";
        public string OriginalDecision { get; set; } = "";
        public string Decision { get; set; } = "";
        public string Notes { get; set; } = "";
    }
}
