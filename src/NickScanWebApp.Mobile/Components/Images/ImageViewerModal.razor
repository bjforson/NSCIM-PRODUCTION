<MudDialog FullScreen="true" Class="image-viewer-modal">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="overflow: hidden; text-overflow: ellipsis;">@(string.IsNullOrWhiteSpace(Title) ? "Image" : Title)</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="1" Style="height: 100%; min-height: 0;">
            <MudStack Row="true" Spacing="1" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="flex-wrap">
                <MudButton StartIcon="@Icons.Material.Filled.ZoomOut" Variant="Variant.Outlined" Size="Size.Small" OnClick="ZoomOut">Out</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.ZoomIn" Variant="Variant.Outlined" Size="Size.Small" OnClick="ZoomIn">In</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.RestartAlt" Variant="Variant.Outlined" Size="Size.Small" OnClick="ResetView">Reset</MudButton>
                <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                <MudButton StartIcon="@Icons.Material.Filled.RotateLeft" Variant="Variant.Outlined" Size="Size.Small" OnClick="RotateLeft">Left</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.RotateRight" Variant="Variant.Outlined" Size="Size.Small" OnClick="RotateRight">Right</MudButton>
            </MudStack>
            <div style="flex: 1; min-height: 0; display: flex; align-items: center; justify-content: center; overflow: auto; background: #121212; padding: 8px;">
                @if (!string.IsNullOrWhiteSpace(ImageUrl))
                {
                    <img src="@ImageUrl"
                         alt="@Title"
                         style="@GetImageStyle()" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="color: #aaa;">No image URL.</MudText>
                }
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close" FullWidth="true">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string ImageUrl { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";

    private double _zoom = 1.0;
    private int _rotation;

    private string GetImageStyle() =>
        $"transform: scale({_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture)}) rotate({_rotation}deg); max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.2s ease;";

    private void ZoomIn() => _zoom = Math.Min(_zoom + 0.25, 4.0);

    private void ZoomOut() => _zoom = Math.Max(_zoom - 0.25, 0.25);

    private void ResetView()
    {
        _zoom = 1.0;
        _rotation = 0;
    }

    private void RotateLeft() => _rotation -= 90;

    private void RotateRight() => _rotation += 90;

    private void Close() => MudDialog.Close();
}
