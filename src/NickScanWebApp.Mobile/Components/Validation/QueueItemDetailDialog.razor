<MudDialog FullWidth="true" MaxWidth="MaxWidth.Small" ContentClass="overflow-y-auto" Style="max-height: 90vh;">
    <TitleContent>
        <MudText Typo="Typo.h6">Queue item</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            @foreach (var row in GetRows())
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex-shrink: 0;">@row.Label</MudText>
                    <MudText Typo="Typo.body2" Style="text-align: right; word-break: break-word;">@row.Value</MudText>
                </MudStack>
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">Error message</MudText>
            <MudPaper Elevation="0" Class="pa-2" Style="background: var(--mud-palette-background-grey);">
                <MudText Typo="Typo.body2" Style="word-break: break-word;">@(string.IsNullOrWhiteSpace(Item.ErrorMessage) ? "—" : Item.ErrorMessage)</MudText>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close" FullWidth="true">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public QueueItemDto Item { get; set; } = new();

    private void Close() => MudDialog.Close();

    private IEnumerable<(string Label, string Value)> GetRows()
    {
        yield return ("Container", Item.ContainerNumber);
        yield return ("Scanner type", Item.ScannerType);
        yield return ("Status", Item.Status);
        yield return ("Inspection ID", FormatObject(Item.InspectionId));
        yield return ("Queued at", FormatDateTime(Item.QueuedAt));
        yield return ("Scan date", FormatDateTime(Item.ScanDate));
        yield return ("Retry", $"{Item.RetryCount} / {Item.MaxRetries}");
        yield return ("Processed at", FormatDateTime(Item.ProcessedAt));
        yield return ("Duration", FormatDuration(Item.ProcessingDuration));
    }

    private static string FormatDateTime(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm:ss") : "—";

    private static string FormatObject(object? value) => value?.ToString() ?? "—";

    private static string FormatDuration(TimeSpan? value) =>
        value.HasValue ? value.Value.ToString(@"hh\:mm\:ss\.fff") : "—";

    public class QueueItemDto
    {
        public string ContainerNumber { get; set; } = "";
        public string ScannerType { get; set; } = "";
        public string Status { get; set; } = "";
        public object? InspectionId { get; set; }
        public DateTime? QueuedAt { get; set; }
        public DateTime? ScanDate { get; set; }
        public int RetryCount { get; set; }
        public int MaxRetries { get; set; }
        public DateTime? ProcessedAt { get; set; }
        public string? ErrorMessage { get; set; }
        public TimeSpan? ProcessingDuration { get; set; }
    }
}
