@using NickScanWebApp.Shared.Services
@using NickScanWebApp.Shared.Models
@using MudBlazor
@inject BLReviewService BLReviewService
@inject ILogger<BLReviewList> Logger
@inject IDialogService DialogService

<MudPaper Elevation="2" Class="pa-2">
    <!-- Header with controls -->
    <MudStack Spacing="2" Class="mb-3">
        <MudTextField @bind-Value="_searchText" 
                     Label="Search BL Number" 
                     Variant="Variant.Outlined" 
                     Adornment="Adornment.Start" 
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     OnKeyUp="HandleSearchKeyPress"
                     Immediate="true" />
        <MudSelect @bind-Value="_selectedStatus" 
                  Label="Status" 
                  Variant="Variant.Outlined"
                  T="string"
                  OnClose="LoadBLGroups">
            <MudSelectItem Value="@("All")">All</MudSelectItem>
            <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
            <MudSelectItem Value="@("InProgress")">In Progress</MudSelectItem>
            <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  StartIcon="@Icons.Material.Filled.Refresh"
                  OnClick="LoadBLGroups"
                  FullWidth="true"
                  Disabled="_isLoading">
            Refresh
        </MudButton>
    </MudStack>

    <!-- Loading state -->
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    <!-- BL Groups List (Mobile-friendly) -->
    @if (!_isLoading && _blGroups.Any())
    {
        <MudStack Spacing="2">
            @foreach (var blGroup in _blGroups)
            {
                <MudPaper Elevation="1" Class="pa-3" @onclick="@(() => OpenReviewDialog(blGroup))">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@blGroup.MasterBlNumber</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(blGroup.ReviewStatus)">
                                @blGroup.ReviewStatus
                            </MudChip>
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Containers: @blGroup.CompleteContainers / @blGroup.TotalContainers
                        </MudText>
                        <MudProgressLinear Color="@GetProgressColor(blGroup)" 
                                          Value="@GetProgressPercentage(blGroup)" 
                                          Size="Size.Small" />
                        <MudStack Row="true" Spacing="2">
                            <MudChip T="string" Size="Size.Small" Color="@GetDecisionColor(blGroup.FinalDecision)">
                                @GetDecisionIcon(blGroup.FinalDecision) @blGroup.FinalDecision
                            </MudChip>
                            @if (!string.IsNullOrEmpty(blGroup.ReviewedBy))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    By: @blGroup.ReviewedBy
                                </MudText>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
    else if (!_isLoading)
    {
        <MudText Typo="Typo.body1" Class="pa-4 text-center">
            No BL groups found. Try adjusting your filters.
        </MudText>
    }

    <!-- Pagination -->
    @if (_totalPages > 1)
    {
        <MudPagination Class="mt-4" 
                      Count="_totalPages" 
                      Selected="_currentPage" 
                      SelectedChanged="OnPageChanged"
                      ShowFirstButton="true"
                      ShowLastButton="true" />
    }
</MudPaper>

@code {
    private List<BLGroupDto> _blGroups = new();
    private BLReviewStatistics? _statistics;
    private bool _isLoading = false;
    private string _searchText = "";
    private string _selectedStatus = "All";
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadBLGroups();
        await LoadStatistics();
    }

    private async Task LoadBLGroups()
    {
        _isLoading = true;
        try
        {
            Logger.LogInformation("Loading BL groups - Page: {Page}, Status: {Status}", _currentPage, _selectedStatus);

            var status = _selectedStatus == "All" ? null : _selectedStatus;
            var groups = await BLReviewService.GetBLGroupsAsync(status, _currentPage, _pageSize);
            _blGroups = groups ?? new List<BLGroupDto>();

            // Filter by search text if provided
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                _blGroups = _blGroups
                    .Where(b => b.MasterBlNumber.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            Logger.LogInformation("✅ Loaded {Count} BL groups", _blGroups.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading BL groups");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadStatistics()
    {
        try
        {
            _statistics = await BLReviewService.GetStatisticsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading statistics");
            _statistics = null;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadBLGroups();
    }

    private async Task HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _currentPage = 1; // Reset to first page
            await LoadBLGroups();
        }
    }

    private async Task OpenReviewDialog(BLGroupDto blGroup)
    {
        var parameters = new DialogParameters
        {
            ["MasterBlNumber"] = blGroup.MasterBlNumber
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.False, 
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true,
            BackdropClick = false
        };

        var dialog = await DialogService.ShowAsync<BLReviewDialog>($"Review BL: {blGroup.MasterBlNumber}", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            // Refresh the list after review
            await LoadBLGroups();
            await LoadStatistics();
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "InProgress" => Color.Info,
        "Completed" => Color.Success,
        _ => Color.Default
    };

    private Color GetDecisionColor(string decision) => decision switch
    {
        "Normal" => Color.Success,
        "Abnormal" => Color.Error,
        "Pending" => Color.Default,
        _ => Color.Default
    };

    private string GetDecisionIcon(string decision) => decision switch
    {
        "Normal" => "✅",
        "Abnormal" => "⚠️",
        _ => "⏳"
    };

    private Color GetProgressColor(BLGroupDto group)
    {
        var percentage = GetProgressPercentage(group);
        if (percentage >= 100) return Color.Success;
        if (percentage >= 50) return Color.Info;
        if (percentage > 0) return Color.Warning;
        return Color.Default;
    }

    private double GetProgressPercentage(BLGroupDto group)
    {
        if (group.CompleteContainers == 0) return 0;
        return (double)group.ReviewedContainers / group.CompleteContainers * 100;
    }
}

