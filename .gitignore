# 1.19.0: submit_backlog.py rewritten as a production tool (pulls multi-container
# scans from OriginalScanRecord, not just crossrecordscans), and
# bootstrap_claude_vision.py is the Claude Vision bootstrap entry point. Both
# are now tracked under source control.

# ICUMS runtime data — written and cleaned up by background services,
# not source. The Backup/Downloads/Outbox subfolders churn constantly.
Data/ICUMS/Backup/
Data/ICUMS/Downloads/
Data/ICUMS/Outbox/

# FS6000 scanner intake — runtime files moved between Staging and Archive
# by the scanner ingestion background services.
Data/FS6000/Archive/
Data/FS6000/Staging/

# FS6000 ingest workspace — FS6000RawChannelIngester copies .img files here
# just long enough to read them, then deletes. Transient scratch space.
Data/FS6000/IngestWorkspace/

# Eagle A25 mirrored scan assets — runtime cache copied from scanner storage
Data/EagleA25/

