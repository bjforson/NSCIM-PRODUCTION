{
  "ConnectionStrings": {
    "CommsDb": "Host=localhost;Port=5432;Database=nick_comms;Username=postgres;Password=***USE_ENV_VAR_NICKCOMMS_ConnectionStrings__CommsDb_Password***"
  },

  "Hubtel": {
    "SmsBaseUrl": "https://smsc.hubtel.com",
    "OtpBaseUrl": "https://api-otp.hubtel.com",
    "ClientId": "***USE_ENV_VAR_NICKCOMMS_Hubtel__ClientId***",
    "ClientSecret": "***USE_ENV_VAR_NICKCOMMS_Hubtel__ClientSecret***",
    "DefaultSenderId": "NSCIM"
  },

  "SmsGateway": {
    "DrainIntervalSeconds": 12,
    "MaxRetries": 2,
    "DefaultCountryCode": "GH"
  },

  "Email": {
    "SmtpServer": "smtp.mail.eu-west-1.awsapps.com",
    "SmtpPort": 465,
    "SmtpUsername": "***USE_ENV_VAR_NICKCOMMS_Email__SmtpUsername***",
    "SmtpPassword": "***USE_ENV_VAR_NICKCOMMS_Email__SmtpPassword***",
    "EnableSsl": true,
    "FromEmail": "systems@nickscan.com",
    "FromName": "NickComms Gateway",
    "DrainIntervalSeconds": 2
  },

  "ApiKeys": {
    "Clients": [
      { "AppName": "nscim-image", "Key": "nscim-img-key-change-me-in-production" },
      { "AppName": "nickhr", "Key": "nickhr-key-change-me-in-production" }
    ]
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5220"
      }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
